  "license": "MIT",
  "homepage": "https://hacecuentas.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/grblasquiz/calculadoras-argentinas"
  },
  "bugs": {
    "url": "https://github.com/grblasquiz/calculadoras-argentinas/issues"
  },
  "devDependencies": {
