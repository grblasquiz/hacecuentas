# ============================================================
# hacecuentas — variables de entorno
# Copiar a .env y completar. .env está en .gitignore.
# ============================================================

# --- Cloudflare (deploy + cache purge) ---
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_ACCOUNT_ID=

# --- Anthropic (scripts de generación) ---
ANTHROPIC_API_KEY=

# --- Sentry (observability — opcional) ---
# Si SENTRY_DSN está vacío, Sentry NO se inicializa (no-op total).
# Crear proyecto en https://sentry.io → Settings → Projects → [project] → Client Keys (DSN).
SENTRY_DSN=
# Solo se usa en CI/prod para uploadear source maps. NO setear en dev.
# Crear en https://sentry.io → Settings → Auth Tokens (scope: project:releases + project:write).
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=hacecuentas
