# Cloudflare Pages — Cache-Control headers
# El problema histórico era que el HTML quedaba cacheado en el browser/edge
# y los usuarios veían versiones viejas. Esto fuerza revalidación en cada visita.

# HTML pages: browser revalida siempre + CF edge NO cachea.
# CDN-Cache-Control: no-store → le dice al edge de CF que NUNCA guarde HTML en su caché.
# Esto elimina el bug recurrente de CF cacheando 404s antes de que el deploy propague.
# En CF Pages los assets ya viven en el edge, así que no perdemos performance.
/*
  Cache-Control: public, max-age=0, must-revalidate
  CDN-Cache-Control: no-store
  # Seguridad: protección contra clickjacking, sniffing y leaks
  X-Content-Type-Options: nosniff
  X-Frame-Options: SAMEORIGIN
  Referrer-Policy: strict-origin-when-cross-origin
  # Bloquea APIs que no usamos (protege si hay compromise client-side)
  Permissions-Policy: camera=(), microphone=(), geolocation=(), payment=(), usb=(), accelerometer=(), gyroscope=(), magnetometer=()
  # HSTS: fuerza HTTPS en browser por 2 años (incluye subdominios, preload-ready)
  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload
  # CSP: whitelist explícito de orígenes permitidos. 'unsafe-inline' para style e
  # inline scripts (astro genera muchos). Si migramos a CSP con nonce, eliminar.
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' https://www.googletagmanager.com https://www.google-analytics.com https://cdn.jsdelivr.net https://static.cloudflareinsights.com; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; font-src 'self' data:; connect-src 'self' https://www.googletagmanager.com https://www.google-analytics.com https://dolarapi.com https://api.argentinadatos.com https://region1.google-analytics.com https://open.er-api.com; frame-src 'self'; object-src 'none'; base-uri 'self'; form-action 'self' mailto:; frame-ancestors 'self'

# Service worker: NUNCA cachear el script, así las actualizaciones bajan inmediato.
/sw.js
  Cache-Control: public, max-age=0, must-revalidate
  Service-Worker-Allowed: /

# Manifest también: chico y quiero que se refresque
/manifest.webmanifest
  Cache-Control: public, max-age=3600

# Astro hashea los archivos en /_astro/ con content hash, son immutable de por vida.
/_astro/*
  Cache-Control: public, max-age=31536000, immutable

# Iconos y favicons: cambian poco, cachear 1 día
/favicon.svg
  Cache-Control: public, max-age=86400
/favicon.ico
  Cache-Control: public, max-age=86400
/apple-touch-icon.png
  Cache-Control: public, max-age=86400

# Imágenes en /img/ o similar: cachear 1 semana
/img/*
  Cache-Control: public, max-age=604800

# Sitemap y RSS: no cachear — se regenera en cada build
/sitemap.xml
  Cache-Control: public, max-age=0, must-revalidate
/rss.xml
  Cache-Control: public, max-age=3600

# robots.txt y ads.txt: cachear 1 día
/robots.txt
  Cache-Control: public, max-age=86400
/ads.txt
  Cache-Control: public, max-age=86400

# Página offline: cacheable a largo plazo
/offline.html
  Cache-Control: public, max-age=3600
