# Cloudflare Pages — Cache-Control headers (rev 2 — forzar redeploy con CSP open.er-api)
# El problema histórico era que el HTML quedaba cacheado en el browser/edge
# y los usuarios veían versiones viejas. Esto fuerza revalidación en cada visita.

# HTML pages: browser revalida siempre + CF edge NO cachea.
# CDN-Cache-Control: no-store → le dice al edge de CF que NUNCA guarde HTML en su caché.
# Esto elimina el bug recurrente de CF cacheando 404s antes de que el deploy propague.
# En CF Pages los assets ya viven en el edge, así que no perdemos performance.
/*
  Cache-Control: public, max-age=0, must-revalidate
  CDN-Cache-Control: no-store
  # Seguridad: protección contra clickjacking, sniffing y leaks
  X-Content-Type-Options: nosniff
  X-Frame-Options: SAMEORIGIN
  Referrer-Policy: strict-origin-when-cross-origin
  # Bloquea APIs que no usamos (protege si hay compromise client-side)
  Permissions-Policy: camera=(), microphone=(), geolocation=(), payment=(), usb=(), accelerometer=(), gyroscope=(), magnetometer=()
  # HSTS: fuerza HTTPS en browser por 2 años (incluye subdominios, preload-ready)
  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload
  # CSP: whitelist explícito de orígenes permitidos. 'unsafe-inline' para style e
  # inline scripts (astro genera muchos). Si migramos a CSP con nonce, eliminar.
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' blob: https://www.googletagmanager.com https://www.google-analytics.com https://cdn.jsdelivr.net https://static.cloudflareinsights.com; worker-src 'self' blob:; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; font-src 'self' data:; connect-src 'self' https://www.googletagmanager.com https://www.google-analytics.com https://dolarapi.com https://api.argentinadatos.com https://region1.google-analytics.com https://open.er-api.com https://api.coingecko.com; frame-src 'self'; object-src 'none'; base-uri 'self'; form-action 'self' mailto:; frame-ancestors 'self'
  # Cross-origin isolation (defense-in-depth + Lighthouse Best Practices).
  # COOP same-origin: aísla window contra cualquier opener de otro dominio.
  # COEP credentialless: permite cargar recursos third-party sin cookies (clave
  #   para que AdSense/iframes Google no se rompan — require-corp los rompía).
  # CORP same-origin: bloquea hotlinking de mis recursos por sitios externos.
  # OJO: /embed/* sobrescribe estos abajo para permitir embeds cross-origin.
  Cross-Origin-Opener-Policy: same-origin
  Cross-Origin-Embedder-Policy: credentialless
  Cross-Origin-Resource-Policy: same-origin

# Service worker: NUNCA cachear el script, así las actualizaciones bajan inmediato.
/sw.js
  Cache-Control: public, max-age=0, must-revalidate
  Service-Worker-Allowed: /

# Manifest también: chico y quiero que se refresque
/manifest.webmanifest
  Cache-Control: public, max-age=3600

# Astro hashea los archivos en /_astro/ con content hash, son immutable de por vida.
/_astro/*
  Cache-Control: public, max-age=31536000, immutable

# Iconos y favicons: cambian poco, cachear 1 día
/favicon.svg
  Cache-Control: public, max-age=86400
/favicon.ico
  Cache-Control: public, max-age=86400
/apple-touch-icon.png
  Cache-Control: public, max-age=86400

# Imágenes en /img/ o similar: cachear 1 semana
/img/*
  Cache-Control: public, max-age=604800

# Sitemap y RSS: no cachear — se regenera en cada build
/sitemap.xml
  Cache-Control: public, max-age=0, must-revalidate
/rss.xml
  Cache-Control: public, max-age=3600

# robots.txt y ads.txt: cachear 1 día
/robots.txt
  Cache-Control: public, max-age=86400
/ads.txt
  Cache-Control: public, max-age=86400

# Página offline: cacheable a largo plazo
/offline.html
  Cache-Control: public, max-age=3600

# Search-index: SWR edge — 10 min fresh + 24h stale-while-revalidate.
# El JSON se invalida en cada deploy via CF Pages purge automático;
# entre deploys el SWR sirve la versión vieja al instante mientras
# revalida en background, evitando que el modal de búsqueda se sienta lento.
# IMPORTANTE: se sobrescribe el `CDN-Cache-Control: no-store` global de /*
# para que el edge SÍ cachee este JSON.
/search-index.json
  Cache-Control: public, max-age=600, stale-while-revalidate=86400
  CDN-Cache-Control: public, max-age=600, stale-while-revalidate=86400

# Embed widget: HABILITAR cross-origin iframes para que /embed/* se pueda
# poner en blogs, medios, fintech. CSP frame-ancestors:* es lo que browsers
# modernos respetan; X-Frame-Options es legacy y CF Pages no acepta header
# sin valor para borrarlo. Override SAMEORIGIN-global a ALLOWALL acá.
# CSP frame-ancestors gana si hay conflicto entre los dos headers.
/embed/*
  X-Frame-Options: ALLOWALL
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' blob: https://www.googletagmanager.com https://www.google-analytics.com https://cdn.jsdelivr.net; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' data: https://fonts.gstatic.com; img-src 'self' data: https:; connect-src 'self' https://www.googletagmanager.com https://www.google-analytics.com https://dolarapi.com https://api.argentinadatos.com https://region1.google-analytics.com https://open.er-api.com https://api.coingecko.com; frame-ancestors *
  # Override del CORP/COOP global: los embeds DEBEN ser embebibles cross-origin
  # (es el feature core de /embed/*). COEP queda heredado.
  Cross-Origin-Resource-Policy: cross-origin
  Cross-Origin-Opener-Policy: unsafe-none
