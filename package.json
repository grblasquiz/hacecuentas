{
  "name": "hacecuentas",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "og": "node --experimental-strip-types scripts/generate-og-images.ts",
    "related": "node --experimental-strip-types scripts/compute-related.ts",
    "validate:data": "node --experimental-strip-types scripts/validate-data-updates.ts",
    "new-calc": "node --experimental-strip-types scripts/new-calc.ts",
    "sitemap": "node --experimental-strip-types scripts/generate-sitemap.ts",
    "prebuild": "npm run validate:data && npm run related && npm run og && npm run sitemap",
    "build": "astro build",
    "preview": "npm run build && wrangler dev",
    "astro": "astro",
    "generate-types": "wrangler types",
    "deploy": "npm run build && wrangler deploy"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^13.1.10",
    "@astrojs/sitemap": "^3.7.2",
    "astro": "^6.1.6",
    "astro-compressor": "^1.3.0"
  },
  "devDependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "satori": "^0.26.0",
    "wrangler": "^4.83.0"
  },
  "overrides": {
    "vite": "^7"
  }
}
