---
import relatedAuto from '../lib/related-auto.json';

export interface Props {
  currentSlug: string;
  category: string;
  limit?: number;
  manualSlugs?: string[]; // override manual desde el JSON de la calc (relatedSlugs)
  lang?: 'es' | 'en' | 'pt';
}

const { currentSlug, category, limit = 4, manualSlugs = [], lang = 'es' } = Astro.props;

// Load calcs by lang
const esModules = import.meta.glob<any>('../content/calcs/*.json', { eager: true });
const enModules = import.meta.glob<any>('../content/calcs-en/*.json', { eager: true });
const ptModules = import.meta.glob<any>('../content/calcs-pt/*.json', { eager: true });
const calcModules = lang === 'en' ? enModules : lang === 'pt' ? ptModules : esModules;
const allCalcs = Object.values(calcModules).map((m: any) => m.default || m);
const bySlug = new Map(allCalcs.map((c: any) => [c.slug, c]));

const linkPrefix = lang === 'en' ? '/en/' : lang === 'pt' ? '/pt/' : '/';

// 1. Slugs manuales (si los definió el autor en el JSON) tienen prioridad
const manual = manualSlugs
  .map((s) => bySlug.get(s))
  .filter((c: any) => c && c.slug !== currentSlug);

// 2. Si faltan para llegar a limit, completamos con el mapping auto (TF-IDF)
const autoSlugs: string[] = (relatedAuto as Record<string, string[]>)[currentSlug] || [];
const auto = autoSlugs
  .map((s) => bySlug.get(s))
  .filter((c: any) => c && c.slug !== currentSlug);

// 3. Deduplicar manteniendo orden manual > auto, y cortar a limit
const seen = new Set<string>([currentSlug]);
const related: any[] = [];
for (const c of [...manual, ...auto]) {
  if (!seen.has(c.slug)) {
    seen.add(c.slug);
    related.push(c);
    if (related.length >= limit) break;
  }
}

// 4. Fallback final: si el mapping auto no tiene nada (JSON recién agregado), misma categoría
if (related.length < limit) {
  // Heuristic score: calcs con más contenido SEO tienden a ser más populares/útiles
  const sameCategory = allCalcs
    .filter((c: any) => c.category === category && !seen.has(c.slug))
    .map((c: any) => ({
      calc: c,
      score:
        (c.faq?.length || 0) * 2 +
        (c.useCases?.length || 0) +
        (c.example ? 3 : 0) +
        (c.explanation ? Math.min(c.explanation.length / 500, 5) : 0) +
        (c.sources?.length || 0) +
        (c.relatedSlugs?.length || 0) +
        (c.presets?.items?.length || 0),
    }))
    .sort((a: any, b: any) => b.score - a.score);
  for (const { calc: c } of sameCategory) {
    seen.add(c.slug);
    related.push(c);
    if (related.length >= limit) break;
  }
}

const categoryLabelsEs: Record<string, string> = {
  finanzas: 'Finanzas',
  negocios: 'Negocios',
  negocio: 'Negocios',
  salud: 'Salud',
  marketing: 'Marketing',
  deportes: 'Deportes',
  viajes: 'Viajes',
  vida: 'Vida cotidiana',
  mascotas: 'Mascotas',
  matematica: 'Matemática',
  construccion: 'Construcción',
  cocina: 'Cocina',
};

const categoryLabelsEn: Record<string, string> = {
  finanzas: 'Finance', negocios: 'Business', negocio: 'Business', salud: 'Health',
  marketing: 'Marketing', deportes: 'Sports', viajes: 'Travel', vida: 'Daily Life',
  mascotas: 'Pets', matematica: 'Math', construccion: 'Construction', cocina: 'Cooking',
  tecnologia: 'Technology', ciencia: 'Science', educacion: 'Education',
  familia: 'Family', automotor: 'Automotive', jardineria: 'Gardening',
  'medio-ambiente': 'Environment', electronica: 'Electronics', entretenimiento: 'Entertainment',
};

const categoryLabelsPt: Record<string, string> = {
  finanzas: 'Finanças', negocios: 'Negócios', negocio: 'Negócios', salud: 'Saúde',
  marketing: 'Marketing', deportes: 'Esportes', viajes: 'Viagens', vida: 'Dia a Dia',
  mascotas: 'Animais', matematica: 'Matemática', construccion: 'Construção', cocina: 'Culinária',
  tecnologia: 'Tecnologia', ciencia: 'Ciência', educacion: 'Educação',
  familia: 'Família', automotor: 'Automotivo', jardineria: 'Jardinagem',
  'medio-ambiente': 'Meio Ambiente', electronica: 'Eletrônica', entretenimiento: 'Entretenimento',
};

const categoryLabels = lang === 'en' ? categoryLabelsEn : lang === 'pt' ? categoryLabelsPt : categoryLabelsEs;
const headerTitle = lang === 'en' ? 'Related calculators' : lang === 'pt' ? 'Calculadoras relacionadas' : 'Calculadoras relacionadas';
const seeAllLabel = lang === 'en' ? 'See all →' : lang === 'pt' ? 'Ver todas →' : 'Ver todas →';
const seeAllHref = lang === 'en' ? '/en' : lang === 'pt' ? '/pt' : '/';
---

{related.length > 0 && (
  <section class="related">
    <div class="related-header">
      <h2>{headerTitle}</h2>
      <a href={seeAllHref} class="see-all">{seeAllLabel}</a>
    </div>
    <div class="related-grid">
      {related.map((c: any) => (
        <a href={`${linkPrefix}${c.slug}`} class="related-card">
          <div class="related-icon">{c.icon}</div>
          <div class="related-body">
            <div class="related-cat">{categoryLabels[c.category] || c.category}</div>
            <div class="related-title">{c.h1}</div>
          </div>
        </a>
      ))}
    </div>
  </section>
)}

<style>
  .related {
    margin-top: 3rem;
  }

  .related-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1.25rem;
    gap: 1rem;
  }

  .related h2 {
    margin: 0;
    font-size: 1.25rem;
    font-weight: 700;
  }

  .see-all {
    font-size: 0.875rem;
    color: var(--accent);
    text-decoration: none;
    font-weight: 500;
    white-space: nowrap;
  }

  .see-all:hover { text-decoration: underline; }

  .related-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 0.625rem;
  }

  .related-card {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.875rem 1rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    text-decoration: none;
    color: var(--text);
    transition: all 0.15s;
  }

  .related-card:hover {
    border-color: var(--accent);
    background: var(--bg);
    transform: translateY(-1px);
    box-shadow: var(--shadow-sm);
  }

  .related-icon {
    flex-shrink: 0;
    width: 36px;
    height: 36px;
    background: var(--accent-soft);
    border-radius: var(--radius-sm);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.125rem;
  }

  .related-body { flex: 1; min-width: 0; }

  .related-cat {
    font-size: 0.6875rem;
    font-weight: 600;
    color: var(--accent);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-bottom: 0.125rem;
  }

  .related-title {
    font-size: 0.875rem;
    font-weight: 600;
    line-height: 1.3;
    color: var(--text);
  }
</style>

<script is:inline>
(() => {
  const cards = document.querySelectorAll('.related .related-card');
  if (!cards.length) return;
  const c = navigator.connection || navigator.mozConnection || navigator.webkitConnection;
  if (c && (c.saveData || c.effectiveType === 'slow-2g' || c.effectiveType === '2g')) return;
  if (matchMedia('(prefers-reduced-data: reduce)').matches) return;
  const done = new Set();
  const prefetch = (href) => {
    if (!href || done.has(href)) return;
    done.add(href);
    const l = document.createElement('link');
    l.rel = 'prefetch';
    l.href = href;
    l.as = 'document';
    document.head.appendChild(l);
  };
  cards.forEach((card) => {
    const handler = () => prefetch(card.getAttribute('href'));
    card.addEventListener('pointerenter', handler, { once: true, passive: true });
    card.addEventListener('focus', handler, { once: true });
  });
})();
</script>
