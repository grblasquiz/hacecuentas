---
// Ad slot reutilizable (Google AdSense).
//
// Cuando se apruebe AdSense:
// 1) Reemplazar PUBLISHER_ID con ca-pub-XXXXXXXX
// 2) Configurar slots reales en el dashboard de AdSense
// 3) Pasar slot="XXXXXX" como prop
//
// Mientras tanto: si no hay publisher ID, no renderiza nada en prod.
// En dev muestra un placeholder visible.

const PUBLISHER_ID = ''; // ca-pub-XXXXXXXXXXXXXXXX
const isDev = import.meta.env.DEV;

export interface Props {
  slot?: string;
  format?: 'auto' | 'fluid' | 'rectangle' | 'horizontal';
  layout?: string;
  responsive?: boolean;
  label?: string; // texto opcional, ej "Publicidad"
}

const {
  slot = '0000000000',
  format = 'auto',
  layout,
  responsive = true,
  label = 'Publicidad',
} = Astro.props;

const enabled = !!PUBLISHER_ID;
---

{enabled && (
  <div class="ad-slot" data-slot={slot}>
    <span class="ad-label">{label}</span>
    <ins
      class="adsbygoogle"
      style="display:block"
      data-ad-client={PUBLISHER_ID}
      data-ad-slot={slot}
      data-ad-format={format}
      data-ad-layout={layout}
      data-full-width-responsive={responsive ? 'true' : 'false'}
    ></ins>
    <script is:inline>
      (window.adsbygoogle = window.adsbygoogle || []).push({});
    </script>
  </div>
)}

{!enabled && isDev && (
  <div class="ad-slot ad-placeholder" data-slot={slot}>
    <span class="ad-label">[AdSlot pendiente — slot {slot}]</span>
  </div>
)}

<style>
  .ad-slot {
    margin: 1.5rem 0;
    text-align: center;
    min-height: 100px;
  }
  .ad-label {
    display: block;
    font-size: 0.6875rem;
    color: var(--text-subtle);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-bottom: 0.375rem;
  }
  .ad-placeholder {
    padding: 2rem 1rem;
    border: 2px dashed var(--border);
    border-radius: var(--radius);
    background: var(--bg-soft);
    color: var(--text-subtle);
    font-size: 0.875rem;
  }
</style>
