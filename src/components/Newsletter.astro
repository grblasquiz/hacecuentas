---
// Sign-up de newsletter. Como aún no hay provider configurado,
// el form abre un mailto a contacto@hacecuentas.com.
// Cuando configuremos Buttondown/ConvertKit/etc., reemplazar el handler.
---

<section class="newsletter" aria-labelledby="news-heading">
  <div class="news-card">
    <div class="news-text">
      <span class="news-eyebrow">Newsletter mensual</span>
      <h2 id="news-heading">Avisos cuando cambia algo importante</h2>
      <p class="news-lead">
        Una vez por mes (a lo sumo): nuevas calculadoras, actualizaciones de fórmulas
        y novedades. Sin spam, puedes darte de baja en cualquier momento.
      </p>
    </div>
    <form class="news-form" id="hc-newsletter-form" novalidate>
      <label class="visually-hidden" for="hc-news-email">Tu email</label>
      <input
        type="email"
        id="hc-news-email"
        name="email"
        placeholder="tu@email.com"
        required
        autocomplete="email"
      />
      <button type="submit" class="news-btn">
        Suscribirme
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
        </svg>
      </button>
      <p class="news-msg" id="hc-news-msg" hidden></p>
    </form>
  </div>

  <script is:inline>
    (function () {
      var form = document.getElementById('hc-newsletter-form');
      var msg = document.getElementById('hc-news-msg');
      if (!form) return;
      form.addEventListener('submit', function (e) {
        e.preventDefault();
        var input = form.querySelector('input[type="email"]');
        var email = input ? input.value.trim() : '';
        if (!email || !/^[^@]+@[^@]+\.[^@]+$/.test(email)) {
          msg.hidden = false;
          msg.textContent = 'Ingresá un email válido.';
          msg.className = 'news-msg news-msg-err';
          return;
        }
        // Sin backend: abrir mailto con el email pre-llenado
        var subject = encodeURIComponent('Suscripción newsletter Hacé Cuentas');
        var body = encodeURIComponent('Quiero suscribirme al newsletter desde: ' + email);
        window.location.href = 'mailto:contacto@hacecuentas.com?subject=' + subject + '&body=' + body;
        msg.hidden = false;
        msg.textContent = '¡Gracias! Te abrimos el mail para confirmar la suscripción.';
        msg.className = 'news-msg news-msg-ok';
        if (typeof window.gtag === 'function') {
          window.gtag('event', 'newsletter_signup', { method: 'mailto' });
        }
      });
    })();
  </script>
</section>

<style>
  .newsletter {
    margin: 4rem auto 2rem;
    max-width: 1080px;
    padding: 0 1rem;
  }
  .news-card {
    display: grid;
    grid-template-columns: 1.3fr 1fr;
    gap: 2rem;
    align-items: center;
    padding: 2rem 2.25rem;
    background: linear-gradient(135deg, var(--accent-soft) 0%, var(--bg-soft) 100%);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
  }
  .news-eyebrow {
    display: inline-block;
    font-size: 0.6875rem;
    font-weight: 700;
    color: var(--accent);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 0.5rem;
  }
  .news-card h2 {
    margin: 0 0 0.5rem;
    font-size: clamp(1.125rem, 2vw, 1.375rem);
    line-height: 1.25;
  }
  .news-lead {
    margin: 0;
    color: var(--text-muted);
    font-size: 0.9375rem;
    line-height: 1.55;
  }
  .news-form {
    display: flex;
    gap: 0.5rem;
    flex-direction: column;
  }
  .news-form input[type="email"] {
    padding: 0.75rem 0.875rem;
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    background: var(--bg);
    font-family: inherit;
    font-size: 0.9375rem;
    color: var(--text);
    transition: border-color 0.15s, box-shadow 0.15s;
  }
  .news-form input[type="email"]:focus {
    outline: none;
    border-color: var(--accent);
    box-shadow: 0 0 0 3px var(--accent-soft);
  }
  .news-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.375rem;
    padding: 0.75rem 1rem;
    background: var(--accent);
    color: #ffffff;
    border: none;
    border-radius: var(--radius-sm);
    font-family: inherit;
    font-size: 0.9375rem;
    font-weight: 600;
    cursor: pointer;
    transition: background 0.15s, transform 0.15s;
  }
  .news-btn:hover { background: var(--accent-strong); transform: translateY(-1px); }
  .news-msg {
    margin: 0.25rem 0 0;
    font-size: 0.8125rem;
    line-height: 1.4;
  }
  .news-msg-ok { color: var(--success, #16a34a); }
  .news-msg-err { color: #dc2626; }
  .visually-hidden {
    position: absolute;
    width: 1px; height: 1px;
    margin: -1px; padding: 0;
    overflow: hidden; clip: rect(0,0,0,0);
    white-space: nowrap; border: 0;
  }
  @media (max-width: 720px) {
    .news-card { grid-template-columns: 1fr; padding: 1.5rem 1.25rem; }
  }
</style>
