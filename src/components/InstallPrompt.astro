---
/**
 * PWA install prompt — banner flotante que aparece cuando el browser dispara
 * `beforeinstallprompt`. El usuario decide si instala o dismisea.
 *
 * Flujo:
 *   1. Browser dispara `beforeinstallprompt` → guardamos el evento.
 *   2. Si el user no dismisseó antes, mostramos el banner después de 30s
 *      en la página (para no molestar a usuarios de paso).
 *   3. Al click en "Instalar" disparamos prompt() nativo.
 *   4. Dismiss → guarda en localStorage 'hc-install-dismissed' por 30 días.
 *   5. Si ya está instalado (display-mode: standalone) → no mostramos nada.
 *
 * Push notifications: requieren backend propio para enviar. Preparamos el
 * request de permiso pero NO enviamos push todavía (fase 2).
 */
---

<div id="hc-install-banner" class="hc-install-banner" hidden role="dialog" aria-labelledby="hc-inst-title">
  <div class="hc-inst-card">
    <div class="hc-inst-icon" aria-hidden="true">📱</div>
    <div class="hc-inst-body">
      <div class="hc-inst-title" id="hc-inst-title">Instalá Hacé Cuentas</div>
      <p class="hc-inst-text">
        Accedé a tus calculadoras desde el escritorio o la pantalla de inicio,
        sin abrir el navegador. Es gratis y pesa menos de 1 MB.
      </p>
      <div class="hc-inst-actions">
        <button type="button" class="hc-inst-btn hc-inst-btn-primary" id="hc-inst-accept">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/>
            <polyline points="7 10 12 15 17 10"/>
            <line x1="12" y1="15" x2="12" y2="3"/>
          </svg>
          Instalar
        </button>
        <button type="button" class="hc-inst-btn hc-inst-btn-ghost" id="hc-inst-dismiss">Ahora no</button>
      </div>
    </div>
    <button type="button" class="hc-inst-close" id="hc-inst-close" aria-label="Cerrar">×</button>
  </div>
</div>

<script is:inline>
(function () {
  var KEY = 'hc-install-dismissed';
  var DISMISS_DAYS = 30;
  var SHOW_AFTER_MS = 25000; // 25s de engagement antes de mostrar

  // Ya instalado? No mostrar
  var isStandalone =
    window.matchMedia('(display-mode: standalone)').matches ||
    window.navigator.standalone === true;
  if (isStandalone) return;

  // Dismiss reciente? No mostrar
  try {
    var raw = localStorage.getItem(KEY);
    if (raw) {
      var when = parseInt(raw, 10);
      if (!isNaN(when) && Date.now() - when < DISMISS_DAYS * 86400000) {
        return;
      }
    }
  } catch (e) {}

  var deferredPrompt = null;
  var banner = document.getElementById('hc-install-banner');

  function showBanner() {
    if (!banner || !deferredPrompt) return;
    banner.hidden = false;
    requestAnimationFrame(function () {
      banner.classList.add('hc-inst-visible');
    });
  }
  function hideBanner() {
    if (!banner) return;
    banner.classList.remove('hc-inst-visible');
    setTimeout(function () { banner.hidden = true; }, 200);
  }
  function remember() {
    try { localStorage.setItem(KEY, String(Date.now())); } catch (e) {}
  }

  window.addEventListener('beforeinstallprompt', function (e) {
    e.preventDefault();
    deferredPrompt = e;
    setTimeout(showBanner, SHOW_AFTER_MS);
  });

  window.addEventListener('appinstalled', function () {
    hideBanner();
    remember();
    if (typeof window.gtag === 'function') {
      window.gtag('event', 'pwa_installed', { method: 'browser_prompt' });
    }
  });

  document.addEventListener('DOMContentLoaded', function () {
    var accept = document.getElementById('hc-inst-accept');
    var dismiss = document.getElementById('hc-inst-dismiss');
    var close = document.getElementById('hc-inst-close');

    if (accept) accept.addEventListener('click', async function () {
      if (!deferredPrompt) { hideBanner(); return; }
      hideBanner();
      deferredPrompt.prompt();
      try {
        var choice = await deferredPrompt.userChoice;
        if (typeof window.gtag === 'function') {
          window.gtag('event', 'pwa_prompt_result', { outcome: choice.outcome });
        }
        if (choice.outcome !== 'accepted') remember();
      } catch (e) {}
      deferredPrompt = null;
    });

    function dismissHandler() { hideBanner(); remember(); }
    if (dismiss) dismiss.addEventListener('click', dismissHandler);
    if (close) close.addEventListener('click', dismissHandler);
  });
})();
</script>

<style is:global>
  .hc-install-banner {
    position: fixed;
    bottom: 1rem;
    left: 1rem;
    right: 1rem;
    z-index: 190;
    pointer-events: none;
    opacity: 0;
    transform: translateY(16px);
    transition: opacity 0.25s, transform 0.25s;
  }
  .hc-install-banner[hidden] { display: none; }
  .hc-install-banner.hc-inst-visible {
    opacity: 1;
    transform: translateY(0);
  }

  .hc-inst-card {
    pointer-events: auto;
    max-width: 440px;
    margin: 0 auto;
    background: var(--bg-card, #fff);
    border: 1px solid var(--border, #e2e8f0);
    border-radius: var(--radius-lg, 14px);
    box-shadow:
      0 1px 3px rgba(15, 23, 42, 0.08),
      0 12px 32px -8px rgba(15, 23, 42, 0.18);
    padding: 1rem 1.125rem;
    display: flex;
    gap: 0.875rem;
    align-items: flex-start;
    position: relative;
  }

  .hc-inst-icon {
    flex-shrink: 0;
    width: 44px;
    height: 44px;
    border-radius: 12px;
    background: linear-gradient(135deg, var(--accent-soft, #e0f2fe) 0%, color-mix(in srgb, #a78bfa 20%, var(--accent-soft, #e0f2fe)) 100%);
    border: 1px solid color-mix(in srgb, var(--accent, #2563eb) 25%, transparent);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.375rem;
  }

  .hc-inst-body { flex: 1; min-width: 0; padding-right: 1.25rem; }

  .hc-inst-title {
    font-weight: 700;
    font-size: 0.9375rem;
    color: var(--text, #0f172a);
    margin-bottom: 0.25rem;
  }
  .hc-inst-text {
    margin: 0 0 0.75rem;
    font-size: 0.8125rem;
    color: var(--text-muted, #475569);
    line-height: 1.5;
  }

  .hc-inst-actions {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .hc-inst-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.5rem 0.875rem;
    border-radius: var(--radius-sm, 6px);
    font-size: 0.8125rem;
    font-weight: 600;
    border: 1px solid transparent;
    cursor: pointer;
    font-family: inherit;
    transition: transform 0.15s, filter 0.15s;
  }
  .hc-inst-btn:active { transform: translateY(1px); }

  .hc-inst-btn-primary {
    background: linear-gradient(135deg, var(--accent, #2563eb) 0%, color-mix(in srgb, var(--accent, #2563eb) 80%, #8b5cf6) 100%);
    color: #ffffff;
    box-shadow: 0 2px 8px -2px color-mix(in srgb, var(--accent, #2563eb) 40%, transparent);
  }
  .hc-inst-btn-primary:hover { filter: brightness(1.05); }

  .hc-inst-btn-ghost {
    background: transparent;
    color: var(--text-muted, #475569);
  }
  .hc-inst-btn-ghost:hover {
    background: var(--bg-soft, #f8fafc);
    color: var(--text, #0f172a);
  }

  .hc-inst-close {
    position: absolute;
    top: 0.5rem;
    right: 0.5rem;
    width: 28px;
    height: 28px;
    border: none;
    background: transparent;
    cursor: pointer;
    font-size: 1.25rem;
    line-height: 1;
    color: var(--text-subtle, #64748b);
    border-radius: var(--radius-sm, 6px);
  }
  .hc-inst-close:hover {
    background: var(--bg-soft, #f8fafc);
    color: var(--text, #0f172a);
  }

  @media (max-width: 540px) {
    .hc-install-banner { left: 0.5rem; right: 0.5rem; bottom: 0.5rem; }
    .hc-inst-card { padding: 0.875rem; }
    .hc-inst-body { padding-right: 1rem; }
    .hc-inst-actions .hc-inst-btn { flex: 1; justify-content: center; }
  }

  @media (prefers-reduced-motion: reduce) {
    .hc-install-banner { transition: none; }
  }
</style>
