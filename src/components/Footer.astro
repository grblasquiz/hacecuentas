---
const year = new Date().getFullYear();
---

<footer>
  <div class="container">
    <div class="col">
      <h4>Hacé Cuentas</h4>
      <p>Calculadoras online gratuitas para Argentina y Latinoamérica.</p>
    </div>
    <div class="col">
      <h4>Categorías</h4>
      <a href="/categoria/finanzas">Finanzas</a>
      <a href="/categoria/salud">Salud</a>
      <a href="/categoria/vida">Vida cotidiana</a>
      <a href="/categoria/negocio">Negocios</a>
    </div>
    <div class="col">
      <h4>Legal</h4>
      <a href="/sobre-nosotros">Sobre nosotros</a>
      <a href="/terminos">Términos</a>
      <a href="/privacidad">Privacidad</a>
      <a href="/contacto">Contacto</a>
    </div>
  </div>
  <div class="bottom">
    <p>© {year} Hacé Cuentas · Hecho en Argentina 🇦🇷</p>
  </div>
</footer>

<style>
  footer {
    background: var(--bg-card);
    border-top: 1px solid var(--border);
    margin-top: 4rem;
    padding: 3rem 1rem 1rem;
  }

  .container {
    max-width: 1100px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 2rem;
  }

  .col h4 {
    font-size: 1rem;
    margin-bottom: 1rem;
    color: var(--text);
  }

  .col p, .col a {
    font-size: 0.875rem;
    color: var(--text-muted);
  }

  .col a {
    display: block;
    margin-bottom: 0.5rem;
    text-decoration: none;
  }

  .col a:hover { color: var(--accent); }

  .bottom {
    max-width: 1100px;
    margin: 2rem auto 0;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border);
    text-align: center;
  }

  .bottom p {
    font-size: 0.875rem;
    color: var(--text-muted);
  }
</style>
