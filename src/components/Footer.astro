<style>
  .site-footer {
    background: var(--bg-soft);
    border-top: 1px solid var(--border);
    margin-top: 6rem;
    padding: 3.5rem 1.25rem 1.5rem;
  }

  .footer-grid {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1.3fr repeat(7, 1fr);
    gap: 1.5rem;
  }

  .col-brand {
    max-width: 340px;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.625rem;
    margin-bottom: 0.75rem;
  }

  .brand-mark {
    width: 28px;
    height: 28px;
  }

  .brand-name {
    font-size: 1rem;
    font-weight: 700;
    color: var(--text);
    letter-spacing: -0.015em;
  }

  .tagline {
    font-size: 0.9375rem;
    color: var(--text-muted);
    margin-bottom: 1rem;
    line-height: 1.6;
  }

  .badges {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .badge {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.25rem 0.625rem;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 999px;
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--text-muted);
  }

  .badge .dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--success);
  }

  .col h3 {
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--text);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-bottom: 1rem;
  }

  .col a {
    display: block;
    font-size: 0.9375rem;
    color: var(--text-muted);
    margin-bottom: 0.625rem;
    text-decoration: none;
    transition: color 0.15s;
  }

  .col a:hover {
    color: var(--accent);
  }

  .col a.see-more {
    color: var(--accent);
    font-weight: 500;
    margin-top: 0.25rem;
    font-size: 0.8125rem;
  }

  .col a.see-more:hover {
    text-decoration: underline;
  }

  .cookie-config-btn {
    display: block;
    background: none;
    border: none;
    padding: 0;
    margin-top: 0.625rem;
    font-family: inherit;
    font-size: 0.8125rem;
    color: var(--accent);
    cursor: pointer;
    text-align: left;
    font-weight: 500;
  }
  .cookie-config-btn:hover { text-decoration: underline; }

  .disclaimer {
    max-width: 1120px;
    margin: 3rem auto 0;
    padding: 1.25rem 1.5rem;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    display: flex;
    gap: 0.875rem;
    align-items: flex-start;
  }

  .disc-icon {
    flex-shrink: 0;
    color: var(--text-subtle);
    margin-top: 2px;
  }

  .disclaimer p {
    font-size: 0.8125rem;
    color: var(--text-subtle);
    line-height: 1.6;
    margin: 0;
  }

  .disclaimer strong {
    color: var(--text-muted);
    font-weight: 600;
  }

  .bottom {
    max-width: 1120px;
    margin: 1.5rem auto 0;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border);
    display: flex;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .bottom p {
    font-size: 0.8125rem;
    color: var(--text-subtle);
    margin: 0;
  }

  .bottom-links a {
    color: var(--text-subtle);
    margin: 0 0.125rem;
  }

  .bottom-links a:hover { color: var(--accent); }

  @media (max-width: 1020px) {
    .footer-grid {
      grid-template-columns: 1fr 1fr 1fr;
      gap: 2.25rem 2rem;
    }
