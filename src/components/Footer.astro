---
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="footer-grid">
    <div class="col col-brand">
      <div class="brand">
        <svg class="brand-mark" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <rect x="2" y="2" width="28" height="28" rx="7" fill="#2563eb"/>
          <rect x="7" y="7" width="18" height="5" rx="1.5" fill="#ffffff" opacity="0.95"/>
          <circle cx="9.5" cy="17.5" r="1.5" fill="#ffffff"/>
          <circle cx="16" cy="17.5" r="1.5" fill="#ffffff"/>
          <circle cx="22.5" cy="17.5" r="1.5" fill="#ffffff"/>
          <circle cx="9.5" cy="23" r="1.5" fill="#ffffff"/>
          <circle cx="16" cy="23" r="1.5" fill="#ffffff"/>
          <circle cx="22.5" cy="23" r="1.5" fill="#ffffff"/>
        </svg>
        <span class="brand-name">Hacé Cuentas</span>
      </div>
      <p class="tagline">
        Calculadoras online gratuitas, precisas y adaptadas a la realidad argentina.
      </p>
      <div class="badges">
        <span class="badge"><span class="dot"></span>Sin registro</span>
        <span class="badge"><span class="dot"></span>100% gratuito</span>
      </div>
    </div>

    <div class="col">
      <h4>Finanzas</h4>
      <a href="/sueldo-en-mano-argentina">Sueldo en mano</a>
      <a href="/calculadora-aguinaldo-sac">Aguinaldo (SAC)</a>
      <a href="/calculadora-cuota-prestamo">Cuota de préstamo</a>
      <a href="/calculadora-monotributo-2026">Monotributo</a>
      <a href="/calculadora-interes-compuesto">Interés compuesto</a>
      <a href="/conversor-dolar-argentina">Dólar Argentina</a>
    </div>

    <div class="col">
      <h4>Salud & Vida</h4>
      <a href="/calculadora-imc">IMC</a>
      <a href="/calculadora-calorias-diarias-tdee">Calorías diarias</a>
      <a href="/calculadora-embarazo">Semanas de embarazo</a>
      <a href="/calculadora-ovulacion-dias-fertiles">Ovulación</a>
      <a href="/calculadora-edad-exacta">Edad exacta</a>
      <a href="/calculadora-porcentajes">Porcentajes</a>
    </div>

    <div class="col">
      <h4>Sobre el sitio</h4>
      <a href="/sobre-nosotros">Sobre nosotros</a>
      <a href="/contacto">Contacto</a>
      <a href="/terminos">Términos</a>
      <a href="/privacidad">Privacidad</a>
    </div>
  </div>

  <div class="disclaimer">
    <p>
      <strong>Aviso legal:</strong> los cálculos de Hacé Cuentas son de carácter
      <em>informativo</em>. Las fórmulas de sueldo, aguinaldo, vacaciones y monotributo se basan en
      la LCT y resoluciones AFIP vigentes al año en curso. Para trámites oficiales o decisiones
      financieras importantes, consultá con un profesional (contador, abogado laboralista o médico según el caso).
    </p>
  </div>

  <div class="bottom">
    <p>© {year} Hacé Cuentas. Hecho en Argentina.</p>
    <p class="bottom-links">
      <a href="/terminos">Términos</a>
      <span aria-hidden="true">·</span>
      <a href="/privacidad">Privacidad</a>
      <span aria-hidden="true">·</span>
      <a href="/contacto">Contacto</a>
    </p>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--bg-soft);
    border-top: 1px solid var(--border);
    margin-top: 6rem;
    padding: 3.5rem 1.25rem 1.5rem;
  }

  .footer-grid {
    max-width: 1120px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1.4fr 1fr 1fr 1fr;
    gap: 3rem;
  }

  .col-brand {
    max-width: 340px;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.625rem;
    margin-bottom: 0.75rem;
  }

  .brand-mark {
    width: 28px;
    height: 28px;
  }

  .brand-name {
    font-size: 1rem;
    font-weight: 700;
    color: var(--text);
    letter-spacing: -0.015em;
  }

  .tagline {
    font-size: 0.9375rem;
    color: var(--text-muted);
    margin-bottom: 1rem;
    line-height: 1.6;
  }

  .badges {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .badge {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.25rem 0.625rem;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 999px;
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--text-muted);
  }

  .badge .dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--success);
  }

  .col h4 {
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--text);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-bottom: 1rem;
  }

  .col a {
    display: block;
    font-size: 0.9375rem;
    color: var(--text-muted);
    margin-bottom: 0.625rem;
    text-decoration: none;
    transition: color 0.15s;
  }

  .col a:hover {
    color: var(--accent);
  }

  .disclaimer {
    max-width: 1120px;
    margin: 3rem auto 0;
    padding: 1.25rem 1.5rem;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: var(--radius);
  }

  .disclaimer p {
    font-size: 0.8125rem;
    color: var(--text-subtle);
    line-height: 1.6;
    margin: 0;
  }

  .disclaimer strong {
    color: var(--text-muted);
    font-weight: 600;
  }

  .bottom {
    max-width: 1120px;
    margin: 1.5rem auto 0;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border);
    display: flex;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .bottom p {
    font-size: 0.8125rem;
    color: var(--text-subtle);
    margin: 0;
  }

  .bottom-links a {
    color: var(--text-subtle);
    margin: 0 0.125rem;
  }

  .bottom-links a:hover { color: var(--accent); }

  @media (max-width: 860px) {
    .footer-grid {
      grid-template-columns: 1fr 1fr;
      gap: 2.25rem 2rem;
    }
    .col-brand { grid-column: 1 / -1; max-width: none; }
  }

  @media (max-width: 480px) {
    .footer-grid { grid-template-columns: 1fr; }
    .bottom { flex-direction: column; align-items: flex-start; }
  }
</style>
