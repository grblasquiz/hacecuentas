<script>
  // Lazy loading por fórmula — Vite genera 1 chunk por archivo (.ts), cargado on-demand.
  // Reemplaza el import eager del 'index' que metía las 1.500 fórmulas en el bundle principal.
  const formulaLoaders = import.meta.glob<any>('../lib/formulas/*.ts');
  const formulaCache = new Map<string, Function>();

  async function loadFormula(formulaId: string): Promise<Function | null> {
    if (formulaCache.has(formulaId)) return formulaCache.get(formulaId)!;
    const loader = formulaLoaders[`../lib/formulas/${formulaId}.ts`];
    if (!loader) return null;
    const mod: any = await loader();
    // Encontrar la función exportada (cualquier export de tipo function)
    const fnKey = Object.keys(mod).find((k) => typeof mod[k] === 'function');
    if (!fnKey) return null;
    formulaCache.set(formulaId, mod[fnKey]);
    return mod[fnKey];
  }

  // ── Chart.js lazy loader (singleton) ─────────────────────────
  const CHART_CDN = 'https://cdn.jsdelivr.net/npm/chart.js@4.4.6/dist/chart.umd.min.js';
  let chartJsPromise: Promise<any> | null = null;
  function loadChartJs(): Promise<any> {
    if ((window as any).Chart) return Promise.resolve((window as any).Chart);
    if (chartJsPromise) return chartJsPromise;
    chartJsPromise = new Promise((resolve, reject) => {
      const s = document.createElement('script');
      s.src = CHART_CDN;
      s.async = true;
      s.crossOrigin = 'anonymous';
      s.onload = () => resolve((window as any).Chart);
      s.onerror = () => {
        chartJsPromise = null;
        reject(new Error('No se pudo cargar Chart.js'));
      };
      document.head.appendChild(s);
    });
    return chartJsPromise;
  }

  function themeColors() {
    const isDark = document.documentElement.getAttribute('data-theme') === 'dark';
    return {
      isDark,
      text: isDark ? '#cbd5e1' : '#475569',
      grid: isDark ? 'rgba(203, 213, 225, 0.12)' : 'rgba(71, 85, 105, 0.12)',
      accent: isDark ? '#60a5fa' : '#2563eb',
      accentSoft: isDark ? 'rgba(96, 165, 250, 0.25)' : 'rgba(37, 99, 235, 0.14)',
      accentStrong: isDark ? '#93c5fd' : '#1d4ed8',
      muted: isDark ? '#94a3b8' : '#64748b',
      mutedSoft: isDark ? 'rgba(148, 163, 184, 0.35)' : 'rgba(100, 116, 139, 0.22)',
    };
  }

  // Formato compacto (1.2k, 3.4M) para ejes numéricos
  function compactFmt(n: number): string {
    if (!isFinite(n)) return String(n);
    const abs = Math.abs(n);
    if (abs >= 1_000_000_000) return (n / 1_000_000_000).toFixed(1).replace(/\.0$/, '') + 'B';
    if (abs >= 1_000_000) return (n / 1_000_000).toFixed(1).replace(/\.0$/, '') + 'M';
    if (abs >= 1_000) return (n / 1_000).toFixed(1).replace(/\.0$/, '') + 'k';
    return String(Math.round(n * 100) / 100);
  }

  // Render: devuelve la instancia Chart o null
  function renderChart(Chart: any, canvas: HTMLCanvasElement, spec: any, existing: any | null): any {
    if (existing) { try { existing.destroy(); } catch {} }
    const col = themeColors();
    const type = spec.type;

    // Tipo "scale": lo renderizamos como un bar horizontal con un único segmento coloreado por categoría,
    // y un marker vertical con annotations (sin plugins: hacemos overlay simple).
    if (type === 'scale') {
      const segments = spec.segments as Array<{ nombre: string; max: number }>;
      const minVal = spec.min ?? 0;
      const marker = spec.marker as number;
      const markerLabel = spec.markerLabel as string;
      const unit = spec.unit || '';
      // Construimos segmentos: cada uno es una barra apilada horizontal
      const defaultPalette = col.isDark
        ? ['#7f1d1d', '#9a3412', '#b45309', '#166534', '#1e40af', '#6d28d9']
        : ['#fecaca', '#fed7aa', '#fde68a', '#bbf7d0', '#bfdbfe', '#ddd6fe'];
      const palText = col.isDark ? '#f1f5f9' : '#334155';
      let cursor = minVal;
      const datasets = segments.map((seg: any, idx: number) => {
        const width = Math.max(0, seg.max - cursor);
        const segColor = seg.color
          ? (col.isDark ? (seg.colorDark || seg.color) : seg.color)
          : defaultPalette[idx % defaultPalette.length];
        const ds = {
          label: seg.nombre,
          data: [width],
          backgroundColor: segColor,
          borderWidth: 0,
          barPercentage: 0.75,
          categoryPercentage: 0.75,
          stack: 's',
        };
        cursor = seg.max;
        return ds;
      });
      const finalMax = segments[segments.length - 1].max;
      // The stacked bar widths accumulate from 0, so the bar coordinate
      // system goes from 0 to (finalMax - minVal).  We must use that same
      // coordinate system for the x-axis and the marker, and offset the
      // tick labels so they show the real absolute values.
      const totalWidth = finalMax - minVal;

      return new Chart(canvas, {
        type: 'bar',
        data: { labels: [spec.markerLabel ? '' : 'Rango'], datasets },
        options: {
          indexAxis: 'y',
          responsive: true,
          maintainAspectRatio: false,
          layout: { padding: { top: 28, bottom: 4, left: 8, right: 16 } },
          plugins: {
            legend: {
              position: 'bottom',
              labels: { color: col.text, boxWidth: 10, padding: 8, font: { size: 11 } },
            },
            tooltip: {
              callbacks: {
                label: (ctx: any) => `${ctx.dataset.label}`,
              },
            },
            markerAnnotation: {
              value: marker - minVal,
              label: markerLabel,
              min: 0,
              max: totalWidth,
              color: col.accent,
              textColor: col.text,
              bg: col.isDark ? '#0f172a' : '#ffffff',
              unit,
            },
          },
          scales: {
            x: {
              stacked: true,
              min: 0,
              max: totalWidth,
              ticks: {
                color: col.text,
                callback: (v: any) => compactFmt(Number(v) + minVal) + (unit ? ' ' + unit.split(' ')[0] : ''),
              },
              grid: { color: col.grid, drawBorder: false },
            },
            y: {
              stacked: true,
              ticks: { color: col.text, display: false },
              grid: { display: false, drawBorder: false },
            },
          },
        },
        plugins: [markerAnnotationPlugin],
      });
    }

    // Line / bar genéricos
    const isBar = type === 'bar';
    const isStacked = !!spec.stacked;
    const indexAxis = spec.indexAxis || 'x';

    const palette = [col.accent, col.muted];
    const paletteSoft = [col.accentSoft, col.mutedSoft];

    const datasets = (spec.data.datasets || []).map((ds: any, idx: number) => {
      const useMuted = ds.color === 'muted' || idx > 0;
      const border = useMuted ? palette[1] : palette[0];
      const fill = useMuted ? paletteSoft[1] : paletteSoft[0];
      const base: any = {
        label: ds.label,
        data: ds.data,
      };
      if (isBar) {
        base.backgroundColor = useMuted ? paletteSoft[1] : col.accent;
        base.borderColor = border;
        base.borderWidth = 0;
        base.borderRadius = 4;
        base.maxBarThickness = 48;
        if (isStacked) base.stack = 's';
      } else {
        base.borderColor = border;
        base.backgroundColor = fill;
        base.fill = ds.fill !== false;
        base.tension = typeof ds.tension === 'number' ? ds.tension : 0.25;
        base.pointRadius = ds.data.length > 40 ? 0 : 2;
        base.pointHoverRadius = 4;
        base.borderWidth = 2;
        if (ds.dashed) base.borderDash = [6, 4];
      }
      return base;
    });

    // suffix para tooltip y ticks
    const suffix = (spec.data.datasets && spec.data.datasets[0] && spec.data.datasets[0].suffix) || '';

    const options: any = {
      responsive: true,
      maintainAspectRatio: false,
      indexAxis,
      interaction: { mode: 'index', intersect: false },
      plugins: {
        legend: {
          display: datasets.length > 1,
          position: 'bottom',
          labels: { color: col.text, boxWidth: 12, padding: 10, font: { size: 11 } },
        },
        tooltip: {
          callbacks: {
            label: (ctx: any) => {
              const v = ctx.parsed.y ?? ctx.parsed.x ?? ctx.parsed;
              const num = typeof v === 'number' ? v : Number(v);
              const s = suffix || '';
              if (s === '%') return `${ctx.dataset.label}: ${num.toFixed(2)}%`;
              if (s) return `${ctx.dataset.label}: ${new Intl.NumberFormat('es-AR').format(num)}${s}`;
              return `${ctx.dataset.label}: ${new Intl.NumberFormat('es-AR').format(num)}`;
            },
          },
        },
      },
      scales: {
        x: (() => {
          const xs: any = {
            stacked: isStacked,
            ticks: {
              color: col.text,
              maxRotation: 0,
              autoSkip: true,
              maxTicksLimit: indexAxis === 'y' ? 8 : 10,
            },
            grid: { color: col.grid, drawBorder: false },
          };
          if (indexAxis === 'y') {
            // Para barras horizontales con rangos, permitimos override de xRange
            if (Array.isArray(spec.xRange) && spec.xRange.length === 2) {
              xs.min = spec.xRange[0];
              xs.max = spec.xRange[1];
            } else {
              xs.beginAtZero = true;
            }
            xs.ticks.callback = (v: any) => compactFmt(Number(v)) + (suffix === '%' ? '%' : '');
          }
          return xs;
        })(),
        y: (() => {
          const ys: any = {
            stacked: isStacked,
            ticks: { color: col.text },
            grid: { color: col.grid, drawBorder: false },
          };
          if (indexAxis === 'x') {
            ys.beginAtZero = true;
            ys.ticks.callback = (v: any) => compactFmt(Number(v)) + (suffix === '%' ? '%' : '');
          }
          return ys;
        })(),
      },
    };

    return new Chart(canvas, {
      type: isBar ? 'bar' : 'line',
      data: { labels: spec.data.labels, datasets },
      options,
    });
  }

  // Plugin: dibuja un marker vertical sobre un gráfico "scale"
  const markerAnnotationPlugin = {
    id: 'markerAnnotation',
    afterDatasetsDraw(chart: any, _args: any, opts: any) {
      if (!opts || typeof opts.value !== 'number') return;
      const { ctx, chartArea, scales } = chart;
      const xScale = scales.x;
      if (!xScale) return;
      const clamped = Math.max(opts.min ?? xScale.min, Math.min(opts.max ?? xScale.max, opts.value));
      const x = xScale.getPixelForValue(clamped);
      const top = chartArea.top - 24;
      const bottom = chartArea.bottom;
      ctx.save();
      // línea vertical
      ctx.strokeStyle = opts.color || '#2563eb';
      ctx.lineWidth = 2;
      ctx.setLineDash([4, 3]);
      ctx.beginPath();
      ctx.moveTo(x, top + 18);
      ctx.lineTo(x, bottom);
      ctx.stroke();
      ctx.setLineDash([]);
      // pill con label
      const label = opts.label || String(opts.value);
      ctx.font = '600 11px system-ui, -apple-system, sans-serif';
      const padX = 8;
      const padY = 4;
      const metrics = ctx.measureText(label);
      const w = metrics.width + padX * 2;
      const h = 20;
      let pillX = x - w / 2;
      if (pillX < chartArea.left) pillX = chartArea.left;
      if (pillX + w > chartArea.right) pillX = chartArea.right - w;
      const pillY = top;
      // fondo
      ctx.fillStyle = opts.color || '#2563eb';
      const r = 10;
      ctx.beginPath();
      ctx.moveTo(pillX + r, pillY);
      ctx.lineTo(pillX + w - r, pillY);
      ctx.quadraticCurveTo(pillX + w, pillY, pillX + w, pillY + r);
      ctx.lineTo(pillX + w, pillY + h - r);
      ctx.quadraticCurveTo(pillX + w, pillY + h, pillX + w - r, pillY + h);
      ctx.lineTo(pillX + r, pillY + h);
      ctx.quadraticCurveTo(pillX, pillY + h, pillX, pillY + h - r);
      ctx.lineTo(pillX, pillY + r);
      ctx.quadraticCurveTo(pillX, pillY, pillX + r, pillY);
      ctx.closePath();
      ctx.fill();
      // texto
      ctx.fillStyle = '#ffffff';
      ctx.textBaseline = 'middle';
      ctx.fillText(label, pillX + padX, pillY + h / 2 + 0.5);
      ctx.restore();
    },
  };

  function animateValue(el: HTMLElement, end: any, duration: number) {
    if (typeof end !== 'number' || isNaN(end) || !isFinite(end)) { el.textContent = end; return; }
    var start = 0;
    var startTime: number | null = null;
    function step(ts: number) {
      if (!startTime) startTime = ts;
      var progress = Math.min((ts - startTime) / duration, 1);
      var eased = 1 - Math.pow(1 - progress, 3); // easeOutCubic
      var current = start + (end - start) * eased;
      el.textContent = (el as any)._formatter ? (el as any)._formatter(current) : current.toLocaleString('es-AR', {maximumFractionDigits: 2});
      if (progress < 1) requestAnimationFrame(step);
    }
    requestAnimationFrame(step);
  }

  function formatValue(value: number | string, format: string, suffix = ''): string {
    if (value === null || value === undefined || value === '') return '—';
    let formatted: string;
    if (format === 'currency') {
      formatted = new Intl.NumberFormat('es-AR', {
        style: 'currency',
        currency: 'ARS',
        maximumFractionDigits: 0,
      }).format(Number(value));
    } else if (format === 'number') {
      formatted = new Intl.NumberFormat('es-AR', { maximumFractionDigits: 2 }).format(Number(value));
    } else if (format === 'percentage') {
      formatted = `${Number(value).toFixed(2)}%`;
    } else if (format === 'date') {
      const d = new Date(value);
      formatted = d.toLocaleDateString('es-AR', { day: '2-digit', month: 'long', year: 'numeric' });
    } else {
      formatted = String(value);
    }
    return suffix ? `${formatted} ${suffix}` : formatted;
  }

  // Parse input "thousand" formatted → number
  function parseThousands(v: string): number {
    return Number(v.replace(/\./g, '').replace(/,/g, '.'));
  }

  function formatThousands(v: string): string {
    const clean = v.replace(/[^\d]/g, '');
    if (!clean) return '';
    return new Intl.NumberFormat('es-AR').format(Number(clean));
  }

  function openEmbedModal(slug: string) {
    const origin = 'https://hacecuentas.com';
    const embedUrl = `${origin}/embed/${slug}`;
    const iframeSnippet = `<iframe src="${embedUrl}" width="100%" height="560" style="border:1px solid #e2e8f0;border-radius:12px;max-width:720px" loading="lazy" title="Calculadora de Hac\u00e9 Cuentas"></iframe>`;
    const scriptSnippet = `<div data-hc-embed="${slug}"></div>\n<script async src="${origin}/embed.js"><\/script>`;

    const overlay = document.createElement('div');
    overlay.className = 'hc-embed-overlay';
    overlay.innerHTML = `
      <div class="hc-embed-modal" role="dialog" aria-modal="true" aria-labelledby="hc-embed-title">
        <div class="hc-embed-head">
          <h3 id="hc-embed-title">Embeber esta calculadora</h3>
          <button type="button" class="hc-embed-close" aria-label="Cerrar">\u00d7</button>
        </div>
        <p class="hc-embed-desc">Cop\u00e1 uno de estos snippets y peg\u00e1 en tu sitio. Da c\u00e9ditos con backlink a hacecuentas.com \u2014 gracias por compartir.</p>
        <div class="hc-embed-tabs">
          <button type="button" class="hc-tab active" data-tab="iframe">iframe (simple)</button>
          <button type="button" class="hc-tab" data-tab="script">Script (responsive)</button>
        </div>
        <pre class="hc-embed-code" data-pane="iframe"><code></code></pre>
        <pre class="hc-embed-code" data-pane="script" hidden><code></code></pre>
        <div class="hc-embed-actions">
          <button type="button" class="btn-primary hc-embed-copy">Copiar c\u00f3digo</button>
          <a href="${embedUrl}" target="_blank" rel="noopener" class="hc-embed-preview">Ver preview \u2192</a>
        </div>
      </div>
    `;
    document.body.appendChild(overlay);

    const iframePane = overlay.querySelector<HTMLElement>('[data-pane="iframe"] code')!;
    const scriptPane = overlay.querySelector<HTMLElement>('[data-pane="script"] code')!;
    iframePane.textContent = iframeSnippet;
    scriptPane.textContent = scriptSnippet;

    const close = () => overlay.remove();
    overlay.querySelector('.hc-embed-close')!.addEventListener('click', close);
    overlay.addEventListener('click', (e) => { if (e.target === overlay) close(); });
    document.addEventListener('keydown', function esc(e) {
      if (e.key === 'Escape') { close(); document.removeEventListener('keydown', esc); }
    });

    overlay.querySelectorAll<HTMLButtonElement>('.hc-tab').forEach((tab) => {
      tab.addEventListener('click', () => {
        overlay.querySelectorAll('.hc-tab').forEach((t) => t.classList.remove('active'));
        tab.classList.add('active');
        const which = tab.dataset.tab;
        overlay.querySelectorAll<HTMLElement>('[data-pane]').forEach((p) => {
          p.hidden = p.dataset.pane !== which;
        });
      });
    });

    overlay.querySelector<HTMLButtonElement>('.hc-embed-copy')!.addEventListener('click', async (e) => {
      const activeTab = overlay.querySelector<HTMLElement>('.hc-tab.active')!.dataset.tab;
      const code = activeTab === 'iframe' ? iframeSnippet : scriptSnippet;
      try {
        await navigator.clipboard.writeText(code);
        const btn = e.currentTarget as HTMLButtonElement;
        const orig = btn.textContent;
        btn.textContent = '\u00a1Copiado!';
        setTimeout(() => { btn.textContent = orig; }, 1500);
        if (typeof (window as any).gtag === 'function') {
          (window as any).gtag('event', 'embed_copy', { calc_slug: slug, type: activeTab });
        }
      } catch {}
    });

    if (typeof (window as any).gtag === 'function') {
      (window as any).gtag('event', 'embed_open', { calc_slug: slug });
    }
  }

  document.querySelectorAll<HTMLElement>('.calc-container').forEach((container) => {
    const slug = container.dataset.slug!;
    const formulaId = container.dataset.formula!;
    const form = container.querySelector<HTMLFormElement>('.calc-form')!;
    const results = container.querySelector<HTMLElement>('.calc-results')!;
    const errorBox = container.querySelector<HTMLElement>('.calc-error')!;
    const submitBtn = form.querySelector<HTMLButtonElement>('.btn-primary')!;
    // Pre-cargar fórmula en background (chunk separado, no bloquea render)
    let formulaRef: Function | null = null;
    const formulaReady = loadFormula(formulaId).then((f) => {
      formulaRef = f;
      if (!f) console.error(`Fórmula no encontrada: ${formulaId}`);
      return f;
    });
    const chartWrap = container.querySelector<HTMLElement>('[data-chart-wrap]');
    const chartCanvas = container.querySelector<HTMLCanvasElement>('[data-chart-canvas]');
    let chartInstance: any = null;
    let lastChartSpec: any = null;
    let whatIfInitialized = false;
    const whatIfEl = container.querySelector<HTMLElement>('[data-what-if]');

    // Formatear valor de slider según format/prefix/suffix
    function formatSliderValue(n: number, fmt: string, prefix: string, suffix: string): string {
      if (fmt === 'currency') {
        return prefix + Math.round(n).toLocaleString('es-AR') + suffix;
      }
      if (fmt === 'percentage') {
        return prefix + (n % 1 === 0 ? n.toString() : n.toFixed(2)) + (suffix || '%');
      }
      return prefix + (n % 1 === 0 ? n.toString() : n.toFixed(2)) + suffix;
    }

    // Lee el valor actual de un input del form (respetando thousands)
    function getFormFieldValue(fieldId: string): number {
      const el = form.querySelector<HTMLInputElement>(`[name="${fieldId}"]`);
      if (!el) return NaN;
      const raw = el.value || (el as HTMLInputElement).placeholder || '';
      if (el.dataset.format === 'thousands' && raw) return parseThousands(raw);
      const n = Number(raw);
      return isNaN(n) ? NaN : n;
    }

    // Corre la fórmula con overrides desde sliders y actualiza outputs + chart (sin side effects)
    let whatIfTimer: any = null;
    function runWhatIfNow(overrides: Record<string, number>) {
      if (!formulaRef) return;
      const inputs: Record<string, string | number> = {};
      const data = new FormData(form);
      data.forEach((v, k) => {
        const el = form.querySelector<HTMLInputElement>(`[name="${k}"]`);
        let raw = v as string;
        if (el?.dataset.format === 'thousands' && raw) {
          inputs[k] = parseThousands(raw);
        } else {
          const num = Number(raw);
          inputs[k] = !isNaN(num) && raw !== '' ? num : raw;
        }
      });
      Object.assign(inputs, overrides);
      let output: any;
      try { output = formulaRef(inputs); } catch { return; }
      // Actualizar outputs (sin animar — cambios son rápidos)
      container.querySelectorAll<HTMLElement>('[data-output]').forEach((el) => {
        const outId = el.dataset.output!;
        const fmt = el.dataset.format!;
        const suf = el.dataset.suffix || '';
        const val = output[outId];
        const valueEl = el.querySelector<HTMLElement>('[data-value]')!;
        valueEl.textContent = formatValue(val, fmt, suf);
      });
      // Actualizar chart (si corresponde)
      if (output._chart && chartWrap && chartCanvas && (window as any).Chart) {
        lastChartSpec = output._chart;
        chartWrap.hidden = false;
        chartInstance = renderChart((window as any).Chart, chartCanvas, output._chart, chartInstance);
      }
    }

    function scheduleWhatIf(overrides: Record<string, number>) {
      if (whatIfTimer) clearTimeout(whatIfTimer);
      whatIfTimer = setTimeout(() => runWhatIfNow(overrides), 40);
    }

    // Inicializa sliders con los valores actuales del form tras el primer cálculo
    function initWhatIf() {
      if (whatIfInitialized || !whatIfEl) return;
      whatIfInitialized = true;
      const sliders = whatIfEl.querySelectorAll<HTMLElement>('[data-what-if-slider]');
      sliders.forEach((sliderEl) => {
        const fieldId = sliderEl.dataset.field!;
        const fmt = sliderEl.dataset.format || 'number';
        const prefix = sliderEl.dataset.prefix || '';
        const suffix = sliderEl.dataset.suffix || '';
        const input = sliderEl.querySelector<HTMLInputElement>('[data-slider-input]')!;
        const valueEl = sliderEl.querySelector<HTMLElement>('[data-slider-value]')!;
        const curVal = getFormFieldValue(fieldId);
        const clamp = (v: number) => Math.max(Number(input.min), Math.min(Number(input.max), v));
        if (!isNaN(curVal)) input.value = String(clamp(curVal));
        valueEl.textContent = formatSliderValue(Number(input.value), fmt, prefix, suffix);
        input.addEventListener('input', () => {
          const v = Number(input.value);
          valueEl.textContent = formatSliderValue(v, fmt, prefix, suffix);
          // Recolectar TODOS los sliders para aplicar como overrides coherentes
          const overrides: Record<string, number> = {};
          whatIfEl.querySelectorAll<HTMLElement>('[data-what-if-slider]').forEach((s) => {
            const fid = s.dataset.field!;
            const i = s.querySelector<HTMLInputElement>('[data-slider-input]')!;
            overrides[fid] = Number(i.value);
          });
          scheduleWhatIf(overrides);
          // Sync con el input original del form (para que al guardar link sea coherente)
          const formEl = form.querySelector<HTMLInputElement>(`[name="${fieldId}"]`);
          if (formEl) {
            if (formEl.dataset.format === 'thousands') formEl.value = formatThousands(String(v));
            else formEl.value = String(v);
          }
        });
      });
    }

    // Live thousand-formatting on inputs marked data-format="thousands"
    form.querySelectorAll<HTMLInputElement>('input[data-format="thousands"]').forEach((inp) => {
      inp.addEventListener('input', () => {
        const cursor = inp.selectionStart || 0;
        const prevLen = inp.value.length;
        inp.value = formatThousands(inp.value);
        const newLen = inp.value.length;
        const diff = newLen - prevLen;
        inp.setSelectionRange(cursor + diff, cursor + diff);
      });
    });

    // Precargar fields desde querystring (viralización: link con datos precargados)
    const urlParams = new URLSearchParams(window.location.search);
    if (urlParams.size > 0) {
      let filled = 0;
      form.querySelectorAll<HTMLInputElement | HTMLSelectElement>('[name]').forEach((el) => {
        const val = urlParams.get(el.name);
        if (val === null) return;
        if ((el as HTMLInputElement).dataset?.format === 'thousands') {
          el.value = formatThousands(val);
        } else {
          el.value = val;
        }
        filled++;
      });
      // Auto-calcular si precargamos y todos los campos required están llenos
      // (no usamos checkValidity porque step=0.1 puede rechazar valores enteros)
      const requiredEls = Array.from(form.querySelectorAll<HTMLInputElement | HTMLSelectElement>('[required]'));
      const allRequiredFilled = requiredEls.every((el) => el.value.trim() !== '');
      if (filled > 0 && allRequiredFilled) {
        setTimeout(() => form.requestSubmit(), 120);
      }
    }

    form.addEventListener('submit', (e) => {
      e.preventDefault();
      errorBox.hidden = true;
      errorBox.textContent = '';

      // Loading state
      submitBtn.classList.add('loading');
      submitBtn.disabled = true;

      // Run formula — wrapped in setTimeout so spinner paints
      setTimeout(async () => {
        try {
          const data = new FormData(form);
          const inputs: Record<string, string | number> = {};
          data.forEach((v, k) => {
            const el = form.querySelector<HTMLInputElement>(`[name="${k}"]`);
            let raw = v as string;
            if (el?.dataset.format === 'thousands' && raw) {
              inputs[k] = parseThousands(raw);
            } else {
              const num = Number(raw);
              inputs[k] = !isNaN(num) && raw !== '' ? num : raw;
            }
          });

          // Asegurar que la fórmula esté cargada (primer submit puede esperar el chunk)
          const formula = formulaRef ?? (await formulaReady);
          if (!formula) {
            throw new Error(`Fórmula no disponible: ${formulaId}`);
          }
          const output = formula(inputs);
          container.querySelectorAll<HTMLElement>('[data-output]').forEach((el) => {
            const outId = el.dataset.output!;
            const format = el.dataset.format!;
            const suffix = el.dataset.suffix || '';
            const val = output[outId];
            const valueEl = el.querySelector<HTMLElement>('[data-value]')!;
            const isPrimary = el.dataset.primary === 'true';
            if (isPrimary && (format === 'currency' || format === 'number' || format === 'percentage') && typeof val === 'number' && isFinite(val)) {
              (valueEl as any)._formatter = (n: number) => formatValue(n, format, suffix);
              animateValue(valueEl, val, 600);
            } else {
              valueEl.textContent = formatValue(val, format, suffix);
            }
          });
          results.hidden = false;
          results.scrollIntoView({ behavior: 'smooth', block: 'nearest' });

          // Chart opcional — solo si la fórmula devolvió _chart
          if (output._chart && chartWrap && chartCanvas) {
            lastChartSpec = output._chart;
            if (output._chart.ariaLabel) {
              chartCanvas.setAttribute('aria-label', output._chart.ariaLabel);
            }
            chartWrap.hidden = false;
            loadChartJs().then((Chart) => {
              chartInstance = renderChart(Chart, chartCanvas, output._chart, chartInstance);
            }).catch((err) => {
              console.warn('[Calculator] Chart.js load failed:', err);
              chartWrap.hidden = true;
            });
          } else if (chartWrap) {
            chartWrap.hidden = true;
            if (chartInstance) { try { chartInstance.destroy(); } catch {} chartInstance = null; }
            lastChartSpec = null;
          }

          // Sliders "¿qué pasa si...?" — mostrar + inicializar tras primer cálculo
          if (whatIfEl) {
            whatIfEl.hidden = false;
            initWhatIf();
          }

          // GA4 event + Google Ads conversion
          if (typeof (window as any).gtag === 'function') {
            (window as any).gtag('event', 'calculator_used', {
              calc_slug: slug,
              formula_id: formulaId,
            });
            (window as any).gtag('event', 'conversion_event_default');
          }

          // Guardar en historial (localStorage) — solo si la primary existe
          try {
            const primaryEl = container.querySelector<HTMLElement>('.result.primary');
            const primaryValue = primaryEl?.querySelector<HTMLElement>('[data-value]')?.textContent || '';
            const primaryLabel = primaryEl?.querySelector<HTMLElement>('.result-label')?.textContent || '';
            if (primaryValue && primaryValue !== '—') {
              saveToHistory(slug, { inputs, primary: primaryValue, label: primaryLabel, ts: Date.now() });
              renderHistory(container, slug, form);
            }
          } catch {}

          // Mostrar email capture CTA
          const emailCapture = container.querySelector<HTMLElement>('[data-email-capture]');
          if (emailCapture) {
            emailCapture.style.display = 'block';
          }

          // Incrementar y mostrar contador de cálculos
          try {
            const countKey = 'hc_calc_count';
            const counts: Record<string, number> = JSON.parse(localStorage.getItem(countKey) || '{}');
            counts[slug] = (counts[slug] || 0) + 1;
            localStorage.setItem(countKey, JSON.stringify(counts));
            const counterEl = container.querySelector<HTMLElement>('[data-calc-counter]');
            if (counterEl) {
              const total = Object.values(counts).reduce((a, b) => a + b, 0);
              counterEl.textContent = `\u{1F525} ${total.toLocaleString('es-AR')} cálculos realizados`;
              counterEl.style.display = 'block';
            }
          } catch {}
        } catch (err: any) {
          errorBox.textContent = err.message || 'Error al calcular. Revisá los datos.';
          errorBox.hidden = false;
        } finally {
          submitBtn.classList.remove('loading');
          submitBtn.disabled = false;
        }
      }, 180);
    });

    // Preset buttons: click precarga y calcula
    container.querySelectorAll<HTMLButtonElement>('.preset-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        try {
          const values = JSON.parse(btn.dataset.preset || '{}') as Record<string, string | number>;
          Object.entries(values).forEach(([name, val]) => {
            const el = form.querySelector<HTMLInputElement | HTMLSelectElement>(`[name="${name}"]`);
            if (!el) return;
            if ((el as HTMLInputElement).dataset?.format === 'thousands') {
              el.value = formatThousands(String(val));
            } else {
              el.value = String(val);
            }
          });
          container.querySelectorAll('.preset-btn').forEach((b) => { b.classList.remove('active'); b.setAttribute('aria-pressed', 'false'); });
          btn.classList.add('active');
          btn.setAttribute('aria-pressed', 'true');
          if (typeof (window as any).gtag === 'function') {
            (window as any).gtag('event', 'preset_click', { calc_slug: slug, preset: btn.textContent?.trim() });
          }
          form.requestSubmit();
        } catch {}
      });
    });

    // Action buttons
    container.querySelectorAll<HTMLButtonElement>('.btn-share').forEach((btn) => {
      btn.addEventListener('click', async () => {
        const action = btn.dataset.action;
        const url = window.location.href;
        const text = `Mirá esta calculadora en Hacé Cuentas: ${document.title}`;

        if (action === 'whatsapp') {
          // Incluir resultado primary si está visible
          const primary = container.querySelector<HTMLElement>('.result.primary [data-value]');
          const primaryLabel = container.querySelector<HTMLElement>('.result.primary .result-label');
          let msg = text;
          if (primary && primaryLabel) {
            msg = `${primaryLabel.textContent}: ${primary.textContent}\n\n${text}`;
          }
          window.open(`https://wa.me/?text=${encodeURIComponent(`${msg} ${url}`)}`, '_blank', 'noopener');
        } else if (action === 'copy-result') {
          const primary = container.querySelector<HTMLElement>('.result.primary [data-value]');
          const fallback = container.querySelector<HTMLElement>('[data-value]');
          const value = (primary || fallback)?.textContent || '';
          try {
            await navigator.clipboard.writeText(value);
            const label = btn.querySelector<HTMLElement>('[data-copy-result-label]')!;
            const original = label.textContent;
            label.textContent = '¡Copiado!';
            btn.classList.add('copied');
            setTimeout(() => {
              label.textContent = original;
              btn.classList.remove('copied');
            }, 1500);
          } catch {}
        } else if (action === 'copy-link') {
          // Armar link con fields actuales como querystring (viralización)
          const data = new FormData(form);
          const params = new URLSearchParams();
          data.forEach((v, k) => {
            if (!v) return;
            const el = form.querySelector<HTMLInputElement>(`[name="${k}"]`);
            if (el?.dataset.format === 'thousands') {
              params.set(k, String(parseThousands(v as string)));
            } else {
              params.set(k, String(v));
            }
          });
          const shareUrl = `${window.location.origin}${window.location.pathname}${params.size > 0 ? '?' + params.toString() : ''}`;
          try {
            await navigator.clipboard.writeText(shareUrl);
            const label = btn.querySelector<HTMLElement>('[data-copy-link-label]')!;
            const original = label.textContent;
            label.textContent = '¡Copiado!';
            btn.classList.add('copied');
            if (typeof (window as any).gtag === 'function') {
              (window as any).gtag('event', 'share_link', { calc_slug: slug });
            }
            setTimeout(() => {
              label.textContent = original;
              btn.classList.remove('copied');
            }, 1500);
          } catch {}
        } else if (action === 'print') {
          if (typeof (window as any).gtag === 'function') {
            (window as any).gtag('event', 'print_pdf', { calc_slug: slug });
          }
          window.print();
        } else if (action === 'embed') {
          openEmbedModal(slug);
        } else if (action === 'reset') {
          form.reset();
          results.hidden = true;
          errorBox.hidden = true;
          if (chartWrap) chartWrap.hidden = true;
          if (chartInstance) { try { chartInstance.destroy(); } catch {} chartInstance = null; }
          lastChartSpec = null;
          // Reset email capture state
          const emailCap = container.querySelector<HTMLElement>('[data-email-capture]');
          if (emailCap) {
            emailCap.style.display = 'none';
            const ef = emailCap.querySelector<HTMLFormElement>('[data-email-form]');
            if (ef) { ef.reset(); ef.style.display = 'flex'; }
            const en = emailCap.querySelector<HTMLElement>('.email-note');
            if (en) en.style.display = 'block';
            const es = emailCap.querySelector<HTMLElement>('[data-email-success]');
            if (es) es.style.display = 'none';
          }
          form.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }
      });
    });

    // ── Re-render del chart al cambiar tema o al resize ────────
    if (chartWrap && chartCanvas) {
      const themeObserver = new MutationObserver(() => {
        if (!lastChartSpec || !(window as any).Chart) return;
        chartInstance = renderChart((window as any).Chart, chartCanvas, lastChartSpec, chartInstance);
      });
      themeObserver.observe(document.documentElement, { attributes: true, attributeFilter: ['data-theme'] });

      let resizeTimer: any = null;
      window.addEventListener('resize', () => {
        if (!chartInstance) return;
        clearTimeout(resizeTimer);
        resizeTimer = setTimeout(() => { try { chartInstance.resize(); } catch {} }, 120);
      });
    }

    // ── Historial ──────────────────────────────────────────────
    renderHistory(container, slug, form);

    container.querySelector<HTMLButtonElement>('[data-history-clear]')?.addEventListener('click', () => {
      try {
        localStorage.removeItem(`hc-history-${slug}`);
        renderHistory(container, slug, form);
      } catch {}
    });

    // ── Feedback ──────────────────────────────────────────────
    const fbEl = container.querySelector<HTMLElement>('[data-feedback]');
    if (fbEl) {
      // Ocultar si ya votó recientemente (hace menos de 30 días)
      try {
        const last = localStorage.getItem(`hc-feedback-${slug}`);
        if (last) {
          const lastTs = Number(last);
          if (!isNaN(lastTs) && Date.now() - lastTs < 30 * 24 * 60 * 60 * 1000) {
            fbEl.hidden = true;
          }
        }
      } catch {}

      let currentVote: 'up' | 'down' | null = null;
      const promptEl = fbEl.querySelector<HTMLElement>('[data-feedback-prompt]')!;
      const followupEl = fbEl.querySelector<HTMLElement>('[data-feedback-followup]')!;
      const labelEl = fbEl.querySelector<HTMLElement>('[data-feedback-label]')!;
      const textEl = fbEl.querySelector<HTMLTextAreaElement>('[data-feedback-text]')!;
      const thanksEl = fbEl.querySelector<HTMLElement>('[data-feedback-thanks]')!;

      fbEl.querySelectorAll<HTMLButtonElement>('[data-feedback-vote]').forEach((btn) => {
        btn.addEventListener('click', () => {
          currentVote = btn.dataset.feedbackVote as 'up' | 'down';
          fbEl.querySelectorAll('[data-feedback-vote]').forEach((b) => b.classList.remove('selected'));
          btn.classList.add('selected');
          labelEl.textContent = currentVote === 'up' ? '¿Qué fue lo mejor? (opcional)' : '¿Qué te faltó o estuvo mal? (opcional)';
          followupEl.hidden = false;
          textEl.focus();
          if (typeof (window as any).gtag === 'function') {
            (window as any).gtag('event', 'feedback_vote', { calc_slug: slug, vote: currentVote });
          }
        });
      });

      fbEl.querySelector<HTMLButtonElement>('[data-feedback-send]')?.addEventListener('click', () => {
        const text = textEl.value.trim().slice(0, 500);
        if (typeof (window as any).gtag === 'function') {
          (window as any).gtag('event', 'feedback_submit', {
            calc_slug: slug,
            vote: currentVote,
            feedback_text: text || '(sin comentario)',
          });
        }
        try { localStorage.setItem(`hc-feedback-${slug}`, String(Date.now())); } catch {}
        promptEl.hidden = true;
        followupEl.hidden = true;
        thanksEl.hidden = false;
      });
    }

    // ── Email capture ─────────────────────────────────────────
    const emailForm = container.querySelector<HTMLFormElement>('[data-email-form]');
    if (emailForm) {
      emailForm.addEventListener('submit', (ev) => {
        ev.preventDefault();
        const emailInput = emailForm.querySelector<HTMLInputElement>('[data-email-input]');
        const email = emailInput?.value.trim();
        if (!email) return;

        // Obtener resultado primary
        const primaryVal = container.querySelector<HTMLElement>('.result.primary [data-value]')?.textContent || '';

        // Guardar en localStorage
        try {
          const stored: any[] = JSON.parse(localStorage.getItem('hc_emails') || '[]');
          stored.push({
            email,
            slug,
            result: primaryVal,
            date: new Date().toISOString(),
          });
          localStorage.setItem('hc_emails', JSON.stringify(stored));
        } catch {}

        // Mostrar éxito
        emailForm.style.display = 'none';
        const noteEl = container.querySelector<HTMLElement>('.email-note');
        if (noteEl) noteEl.style.display = 'none';
        const successEl = container.querySelector<HTMLElement>('[data-email-success]');
        if (successEl) successEl.style.display = 'block';

        // GA4 event
        if (typeof (window as any).gtag === 'function') {
          (window as any).gtag('event', 'email_capture', { calc_slug: slug });
        }
      });
    }

    // ── Mostrar contador existente al cargar ──────────────────
    try {
      const counts: Record<string, number> = JSON.parse(localStorage.getItem('hc_calc_count') || '{}');
      const total = Object.values(counts).reduce((a, b) => a + b, 0);
      if (total > 0) {
        const counterEl = container.querySelector<HTMLElement>('[data-calc-counter]');
        if (counterEl) {
          counterEl.textContent = `\u{1F525} ${total.toLocaleString('es-AR')} cálculos realizados`;
          counterEl.style.display = 'block';
        }
      }
    } catch {}
  });

  // ── Helpers de historial ─────────────────────────────────────
  const HISTORY_MAX = 5;

  function saveToHistory(
    slug: string,
    entry: { inputs: Record<string, string | number>; primary: string; label: string; ts: number }
  ) {
    try {
      const key = `hc-history-${slug}`;
      const existing: any[] = JSON.parse(localStorage.getItem(key) || '[]');
      // Deduplicar: si ya existe un entry con los mismos inputs, lo movemos al frente (no duplicamos)
      const inputsKey = JSON.stringify(entry.inputs);
      const filtered = existing.filter((e) => JSON.stringify(e.inputs) !== inputsKey);
      const next = [entry, ...filtered].slice(0, HISTORY_MAX);
      localStorage.setItem(key, JSON.stringify(next));
    } catch {}
  }

  function renderHistory(container: HTMLElement, slug: string, form: HTMLFormElement) {
    const widget = container.querySelector<HTMLElement>('[data-history-widget]');
    const list = container.querySelector<HTMLElement>('[data-history-list]');
    if (!widget || !list) return;

    let history: any[] = [];
    try { history = JSON.parse(localStorage.getItem(`hc-history-${slug}`) || '[]'); } catch {}

    if (history.length === 0) {
      widget.hidden = true;
      return;
    }
    widget.hidden = false;
    list.innerHTML = '';

    history.forEach((entry) => {
      const btn = document.createElement('button');
      btn.type = 'button';
      btn.className = 'history-item';
      const timeAgo = relativeTime(entry.ts);
      btn.innerHTML = `<strong>${escapeHtml(entry.primary)}</strong><span>${escapeHtml(entry.label || '')}</span><time>${timeAgo}</time>`;
      btn.addEventListener('click', () => {
        // Precargar form con los inputs del entry y resubmit
        Object.entries(entry.inputs).forEach(([name, val]) => {
          const el = form.querySelector<HTMLInputElement | HTMLSelectElement>(`[name="${name}"]`);
          if (!el) return;
          if ((el as HTMLInputElement).dataset?.format === 'thousands') {
            el.value = new Intl.NumberFormat('es-AR').format(Number(val));
          } else {
            el.value = String(val);
          }
        });
        form.requestSubmit();
      });
      list.appendChild(btn);
    });
  }

  function relativeTime(ts: number): string {
    const diff = Date.now() - ts;
    const min = Math.floor(diff / 60000);
    if (min < 1) return 'ahora';
    if (min < 60) return `hace ${min} min`;
    const hr = Math.floor(min / 60);
    if (hr < 24) return `hace ${hr} h`;
    const day = Math.floor(hr / 24);
    if (day < 30) return `hace ${day} d`;
    return new Date(ts).toLocaleDateString('es-AR', { day: '2-digit', month: '2-digit' });
  }

  function escapeHtml(s: string): string {
    return s.replace(/[&<>"']/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c]!));
  }
</script>
