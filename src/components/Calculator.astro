  }
  /* Oculta empty state cuando hay resultados visibles */
  .calc-container:has(.calc-results:not([hidden])) .empty-preview {
    display: none;
  }

  /* Chart (lazy loaded Chart.js) */
  .chart-wrap {
    margin-top: 1rem;
    padding: 0.875rem;
    background: var(--bg-soft);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    position: relative;
  }
  .chart-wrap[hidden] { display: none; }
  .chart-wrap canvas {
    display: block;
    width: 100% !important;
    max-width: 100%;
    height: 280px !important;
  }
  @media (max-width: 640px) {
    .chart-wrap canvas { height: 240px !important; }
    .chart-wrap { padding: 0.625rem; }
  }

  /* What-if interactive sliders */
  .what-if {
    margin-top: 1rem;
    padding: 1rem 1.125rem 1.125rem;
    background: linear-gradient(135deg, rgba(37,99,235,0.06), rgba(37,99,235,0.02));
    border: 1px solid rgba(37,99,235,0.22);
    border-radius: var(--radius-sm);
  }
  :root[data-theme="dark"] .what-if {
    background: linear-gradient(135deg, rgba(96,165,250,0.08), rgba(96,165,250,0.03));
    border-color: rgba(96,165,250,0.25);
