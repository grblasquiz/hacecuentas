  label {
    font-weight: 500;
    font-size: 0.875rem;
    color: var(--text);
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .label-text { letter-spacing: -0.005em; }

  .help-wrap {
    position: relative;
    display: inline-flex;
  }

  .help {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 16px;
    height: 16px;
