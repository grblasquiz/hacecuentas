    font-size: 0.875rem;
    font-weight: 500;
    display: flex;
    align-items: center;
    border-left: 1px solid var(--border);
  }

  .prefix {
    border-left: none;
    border-right: 1px solid var(--border);
  }

  /* Modo simple/experto */
  .advanced-toggle {
    margin: 0.875rem 0 1rem;
    border: 1px dashed var(--border);
    border-radius: var(--radius);
    background: transparent;
  }
  .advanced-toggle[open] {
    background: var(--bg-soft);
    border-style: solid;
    border-color: var(--border);
  }
  .advanced-toggle summary {
    list-style: none;
    cursor: pointer;
    padding: 0.625rem 0.875rem;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--text-muted);
    user-select: none;
  }
  .advanced-toggle summary::-webkit-details-marker { display: none; }
  .advanced-toggle summary:hover { color: var(--accent); }
  .advanced-toggle .adv-count {
    font-weight: 500;
    color: var(--text-subtle);
  }
  .advanced-grid {
    padding: 0.5rem 0.875rem 0.875rem;
    border-top: 1px solid var(--border);
    margin-top: 0.25rem;
  }

  /* Submit */
  .btn-primary {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 1rem 1.5rem;
    background: linear-gradient(135deg, var(--accent) 0%, color-mix(in srgb, var(--accent) 85%, #8b5cf6) 100%);
    color: #ffffff;
    border-radius: var(--radius-sm);
    font-weight: 700;
    font-size: 1rem;
    transition: transform 0.15s, box-shadow 0.2s, filter 0.15s;
    box-shadow:
      0 1px 2px rgba(37, 99, 235, 0.1),
      0 4px 12px -2px color-mix(in srgb, var(--accent) 35%, transparent);
    width: 100%;
    letter-spacing: -0.005em;
    overflow: hidden;
    border: none;
    cursor: pointer;
  }

  .btn-primary::after {
    content: '';
    position: absolute;
    top: 0; left: -75%;
    width: 50%; height: 100%;
    background: linear-gradient(120deg, transparent, rgba(255,255,255,0.25), transparent);
    transform: skewX(-20deg);
    transition: left 0.6s;
    pointer-events: none;
  }
  .btn-primary:hover:not(:disabled)::after { left: 125%; }

  .btn-primary:hover:not(:disabled) {
    transform: translateY(-2px);
    filter: brightness(1.05);
    box-shadow:
      0 2px 4px rgba(37, 99, 235, 0.15),
      0 8px 24px -4px color-mix(in srgb, var(--accent) 45%, transparent);
  }

  .btn-primary:active:not(:disabled) {
    transform: translateY(0) scale(0.99);
  }

  .btn-primary:disabled {
    cursor: wait;
    opacity: 0.85;
  }

  .btn-content, .btn-spinner {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }

  .btn-spinner { display: none; }
  .btn-spinner svg { animation: spin 0.7s linear infinite; }

  .btn-primary.loading .btn-content { display: none; }
  .btn-primary.loading .btn-spinner { display: inline-flex; }

  @keyframes spin {
    to { transform: rotate(360deg); }
  }

  /* Results */
  .calc-results {
    margin-top: 0;
    padding: 1.75rem;
    border-top: 1px solid var(--border);
    background: color-mix(in srgb, var(--accent) 3%, var(--bg-card));
    animation: slideUp 0.35s cubic-bezier(0.16, 1, 0.3, 1);
  }

  @keyframes slideUp {
    from { opacity: 0; transform: translateY(12px); }
    to { opacity: 1; transform: translateY(0); }
