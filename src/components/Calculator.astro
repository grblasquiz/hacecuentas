  .presets-title {
    font-size: 0.8125rem;
    color: var(--text-subtle);
    font-weight: 500;
  }
  .presets-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .preset-btn {
    padding: 0.4375rem 0.875rem;
    background: var(--bg-soft);
    color: var(--text);
    border: 1px solid var(--border);
    border-radius: 999px;
