  .calc-card-badge {
    margin-left: auto;
    font-size: 0.6875rem;
    font-weight: 500;
    color: var(--text-muted);
    background: var(--bg-soft);
    padding: 0.1875rem 0.5rem;
    border-radius: 999px;
    border: 1px solid var(--border);
    letter-spacing: 0.02em;
  }

  .calc-container > :not(.calc-card-header):not(.calc-results) {
    padding-left: 1.75rem;
    padding-right: 1.75rem;
  }
  .calc-container > .calc-history { padding-top: 1rem; }
  .calc-container > .data-freshness { margin-left: 1.75rem; margin-top: 1.25rem; }
  .calc-container > .presets { padding-top: 1.25rem; margin-left: 1.75rem; margin-right: 1.75rem; padding-left: 0; padding-right: 0; }
  .calc-container > .calc-form { padding: 1.5rem 1.75rem; }
  .calc-container > .calc-error { margin: 0 1.75rem 1rem; }

  .calc-form { display: block; }

  /* Presets (valores sugeridos tipo botones de bancos) */
  .data-freshness {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.375rem 0.625rem;
    margin-bottom: 1rem;
    background: var(--bg-soft);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    font-size: 0.75rem;
    color: var(--text-muted);
    line-height: 1.3;
  }
  .data-freshness svg {
    flex-shrink: 0;
    color: var(--accent);
  }
  .data-freshness time { font-weight: 600; color: var(--text); }
  .data-freshness a {
    color: var(--accent);
