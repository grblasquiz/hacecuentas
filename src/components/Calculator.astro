    gap: 0.75rem;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
  }

  .result {
    position: relative;
    padding: 1.125rem 1.25rem 1.125rem 1.375rem;
    background: var(--bg-card);
    border-radius: var(--radius-sm);
    border: 1px solid var(--border);
    transition: transform 0.15s, box-shadow 0.15s, border-color 0.15s;
  }
  .result::before {
    content: '';
    position: absolute;
    left: 0; top: 12%;
    width: 3px; height: 76%;
    background: var(--accent);
    border-radius: 0 3px 3px 0;
    opacity: 0.55;
  }
  .result:hover {
    transform: translateY(-2px);
    border-color: color-mix(in srgb, var(--accent) 30%, var(--border));
    box-shadow: 0 4px 12px -4px color-mix(in srgb, var(--accent) 25%, transparent);
  }
  .result:hover::before { opacity: 1; }

  .result.primary {
    grid-column: 1 / -1;
    background:
      radial-gradient(circle at 100% 0%, color-mix(in srgb, var(--accent) 18%, transparent) 0%, transparent 55%),
      linear-gradient(135deg, var(--accent-soft) 0%, color-mix(in srgb, #a78bfa 15%, var(--accent-soft)) 100%);
    border: 1.5px solid color-mix(in srgb, var(--accent) 35%, transparent);
    padding: 2rem 1.75rem;
    overflow: hidden;
    animation: primary-reveal 0.9s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .result.primary::before { display: none; }
  .result.primary::after {
    content: '';
    position: absolute;
    top: -20%; right: -10%;
    width: 180px; height: 180px;
    background: radial-gradient(circle, color-mix(in srgb, var(--accent) 18%, transparent), transparent 70%);
    border-radius: 50%;
    pointer-events: none;
  }

  /* Halo de primera aparición — se expande y desvanece una sola vez */
  @keyframes primary-reveal {
    0%   { box-shadow: 0 0 0 0 color-mix(in srgb, var(--accent) 28%, transparent); }
    60%  { box-shadow: 0 0 0 12px color-mix(in srgb, var(--accent) 10%, transparent); }
    100% { box-shadow: 0 0 0 0 transparent; }
  }

  /* Dark mode: reemplazar gradiente pastel por tint azul sobre el fondo oscuro */
  html[data-theme="dark"] .result.primary {
    background:
      radial-gradient(circle at 100% 0%, rgba(96, 165, 250, 0.18) 0%, transparent 55%),
      linear-gradient(135deg, rgba(37, 99, 235, 0.12) 0%, rgba(124, 58, 237, 0.10) 100%);
    border-color: rgba(147, 197, 253, 0.28);
  }
  html[data-theme="dark"] .result.primary::after {
    background: radial-gradient(circle, rgba(96, 165, 250, 0.22), transparent 70%);
