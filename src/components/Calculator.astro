---
export interface Field {
  id: string;
  label: string;
  type: 'number' | 'text' | 'select' | 'date';
  placeholder?: string;
  suffix?: string;
  prefix?: string;
  min?: number;
  max?: number;
  step?: number;
  default?: string | number;
  options?: { value: string; label: string }[];
  required?: boolean;
  help?: string;
  format?: 'thousands';
  advanced?: boolean;
}

export interface Preset {
  label: string;
  values: Record<string, string | number>;
  note?: string;
}

export interface PresetsGroup {
  title?: string;
  items: Preset[];
}

export type UpdateFrequency = 'never' | 'daily' | 'weekly' | 'monthly' | 'biannual' | 'yearly';
export type UpdateType = 'manual' | 'auto-api' | 'auto-scrape' | 'auto-llm';

export interface DataUpdate {
  frequency: UpdateFrequency;
  lastUpdated: string; // YYYY-MM-DD
  source?: string | null;
  sourceUrl?: string | null;
  updateType: UpdateType;
  notes?: string;
}

export interface CalcConfig {
  slug: string;
  title: string;
  h1: string;
  description: string;
  category: string;
  icon: string;
  fields: Field[];
  formulaId: string;
  presets?: PresetsGroup;
  dataUpdate?: DataUpdate;
  outputs: {
    id: string;
    label: string;
    format: 'currency' | 'number' | 'percentage' | 'date' | 'text' | 'duration';
    primary?: boolean;
    suffix?: string;
  }[];
  interactive?: {
    sliders: Array<{
      fieldId: string;
      min: number;
      max: number;
      step: number;
      label: string;
      format?: 'currency' | 'number' | 'percentage';
      prefix?: string;
      suffix?: string;
    }>;
  };
}

export interface Props {
  config: CalcConfig;
  lang?: 'es' | 'en';
}

const { config, lang = 'es' } = Astro.props;
const t = lang === 'en' ? {
  calculator: 'Calculator', badge: 'Free · Private', calculate: 'Calculate',
  showAdvanced: 'Show advanced', hideAdvanced: 'Hide advanced',
  embed: 'Embed on your site', embedHint: 'Free — copy the code and paste it on your website',
  share: 'Share:', copyResult: 'Copy result', copyLink: 'Copy link with data',
  newCalc: 'New calculation', helpful: 'Was this calculation helpful?',
  yes: 'Yes', no: 'No', feedback: 'Tell us (optional, 500 chars)', send: 'Send',
  disclaimer: '', dataUpdated: 'Data updated',
} : {
  calculator: 'Calculadora', badge: 'Gratis · Privada', calculate: 'Calcular',
  showAdvanced: 'Mostrar avanzados', hideAdvanced: 'Ocultar avanzados',
  embed: 'Embeber en tu sitio', embedHint: 'Gratis — copiá el código y pegalo en tu web',
  share: 'Compartir:', copyResult: 'Copiar resultado', copyLink: 'Copiar link con datos',
  newCalc: 'Nuevo cálculo', helpful: '¿Te sirvió este cálculo?',
  yes: 'Sí', no: 'No', feedback: 'Contanos (opcional, 500 chars)', send: 'Enviar',
  disclaimer: '', dataUpdated: 'Datos actualizados',
};

// Disclaimers inline por calculadora sensible (override específico).
// El fallback por categoría aplica a CUALQUIER calc de finanzas/salud/etc.
const disclaimers: Record<string, string> = {
  'sueldo-en-mano-argentina': 'Cálculo aproximado según escala del impuesto a las ganancias 2026. Consultá con tu empleador o contador para tu caso específico.',
  'calculadora-aguinaldo-sac': 'El aguinaldo se calcula sobre la mejor remuneración del semestre (Ley 27.073). Para liquidación final, consultá a tu contador.',
  'calculadora-monotributo-2026': 'Los montos son de ARCA (ex-AFIP) 2026. Pueden actualizarse semestralmente. Consultá arca.gob.ar para confirmar o hablá con tu contador.',
  'calculadora-cuota-prestamo': 'Cálculo ilustrativo de cuota francesa. La CFT real puede diferir por seguros, gastos e impuestos. Consultá al banco antes de firmar.',
  'calculadora-imc': 'El IMC es orientativo. No reemplaza una consulta médica. Factores como masa muscular afectan el resultado.',
  'calculadora-calorias-diarias-tdee': 'Estimación basada en fórmula Mifflin-St Jeor. Consultá a un nutricionista matriculado para planes específicos.',
  'calculadora-embarazo': 'Cálculo por regla de Naegele. La fecha real puede variar ±2 semanas. Consultá a tu obstetra.',
  'calculadora-ovulacion-dias-fertiles': 'Estimación estadística. Consultá a un ginecólogo si buscás o evitás un embarazo.',
  'calculadora-interes-compuesto': 'Cálculo ilustrativo. No constituye asesoramiento en inversión (Ley 26.831 / RG CNV 840/2020). Las inversiones reales varían según mercado, comisiones e impuestos.',
};

// Fallback por categoría — cubre YMYL (finanzas, salud, negocios) aunque la
// calc específica no tenga disclaimer individual definido.
const categoryDisclaimers: Record<string, string> = {
  finanzas: 'Herramienta educativa. No constituye asesoramiento en inversión (Ley 26.831 / RG CNV 840/2020). Consultá a un contador o asesor financiero matriculado antes de tomar decisiones.',
  negocios: 'Cálculo ilustrativo. No constituye asesoramiento contable ni financiero. Consultá a un contador público para tu caso específico.',
  salud: 'Resultado orientativo. No reemplaza el diagnóstico ni el tratamiento médico. Consultá con un profesional de la salud matriculado.',
  deportes: 'Estimación genérica. Consultá con un profesional del deporte o médico deportólogo para planes personalizados.',
  familia: 'Información general. Para decisiones de salud, fertilidad o crianza consultá con profesionales matriculados.',
  mascotas: 'Orientativo. Consultá con veterinario matriculado para el estado de salud de tu mascota.',
  construccion: 'Estimación. Los proyectos constructivos requieren cálculo estructural profesional y dirección técnica.',
};

const disclaimer = disclaimers[config.slug] || categoryDisclaimers[config.category] || '';

const basicFields = config.fields.filter((f) => !f.advanced);
const advancedFields = config.fields.filter((f) => f.advanced);

// Data freshness: formatear última actualización para calcs con datos externos
const dataUpdate = config.dataUpdate;
const showFreshness = dataUpdate && dataUpdate.frequency !== 'never';
const freshnessMonths: Record<string, string> = {
  '01': 'ene', '02': 'feb', '03': 'mar', '04': 'abr', '05': 'may', '06': 'jun',
  '07': 'jul', '08': 'ago', '09': 'sep', '10': 'oct', '11': 'nov', '12': 'dic',
};
const formatFreshnessDate = (iso: string): string => {
  const [y, m, d] = iso.split('-');
  return `${parseInt(d, 10)} ${freshnessMonths[m] || m} ${y}`;
};
---

<div class="calc-container" data-slug={config.slug} data-formula={config.formulaId}>
  <div class="calc-card-header">
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <rect x="4" y="2" width="16" height="20" rx="2"/>
      <line x1="8" y1="6" x2="16" y2="6"/>
      <line x1="16" y1="14" x2="16" y2="18"/>
      <line x1="8" y1="10" x2="8" y2="10.01"/>
      <line x1="12" y1="10" x2="12" y2="10.01"/>
      <line x1="16" y1="10" x2="16" y2="10.01"/>
      <line x1="8" y1="14" x2="8" y2="14.01"/>
      <line x1="12" y1="14" x2="12" y2="14.01"/>
      <line x1="8" y1="18" x2="8" y2="18.01"/>
      <line x1="12" y1="18" x2="12" y2="18.01"/>
    </svg>
    <span>{t.calculator}</span>
    <span class="calc-card-badge">{t.badge}</span>
  </div>
  <!-- Historial: últimos cálculos del usuario (localStorage) — solo se muestra si hay entries -->
  <div class="calc-history" data-history-widget hidden>
    <div class="history-head">
      <span class="history-title">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/><path d="M3 3v5h5"/><path d="M12 7v5l4 2"/></svg>
        Tus últimos cálculos
      </span>
      <button type="button" class="history-clear" data-history-clear aria-label="Borrar historial">Limpiar</button>
    </div>
    <div class="history-list" data-history-list></div>
  </div>

  {showFreshness && dataUpdate && (
    <div class="data-freshness" title={dataUpdate.notes}>
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
      <span>
        Datos actualizados: <time datetime={dataUpdate.lastUpdated}>{formatFreshnessDate(dataUpdate.lastUpdated)}</time>
        {dataUpdate.source && (
          <>
            {' · Fuente: '}
            {dataUpdate.sourceUrl ? (
              <a href={dataUpdate.sourceUrl} target="_blank" rel="noopener noreferrer">{dataUpdate.source}</a>
            ) : (
              <span>{dataUpdate.source}</span>
            )}
          </>
        )}
      </span>
    </div>
  )}

  {config.presets && config.presets.items.length > 0 && (
    <div class="presets">
      {config.presets.title && <span class="presets-title">{config.presets.title}</span>}
      <div class="presets-list">
        {config.presets.items.map((p) => (
          <button
            type="button"
            class="preset-btn"
            data-preset={JSON.stringify(p.values)}
            title={p.note}
            aria-pressed="false"
          >
            {p.label}
          </button>
        ))}
      </div>
    </div>
  )}

  <form id={`form-${config.slug}`} class="calc-form" novalidate>
    <div class="fields-grid">
      {basicFields.map((field) => (
        <div class={`field ${field.type === 'select' || field.type === 'date' ? 'field-wide' : ''}`}>
          <label for={field.id}>
            <span class="label-text">{field.label}</span>
            {field.help && (
              <span class="help-wrap">
                <span class="help" tabindex="0" aria-describedby={`tip-${field.id}`}>?</span>
                <span class="help-tip" id={`tip-${field.id}`} role="tooltip">{field.help}</span>
              </span>
            )}
          </label>
          <div class="input-wrap">
            {field.prefix && <span class="prefix">{field.prefix}</span>}
            {field.type === 'select' ? (
              <select id={field.id} name={field.id} required={field.required}>
                {field.options?.map((opt) => (
                  <option value={opt.value} selected={opt.value === field.default}>
                    {opt.label}
                  </option>
                ))}
              </select>
            ) : (
              <input
                id={field.id}
                name={field.id}
                type={field.type === 'number' && field.format === 'thousands' ? 'text' : field.type}
                placeholder={field.placeholder}
                min={field.min}
                max={field.max}
                step={field.step}
                value={field.default === 0 || field.default === undefined ? undefined : field.default}
                required={field.required}
                inputmode={field.type === 'number' ? 'decimal' : undefined}
                autocomplete="off"
                data-format={field.format}
                data-type={field.type}
              />
            )}
            {field.suffix && <span class="suffix">{field.suffix}</span>}
          </div>
        </div>
      ))}
    </div>

    {advancedFields.length > 0 && (
      <details class="advanced-toggle">
        <summary>
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>
          Opciones avanzadas
          <span class="adv-count">({advancedFields.length})</span>
        </summary>
        <div class="fields-grid advanced-grid">
          {advancedFields.map((field) => (
            <div class={`field ${field.type === 'select' || field.type === 'date' ? 'field-wide' : ''}`}>
              <label for={field.id}>
                <span class="label-text">{field.label}</span>
                {field.help && (
                  <span class="help-wrap">
                    <span class="help" tabindex="0" aria-describedby={`tip-${field.id}`}>?</span>
                    <span class="help-tip" id={`tip-${field.id}`} role="tooltip">{field.help}</span>
                  </span>
                )}
              </label>
              <div class="input-wrap">
                {field.prefix && <span class="prefix">{field.prefix}</span>}
                {field.type === 'select' ? (
                  <select id={field.id} name={field.id} required={field.required}>
                    {field.options?.map((opt) => (
                      <option value={opt.value} selected={opt.value === field.default}>
                        {opt.label}
                      </option>
                    ))}
                  </select>
                ) : (
                  <input
                    id={field.id}
                    name={field.id}
                    type={field.type === 'number' && field.format === 'thousands' ? 'text' : field.type}
                    placeholder={field.placeholder}
                    min={field.min}
                    max={field.max}
                    step={field.step}
                    value={field.default === 0 || field.default === undefined ? undefined : field.default}
                    required={field.required}
                    inputmode={field.type === 'number' ? 'decimal' : undefined}
                    autocomplete="off"
                    data-format={field.format}
                    data-type={field.type}
                  />
                )}
                {field.suffix && <span class="suffix">{field.suffix}</span>}
              </div>
            </div>
          ))}
        </div>
      </details>
    )}

    <button type="submit" class="btn-primary">
      <span class="btn-content">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" aria-hidden="true">
          <line x1="5" y1="9" x2="19" y2="9"/>
          <line x1="5" y1="15" x2="19" y2="15"/>
        </svg>
        {t.calculate}
      </span>
      <span class="btn-spinner" aria-hidden="true">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 12a9 9 0 1 1-6.219-8.56"/>
        </svg>
        Calculando...
      </span>
    </button>
  </form>

  <div class="empty-preview" data-empty-preview aria-hidden="true">
    <div class="empty-icon" aria-hidden="true">{config.icon}</div>
    <div class="empty-text">Tu resultado va a aparecer acá</div>
    <div class="empty-sub">Completá los datos y tocá <strong>Calcular</strong></div>
  </div>

  <div class="calc-results" id={`results-${config.slug}`} hidden aria-live="polite" aria-atomic="true">
    <div class="results-header">
      <span class="results-badge">Resultado</span>
    </div>
    <div class="results-grid">
      {config.outputs.map((out) => (
        <div class={`result ${out.primary ? 'primary' : ''}`} data-output={out.id} data-format={out.format} data-suffix={out.suffix || ''} data-primary={out.primary ? 'true' : 'false'}>
          <div class="result-label">{out.label}</div>
          <div class="result-value" data-value></div>
        </div>
      ))}
    </div>

    <div class="chart-wrap" data-chart-wrap hidden>
      <canvas data-chart-canvas role="img" aria-label="Gráfico del resultado"></canvas>
    </div>

    {config.interactive && config.interactive.sliders && config.interactive.sliders.length > 0 && (
      <div class="what-if" data-what-if hidden>
        <div class="what-if-head">
          <span class="what-if-badge">🎚️ ¿Qué pasa si...?</span>
          <span class="what-if-hint">Movelo y mirá cómo cambia todo</span>
        </div>
        <div class="what-if-sliders">
          {config.interactive.sliders.map((s) => (
            <div class="what-if-slider" data-what-if-slider data-field={s.fieldId} data-format={s.format || 'number'} data-prefix={s.prefix || ''} data-suffix={s.suffix || ''}>
              <div class="what-if-row">
                <label>{s.label}</label>
                <span class="what-if-value" data-slider-value>—</span>
              </div>
              <input type="range" min={s.min} max={s.max} step={s.step} data-slider-input aria-label={s.label} />
              <div class="what-if-range">
                <span>{s.prefix || ''}{s.min.toLocaleString('es-AR')}{s.suffix || ''}</span>
                <span>{s.prefix || ''}{s.max.toLocaleString('es-AR')}{s.suffix || ''}</span>
              </div>
            </div>
          ))}
        </div>
      </div>
    )}

    {disclaimer && (
      <div class="inline-disclaimer" role="note">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="12" cy="12" r="10"/>
          <line x1="12" y1="8" x2="12" y2="12"/>
          <line x1="12" y1="16" x2="12.01" y2="16"/>
        </svg>
        <span>{disclaimer}</span>
      </div>
    )}

    <div class="embed-cta">
      <button type="button" class="btn-embed" data-action="embed" title="Copiá el código para embeber esta calc en tu sitio">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
        {t.embed}
      </button>
      <span class="embed-hint">{t.embedHint}</span>
    </div>

    <div class="share">
      <span class="share-label">{t.share}</span>
      <button type="button" class="btn-share" data-action="copy-result">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
        <span data-copy-result-label>{t.copyResult}</span>
      </button>
      <button type="button" class="btn-share" data-action="whatsapp" aria-label="Compartir por WhatsApp">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 00-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
        WhatsApp
      </button>
      <button type="button" class="btn-share" data-action="copy-link" title="Copia un link que, al abrirlo, precarga los datos y vuelve a calcular">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
        <span data-copy-link-label>{t.copyLink}</span>
      </button>
      <button type="button" class="btn-share" data-action="print" title="Abre el diálogo de imprimir (podés guardarlo como PDF)">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 9 6 2 18 2 18 9"/><path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"/><rect x="6" y="14" width="12" height="8"/></svg>
        PDF
      </button>
      <button type="button" class="btn-share" data-action="reset">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 1 0 2.13-9.36L1 10"/></svg>
        {t.newCalc}
      </button>
    </div>

    <!-- Email capture CTA -->
    <div class="email-capture" data-email-capture style="display:none">
      <p class="email-heading"><strong>Recibí este resultado por email</strong></p>
      <form class="email-form" data-email-form>
        <input type="email" placeholder="tu@email.com" required data-email-input>
        <button type="submit">Enviar</button>
      </form>
      <p class="email-note">Gratis. Sin spam. Solo tu resultado.</p>
      <p class="email-success" data-email-success style="display:none">Guardado. Próximamente vas a recibir tus resultados por email.</p>
    </div>

    <!-- Calc usage counter -->
    <div class="calc-counter" data-calc-counter style="display:none"></div>

    <!-- Feedback inline: thumbs + comentario opcional -->
    <div class="feedback" data-feedback>
      <div class="feedback-prompt" data-feedback-prompt>
        <span>{t.helpful}</span>
        <button type="button" class="fb-btn" data-feedback-vote="up" aria-label="Sí, me sirvió">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M7 10v12"/><path d="M15 5.88 14 10h5.83a2 2 0 0 1 1.92 2.56l-2.33 8A2 2 0 0 1 17.5 22H7V10l4-8a1 1 0 0 1 1 .52z" fill="none"/></svg>
          {t.yes}
        </button>
        <button type="button" class="fb-btn" data-feedback-vote="down" aria-label={lang === 'en' ? 'No, not helpful' : 'No, no me sirvió'}>
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M17 14V2"/><path d="M9 18.12 10 14H4.17a2 2 0 0 1-1.92-2.56l2.33-8A2 2 0 0 1 6.5 2H17v12l-4 8a1 1 0 0 1-1-.52z" fill="none"/></svg>
          {t.no}
        </button>
      </div>
      <div class="feedback-followup" data-feedback-followup hidden>
        <label for={`fb-msg-${config.slug}`} class="fb-label" data-feedback-label></label>
        <textarea id={`fb-msg-${config.slug}`} rows="2" maxlength="500" placeholder={t.feedback} data-feedback-text></textarea>
        <button type="button" class="fb-send" data-feedback-send>{t.send}</button>
      </div>
      <div class="feedback-thanks" data-feedback-thanks hidden>¡Gracias! Tu feedback nos ayuda a mejorar.</div>
    </div>
  </div>

  <div class="calc-error" id={`error-${config.slug}`} hidden role="alert"></div>
</div>

<style>
  .calc-container {
    background: var(--bg-card);
