---
export interface Field {
  id: string;
  label: string;
  type: 'number' | 'text' | 'select' | 'date';
  placeholder?: string;
  suffix?: string;
  prefix?: string;
  min?: number;
  max?: number;
  step?: number;
  default?: string | number;
  options?: { value: string; label: string }[];
  required?: boolean;
  help?: string;
}

export interface CalcConfig {
  slug: string;
  title: string;
  h1: string;
  description: string;
  category: string;
  icon: string;
  fields: Field[];
  formulaId: string;
  outputs: {
    id: string;
    label: string;
    format: 'currency' | 'number' | 'percentage' | 'date' | 'text' | 'duration';
    primary?: boolean;
  }[];
}

export interface Props {
  config: CalcConfig;
}

const { config } = Astro.props;
---

<div class="calc-container" data-slug={config.slug} data-formula={config.formulaId}>
  <form id={`form-${config.slug}`} class="calc-form">
    {config.fields.map((field) => (
      <div class="field">
        <label for={field.id}>
          {field.label}
          {field.help && <span class="help" title={field.help}>?</span>}
        </label>
        <div class="input-wrap">
          {field.prefix && <span class="prefix">{field.prefix}</span>}
          {field.type === 'select' ? (
            <select id={field.id} name={field.id} required={field.required}>
              {field.options?.map((opt) => (
                <option value={opt.value} selected={opt.value === field.default}>
                  {opt.label}
                </option>
              ))}
            </select>
          ) : (
            <input
              id={field.id}
              name={field.id}
              type={field.type}
              placeholder={field.placeholder}
              min={field.min}
              max={field.max}
              step={field.step}
              value={field.default}
              required={field.required}
              inputmode={field.type === 'number' ? 'decimal' : undefined}
            />
          )}
          {field.suffix && <span class="suffix">{field.suffix}</span>}
        </div>
      </div>
    ))}
    <button type="submit" class="btn-primary">Calcular</button>
  </form>

  <div class="calc-results" id={`results-${config.slug}`} hidden>
    <h2>Resultado</h2>
    <div class="results-grid">
      {config.outputs.map((out) => (
        <div class={`result ${out.primary ? 'primary' : ''}`} data-output={out.id} data-format={out.format}>
          <div class="result-label">{out.label}</div>
          <div class="result-value" data-value></div>
        </div>
      ))}
    </div>
    <div class="share">
      <button type="button" class="btn-share" data-action="whatsapp">
        📱 Compartir por WhatsApp
      </button>
      <button type="button" class="btn-share" data-action="copy">
        🔗 Copiar link
      </button>
    </div>
  </div>

  <div class="calc-error" id={`error-${config.slug}`} hidden></div>
</div>

<style>
  .calc-container {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 1.5rem;
    margin-bottom: 2rem;
  }

  .calc-form {
    display: grid;
    gap: 1rem;
  }

  .field {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
  }

  label {
    font-weight: 500;
    font-size: 0.9375rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .help {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 18px;
    height: 18px;
    border-radius: 50%;
    background: var(--border);
    color: var(--text-muted);
    font-size: 0.75rem;
    cursor: help;
  }

  .input-wrap {
    display: flex;
    align-items: stretch;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 8px;
    overflow: hidden;
    transition: border-color 0.15s;
  }

  .input-wrap:focus-within {
    border-color: var(--accent);
  }

  input, select {
    flex: 1;
    padding: 0.75rem 1rem;
    background: transparent;
    color: var(--text);
    border: none;
    outline: none;
    width: 100%;
  }

  .prefix, .suffix {
    padding: 0.75rem 1rem;
    background: rgba(148, 163, 184, 0.1);
    color: var(--text-muted);
    font-size: 0.875rem;
    display: flex;
    align-items: center;
  }

  .btn-primary {
    margin-top: 0.5rem;
    padding: 0.875rem 1.5rem;
    background: var(--accent);
    color: var(--bg);
    border-radius: 8px;
    font-weight: 600;
    font-size: 1rem;
    transition: background 0.15s;
  }

  .btn-primary:hover {
    background: var(--accent-hover);
  }

  .calc-results {
    margin-top: 1.5rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border);
  }

  .calc-results h2 {
    margin: 0 0 1rem;
  }

  .results-grid {
    display: grid;
    gap: 0.75rem;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
  }

  .result {
    background: var(--bg);
    padding: 1rem;
    border-radius: 8px;
    border: 1px solid var(--border);
  }

  .result.primary {
    background: linear-gradient(135deg, rgba(34, 211, 238, 0.1), rgba(16, 185, 129, 0.1));
    border-color: var(--accent);
  }

  .result-label {
    font-size: 0.8125rem;
    color: var(--text-muted);
    margin-bottom: 0.25rem;
  }

  .result-value {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--text);
  }

  .result.primary .result-value {
    color: var(--accent);
    font-size: 1.875rem;
  }

  .share {
    display: flex;
    gap: 0.75rem;
    margin-top: 1.25rem;
    flex-wrap: wrap;
  }

  .btn-share {
    padding: 0.625rem 1rem;
    background: transparent;
    color: var(--text);
    border: 1px solid var(--border);
    border-radius: 8px;
    font-size: 0.875rem;
    font-weight: 500;
    transition: all 0.15s;
  }

  .btn-share:hover {
    background: var(--bg);
    border-color: var(--accent);
    color: var(--accent);
  }

  .calc-error {
    margin-top: 1rem;
    padding: 0.75rem 1rem;
    background: rgba(239, 68, 68, 0.1);
    border: 1px solid var(--danger);
    border-radius: 8px;
    color: var(--danger);
    font-size: 0.875rem;
  }
</style>

<script>
  import { formulas } from '../lib/formulas/index';

  function formatValue(value: number | string, format: string): string {
    if (value === null || value === undefined || value === '') return '—';
    if (format === 'currency') {
      return new Intl.NumberFormat('es-AR', {
        style: 'currency',
        currency: 'ARS',
        maximumFractionDigits: 0,
      }).format(Number(value));
    }
    if (format === 'number') {
      return new Intl.NumberFormat('es-AR', { maximumFractionDigits: 2 }).format(Number(value));
    }
    if (format === 'percentage') {
      return `${Number(value).toFixed(2)}%`;
    }
    if (format === 'date') {
      const d = new Date(value);
      return d.toLocaleDateString('es-AR', { day: '2-digit', month: 'long', year: 'numeric' });
    }
    if (format === 'duration') {
      return String(value);
    }
    return String(value);
  }

  document.querySelectorAll<HTMLElement>('.calc-container').forEach((container) => {
    const slug = container.dataset.slug!;
    const formulaId = container.dataset.formula!;
    const form = container.querySelector<HTMLFormElement>('.calc-form')!;
    const results = container.querySelector<HTMLElement>('.calc-results')!;
    const errorBox = container.querySelector<HTMLElement>('.calc-error')!;
    const formula = (formulas as any)[formulaId];

    if (!formula) {
      console.error(`Fórmula no encontrada: ${formulaId}`);
      return;
    }

    form.addEventListener('submit', (e) => {
      e.preventDefault();
      errorBox.hidden = true;
      errorBox.textContent = '';

      const data = new FormData(form);
      const inputs: Record<string, string | number> = {};
      data.forEach((v, k) => {
        const num = Number(v);
        inputs[k] = !isNaN(num) && v !== '' ? num : (v as string);
      });

      try {
        const output = formula(inputs);
        container.querySelectorAll<HTMLElement>('[data-output]').forEach((el) => {
          const outId = el.dataset.output!;
          const format = el.dataset.format!;
          const val = output[outId];
          const valueEl = el.querySelector<HTMLElement>('[data-value]')!;
          valueEl.textContent = formatValue(val, format);
        });
        results.hidden = false;
        results.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
      } catch (err: any) {
        errorBox.textContent = err.message || 'Error al calcular. Revisá los datos.';
        errorBox.hidden = false;
      }
    });

    // Share buttons
    container.querySelectorAll<HTMLButtonElement>('.btn-share').forEach((btn) => {
      btn.addEventListener('click', async () => {
        const action = btn.dataset.action;
        const url = window.location.href;
        const text = `Mirá esta calculadora en Hacé Cuentas: ${document.title}`;
        if (action === 'whatsapp') {
          window.open(`https://wa.me/?text=${encodeURIComponent(`${text} ${url}`)}`, '_blank');
        } else if (action === 'copy') {
          await navigator.clipboard.writeText(url);
          btn.textContent = '✅ Copiado';
          setTimeout(() => (btn.textContent = '🔗 Copiar link'), 1500);
        }
      });
    });
  });
</script>
