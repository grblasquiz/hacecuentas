    font-weight: 500;
  }
  .data-freshness a:hover { text-decoration: underline; }

  .presets {
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
    margin-bottom: 1.25rem;
    padding-bottom: 1rem;
    border-bottom: 1px dashed var(--border);
