---
---

<header>
  <div class="container">
    <a href="/" class="logo">
      <span class="logo-icon">🧮</span>
      <span class="logo-text">Hacé Cuentas</span>
    </a>
    <nav>
      <a href="/categoria/finanzas">Finanzas</a>
      <a href="/categoria/salud">Salud</a>
      <a href="/categoria/vida">Vida</a>
      <a href="/buscar">Buscar</a>
    </nav>
  </div>
</header>

<style>
  header {
    background: var(--bg-card);
    border-bottom: 1px solid var(--border);
    padding: 1rem 0;
    position: sticky;
    top: 0;
    z-index: 100;
    backdrop-filter: blur(10px);
  }

  .container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 1rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-weight: 700;
    font-size: 1.25rem;
    color: var(--text);
    text-decoration: none;
  }

  .logo:hover { color: var(--accent); }

  .logo-icon {
    font-size: 1.5rem;
  }

  nav {
    display: flex;
    gap: 1.25rem;
  }

  nav a {
    color: var(--text-muted);
    font-size: 0.9375rem;
    font-weight: 500;
  }

  nav a:hover {
    color: var(--accent);
    text-decoration: none;
  }

  @media (max-width: 640px) {
    nav { display: none; }
  }
</style>
