---
const currentPath = Astro.url.pathname;
const isActive = (path: string) => currentPath.startsWith(path);
---

<header class="site-header">
  <div class="header-container">
    <a href="/" class="logo" aria-label="Hacé Cuentas — Inicio">
      <svg class="logo-mark" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <rect x="2" y="2" width="28" height="28" rx="7" fill="#2563eb"/>
        <rect x="7" y="7" width="18" height="5" rx="1.5" fill="#ffffff" opacity="0.95"/>
        <circle cx="9.5" cy="17.5" r="1.5" fill="#ffffff"/>
        <circle cx="16" cy="17.5" r="1.5" fill="#ffffff"/>
        <circle cx="22.5" cy="17.5" r="1.5" fill="#ffffff"/>
        <circle cx="9.5" cy="23" r="1.5" fill="#ffffff"/>
        <circle cx="16" cy="23" r="1.5" fill="#ffffff"/>
        <circle cx="22.5" cy="23" r="1.5" fill="#ffffff"/>
      </svg>
      <span class="logo-text">Hacé Cuentas</span>
    </a>

    <nav aria-label="Navegación principal">
      <a href="/categoria/finanzas" class={isActive('/categoria/finanzas') ? 'active' : ''}>Finanzas</a>
      <a href="/categoria/salud" class={isActive('/categoria/salud') ? 'active' : ''}>Salud</a>
      <a href="/categoria/vida" class={isActive('/categoria/vida') ? 'active' : ''}>Vida</a>
    </nav>

    <button class="menu-toggle" aria-label="Abrir menú" aria-expanded="false" id="menu-toggle">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
        <line x1="4" y1="7" x2="20" y2="7"/>
        <line x1="4" y1="12" x2="20" y2="12"/>
        <line x1="4" y1="17" x2="20" y2="17"/>
      </svg>
    </button>
  </div>

  <div class="mobile-nav" id="mobile-nav" hidden>
    <a href="/categoria/finanzas">Finanzas</a>
    <a href="/categoria/salud">Salud</a>
    <a href="/categoria/vida">Vida</a>
  </div>
</header>

<style>
  .site-header {
    background: rgba(255, 255, 255, 0.85);
    backdrop-filter: saturate(180%) blur(14px);
    -webkit-backdrop-filter: saturate(180%) blur(14px);
    border-bottom: 1px solid var(--border);
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .header-container {
    max-width: 1120px;
    margin: 0 auto;
    padding: 0.875rem 1.25rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
  }

  .logo {
    display: inline-flex;
    align-items: center;
    gap: 0.625rem;
    color: var(--text);
    text-decoration: none;
    font-weight: 700;
  }

  .logo:hover { color: var(--text); text-decoration: none; }

  .logo-mark {
    width: 30px;
    height: 30px;
    flex-shrink: 0;
  }

  .logo-text {
    font-size: 1.0625rem;
    letter-spacing: -0.02em;
  }

  nav {
    display: flex;
    gap: 0.25rem;
    align-items: center;
    margin-left: auto;
  }

  nav a {
    color: var(--text-muted);
    font-size: 0.9375rem;
    font-weight: 500;
    padding: 0.5rem 0.875rem;
    border-radius: var(--radius-sm);
    transition: all 0.15s;
    text-decoration: none;
  }

  nav a:hover {
    color: var(--text);
    background: var(--bg-muted);
    text-decoration: none;
  }

  nav a.active {
    color: var(--accent);
    background: var(--accent-soft);
  }

  .menu-toggle {
    display: none;
    color: var(--text);
    padding: 0.5rem;
    border-radius: var(--radius-sm);
  }

  .menu-toggle:hover {
    background: var(--bg-muted);
  }

  .mobile-nav {
    display: none;
    flex-direction: column;
    border-top: 1px solid var(--border);
    padding: 0.5rem 1.25rem 0.75rem;
  }

  .mobile-nav a {
    color: var(--text-muted);
    font-size: 0.9375rem;
    font-weight: 500;
    padding: 0.75rem 0.5rem;
    text-decoration: none;
    border-bottom: 1px solid var(--border);
  }

  .mobile-nav a:last-child { border-bottom: none; }

  .mobile-nav[aria-expanded="true"], .mobile-nav:not([hidden]) {
    display: flex;
  }

  @media (max-width: 640px) {
    nav { display: none; }
    .menu-toggle { display: inline-flex; }
  }
</style>

<script>
  const toggle = document.getElementById('menu-toggle');
  const mobile = document.getElementById('mobile-nav');
  if (toggle && mobile) {
    toggle.addEventListener('click', () => {
      const open = !mobile.hasAttribute('hidden');
      if (open) {
        mobile.setAttribute('hidden', '');
        toggle.setAttribute('aria-expanded', 'false');
      } else {
        mobile.removeAttribute('hidden');
        toggle.setAttribute('aria-expanded', 'true');
      }
    });
  }
</script>
