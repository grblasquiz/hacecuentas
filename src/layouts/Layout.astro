---
import CookieConsent from '../components/CookieConsent.astro';

export interface Props {
  title: string;
  description: string;
  canonical?: string;
  schema?: object;
  image?: string;
  audience?: 'AR' | 'global'; // 'AR' = calculadora/página específica de Argentina; default 'global'
}

const {
  title,
  description,
  canonical,
  schema,
  image = '/og-default.png',
  audience = 'global',
} = Astro.props;

const siteUrl = 'https://hacecuentas.com';
// Cloudflare Pages sirve /foo.html en /foo — canonical sin .html para matchear sitemap
const cleanPath = Astro.url.pathname.replace(/\.html$/, '').replace(/\/index$/, '/') || '/';
const fullCanonical = canonical ? `${siteUrl}${canonical}` : `${siteUrl}${cleanPath}`;
const fullImage = image.startsWith('http') ? image : `${siteUrl}${image}`;

// Lang/locale dinámicos según audience.
// Para AR-only: es-AR fuerte (Google la prioriza para usuarios argentinos).
// Para globales: es genérico + alternate es-AR/es-419 (es-419 = español Latinoamérica).
const htmlLang = audience === 'AR' ? 'es-AR' : 'es';
const ogLocale = audience === 'AR' ? 'es_AR' : 'es_419';
const schemaLang = audience === 'AR' ? 'es-AR' : 'es';

// Schema.org WebSite + Organization global (siempre presente)
const globalSchema = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Organization',
      '@id': `${siteUrl}/#organization`,
      name: 'Hacé Cuentas',
      url: siteUrl,
      logo: `${siteUrl}/favicon.svg`,
      description: 'Calculadoras online gratuitas para todo el mundo hispanohablante, con cobertura específica para Argentina.',
      sameAs: [
        'https://github.com/grblasquiz/hacecuentas',
      ],
    },
    {
      '@type': 'WebSite',
      '@id': `${siteUrl}/#website`,
      url: siteUrl,
      name: 'Hacé Cuentas',
      publisher: { '@id': `${siteUrl}/#organization` },
      inLanguage: ['es', 'es-AR', 'es-419'],
      potentialAction: {
        '@type': 'SearchAction',
        target: `${siteUrl}/buscar?q={search_term_string}`,
        'query-input': 'required name=search_term_string',
      },
    },
  ],
};
---

<!doctype html>
<html lang={htmlLang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#ffffff" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#0f172a" media="(prefers-color-scheme: dark)" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/manifest.webmanifest" />
    <meta name="format-detection" content="telephone=no" />

    <!-- Theme init: prevent FOUC leyendo localStorage antes del paint -->
    <script is:inline>
      (function() {
        try {
          var t = localStorage.getItem('theme');
          if (t === 'dark' || (t === null && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
            document.documentElement.setAttribute('data-theme', 'dark');
          }
        } catch (e) {}
      })();
    </script>

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={fullCanonical} />
    {audience === 'AR' ? (
      <>
        <link rel="alternate" hreflang="es-AR" href={fullCanonical} />
        <link rel="alternate" hreflang="x-default" href={fullCanonical} />
      </>
    ) : (
      <>
        <link rel="alternate" hreflang="es" href={fullCanonical} />
        <link rel="alternate" hreflang="es-AR" href={fullCanonical} />
        <link rel="alternate" hreflang="es-419" href={fullCanonical} />
        <link rel="alternate" hreflang="x-default" href={fullCanonical} />
      </>
    )}
    <link rel="sitemap" type="application/xml" href="/sitemap.xml" />
    <link rel="alternate" type="application/rss+xml" title="Hacé Cuentas — Calculadoras actualizadas" href="/rss.xml" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={fullCanonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={fullImage} />
    <meta property="og:locale" content={ogLocale} />
    {audience !== 'AR' && <meta property="og:locale:alternate" content="es_AR" />}
    <meta property="og:site_name" content="Hacé Cuentas" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={fullImage} />

    <!-- Schema.org global (Organization + WebSite) -->
    <script type="application/ld+json" set:html={JSON.stringify(globalSchema)} />
    <!-- Schema.org específico de página -->
    {schema && <script type="application/ld+json" set:html={JSON.stringify(schema)} />}

    <!-- Fonts — preload CSS para evitar render-blocking -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="preload"
      as="style"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@500&display=swap"
      onload="this.onload=null;this.rel='stylesheet'"
    />
    <noscript><link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@500&display=swap" rel="stylesheet" /></noscript>

    <!-- Preconnect CDN externo (Chart.js, KaTeX) -->
    <link rel="dns-prefetch" href="https://cdn.jsdelivr.net" />
    <link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin />

    <!-- Google Consent Mode v2 — default 'denied' hasta que el usuario decida (GDPR/AdSense compliant) -->
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('consent', 'default', {
        ad_storage: 'denied',
        ad_user_data: 'denied',
        ad_personalization: 'denied',
        analytics_storage: 'denied',
        functionality_storage: 'granted',
        security_storage: 'granted',
        wait_for_update: 500
      });
      gtag('js', new Date());
      gtag('config', 'G-789KMTKWX2', { anonymize_ip: true });
    </script>
    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-789KMTKWX2"></script>
  </head>
  <body>
    <slot name="header" />
    <main>
      <slot />
    </main>
    <slot name="footer" />
    <CookieConsent />

    <!-- Service Worker — solo en producción y si el browser lo soporta -->
    <script is:inline>
      if ('serviceWorker' in navigator && location.protocol === 'https:') {
        window.addEventListener('load', function () {
          navigator.serviceWorker.register('/sw.js').catch(function () {
            /* silencioso: el sitio funciona sin SW */
          });
        });
      }
    </script>

    <style is:global>
      :root {
        /* Surfaces */
        --bg: #ffffff;
        --bg-soft: #f8fafc;
        --bg-muted: #f1f5f9;
        --bg-card: #ffffff;

        /* Borders */
        --border: #e2e8f0;
        --border-strong: #cbd5e1;

        /* Text */
        --text: #0f172a;
        --text-muted: #475569;
        --text-subtle: #64748b;

        /* Brand — trust blue */
        --accent: #2563eb;
        --accent-hover: #1d4ed8;
        --accent-soft: #eff6ff;
        --accent-strong: #1e40af;

        /* Status */
        --success: #16a34a;
        --success-soft: #f0fdf4;
        --danger: #dc2626;
        --danger-soft: #fef2f2;
        --warning: #d97706;
        --warning-soft: #fffbeb;

        /* Elevation */
        --shadow-sm: 0 1px 2px 0 rgb(15 23 42 / 0.05);
        --shadow: 0 1px 3px 0 rgb(15 23 42 / 0.08), 0 1px 2px -1px rgb(15 23 42 / 0.06);
        --shadow-md: 0 4px 6px -1px rgb(15 23 42 / 0.08), 0 2px 4px -2px rgb(15 23 42 / 0.05);
        --shadow-lg: 0 10px 15px -3px rgb(15 23 42 / 0.1), 0 4px 6px -4px rgb(15 23 42 / 0.05);

        /* Radii */
        --radius-sm: 6px;
        --radius: 10px;
        --radius-lg: 14px;
        --radius-xl: 20px;

        /* Type */
        --font-body: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
        --font-mono: 'JetBrains Mono', 'SF Mono', Monaco, monospace;
      }

      /* Dark mode — data-theme="dark" en <html> */
      html[data-theme="dark"] {
        --bg: #0f172a;
        --bg-soft: #1e293b;
        --bg-muted: #334155;
        --bg-card: #1e293b;

        --border: #334155;
        --border-strong: #475569;

        --text: #f1f5f9;
        --text-muted: #cbd5e1;
        --text-subtle: #94a3b8;

        --accent: #60a5fa;
        --accent-hover: #3b82f6;
        --accent-soft: #1e3a8a33;
        --accent-strong: #93c5fd;

        --success: #4ade80;
        --success-soft: #14532d33;
        --danger: #f87171;
        --danger-soft: #7f1d1d33;
        --warning: #fbbf24;
        --warning-soft: #78350f33;

        --shadow-sm: 0 1px 2px 0 rgb(0 0 0 / 0.25);
        --shadow: 0 1px 3px 0 rgb(0 0 0 / 0.35), 0 1px 2px -1px rgb(0 0 0 / 0.25);
        --shadow-md: 0 4px 6px -1px rgb(0 0 0 / 0.35), 0 2px 4px -2px rgb(0 0 0 / 0.25);
        --shadow-lg: 0 10px 15px -3px rgb(0 0 0 / 0.5), 0 4px 6px -4px rgb(0 0 0 / 0.3);
      }

      html[data-theme="dark"] ::selection {
        background: var(--accent-soft);
        color: var(--accent-strong);
      }

      * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      html {
        font-family: var(--font-body);
        scroll-behavior: smooth;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
        text-rendering: optimizeLegibility;
      }

      body {
        background: var(--bg);
        color: var(--text);
        line-height: 1.6;
        min-height: 100vh;
        font-size: 16px;
      }

      main {
        max-width: 1120px;
        margin: 0 auto;
        padding: 2rem 1.25rem 4rem;
      }

      h1, h2, h3, h4 {
        line-height: 1.2;
        font-weight: 700;
        color: var(--text);
        letter-spacing: -0.015em;
      }

      h1 {
        font-size: clamp(1.875rem, 4vw, 2.75rem);
        letter-spacing: -0.025em;
        font-weight: 800;
      }

      h2 {
        font-size: clamp(1.375rem, 3vw, 1.875rem);
        margin-bottom: 0.5rem;
      }

      h3 {
        font-size: 1.125rem;
      }

      h4 {
        font-size: 0.9375rem;
        font-weight: 600;
      }

      p {
        color: var(--text-muted);
        line-height: 1.65;
      }

      a {
        color: var(--accent);
        text-decoration: none;
        transition: color 0.15s;
      }

      a:hover {
        color: var(--accent-hover);
      }

      button {
        font-family: inherit;
        cursor: pointer;
        border: none;
        background: none;
      }

      input, select, textarea {
        font-family: inherit;
        font-size: 1rem;
        color: inherit;
      }

      ::selection {
        background: var(--accent-soft);
        color: var(--accent-strong);
      }

      /* Focus ring universal */
      *:focus-visible {
        outline: 2px solid var(--accent);
        outline-offset: 2px;
        border-radius: 4px;
      }

      .container {
        max-width: 1120px;
        margin: 0 auto;
        padding: 0 1.25rem;
      }

      /* Respect prefers-reduced-motion */
      @media (prefers-reduced-motion: reduce) {
        *, *::before, *::after {
          animation-duration: 0.01ms !important;
          animation-iteration-count: 1 !important;
          transition-duration: 0.01ms !important;
          scroll-behavior: auto !important;
        }
        html { scroll-behavior: auto; }
      }

      /* Print — optimizar para cuando imprimen resultados (PDF-friendly) */
      @media print {
        :root {
          --bg: #fff;
          --bg-soft: #fff;
          --bg-card: #fff;
          --bg-muted: #fff;
          --border: #ccc;
          --text: #000;
          --text-muted: #333;
          --accent: #000;
          --accent-soft: #eee;
          --shadow-sm: none;
          --shadow: none;
          --shadow-md: none;
          --shadow-lg: none;
        }
        body { font-size: 11pt; color: #000; background: #fff; }
        main { max-width: 100%; padding: 0; margin: 0; }
        /* Ocultar todo excepto el calc container, título H1 y breadcrumbs */
        header, footer, .skip-link, nav:not(.breadcrumbs), button, .share, .cta-back,
        .scroll-top, .scroll-progress, .related, .hero-featured, .sources,
        .hero-meta, .explanation, .faq, .key-takeaway, .intro, .use-cases,
        .example-box, .seo-content, .cat-faq, .hc-embed-overlay { display: none !important; }
        .breadcrumbs { font-size: 9pt; color: #666; margin-bottom: 0.5cm; }
        h1 { font-size: 20pt; margin-bottom: 0.3cm; }
        a, a:visited { color: #000; text-decoration: none; }
        .calc-container { border: 1px solid #000; box-shadow: none; page-break-inside: avoid; padding: 1cm; }
        .result.primary { background: #f5f5f5 !important; color: #000 !important; border: 2px solid #000; }
        h1, h2, h3 { page-break-after: avoid; }
        /* Branding footer en print: logo Hacé Cuentas + URL + fecha */
        body::after {
          content: "Cálculo generado con Hacé Cuentas — hacecuentas.com";
          display: block;
          text-align: center;
          font-size: 9pt;
          color: #666;
          margin-top: 1cm;
          padding-top: 0.5cm;
          border-top: 1px solid #ccc;
        }
        /* Force date via ::before si es útil */
        .calc-container::before {
          content: "Hacé Cuentas · " attr(data-slug);
          display: block;
          font-size: 9pt;
          color: #888;
          margin-bottom: 0.5cm;
          text-transform: uppercase;
          letter-spacing: 0.05em;
        }
      }
    </style>
  </body>
</html>
