---
import CookieConsent from '../components/CookieConsent.astro';

// Self-hosted fonts (subset latin) — elimina render-blocking de Google Fonts.
// Cada latin-NNN.css trae ~150 bytes de CSS + 1 woff2 (~17 KB).
// Total: ~100 KB de fuentes servidas desde el mismo dominio, con font-display: swap.
import '@fontsource/inter/latin-400.css';
import '@fontsource/inter/latin-500.css';
import '@fontsource/inter/latin-600.css';
import '@fontsource/inter/latin-700.css';
import '@fontsource/inter/latin-800.css';
import '@fontsource/jetbrains-mono/latin-500.css';
// Preload para fonts arriba-del-fold. Vite les da hash correcto.
// 400 = body | 700 = headings secundarios | 800 = H1 hero (LCP en home)
import interFont400Url from '@fontsource/inter/files/inter-latin-400-normal.woff2?url';
import interFont700Url from '@fontsource/inter/files/inter-latin-700-normal.woff2?url';
import interFont800Url from '@fontsource/inter/files/inter-latin-800-normal.woff2?url';

export interface Props {
  title: string;
  description: string;
  canonical?: string;
  schema?: object;
  image?: string;
  audience?: 'AR' | 'global'; // 'AR' = calculadora/página específica de Argentina; default 'global'
  lang?: 'es' | 'en';
  hreflang?: Array<{lang: string, href: string}>;
  noindex?: boolean;
}

const {
  title,
  description,
  canonical,
  schema,
  image = '/og-default.png',
  audience = 'global',
  lang,
  hreflang,
  noindex = false,
} = Astro.props;

const siteUrl = 'https://hacecuentas.com';
// Cloudflare Pages sirve /foo.html en /foo — canonical sin .html para matchear sitemap
const cleanPath = Astro.url.pathname.replace(/\.html$/, '').replace(/\/index$/, '/') || '/';
const fullCanonical = canonical ? `${siteUrl}${canonical}` : `${siteUrl}${cleanPath}`;
const fullImage = image.startsWith('http') ? image : `${siteUrl}${image}`;

// Lang/locale dinámicos según audience y lang.
// Para EN: 'en' + en_US.
// Para AR-only: es-AR fuerte (Google la prioriza para usuarios argentinos).
// Para globales: es genérico + alternate es-AR/es-419 (es-419 = español Latinoamérica).
const htmlLang = lang === 'en' ? 'en' : audience === 'AR' ? 'es-AR' : 'es';
const ogLocale = lang === 'en' ? 'en_US' : audience === 'AR' ? 'es_AR' : 'es_419';
const schemaLang = lang === 'en' ? 'en' : audience === 'AR' ? 'es-AR' : 'es';

// Schema.org WebSite + Organization global (siempre presente)
const globalSchema = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Organization',
      '@id': `${siteUrl}/#organization`,
      name: 'Hacé Cuentas',
      url: siteUrl,
      logo: `${siteUrl}/logo.png`,
      description: lang === 'en'
        ? 'Free online calculators covering finance, health, cooking, math and more — no signup, private, fast.'
        : 'Calculadoras online gratuitas para todo el mundo hispanohablante, con cobertura específica para Argentina.',
      sameAs: [
        'https://github.com/grblasquiz/hacecuentas',
      ],
    },
    {
      '@type': 'WebSite',
      '@id': `${siteUrl}/#website`,
      url: siteUrl,
      name: 'Hacé Cuentas',
      publisher: { '@id': `${siteUrl}/#organization` },
      inLanguage: lang === 'en' ? ['en', 'en-US'] : ['es', 'es-AR', 'es-419'],
      potentialAction: {
        '@type': 'SearchAction',
        target: lang === 'en' ? `${siteUrl}/en?q={search_term_string}` : `${siteUrl}/buscar?q={search_term_string}`,
        'query-input': 'required name=search_term_string',
      },
    },
    // SiteNavigationElement: ayuda a Google a entender el menú principal
    // y a generar sitelinks en SERP debajo del resultado principal del brand.
    lang === 'en' ? {
      '@type': 'SiteNavigationElement',
      '@id': `${siteUrl}/en/#nav`,
      name: [
        'All calculators', 'Finance', 'Health & Fitness', 'Math', 'Cooking',
        'Sports', 'Pets', 'Family', 'Home & Construction', 'Tech',
      ],
      url: [
        `${siteUrl}/en`,
        `${siteUrl}/en/compound-interest-calculator`,
        `${siteUrl}/en/bmi-calculator`,
        `${siteUrl}/en/percentage-calculator`,
        `${siteUrl}/en/cups-to-grams-converter`,
        `${siteUrl}/en/running-pace-calculator`,
        `${siteUrl}/en/cat-age-to-human-years`,
        `${siteUrl}/en/pregnancy-due-date-calculator`,
        `${siteUrl}/en/ceramic-tile-calculator`,
        `${siteUrl}/en/claude-gemini-tokens-pricing-comparison`,
      ],
    } : {
      '@type': 'SiteNavigationElement',
      '@id': `${siteUrl}/#nav`,
      name: [
        'Cambio de monedas', 'Cripto', 'Inflación', 'Guías', 'Finanzas',
        'Salud', 'Marketing', 'Viajes', 'Vida diaria', 'Presupuesto familiar',
        'Simulador jubilación', 'Buscador',
      ],
      url: [
        `${siteUrl}/cambio-de-monedas`,
        `${siteUrl}/cotizacion-cripto`,
        `${siteUrl}/inflacion-argentina`,
        `${siteUrl}/guias`,
        `${siteUrl}/categoria/finanzas`,
        `${siteUrl}/categoria/salud`,
        `${siteUrl}/categoria/marketing`,
        `${siteUrl}/categoria/viajes`,
        `${siteUrl}/categoria/vida`,
        `${siteUrl}/presupuesto-familiar`,
        `${siteUrl}/simulador-jubilacion-anses`,
        `${siteUrl}/buscar`,
      ],
    },
  ],
};
---

<!doctype html>
<html lang={htmlLang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#ffffff" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#0f172a" media="(prefers-color-scheme: dark)" />
    <!-- Favicon v3 (logo completo sin bandas blancas) -->
    <link rel="icon" type="image/x-icon" href="/favicon.ico?v=3" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png?v=3" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png?v=3" />
    <link rel="shortcut icon" href="/favicon.ico?v=3" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/manifest.webmanifest" />
    <meta name="format-detection" content="telephone=no" />

    <!-- Theme init: prevent FOUC leyendo localStorage antes del paint -->
    <script is:inline>
      (function() {
        try {
          var t = localStorage.getItem('theme');
          if (t === 'dark' || (t === null && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
            document.documentElement.setAttribute('data-theme', 'dark');
          }
        } catch (e) {}
      })();
    </script>

    <title>{title}</title>
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, follow" />}
    <link rel="canonical" href={fullCanonical} />
    {hreflang ? (
      hreflang.map(h => <link rel="alternate" hreflang={h.lang} href={h.href} />)
    ) : audience === 'AR' ? (
      <>
        <link rel="alternate" hreflang="es-AR" href={fullCanonical} />
        <link rel="alternate" hreflang="x-default" href={fullCanonical} />
      </>
    ) : (
      /* Página en español global (sin variante por país): Google interpreta
         múltiples hreflang apuntando a la misma URL como error. Declaramos
         sólo 'es' + x-default. */
      <>
        <link rel="alternate" hreflang="es" href={fullCanonical} />
        <link rel="alternate" hreflang="x-default" href={fullCanonical} />
      </>
    )}
    <link rel="sitemap" type="application/xml" href="/sitemap.xml" />
    <link rel="alternate" type="application/rss+xml" title="Hacé Cuentas — Calculadoras actualizadas" href="/rss.xml" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={fullCanonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={fullImage} />
    <meta property="og:locale" content={ogLocale} />
    {audience !== 'AR' && <meta property="og:locale:alternate" content="es_AR" />}
    <meta property="og:site_name" content="Hacé Cuentas" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={fullImage} />

    <!-- Schema.org global (Organization + WebSite) -->
    <script type="application/ld+json" set:html={JSON.stringify(globalSchema)} />
    <!-- Schema.org específico de página -->
    {schema && <script type="application/ld+json" set:html={JSON.stringify(schema)} />}

    <!-- Fuentes self-hosted — solo preload del weight crítico (800 = H1/LCP).
         400 y 700 NO preload: cargan vía @font-face con font-display:swap sin bloquear
         el critical path, reduciendo LCP P75 de 3.6s → ~2.5s en mobile. -->
    <link rel="preload" href={interFont800Url} as="font" type="font/woff2" crossorigin />

    <!-- Preconnect: establece conexión (DNS + TCP + TLS) antes de que se necesite.
         Googletagmanager se pide en ~todos los page views (Partytown lo carga en
         worker). cdn.jsdelivr solo en calcs que usan Chart.js, dns-prefetch alcanza. -->
    <link rel="preconnect" href="https://www.googletagmanager.com" crossorigin />
    <link rel="dns-prefetch" href="https://cdn.jsdelivr.net" />
    <link rel="dns-prefetch" href="https://www.google-analytics.com" />
    <link rel="dns-prefetch" href="https://static.cloudflareinsights.com" />

    <!-- Google Consent Mode v2
         Default 'granted' para analytics (Argentina/LATAM no requiere opt-in bajo Ley 25.326).
         ad_storage denied por default por compliance AdSense/UE; user lo activa via banner.
         url_passthrough + ads_data_redaction permiten pings cookieless cuando el user rechaza.
         wait_for_update bajado a 500ms — con analytics_storage granted default no
         necesitamos esperar tanto; 2000ms hacía perder sesiones cortas. -->
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('consent', 'default', {
        analytics_storage: 'granted',
        functionality_storage: 'granted',
        security_storage: 'granted',
        ad_storage: 'denied',
        ad_user_data: 'denied',
        ad_personalization: 'denied',
        wait_for_update: 500
      });
      gtag('set', 'url_passthrough', true);
      gtag('set', 'ads_data_redaction', true);
      gtag('js', new Date());
      // send_page_view true (default) + anonymize_ip. Config explícito para debug.
      gtag('config', 'G-789KMTKWX2', {
        anonymize_ip: true,
        send_page_view: true,
        transport_type: 'beacon',
      });
      gtag('config', 'AW-18096606872');
      function gtagSendEvent(url) {
        var callback = function () {
          if (typeof url === 'string') { window.location = url; }
        };
        gtag('event', 'conversion_event_default', {
          'event_callback': callback,
          'event_timeout': 2000,
        });
        return false;
      }
      // Helper sin navegación: dispara conversion_event_default sin redirigir.
      // Usado por Calculator.astro al completar cada cálculo (cada uso = 1 conversión).
      function gtagTriggerConversion() {
        if (typeof gtag !== 'function') return;
        gtag('event', 'conversion_event_default', {});
      }
    </script>
    <!-- gtag.js async en <head>. NIVEL 1: el fetch tiene que arrancar ASAP.
         Antes estaba al final del <body> para "no bloquear render", pero async
         no bloquea render desde ninguna posición — y al final del body el request
         recién salía después de parsear todo el DOM, perdiendo pageviews en sesiones
         cortas (bounce <2s, clicks rápidos). Con async en head la red arranca
         inmediato y el inline de arriba ya dejó el pageview encolado en dataLayer. -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-789KMTKWX2"></script>
    <script async src="https://www.googletagmanager.com/gtag/js?id=AW-18096606872"></script>
  </head>
  <body>
    <!-- Print-only header (hidden on screen, visible when printing) -->
    <div class="print-header" aria-hidden="true">{lang === 'en' ? 'Calculator result — hacecuentas.com' : 'Resultado de calculadora — hacecuentas.com'}</div>

    <slot name="header" />
    <main>
      <slot />
    </main>
    <slot name="footer" />
    <CookieConsent />

    <!-- Service Worker — solo en producción y si el browser lo soporta -->
    <!-- SW registration + print-header date: diferidos a idle para no bloquear TBT -->
    <script is:inline>
      (function () {
        var deferFn = window.requestIdleCallback || function (fn) { return setTimeout(fn, 1); };
        deferFn(function () {
          // Service Worker
          if ('serviceWorker' in navigator && location.protocol === 'https:') {
            navigator.serviceWorker.register('/sw.js').catch(function () {});
          }
          // Print header date (lang-aware via html lang attr)
          var ph = document.querySelector('.print-header');
          if (ph) {
            var d = new Date();
            var isEn = (document.documentElement.lang || '').toLowerCase().indexOf('en') === 0;
            var locale = isEn ? 'en-US' : 'es-AR';
            var fecha = d.toLocaleDateString(locale, { year: 'numeric', month: 'long', day: 'numeric' });
            var label = isEn ? 'Calculator result' : 'Resultado de calculadora';
            ph.textContent = label + ' — hacecuentas.com — ' + fecha;
          }
        });
      })();
    </script>

    <style is:global>
      /* Print header: hidden on screen, shown on print */
      .print-header { display: none; }
      :root {
        /* Surfaces */
        --bg: #ffffff;
        --bg-soft: #f8fafc;
        --bg-muted: #f1f5f9;
        --bg-card: #ffffff;

        /* Borders */
        --border: #e2e8f0;
        --border-strong: #cbd5e1;

        /* Text */
        --text: #0f172a;
        --text-muted: #475569;
        --text-subtle: #64748b;

        /* Brand — trust blue */
        --accent: #2563eb;
        --accent-hover: #1d4ed8;
        --accent-soft: #eff6ff;
        --accent-strong: #1e40af;

        /* Status */
        --success: #16a34a;
        --success-soft: #f0fdf4;
        --danger: #dc2626;
        --danger-soft: #fef2f2;
        --warning: #d97706;
        --warning-soft: #fffbeb;

        /* Elevation */
        --shadow-sm: 0 1px 2px 0 rgb(15 23 42 / 0.05);
        --shadow: 0 1px 3px 0 rgb(15 23 42 / 0.08), 0 1px 2px -1px rgb(15 23 42 / 0.06);
        --shadow-md: 0 4px 6px -1px rgb(15 23 42 / 0.08), 0 2px 4px -2px rgb(15 23 42 / 0.05);
        --shadow-lg: 0 10px 15px -3px rgb(15 23 42 / 0.1), 0 4px 6px -4px rgb(15 23 42 / 0.05);

        /* Radii */
        --radius-sm: 6px;
        --radius: 10px;
        --radius-lg: 14px;
        --radius-xl: 20px;

        /* Type */
        --font-body: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
        --font-mono: 'JetBrains Mono', 'SF Mono', Monaco, monospace;
      }

      /* Dark mode — data-theme="dark" en <html> */
      html[data-theme="dark"] {
        --bg: #0f172a;
        --bg-soft: #1e293b;
        --bg-muted: #334155;
        --bg-card: #1e293b;

        --border: #334155;
        --border-strong: #475569;

        --text: #f1f5f9;
        --text-muted: #cbd5e1;
        --text-subtle: #94a3b8;

        --accent: #60a5fa;
        --accent-hover: #3b82f6;
        --accent-soft: #1e3a8a33;
        --accent-strong: #93c5fd;

        --success: #4ade80;
        --success-soft: #14532d33;
        --danger: #f87171;
        --danger-soft: #7f1d1d33;
        --warning: #fbbf24;
        --warning-soft: #78350f33;

        --shadow-sm: 0 1px 2px 0 rgb(0 0 0 / 0.25);
        --shadow: 0 1px 3px 0 rgb(0 0 0 / 0.35), 0 1px 2px -1px rgb(0 0 0 / 0.25);
        --shadow-md: 0 4px 6px -1px rgb(0 0 0 / 0.35), 0 2px 4px -2px rgb(0 0 0 / 0.25);
        --shadow-lg: 0 10px 15px -3px rgb(0 0 0 / 0.5), 0 4px 6px -4px rgb(0 0 0 / 0.3);
      }

      html[data-theme="dark"] ::selection {
        background: var(--accent-soft);
        color: var(--accent-strong);
      }

      * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      html {
        font-family: var(--font-body);
        scroll-behavior: smooth;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
        text-rendering: optimizeLegibility;
      }

      body {
        background: var(--bg);
        color: var(--text);
        line-height: 1.6;
        min-height: 100vh;
        font-size: 16px;
      }

      main {
        max-width: 1120px;
        margin: 0 auto;
        padding: 2rem 1.25rem 4rem;
      }

      h1, h2, h3, h4 {
        line-height: 1.2;
        font-weight: 700;
        color: var(--text);
        letter-spacing: -0.015em;
      }

      h1 {
        font-size: clamp(1.875rem, 4vw, 2.75rem);
        letter-spacing: -0.025em;
        font-weight: 800;
      }

      h2 {
        font-size: clamp(1.375rem, 3vw, 1.875rem);
        margin-bottom: 0.5rem;
      }

      h3 {
        font-size: 1.125rem;
      }

      h4 {
        font-size: 0.9375rem;
        font-weight: 600;
      }

      p {
        color: var(--text-muted);
        line-height: 1.65;
      }

      a {
        color: var(--accent);
        text-decoration: none;
        transition: color 0.15s;
      }

      a:hover {
        color: var(--accent-hover);
      }

      button {
        font-family: inherit;
        cursor: pointer;
        border: none;
        background: none;
      }

      input, select, textarea {
        font-family: inherit;
        font-size: 1rem;
        color: inherit;
      }

      ::selection {
        background: var(--accent-soft);
        color: var(--accent-strong);
      }

      /* Focus ring universal */
      *:focus-visible {
        outline: 2px solid var(--accent);
        outline-offset: 2px;
        border-radius: 4px;
      }

      .container {
        max-width: 1120px;
        margin: 0 auto;
        padding: 0 1.25rem;
      }

      /* Respect prefers-reduced-motion */
      @media (prefers-reduced-motion: reduce) {
        *, *::before, *::after {
          animation-duration: 0.01ms !important;
          animation-iteration-count: 1 !important;
          transition-duration: 0.01ms !important;
          scroll-behavior: auto !important;
        }
        html { scroll-behavior: auto; }
      }

      /* ========================================
         Print stylesheet — PDF-friendly output
         ======================================== */
      @media print {
        :root {
          --bg: #fff;
          --bg-soft: #fff;
          --bg-card: #fff;
          --bg-muted: #fff;
          --border: #ccc;
          --border-strong: #999;
          --text: #000;
          --text-muted: #333;
          --text-subtle: #555;
          --accent: #000;
          --accent-soft: #eee;
          --accent-hover: #000;
          --accent-strong: #000;
          --shadow-sm: none;
          --shadow: none;
          --shadow-md: none;
          --shadow-lg: none;
        }

        /* 1. System fonts — remove web fonts for print */
        html {
          font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif !important;
        }
        * {
          font-family: inherit !important;
        }
        code, pre, .result-value, [data-value] {
          font-family: 'Courier New', Courier, monospace !important;
        }

        /* 2. Clean base — black on white, no decorations */
        body {
          font-size: 11pt;
          color: #000;
          background: #fff !important;
          -webkit-print-color-adjust: exact;
          print-color-adjust: exact;
        }
        main { max-width: 100%; padding: 0; margin: 0; }

        /* 3. Hide non-essential elements */
        header, footer, .skip-link, nav:not(.breadcrumbs),
        .scroll-top, .scroll-progress, .related, .hero-featured, .sources,
        .hero-meta, .explanation, .faq, .key-takeaway, .intro, .use-cases,
        .example-box, .seo-content, .cat-faq, .hc-embed-overlay,
        /* Cookie consent & modal */
        .hc-cookie-banner, .hc-cookie-modal,
        /* Ads */
        .ad-slot, .adsbygoogle,
        /* Share buttons, embed button */
        .share, .embed-cta,
        /* Feedback section */
        .feedback,
        /* Search overlay */
        #search-modal,
        /* CTA & navigation */
        .cta-back, .mobile-nav,
        /* Theme toggle, menu toggle, search btn */
        #theme-toggle, #menu-toggle, #open-search,
        /* Data update badge (not useful on print) */
        .data-update,
        /* Presets section (already selected) */
        .presets { display: none !important; }

        /* Hide all interactive buttons on print */
        button { display: none !important; }

        /* 4. Show calculator title (h1) prominently */
        .breadcrumbs { font-size: 9pt; color: #666; margin-bottom: 0.5cm; }
        h1 { font-size: 20pt; margin-bottom: 0.3cm; }
        a, a:visited { color: #000; text-decoration: none; }

        /* 5. Calculator container — clean, no shadows/radius */
        .calc-container {
          border: 1px solid #000;
          box-shadow: none !important;
          border-radius: 0 !important;
          page-break-inside: avoid;
          padding: 0.75cm;
        }

        /* 6. Inputs — visible with their values */
        .calc-form {
          page-break-inside: avoid;
        }
        .field-group {
          margin-bottom: 0.3cm;
        }
        input, select, textarea {
          border: 1px solid #999 !important;
          background: #fff !important;
          box-shadow: none !important;
          border-radius: 0 !important;
          padding: 0.15cm 0.25cm;
          font-size: 10pt;
        }
        label {
          font-size: 9pt;
          font-weight: 600;
          color: #000;
        }
        /* Show advanced fields (they might be hidden) */
        .advanced-fields, .advanced-fields[hidden] {
          display: block !important;
        }

        /* 7. Results — prominent display */
        .calc-results, .calc-results[hidden] {
          display: block !important;
        }
        .results-grid {
          gap: 0.3cm;
        }
        .result {
          border: 1px solid #999;
          border-radius: 0 !important;
          box-shadow: none !important;
          padding: 0.3cm 0.4cm;
          page-break-inside: avoid;
          background: #fff !important;
        }
        .result.primary {
          background: #f0f0f0 !important;
          color: #000 !important;
          border: 2px solid #000;
          font-size: 12pt;
        }
        .result-label {
          font-size: 9pt;
          color: #333;
        }
        .result-value {
          font-size: 14pt;
          font-weight: 700;
          color: #000 !important;
        }
        .result.primary .result-value {
          font-size: 18pt;
        }

        /* 8. Chart — show if visible, avoid break */
        .chart-wrap {
          page-break-inside: avoid;
          margin-top: 0.5cm;
        }
        .chart-wrap[hidden] { display: none !important; }

        /* 9. Disclaimer — keep visible */
        .inline-disclaimer {
          font-size: 8pt;
          color: #555;
          border: none;
          padding: 0.2cm 0;
          background: none !important;
        }

        /* 10. Page break rules */
        h1, h2, h3 { page-break-after: avoid; }
        .result { page-break-inside: avoid; }

        /* 11. Remove all shadows, border-radius, decorative elements */
        *, *::before, *::after {
          box-shadow: none !important;
          text-shadow: none !important;
        }

        /* 12. Print header — "Resultado de calculadora" + date via JS-injected element */
        .print-header {
          display: block !important;
          font-size: 9pt;
          color: #666;
          text-align: center;
          padding-bottom: 0.4cm;
          margin-bottom: 0.5cm;
          border-bottom: 1px solid #ccc;
        }

        /* 13. Branding footer on printed pages */
        @page {
          margin: 1.5cm;
        }
        body::after {
          content: "Cálculo generado con hacecuentas.com";
          display: block;
          text-align: center;
          font-size: 9pt;
          color: #666;
          margin-top: 1cm;
          padding-top: 0.5cm;
          border-top: 1px solid #ccc;
        }

        /* 14. Calc container header with slug */
        .calc-container::before {
          content: "Hacé Cuentas · " attr(data-slug);
          display: block;
          font-size: 9pt;
          color: #888;
          margin-bottom: 0.5cm;
          text-transform: uppercase;
          letter-spacing: 0.05em;
        }
      }
    </style>
