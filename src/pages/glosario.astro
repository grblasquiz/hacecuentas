---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Term {
  term: string;
  short: string;
  long: string;
  category: string;
  related?: string[]; // slugs de calcs
}

const terms: Term[] = [
  // FINANZAS / EMPLEO
  {
    term: 'SAC (Sueldo Anual Complementario)',
    short: 'El "aguinaldo": medio sueldo extra que se cobra en junio y diciembre.',
    long: 'Establecido por la Ley 27.073, el SAC equivale al 50% del mejor sueldo mensual del semestre. Se paga en dos cuotas: junio (primera mitad del año) y diciembre (segunda mitad). Si trabajaste menos de 6 meses, se calcula proporcional.',
    category: 'finanzas',
    related: ['calculadora-aguinaldo-sac'],
  },
  {
    term: 'LCT (Ley de Contrato de Trabajo)',
    short: 'Ley 20.744, marco general del empleo en relación de dependencia en Argentina.',
    long: 'Regula desde el contrato de trabajo, salario, vacaciones, indemnización por despido, hasta licencias por enfermedad y maternidad. Es la norma de referencia para casi todos los cálculos de empleo.',
    category: 'finanzas',
    related: ['sueldo-en-mano-argentina', 'calculadora-indemnizacion-despido'],
  },
  {
    term: 'Vizzoti (fallo)',
    short: 'Tope a la indemnización por despido fijado por la Corte Suprema en 2004.',
    long: 'En el caso "Vizzoti c/ AMSA", la Corte declaró que la indemnización no puede reducirse por debajo del 67% del mejor sueldo del último año. Si el tope legal del convenio resulta menor, se aplica el 67% como piso real.',
    category: 'finanzas',
    related: ['calculadora-indemnizacion-despido'],
  },
  {
    term: 'Monotributo',
    short: 'Régimen tributario simplificado para autónomos con baja facturación.',
    long: 'Ley 24.977. Unifica IVA, Ganancias y aportes en una cuota única mensual. Tiene categorías A-K según facturación, alquileres y consumo eléctrico. AFIP/ARCA actualiza los topes semestralmente.',
    category: 'finanzas',
    related: ['calculadora-monotributo-2026'],
  },
  {
    term: 'Ganancias (4ta categoría)',
    short: 'Impuesto sobre sueldos altos y honorarios profesionales.',
    long: 'Ley 20.628 y RG AFIP. Grava ingresos en relación de dependencia que superan el mínimo no imponible. Tiene escala progresiva y permite deducciones por cargas de familia, alquileres, seguros, etc.',
    category: 'finanzas',
    related: ['calculadora-impuesto-ganancias-sueldo'],
  },
  {
    term: 'TNA (Tasa Nominal Anual)',
    short: 'Tasa de interés anual sin capitalizar — la que publica el banco.',
    long: 'No refleja el rendimiento real porque no considera la capitalización de intereses. Sirve para comparar productos en igualdad de condiciones, pero la TEA es lo que realmente rinde.',
    category: 'finanzas',
    related: ['calculadora-plazo-fijo'],
  },
  {
    term: 'TEA (Tasa Efectiva Anual)',
    short: 'Tasa de interés anual con capitalización — el rendimiento real.',
    long: 'Si reinvertís los intereses, la TEA es lo que ganás. Siempre es mayor o igual a la TNA. Para inversiones que renuevan automáticamente (plazo fijo a 30 días), la TEA es la métrica relevante.',
    category: 'finanzas',
    related: ['calculadora-plazo-fijo'],
  },
  {
    term: 'CFT (Costo Financiero Total)',
    short: 'El "verdadero precio" de un préstamo: TNA + IVA + comisiones + seguros.',
    long: 'Obligatorio publicarlo en Argentina por norma del BCRA. Para comparar préstamos, mirá siempre CFT, no TNA — es el único número que refleja lo que realmente vas a pagar.',
    category: 'finanzas',
    related: ['calculadora-cuota-prestamo'],
  },
  {
    term: 'UVA',
    short: 'Unidad de Valor Adquisitivo, indexa préstamos a la inflación.',
    long: 'Creada por el BCRA en 2016. Cada UVA equivale a una milésima del costo de construcción de 1 m². Préstamos UVA mantienen poder adquisitivo del capital pero la cuota varía mes a mes con la inflación.',
    category: 'finanzas',
  },
  {
    term: 'Sistema francés',
    short: 'Sistema de amortización con cuota fija en valor nominal.',
    long: 'Es el más usado en préstamos personales y prendarios. La cuota mensual es constante: al principio paga más intereses y poco capital, al final al revés. La Tasa Efectiva Mensual aplicada es i/12 = TNA/12.',
    category: 'finanzas',
    related: ['calculadora-cuota-prestamo'],
  },
  {
    term: 'Bienes Personales',
    short: 'Impuesto patrimonial anual sobre activos al 31 de diciembre.',
    long: 'Ley 23.966. Grava el patrimonio neto que supere el mínimo no imponible (~$292M para 2024). Tiene escala progresiva y exime la vivienda única hasta cierto valor.',
    category: 'finanzas',
  },

  // SALUD
  {
    term: 'IMC (Índice de Masa Corporal)',
    short: 'peso(kg) / altura(m)². Indicador estándar de la OMS.',
    long: 'Propuesto por Adolphe Quetelet (1832), estandarizado por la OMS. Clasifica: <18.5 bajo peso, 18.5-24.9 normal, 25-29.9 sobrepeso, 30+ obesidad. NO distingue músculo de grasa.',
    category: 'salud',
    related: ['calculadora-imc'],
  },
  {
    term: 'BMR (Tasa Metabólica Basal)',
    short: 'Calorías que tu cuerpo gasta en reposo absoluto en 24 horas.',
    long: 'Mide el costo energético de mantener funciones vitales (respiración, circulación, digestión). Fórmula estándar: Mifflin-St Jeor (1990). Es la base para calcular calorías totales (TDEE).',
    category: 'salud',
    related: ['calculadora-calorias-diarias-tdee'],
  },
  {
    term: 'TDEE (Total Daily Energy Expenditure)',
    short: 'BMR × factor de actividad. Calorías totales que gastás por día.',
    long: 'Multiplica BMR por un factor: 1.2 (sedentario), 1.375 (actividad ligera), 1.55 (moderada), 1.725 (intensa), 1.9 (atleta). Es lo que necesitás para mantener peso. Para bajar, restar 300-500 kcal/día.',
    category: 'salud',
    related: ['calculadora-calorias-diarias-tdee'],
  },
  {
    term: 'FUM (Fecha de Última Menstruación)',
    short: 'Punto de partida para datar un embarazo según regla de Naegele.',
    long: 'FPP (Fecha Probable de Parto) = FUM + 280 días (40 semanas). Asume ciclos regulares de 28 días con ovulación al día 14. Para ciclos irregulares, la ecografía del primer trimestre es más precisa.',
    category: 'salud',
    related: ['calculadora-embarazo'],
  },
  {
    term: 'Naegele (regla de)',
    short: 'Fórmula obstétrica para estimar fecha de parto.',
    long: 'Propuesta por Franz Karl Naegele (1830). FPP = FUM + 1 año − 3 meses + 7 días. Equivale a sumar 280 días. Estándar histórico, pero la ecografía del primer trimestre es más confiable.',
    category: 'salud',
    related: ['calculadora-embarazo'],
  },
  {
    term: 'Mifflin-St Jeor',
    short: 'Fórmula moderna para BMR — más precisa que Harris-Benedict.',
    long: 'Hombres: 10×peso + 6.25×altura − 5×edad + 5. Mujeres: 10×peso + 6.25×altura − 5×edad − 161. Validada en 1990, es referencia en nutrición clínica desde entonces.',
    category: 'salud',
    related: ['calculadora-calorias-diarias-tdee'],
  },
  {
    term: 'Tanaka (fórmula de)',
    short: 'Frecuencia cardíaca máxima = 208 − (0.7 × edad).',
    long: 'Publicada por Tanaka, Monahan y Seals en 2001 (Journal of the American College of Cardiology). Más precisa que la vieja "220 − edad", especialmente en mayores de 40 años.',
    category: 'salud',
  },

  // DEPORTES
  {
    term: 'Pace',
    short: 'Tiempo en correr 1 km. La métrica universal del running.',
    long: 'Pace = tiempo total / distancia. Si corrés 10 km en 50 minutos, tu pace es 5:00 min/km. Más bajo = más rápido. Es lo opuesto a velocidad (km/h).',
    category: 'deportes',
    related: ['calculadora-pace-ritmo-running'],
  },
  {
    term: '1RM (One Rep Max)',
    short: 'Peso máximo que podés levantar en UNA repetición.',
    long: 'Referencia universal en fuerza. Se estima sin levantarlo realmente con la fórmula de Brzycki: 1RM = peso × (36 / (37 − reps)). Funciona bien con 2-10 reps.',
    category: 'deportes',
    related: ['calculadora-1rm-peso-maximo-levantamiento'],
  },
  {
    term: 'VO2 max',
    short: 'Cantidad máxima de oxígeno que tu cuerpo usa por minuto en ejercicio.',
    long: 'Medido en ml/kg/min. Excelente >48 (varón joven), 40-48 bueno. Atletas elite alcanzan 70+. Se estima con test de Cooper (12 min de carrera) o Rockport (1 milla caminata).',
    category: 'deportes',
  },
  {
    term: 'Riegel (fórmula de)',
    short: 'Predicción de tiempo en distancias diferentes a las entrenadas.',
    long: 'T2 = T1 × (D2/D1)^1.06. Si corrés 10K en 50 min, tu maratón estimado es 50 × (42.195/10)^1.06 ≈ 4h. Precisión ±5% si entrenaste consistentemente.',
    category: 'deportes',
  },

  // NEGOCIOS / MARKETING
  {
    term: 'Margen bruto',
    short: '(Ingresos − COGS) / Ingresos × 100. La rentabilidad del producto.',
    long: 'Mide cuánto te queda después de pagar el costo directo de producir/vender. >40% es saludable en retail; >70% típico en SaaS. Margen bruto bajo limita lo que podés gastar en marketing y operación.',
    category: 'negocios',
    related: ['calculadora-margen-ganancia-markup'],
  },
  {
    term: 'Break-even (punto de equilibrio)',
    short: 'Cuántas unidades tenés que vender para no perder ni ganar.',
    long: 'Costos fijos / (precio unitario − costo variable unitario). Si tus costos fijos son $2M y tu margen variable es $6k, tu break-even es 334 unidades/mes. Bajo de eso, perdés plata.',
    category: 'negocios',
    related: ['calculadora-punto-equilibrio-break-even'],
  },
  {
    term: 'CAC (Costo de Adquisición de Cliente)',
    short: 'Plata gastada en marketing dividida por clientes nuevos del período.',
    long: 'Métrica clave en SaaS y e-commerce. Si gastás $300k en marketing y conseguís 100 clientes, tu CAC es $3k. Idealmente, LTV/CAC > 3. Si tu CAC es mayor que tu LTV, tenés un problema serio.',
    category: 'negocios',
    related: ['calculadora-cac-ltv-costo-adquisicion-cliente'],
  },
  {
    term: 'LTV (Lifetime Value)',
    short: 'Plata total que un cliente te genera en toda su relación con vos.',
    long: 'En SaaS: ARPU / churn mensual. Si un cliente paga $5k/mes y churn es 5%, su LTV es $100k. Compará siempre con CAC: si LTV/CAC < 3, no escalás.',
    category: 'negocios',
    related: ['calculadora-cac-ltv-costo-adquisicion-cliente'],
  },
  {
    term: 'Churn (rate)',
    short: 'Porcentaje de clientes que se dan de baja en un período.',
    long: 'Si empezás con 100 clientes y pierdes 5 en el mes, tu churn mensual es 5%. SMB SaaS aceptable: <5-7%. Mid-market: <2-3%. Enterprise: <1%. Churn anual >30% indica problemas de PMF.',
    category: 'negocios',
  },
  {
    term: 'CTR (Click-Through Rate)',
    short: 'Clicks / impresiones × 100. Mide la atracción de un anuncio o link.',
    long: 'Google Ads search promedio: 3-5%. Display: 0.05-0.5%. Email: 2-5%. SEO orgánico posición 1: 30-40%. Un CTR bajo indica que el copy o creative no resuena.',
    category: 'marketing',
    related: ['calculadora-ctr-click-through-rate'],
  },
  {
    term: 'ROAS (Return on Ad Spend)',
    short: 'Ingresos generados / plata gastada en publicidad.',
    long: 'Si gastás $100k en ads y vendés $500k, tu ROAS es 5x. ROAS saludable depende del margen: con margen 30% necesitás ROAS >3.3 para break-even publicitario. Para crecer rentablemente, apuntar a ROAS 4x+.',
    category: 'marketing',
    related: ['calculadora-roas-retorno-inversion-publicitaria'],
  },
  {
    term: 'IVA (Impuesto al Valor Agregado)',
    short: 'Impuesto al consumo del 21% en Argentina (alícuota general).',
    long: 'Hay alícuota reducida (10.5%) para ciertos productos básicos y aumentada (27%) para servicios públicos a inscriptos. Se calcula sobre el precio neto: precio final = neto × 1.21.',
    category: 'negocios',
    related: ['calculadora-iva-agregar-discriminar'],
  },

  // OTROS
  {
    term: 'AFIP / ARCA',
    short: 'Organismo recaudador de impuestos de Argentina (ex-AFIP, hoy ARCA).',
    long: 'Administración Federal de Ingresos Públicos (AFIP) fue renombrada Agencia de Recaudación y Control Aduanero (ARCA) en 2024. Es la autoridad para Ganancias, Monotributo, IVA y operaciones aduaneras.',
    category: 'finanzas',
  },
  {
    term: 'BCRA',
    short: 'Banco Central de la República Argentina.',
    long: 'Autoridad monetaria. Publica las tasas de referencia (TNA mínima de plazo fijo, tasa de política monetaria), regula a los bancos, y mantiene las reservas internacionales.',
    category: 'finanzas',
  },
];

// Ordenar alfabéticamente
terms.sort((a, b) => a.term.localeCompare(b.term, 'es'));

// Calcs lookup
const calcModules = import.meta.glob<any>('../content/calcs/*.json', { eager: true });
const allCalcs = Object.values(calcModules).map((m: any) => m.default || m);
function findCalc(slug: string) {
  return allCalcs.find((c: any) => c.slug === slug);
}

const today = new Date().toLocaleDateString('es-AR', { day: '2-digit', month: 'long', year: 'numeric' });

// Schema.org DefinedTermSet
const schema = {
  '@context': 'https://schema.org',
  '@type': 'DefinedTermSet',
  name: 'Glosario financiero, de salud y negocios',
  description: 'Definiciones de términos clave usados en las calculadoras de Hacé Cuentas.',
  inLanguage: 'es-AR',
  hasDefinedTerm: terms.map((t) => ({
    '@type': 'DefinedTerm',
    name: t.term,
    description: t.long,
    inDefinedTermSet: 'https://hacecuentas.com/glosario',
  })),
};
---

<Layout
  title="Glosario — Términos financieros, de salud y negocios | Hacé Cuentas"
  description="Glosario de términos clave usados en las calculadoras: SAC, IMC, BMR, TNA, CFT, ROAS, LTV y muchos más. Definiciones cortas con fuente y ejemplo."
  schema={schema}
>
  <Header slot="header" />

  <article class="glosario">
    <nav class="breadcrumbs" aria-label="Ruta de navegación">
      <a href="/">Inicio</a>
      <span class="sep" aria-hidden="true">/</span>
      <span class="current">Glosario</span>
    </nav>

    <header class="g-header">
      <span class="eyebrow">Glosario</span>
      <h1>Términos financieros, de salud y negocios</h1>
      <p class="lead">
        Definiciones cortas y verificables de los conceptos que usamos en nuestras calculadoras.
        {terms.length} términos ordenados alfabéticamente.
      </p>
      <p class="date">Actualizado al {today}</p>
    </header>

    <div class="g-toolbar">
      <label class="search-wrap" for="g-filter">
        <svg class="s-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
        </svg>
        <input type="search" id="g-filter" placeholder={`Filtrar entre ${terms.length} términos…`} autocomplete="off" />
      </label>
    </div>

    <dl class="g-list" id="g-list">
      {terms.map((t) => (
        <div class="g-item" data-name={(t.term + ' ' + t.short + ' ' + t.long).toLowerCase()}>
          <dt>
            <span class="g-term">{t.term}</span>
            <span class="g-cat">{t.category}</span>
          </dt>
          <dd>
            <p class="g-short">{t.short}</p>
            <p class="g-long">{t.long}</p>
            {t.related && t.related.length > 0 && (
              <p class="g-related">
                <span class="g-related-label">Calculadoras:</span>
                {t.related.map((slug) => {
                  const c = findCalc(slug);
                  return c ? <a href={`/${slug}`}>{c.h1}</a> : null;
                })}
              </p>
            )}
          </dd>
        </div>
      ))}
    </dl>

    <p class="g-empty" id="g-empty" hidden>No encontramos términos que coincidan.</p>

    <script is:inline>
      (function () {
        var input = document.getElementById('g-filter');
        var list = document.getElementById('g-list');
        var empty = document.getElementById('g-empty');
        if (!input || !list) return;
        var items = Array.from(list.querySelectorAll('.g-item'));
        function norm(s) { return s.toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g, ''); }
        input.addEventListener('input', function () {
          var q = norm(input.value.trim());
          var visible = 0;
          items.forEach(function (el) {
            var hay = norm(el.dataset.name || '');
            var match = !q || hay.indexOf(q) !== -1;
            el.hidden = !match;
            if (match) visible++;
          });
          if (empty) empty.hidden = visible > 0;
        });
      })();
    </script>
  </article>

  <Footer slot="footer" />
</Layout>

<style>
  .glosario { max-width: 920px; margin: 0 auto; padding: 0 1rem; }
  .breadcrumbs {
    display: flex;
    gap: 0.5rem;
    font-size: 0.8125rem;
    color: var(--text-subtle);
    margin-bottom: 1.5rem;
  }
  .breadcrumbs a { color: var(--text-muted); text-decoration: none; }
  .breadcrumbs .sep { color: var(--border-strong); }
  .breadcrumbs .current { color: var(--text); font-weight: 500; }

  .g-header { margin-bottom: 1.5rem; }
  .eyebrow {
    display: inline-block;
    font-size: 0.6875rem;
    font-weight: 700;
    color: var(--accent);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 0.5rem;
  }
  .g-header h1 {
    margin: 0 0 0.5rem;
    font-size: clamp(1.625rem, 3.5vw, 2.125rem);
  }
  .lead {
    color: var(--text-muted);
    font-size: 1rem;
    line-height: 1.55;
    margin: 0 0 0.25rem;
  }
  .date {
    color: var(--text-subtle);
    font-size: 0.8125rem;
    margin: 0;
  }

  .g-toolbar { margin: 1.25rem 0; }
  .search-wrap {
    position: relative;
    display: flex;
    align-items: center;
    max-width: 480px;
  }
  .search-wrap .s-icon {
    position: absolute;
    left: 0.875rem;
    color: var(--text-subtle);
    pointer-events: none;
  }
  .search-wrap input {
    width: 100%;
    padding: 0.625rem 0.875rem 0.625rem 2.375rem;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    font-size: 0.9375rem;
    color: var(--text);
    font-family: inherit;
  }
  .search-wrap input:focus {
    outline: none;
    border-color: var(--accent);
    box-shadow: 0 0 0 3px var(--accent-soft);
  }

  .g-list {
    display: grid;
    gap: 1rem;
    margin: 0;
    padding: 0;
  }
  .g-item {
    padding: 1.125rem 1.25rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
  }
  .g-item dt {
    display: flex;
    align-items: baseline;
    gap: 0.625rem;
    margin-bottom: 0.375rem;
  }
  .g-term { font-weight: 700; color: var(--text); font-size: 1.0625rem; }
  .g-cat {
    display: inline-block;
    padding: 0.0625rem 0.5rem;
    background: var(--accent-soft);
    color: var(--accent-strong);
    border-radius: 999px;
    font-size: 0.6875rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    font-weight: 600;
  }
  .g-item dd { margin: 0; }
  .g-short {
    color: var(--text);
    font-size: 0.9375rem;
    margin: 0 0 0.5rem;
    line-height: 1.5;
    font-weight: 500;
  }
  .g-long {
    color: var(--text-muted);
    font-size: 0.9375rem;
    line-height: 1.65;
    margin: 0 0 0.625rem;
  }
  .g-related {
    margin: 0;
    font-size: 0.8125rem;
    color: var(--text-subtle);
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    align-items: center;
  }
  .g-related-label { font-weight: 600; }
  .g-related a {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .g-empty {
    margin: 1.5rem 0;
    padding: 1.25rem;
    background: var(--bg-soft);
    border: 1px dashed var(--border);
    border-radius: var(--radius);
    color: var(--text-muted);
    text-align: center;
  }
</style>
