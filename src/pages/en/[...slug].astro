---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Calculator from '../../components/Calculator.astro';
import RelatedCalcs from '../../components/RelatedCalcs.astro';
import ScrollToTop from '../../components/ScrollToTop.astro';
import { md, mdInline } from '../../lib/markdown';

export async function getStaticPaths() {
  const calcs = import.meta.glob<any>('../../content/calcs-en/*.json', { eager: true });
  return Object.values(calcs).map((mod: any) => {
    const c = mod.default || mod;
    return {
      params: { slug: c.slug },
      props: { calc: c },
    };
  });
}

const { calc } = Astro.props;

const categoryLabels: Record<string, string> = {
  finanzas: 'Finance',
  negocios: 'Business',
  negocio: 'Business',
  salud: 'Health',
  marketing: 'Marketing',
  deportes: 'Sports',
  viajes: 'Travel',
  vida: 'Daily Life',
  mascotas: 'Pets',
  matematica: 'Math',
  construccion: 'Construction',
  cocina: 'Cooking',
  educacion: 'Education',
  automotor: 'Automotive',
  tecnologia: 'Technology',
  'medio-ambiente': 'Environment',
  electronica: 'Electronics',
};

// dateModified = lastReviewed from JSON > mtime > build date
let dateModified: string;
let lastReviewedLabel: string;
// OG image: if /public/og/{slug}.png exists use it, else fallback to default
let ogImage = '/og-default.png';
try {
  const { statSync, existsSync } = await import('node:fs');
  const { join } = await import('node:path');
  const cwd = process.cwd();
  const filePath = join(cwd, 'src', 'content', 'calcs-en', `${calc.formulaId || calc.slug}.json`);
  const ogPath = join(cwd, 'public', 'og', `${calc.slug}.png`);
  if (existsSync(ogPath)) ogImage = `/og/${calc.slug}.png`;
  if (calc.lastReviewed && /^\d{4}-\d{2}-\d{2}$/.test(calc.lastReviewed)) {
    dateModified = new Date(calc.lastReviewed + 'T00:00:00Z').toISOString();
  } else {
    dateModified = statSync(filePath).mtime.toISOString();
  }
} catch {
  dateModified = new Date().toISOString();
}
lastReviewedLabel = new Date(dateModified).toLocaleDateString('en-US', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});
const datePublished = '2025-09-01T00:00:00Z';

// audience: 'AR' = Argentina-specific; 'global' (default) = worldwide
const audience: 'AR' | 'global' = calc.audience === 'AR' ? 'AR' : 'global';

const schemaHowTo = {
  '@context': 'https://schema.org',
  '@type': 'HowTo',
  name: calc.h1,
  description: calc.description,
  totalTime: 'PT1M',
  inLanguage: 'en',
  step: calc.fields.map((f: any, i: number) => ({
    '@type': 'HowToStep',
    position: i + 1,
    name: f.label,
    text: f.help || `Enter ${f.label.toLowerCase()}`,
  })),
};

const schemaFAQ = calc.faq && calc.faq.length > 0 ? {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: calc.faq.map((f: any) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: {
      '@type': 'Answer',
      text: f.a,
    },
  })),
} : null;

const schemaBreadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://hacecuentas.com/en/' },
    { '@type': 'ListItem', position: 2, name: categoryLabels[calc.category] || calc.category, item: 'https://hacecuentas.com/en/' },
    { '@type': 'ListItem', position: 3, name: calc.h1 },
  ],
};

// SoftwareApplication + WebApplication
const schemaApp = {
  '@context': 'https://schema.org',
  '@type': ['SoftwareApplication', 'WebApplication'],
  name: calc.h1,
  description: calc.description,
  url: `https://hacecuentas.com/en/${calc.slug}`,
  mainEntityOfPage: `https://hacecuentas.com/en/${calc.slug}`,
  applicationCategory: 'UtilitiesApplication',
  applicationSubCategory: 'Calculator',
  operatingSystem: 'Any (Web)',
  browserRequirements: 'Requires JavaScript. Requires HTML5.',
  inLanguage: 'en',
  isAccessibleForFree: true,
  datePublished,
  dateModified,
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
  publisher: {
    '@type': 'Organization',
    name: 'Hacé Cuentas',
    url: 'https://hacecuentas.com',
  },
};

// Article schema for YMYL categories
const isYMYL = ['finanzas', 'salud', 'negocios', 'mascotas'].includes(calc.category);
const schemaArticle = (isYMYL || (calc.explanation && calc.explanation.length > 1500)) ? {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: calc.h1,
  description: calc.description,
  url: `https://hacecuentas.com/en/${calc.slug}`,
  mainEntityOfPage: `https://hacecuentas.com/en/${calc.slug}`,
  inLanguage: 'en',
  datePublished,
  dateModified,
  author: {
    '@type': 'Organization',
    name: 'Hacé Cuentas Team',
    url: 'https://hacecuentas.com/politica-editorial',
  },
  publisher: {
    '@type': 'Organization',
    name: 'Hacé Cuentas',
    url: 'https://hacecuentas.com',
    logo: {
      '@type': 'ImageObject',
      url: 'https://hacecuentas.com/og-default.png',
    },
  },
  about: categoryLabels[calc.category] || calc.category,
  isAccessibleForFree: true,
  citation: calc.sources?.map((s: any) => s.url || s.name).filter(Boolean) || [],
} : null;

const schemaGraph: any[] = [schemaHowTo, schemaBreadcrumb, schemaApp];
if (schemaFAQ) schemaGraph.push(schemaFAQ);
if (schemaArticle) schemaGraph.push(schemaArticle);
const schema = { '@context': 'https://schema.org', '@graph': schemaGraph };

const updated = lastReviewedLabel;

// Reading time: ~250 words/minute in English
const wordCount = calc.explanation ? calc.explanation.split(/\s+/).length : 0;
const readingMin = Math.max(1, Math.round(wordCount / 250));

// Optional SEO fields
const sources: Array<{ name: string; url?: string }> = calc.sources || [];
const useCases: string[] = calc.useCases || [];
const example: { title?: string; steps?: string[]; result?: string } | null = calc.example || null;
const keyTakeaway: string = calc.keyTakeaway || '';
const relatedSlugs: string[] = calc.relatedSlugs || [];

// Lookup for related links — load English calcs
const allCalcsModules = import.meta.glob<any>('../../content/calcs-en/*.json', { eager: true });
const allCalcs = Object.values(allCalcsModules).map((m: any) => m.default || m);
const relatedContextual = relatedSlugs
  .map((s) => allCalcs.find((c) => c.slug === s))
  .filter(Boolean);

// TOC: top-level rendered sections (in order of appearance)
const tocSections: Array<{ id: string; label: string }> = [
  { id: 'calculator', label: 'Calculator' },
];
if (keyTakeaway) tocSections.push({ id: 'summary', label: 'In a nutshell' });
if (useCases.length > 0) tocSections.push({ id: 'when-to-use', label: 'When to use' });
if (example && example.steps) tocSections.push({ id: 'example', label: 'Step-by-step example' });
if (calc.explanation) tocSections.push({ id: 'how-it-works', label: 'How it works' });
if (calc.faq && calc.faq.length > 0) tocSections.push({ id: 'faq', label: 'FAQ' });
if (sources.length > 0) tocSections.push({ id: 'sources', label: 'Sources' });

// Heuristic LaTeX detection in explanation (to conditionally load KaTeX)
const hasMath = calc.explanation && /(\$[^$\n]+\$|\\frac|\\sqrt|\\sum|\\times|\\cdot)/.test(calc.explanation);

// Pre-filled subject for "Report error"
const reportSubject = encodeURIComponent(`Error in /en/${calc.slug}`);
const reportBody = encodeURIComponent(
  `Hi Hacé Cuentas Team,\n\nI found an error in the calculator "${calc.h1}":\n\nURL: https://hacecuentas.com/en/${calc.slug}\nInput data: \nExpected result: \nActual result: \nSource / reference: \n\nThank you.`
);

// hreflang: link to Spanish equivalent via esSlug
const esSlug = calc.esSlug;
const hreflangTags = esSlug ? [
  { lang: 'es', href: `https://hacecuentas.com/${esSlug}` },
  { lang: 'en', href: `https://hacecuentas.com/en/${calc.slug}` },
  { lang: 'x-default', href: `https://hacecuentas.com/${esSlug}` },
] : undefined;
---

<Layout
  title={calc.title}
  description={calc.description}
  schema={schema}
  audience={audience}
  image={ogImage}
  lang="en"
  hreflang={hreflangTags}
>
  <Header slot="header" lang="en" />

  <article class="calc-page">
    <nav class="breadcrumbs" aria-label="Breadcrumb">
      <a href="/en/">Home</a>
      <span class="sep" aria-hidden="true">/</span>
      <span>{categoryLabels[calc.category] || calc.category}</span>
      <span class="sep" aria-hidden="true">/</span>
      <span class="current">{calc.h1}</span>
    </nav>

    <header class="calc-header">
      <div class="header-left">
        <span class="icon-wrap" aria-hidden="true">{calc.icon}</span>
        <div>
          <div class="eyebrow">{categoryLabels[calc.category] || calc.category}</div>
          <h1>{calc.h1}{audience === 'AR' && <span class="ar-badge-h1" title="Argentina-specific" aria-label="Argentina-specific">🇦🇷</span>}</h1>
        </div>
      </div>
    </header>

    <div class="calc-layout">
      {tocSections.length > 2 && (
        <aside class="toc" aria-label="Table of contents">
          <div class="toc-title">On this page</div>
          <ol class="toc-list">
            {tocSections.map((s) => (
              <li><a href={`#${s.id}`} data-toc-link={s.id}>{s.label}</a></li>
            ))}
          </ol>
        </aside>
      )}

      <div class="calc-main">
        <section id="calculator">
          <Calculator config={calc} lang="en" />
        </section>

        <div class="calc-actions" id="calc-actions">
          <div class="ca-feedback" data-state="ask">
            <span class="ca-q">Was this calculator helpful?</span>
            <div class="ca-buttons">
              <button type="button" class="ca-vote" data-vote="up" aria-label="Yes, it was helpful">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 10v12"/><path d="M15 5.88 14 10h5.83a2 2 0 0 1 1.92 2.56l-2.33 8A2 2 0 0 1 17.5 22H7"/></svg>
                Yes
              </button>
              <button type="button" class="ca-vote" data-vote="down" aria-label="Not helpful">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 14V2"/><path d="M9 18.12 10 14H4.17a2 2 0 0 1-1.92-2.56l2.33-8A2 2 0 0 1 6.5 2H17"/></svg>
                No
              </button>
            </div>
          </div>
          <div class="ca-tools">
            <button type="button" class="ca-tool" id="ca-share" data-url={`https://hacecuentas.com/en/${calc.slug}`} data-title={calc.h1}>
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/></svg>
              Share
            </button>
            <a class="ca-tool" href={`mailto:errores@hacecuentas.com?subject=${reportSubject}&body=${reportBody}`}>
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 15s1-1 4-1 5 2 8 2 4-1 4-1V3s-1 1-4 1-5-2-8-2-4 1-4 1z"/><line x1="4" y1="22" x2="4" y2="15"/></svg>
              Report error
            </a>
          </div>
        </div>

        <p class="intro" set:html={mdInline(calc.intro)}></p>

        {audience === 'AR' && (
          <aside class="audience-notice" role="note" aria-label="Audience notice for this calculator">
            <span class="an-flag" aria-hidden="true">🇦🇷</span>
            <div class="an-body">
              <strong>Argentina-specific calculator.</strong>
              The laws, tax brackets, and values used are those in effect in Argentina (AFIP/ARCA, BCRA, ANSES). They do not apply to other countries.
            </div>
          </aside>
        )}

        <div class="meta">
          <span class="meta-item" title={`Last reviewed: ${updated} · Hacé Cuentas Team`}>
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            Last reviewed: <strong>{updated}</strong>
          </span>
          <span class="meta-item meta-reviewer">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
            Verified by <a href="/politica-editorial">Hacé Cuentas Team</a>
          </span>
          {sources.length > 0 && (
            <span class="meta-item">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>
              Source: {sources.map((s) => s.name).join(', ')}
            </span>
          )}
          {sources.length === 0 && (
            <span class="meta-item">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
              Formula explained
            </span>
          )}
          <span class="meta-item">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            100% private
          </span>
        </div>

        {keyTakeaway && (
          <aside id="summary" class="key-takeaway" aria-label="Quick summary">
            <div class="kt-icon" aria-hidden="true">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>
            </div>
            <div><strong>In a nutshell:</strong> <span set:html={md(keyTakeaway)} /></div>
          </aside>
        )}

        {useCases.length > 0 && (
          <section id="when-to-use" class="use-cases" aria-labelledby="use-cases-heading">
            <h2 id="use-cases-heading">When to use this calculator</h2>
            <ul>
              {useCases.map((u: string) => (
                <li set:html={md(u)} />
              ))}
            </ul>
          </section>
        )}

        {example && example.steps && (
          <section id="example" class="example" aria-labelledby="example-heading">
            <h2 id="example-heading">{example.title || 'Step-by-step example'}</h2>
            <ol class="example-steps">
              {example.steps.map((s: string) => <li set:html={md(s)} />)}
            </ol>
            {example.result && (
              <div class="example-result"><strong>Result:</strong> <span set:html={md(example.result)} /></div>
            )}
          </section>
        )}

        {calc.explanation && (
          <section id="how-it-works" class="explanation" data-has-math={hasMath ? 'true' : 'false'}>
            <div class="explanation-header">
              <h2 class="explanation-title">How it works</h2>
              <span class="reading-time">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>
                {readingMin} min read
              </span>
            </div>
            <Fragment set:html={`<p>${md(calc.explanation)}</p>`} />
          </section>
        )}

        {calc.faq && calc.faq.length > 0 && (
          <section id="faq" class="faq">
            <h2>Frequently asked questions</h2>
            <div class="faq-list">
              {calc.faq.map((f: any) => (
                <details>
                  <summary>
                    <span>{f.q}</span>
                    <svg class="chev" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
                  </summary>
                  <div set:html={`<p>${md(f.a)}</p>`} />
                </details>
              ))}
            </div>
          </section>
        )}

        {sources.length > 0 && (
          <section id="sources" class="sources-box" aria-labelledby="sources-heading">
            <h2 id="sources-heading">Sources and references</h2>
            <ul>
              {sources.map((s: any) => (
                <li>
                  {s.url
                    ? <a href={s.url} target="_blank" rel="noopener nofollow">{s.name}</a>
                    : <span>{s.name}</span>
                  }
                </li>
              ))}
            </ul>
          </section>
        )}

        {relatedContextual.length > 0 && (
          <section class="also-see" aria-labelledby="also-heading">
            <h2 id="also-heading">You may also find useful</h2>
            <div class="also-grid">
              {relatedContextual.map((c: any) => (
                <a href={`/en/${c.slug}`} class="also-card">
                  <span class="also-icon" aria-hidden="true">{c.icon}</span>
                  <span class="also-body">
                    <span class="also-title">{c.h1}</span>
                    <span class="also-desc">{c.description}</span>
                  </span>
                </a>
              ))}
            </div>
          </section>
        )}

        <RelatedCalcs currentSlug={calc.slug} category={calc.category} limit={4} manualSlugs={relatedSlugs} />

        <aside class="cta-back">
          <p>Looking for a different calculator?</p>
          <a href="/en/" class="btn-ghost">See all calculators &rarr;</a>
          <p class="cta-suggest">Can't find what you need? <a href="mailto:ideas@hacecuentas.com?subject=Calculator idea&body=I'd like Hacé Cuentas to have a calculator for...">Request a new calculator &rarr;</a></p>
        </aside>
      </div>
    </div>
  </article>

  {hasMath && (
    <Fragment>
      <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.11/dist/katex.min.css" integrity="sha384-nB0miv6/jRmo5UMMR1wu3Gz6NLsoTkbqJghGIsx//Rlm+ZU03BU6SQNC66uf4l5+" crossorigin="anonymous" />
      <script defer src="https://cdn.jsdelivr.net/npm/katex@0.16.11/dist/katex.min.js" integrity="sha384-7zkQWkzuo3B5mTepMUcHkMB5jZaolc2xDwL6VFqjFALcbeS9Ggm/Yr2r3Dy4lfFg" crossorigin="anonymous"></script>
      <script defer src="https://cdn.jsdelivr.net/npm/katex@0.16.11/dist/contrib/auto-render.min.js" integrity="sha384-43gviWU0YVjaDtb/GhzOouOXtZMP/7XUzwPTstBeZFe/+rCMvRwr4yROQP43s0Xk" crossorigin="anonymous" onload="renderMathInElement(document.querySelector('#how-it-works'), {delimiters:[{left:'$$',right:'$$',display:true},{left:'$',right:'$',display:false},{left:'\\\\(',right:'\\\\)',display:false},{left:'\\\\[',right:'\\\\]',display:true}], throwOnError:false});"></script>
    </Fragment>
  )}

  <script is:inline>
    (function () {
      // Thumbs feedback
      var feedback = document.querySelector('.ca-feedback');
      if (feedback) {
        var slug = window.location.pathname;
        var key = 'hc-vote-' + slug;
        var prev = null;
        try { prev = localStorage.getItem(key); } catch (e) {}
        if (prev === 'up' || prev === 'down') {
          renderThanks(prev);
        }
        feedback.querySelectorAll('.ca-vote').forEach(function (btn) {
          btn.addEventListener('click', function () {
            var v = btn.getAttribute('data-vote');
            try { localStorage.setItem(key, v); } catch (e) {}
            renderThanks(v);
            if (typeof window.gtag === 'function') {
              window.gtag('event', 'calc_feedback', { value: v, slug: slug });
            }
          });
        });
        function renderThanks(v) {
          if (v === 'up') {
            feedback.setAttribute('data-state', 'thanks');
            feedback.innerHTML = '<span class="ca-msg">Thanks for your feedback!</span>';
          } else {
            feedback.setAttribute('data-state', 'sorry');
            feedback.innerHTML = '<span class="ca-msg">Thanks. What\'s missing or wrong? <a href="mailto:errores@hacecuentas.com?subject=Improvement for ' + encodeURIComponent(slug) + '">Let us know by email</a>.</span>';
          }
        }
      }

      // Share
      var shareBtn = document.getElementById('ca-share');
      if (shareBtn) {
        shareBtn.addEventListener('click', async function () {
          var url = shareBtn.getAttribute('data-url');
          var title = shareBtn.getAttribute('data-title');
          if (navigator.share) {
            try { await navigator.share({ title: title, url: url }); } catch (e) {}
          } else if (navigator.clipboard) {
            try {
              await navigator.clipboard.writeText(url);
              var orig = shareBtn.innerHTML;
              shareBtn.innerHTML = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg> Copied!';
              setTimeout(function () { shareBtn.innerHTML = orig; }, 2000);
            } catch (e) {}
          }
        });
      }

      // TOC scrollspy
      var tocLinks = document.querySelectorAll('[data-toc-link]');
      if (tocLinks.length > 0 && 'IntersectionObserver' in window) {
        var sections = Array.from(tocLinks).map(function (l) {
          return document.getElementById(l.getAttribute('data-toc-link'));
        }).filter(Boolean);
        var observer = new IntersectionObserver(function (entries) {
          entries.forEach(function (entry) {
            if (entry.isIntersecting) {
              tocLinks.forEach(function (l) { l.classList.remove('active'); });
              var match = document.querySelector('[data-toc-link="' + entry.target.id + '"]');
              if (match) match.classList.add('active');
            }
          });
        }, { rootMargin: '-80px 0px -60% 0px' });
        sections.forEach(function (s) { observer.observe(s); });
      }

      // Floating recalculate FAB (mobile only)
      var fab = document.getElementById('fab-recalc');
      if (fab && window.innerWidth < 1100) {
        var calcSection = document.getElementById('calculator');
        if (calcSection) {
          var resultsEl = calcSection.querySelector('.calc-results');
          var calcObs = new IntersectionObserver(function (entries) {
