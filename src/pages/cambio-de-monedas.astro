  let STATE: FxState = { arsPerUnit: {}, intlPerUsd: {}, intlNames: INTL_NAMES, updatedAt: 0 };

  // ==========================================================
  //  LOAD DATA
  // ==========================================================
  async function load(force = false) {
    if (force) clearCache();
    setStatus('loading', 'Cargando cotizaciones…');
    try {
      const [dolares, otras, intl] = await Promise.all([fetchArDolares(), fetchArOtras(), fetchIntl()]);

      const ars: FxState['arsPerUnit'] = {};
      for (const d of dolares) {
        const key = `USD_${d.casa.toUpperCase().replace('CONTADOCONLIQUI','CCL').replace('TURISTA','TARJETA')}`;
        const k = key in COIN_LABELS ? key : `USD_${d.casa.toUpperCase()}`;
        ars[k] = { ...COIN_LABELS[k] || { label: d.nombre, flag: '🇦🇷' }, venta: d.venta, compra: d.compra, casa: d.casa };
      }
      for (const o of otras) {
        const ok = `${o.moneda}_AR`;
        if (COIN_LABELS[ok]) ars[ok] = { ...COIN_LABELS[ok], venta: o.venta, compra: o.compra };
      }

      STATE = {
        arsPerUnit: ars,
        intlPerUsd: intl.rates,
        intlNames: INTL_NAMES,
        updatedAt: getCacheTs('fx_ar_dolares') || Date.now(),
      };

      renderAll();
      setStatus('ok', `Actualizado ${humanAgo(STATE.updatedAt)}`);
    } catch (e) {
      console.error(e);
      setStatus('err', '⚠️ No se pudo cargar. Reintentá.');
    }
  }

  function setStatus(kind: 'loading' | 'ok' | 'err', text: string) {
    const dot = document.getElementById('status-dot')!;
    dot.className = 'dot ' + (kind === 'ok' ? 'ok' : kind === 'err' ? 'err' : '');
    document.getElementById('status-text')!.textContent = text;
  }

  // ==========================================================
  //  RENDER: AR TABLE
  // ==========================================================
  const AR_BADGES: Record<string, string> = {
    USD_OFICIAL: 'oficial', USD_BLUE: 'blue', USD_MEP: 'mep', USD_CCL: 'ccl',
    USD_TARJETA: 'tarjeta', USD_CRIPTO: 'cripto', USD_MAYORISTA: 'mayo',
    EUR_AR: 'eur', BRL_AR: 'brl', CLP_AR: 'clp', UYU_AR: 'uyu',
  };

  function renderArTable() {
    const container = document.getElementById('ar-table')!;
    const order = ['USD_OFICIAL', 'USD_BLUE', 'USD_MEP', 'USD_CCL', 'USD_TARJETA', 'USD_CRIPTO', 'USD_MAYORISTA', 'EUR_AR', 'BRL_AR', 'CLP_AR', 'UYU_AR'];
    const rows: string[] = [];
    for (const k of order) {
      const q = STATE.arsPerUnit[k];
      if (!q) continue;
      const spread = q.compra && q.venta && q.compra > 0 ? ((q.venta - q.compra) / q.compra * 100) : null;
      const badgeClass = AR_BADGES[k] ? `badge-${AR_BADGES[k]}` : '';
      const badgeText = q.label.replace(/^USD /, '').replace(/\s*\(.*\)$/, '');
      const isDolar = k.startsWith('USD_');
      rows.push(`
        <div class="rate-row">
          <div class="nom-wrap">
            <span class="nom">${q.flag} ${isDolar ? 'Dólar' : q.label.replace(/\s*\(.*\)$/, '')}<span class="badge ${badgeClass}">${isDolar ? badgeText : '1 unidad'}</span></span>
            <span class="sub">${q.casa ? 'dolarapi · casa ' + q.casa : 'vs peso argentino'}</span>
          </div>
          <div class="cp">${q.compra ? fmtArs(q.compra) : '—'}</div>
          <div class="val">${fmtArs(q.venta)}</div>
          <div class="var">${spread !== null ? `${spread.toFixed(1)}%` : '—'}</div>
        </div>
      `);
    }
    container.innerHTML = rows.join('') || '<div class="loading">Sin datos</div>';

    // Brecha
    const oficial = STATE.arsPerUnit['USD_OFICIAL']?.venta;
    const blue = STATE.arsPerUnit['USD_BLUE']?.venta;
    const box = document.getElementById('brecha-box')!;
    if (oficial && blue && oficial > 0) {
      const brecha = ((blue - oficial) / oficial * 100);
      const clima = brecha < 10 ? '🟢 baja (estabilidad)' : brecha < 30 ? '🟡 media (atención)' : '🔴 alta (tensión cambiaria)';
      box.style.display = '';
      box.innerHTML = `<div><strong>Brecha blue vs oficial:</strong> ${brecha.toFixed(1)}% · ${clima}</div>`;
    } else {
      box.style.display = 'none';
    }
  }

  // ==========================================================
  //  RENDER: INTL TABLE
  // ==========================================================
  let INTL_EXPANDED = false;
  let INTL_FILTER = '';

  function renderIntlTable() {
    const container = document.getElementById('intl-table')!;
    const countEl = document.getElementById('intl-count')!;
    const toggleBtn = document.getElementById('intl-toggle') as HTMLButtonElement;

    const allKeys = Object.keys(STATE.intlPerUsd).filter(k => k !== 'USD' && k !== 'ARS');
    countEl.textContent = allKeys.length.toString();

    // Filtrado
    const filter = INTL_FILTER.trim().toLowerCase();
    let visible: string[];
    if (filter) {
      visible = allKeys.filter(k => {
        const name = (INTL_NAMES[k] || k).toLowerCase();
        return k.toLowerCase().includes(filter) || name.includes(filter);
      });
    } else if (INTL_EXPANDED) {
      visible = allKeys.slice().sort((a, b) => (INTL_NAMES[a] || a).localeCompare(INTL_NAMES[b] || b, 'es'));
    } else {
      visible = INTL_TOP.filter(k => STATE.intlPerUsd[k]);
    }

    const rows: string[] = [];
    for (const sym of visible) {
      const rate = STATE.intlPerUsd[sym];
      if (!rate) continue;
      const inv = 1 / rate;
      const name = INTL_NAMES[sym] || sym;
      rows.push(`
        <div class="rate-row">
          <div class="nom-wrap">
            <span class="nom">${name}</span>
            <span class="sub">ISO ${sym}</span>
          </div>
          <div></div>
          <div class="val">${fmtNum(rate, 4)} ${sym}</div>
          <div class="var">${fmtNum(inv, 6)} USD</div>
        </div>
      `);
    }
    container.innerHTML = rows.join('') || '<div class="loading">Sin resultados</div>';

    if (filter) {
      toggleBtn.style.display = 'none';
    } else {
      toggleBtn.style.display = '';
      toggleBtn.textContent = INTL_EXPANDED ? '← Ver solo las 15 más populares' : `Ver las ${allKeys.length} monedas →`;
    }
  }

  // ==========================================================
  //  CONVERTER
  // ==========================================================
  function populateSelects() {
    const selects = [document.getElementById('from-currency'), document.getElementById('to-currency')] as HTMLSelectElement[];
    const optGroups: string[] = [];

    // AR group
    const arKeys = ['USD_OFICIAL','USD_BLUE','USD_MEP','USD_CCL','USD_TARJETA','USD_CRIPTO','USD_MAYORISTA','EUR_AR','BRL_AR','CLP_AR','UYU_AR'].filter(k => STATE.arsPerUnit[k]);
    if (arKeys.length) {
      const items = arKeys.map(k => `<option value="${k}">${STATE.arsPerUnit[k].flag} ${STATE.arsPerUnit[k].label}</option>`).join('');
      optGroups.push(`<optgroup label="🇦🇷 Argentina (vs ARS)">${items}</optgroup>`);
    }

    // ARS base
    optGroups.push(`<optgroup label="Peso argentino"><option value="ARS">🇦🇷 ARS (Peso argentino)</option></optgroup>`);

    // Intl group: TODAS las monedas que devuelva la API, ordenadas alfabéticamente
    const allIntl = Object.keys(STATE.intlPerUsd).filter(k => k !== 'ARS'); // ARS ya está en AR
    if (!allIntl.includes('USD')) allIntl.unshift('USD');
    allIntl.sort((a, b) => {
      // USD y top monedas primero
      const tops = ['USD', 'EUR', 'GBP', 'JPY', 'CNY', 'CHF', 'BRL', 'MXN'];
      const ai = tops.indexOf(a), bi = tops.indexOf(b);
      if (ai !== -1 && bi !== -1) return ai - bi;
      if (ai !== -1) return -1;
      if (bi !== -1) return 1;
      return (INTL_NAMES[a] || a).localeCompare(INTL_NAMES[b] || b, 'es');
    });
    const intlItems = allIntl.map(k => `<option value="INTL_${k}">${INTL_NAMES[k] || k + ' (' + k + ')'}</option>`).join('');
    optGroups.push(`<optgroup label="🌍 Internacional (${allIntl.length} monedas, base USD)">${intlItems}</optgroup>`);

    const html = optGroups.join('');
    const fromSaved = selects[0].value;
    const toSaved = selects[1].value;
    selects[0].innerHTML = html;
    selects[1].innerHTML = html;

    // Set defaults or restore
    selects[0].value = STATE.arsPerUnit[fromSaved] || fromSaved.startsWith('INTL_') || fromSaved === 'ARS' ? fromSaved : 'USD_BLUE';
    selects[1].value = STATE.arsPerUnit[toSaved] || toSaved.startsWith('INTL_') || toSaved === 'ARS' ? toSaved : 'ARS';
  }

  // Convert X units of "from" to "to"
  // Uses ARS as common pivot for AR-coins, and USD as pivot for intl.
  // Cross: if one is AR and other is INTL, goes AR → ARS → USD (oficial) → INTL.
  function convert(amount: number, from: string, to: string): { value: number; explain: string } | null {
    if (!amount || from === to) return { value: amount, explain: '1:1' };

    const oficialVenta = STATE.arsPerUnit['USD_OFICIAL']?.venta;
    const usdPerArs = oficialVenta ? 1 / oficialVenta : null;

    // Helper: convert ANY currency to USD amount
    const toUsd = (amt: number, sym: string): number | null => {
      if (sym === 'USD' || sym === 'INTL_USD') return amt;
      if (sym.startsWith('INTL_')) {
        const code = sym.replace('INTL_', '');
        const r = STATE.intlPerUsd[code];
        return r ? amt / r : null;
      }
      if (sym === 'ARS') return usdPerArs ? amt * usdPerArs : null;
      // AR coin (USD_BLUE etc) - venta = ARS per 1 unit
      const q = STATE.arsPerUnit[sym];
      if (!q) return null;
      if (sym.startsWith('USD_')) return amt; // is already USD (variant)
      // EUR_AR, BRL_AR, etc: 1 unit = q.venta ARS, convert to USD via oficial
      if (!usdPerArs) return null;
      return amt * q.venta * usdPerArs;
    };

    // Helper: convert USD amount to target
    const fromUsd = (usd: number, sym: string): number | null => {
      if (sym === 'USD' || sym === 'INTL_USD') return usd;
      if (sym.startsWith('INTL_')) {
        const code = sym.replace('INTL_', '');
        const r = STATE.intlPerUsd[code];
        return r ? usd * r : null;
      }
      if (sym === 'ARS') return oficialVenta ? usd * oficialVenta : null;
      if (sym.startsWith('USD_')) return usd; // USD variant = same units of USD
      const q = STATE.arsPerUnit[sym];
      if (!q || !usdPerArs) return null;
      return usd / (q.venta * usdPerArs);
    };

    // Special case: both AR-coins with ARS pivot (more accurate than USD pivot)
    const fromIsAr = from in STATE.arsPerUnit || from === 'ARS';
    const toIsAr = to in STATE.arsPerUnit || to === 'ARS';
    if (fromIsAr && toIsAr) {
      const arsFrom = from === 'ARS' ? amount : amount * STATE.arsPerUnit[from].venta;
      const result = to === 'ARS' ? arsFrom : arsFrom / STATE.arsPerUnit[to].venta;
      return { value: result, explain: `vía ARS` };
    }

    // Intl cross
    const usd = toUsd(amount, from);
    if (usd === null) return null;
    const result = fromUsd(usd, to);
    if (result === null) return null;
    return { value: result, explain: 'vía USD' };
  }

  function renderConverter() {
    const fromAmtEl = document.getElementById('from-amount') as HTMLInputElement;
    const toAmtEl = document.getElementById('to-amount') as HTMLInputElement;
    const fromEl = document.getElementById('from-currency') as HTMLSelectElement;
    const toEl = document.getElementById('to-currency') as HTMLSelectElement;
    const rateLine = document.getElementById('rate-line')!;

    const amount = parseAmount(fromAmtEl.value);
    const conv = convert(amount, fromEl.value, toEl.value);
    if (conv === null) {
      toAmtEl.value = '—';
      rateLine.textContent = 'Sin cotización disponible';
      return;
    }
    toAmtEl.value = fmtNum(conv.value, 4);
    const unit = convert(1, fromEl.value, toEl.value);
    if (unit) {
      const fromLabel = fromEl.options[fromEl.selectedIndex].text;
      const toLabel = toEl.options[toEl.selectedIndex].text;
      rateLine.textContent = `1 ${fromLabel} = ${fmtNum(unit.value, 6)} ${toLabel} (${conv.explain})`;
    }
  }

  function renderAll() {
    renderArTable();
    renderIntlTable();
    populateSelects();
    renderConverter();
  }

  // ==========================================================
  //  EVENTS
  // ==========================================================
  document.getElementById('from-amount')!.addEventListener('input', renderConverter);
  document.getElementById('from-currency')!.addEventListener('change', renderConverter);
  document.getElementById('to-currency')!.addEventListener('change', renderConverter);
  document.getElementById('swap')!.addEventListener('click', () => {
    const fromEl = document.getElementById('from-currency') as HTMLSelectElement;
    const toEl = document.getElementById('to-currency') as HTMLSelectElement;
    [fromEl.value, toEl.value] = [toEl.value, fromEl.value];
    renderConverter();
  });
  document.getElementById('refresh')!.addEventListener('click', () => load(true));
  document.getElementById('intl-toggle')!.addEventListener('click', () => {
    INTL_EXPANDED = !INTL_EXPANDED;
    renderIntlTable();
  });
  document.getElementById('intl-search')!.addEventListener('input', (e) => {
    INTL_FILTER = (e.target as HTMLInputElement).value;
    renderIntlTable();
  });

  // ==========================================================
  //  INIT
  // ==========================================================
  load(false);
</script>
