---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

// ─── Load all glossary terms from JSON content collection ───────────────────
const glosarioModules = import.meta.glob<any>('../../content/glosario/*.json', { eager: true });
const allGlosarioTerms = Object.values(glosarioModules).map((m: any) => m.default || m);

// ─── Legacy inline terms (those without individual pages yet) ───────────────
interface LegacyTerm {
  term: string;
  short: string;
  category: string;
  related?: string[];
}

const legacyOnlyTerms: LegacyTerm[] = [
  { term: 'LCT (Ley de Contrato de Trabajo)', short: 'Ley 20.744, marco general del empleo en relación de dependencia en Argentina.', category: 'finanzas', related: ['sueldo-en-mano-argentina', 'calculadora-indemnizacion-despido'] },
  { term: 'Vizzoti (fallo)', short: 'Tope a la indemnización por despido fijado por la Corte Suprema en 2004.', category: 'finanzas', related: ['calculadora-indemnizacion-despido'] },
  { term: 'CFT (Costo Financiero Total)', short: 'El "verdadero precio" de un préstamo: TNA + IVA + comisiones + seguros.', category: 'finanzas', related: ['calculadora-cuota-prestamo'] },
  { term: 'Sistema francés', short: 'Sistema de amortización con cuota fija en valor nominal.', category: 'finanzas', related: ['calculadora-cuota-prestamo'] },
  { term: 'Bienes Personales', short: 'Impuesto patrimonial anual sobre activos al 31 de diciembre.', category: 'finanzas' },
  { term: 'FUM (Fecha de Última Menstruación)', short: 'Punto de partida para datar un embarazo según regla de Naegele.', category: 'salud', related: ['calculadora-embarazo'] },
  { term: 'Naegele (regla de)', short: 'Fórmula obstétrica para estimar fecha de parto.', category: 'salud', related: ['calculadora-embarazo'] },
  { term: 'Mifflin-St Jeor', short: 'Fórmula moderna para BMR — más precisa que Harris-Benedict.', category: 'salud', related: ['calculadora-calorias-diarias-tdee'] },
  { term: 'Tanaka (fórmula de)', short: 'Frecuencia cardíaca máxima = 208 − (0.7 × edad).', category: 'salud' },
  { term: 'Pace', short: 'Tiempo en correr 1 km. La métrica universal del running.', category: 'deportes', related: ['calculadora-pace-ritmo-running'] },
  { term: '1RM (One Rep Max)', short: 'Peso máximo que podés levantar en UNA repetición.', category: 'deportes', related: ['calculadora-1rm-peso-maximo-levantamiento'] },
  { term: 'Riegel (fórmula de)', short: 'Predicción de tiempo en distancias diferentes a las entrenadas.', category: 'deportes' },
  { term: 'Margen bruto', short: '(Ingresos − COGS) / Ingresos × 100. La rentabilidad del producto.', category: 'negocios', related: ['calculadora-margen-ganancia-markup'] },
  { term: 'Break-even (punto de equilibrio)', short: 'Cuántas unidades tenés que vender para no perder ni ganar.', category: 'negocios', related: ['calculadora-punto-equilibrio-break-even'] },
  { term: 'CAC (Costo de Adquisición de Cliente)', short: 'Plata gastada en marketing dividida por clientes nuevos del período.', category: 'negocios', related: ['calculadora-cac-ltv-costo-adquisicion-cliente'] },
  { term: 'LTV (Lifetime Value)', short: 'Plata total que un cliente te genera en toda su relación con vos.', category: 'negocios', related: ['calculadora-cac-ltv-costo-adquisicion-cliente'] },
  { term: 'Churn (rate)', short: 'Porcentaje de clientes que se dan de baja en un período.', category: 'negocios' },
  { term: 'CTR (Click-Through Rate)', short: 'Clicks / impresiones × 100. Mide la atracción de un anuncio o link.', category: 'marketing', related: ['calculadora-ctr-click-through-rate'] },
  { term: 'ROAS (Return on Ad Spend)', short: 'Ingresos generados / plata gastada en publicidad.', category: 'marketing', related: ['calculadora-roas-retorno-inversion-publicitaria'] },
];

// ─── Build combined display list ────────────────────────────────────────────
interface DisplayTerm {
  term: string;
  short: string;
  category: string;
  slug?: string;
  related?: string[];
}

const jsonTerms: DisplayTerm[] = allGlosarioTerms.map((t: any) => ({
  term: t.term,
  short: t.shortDef,
  category: t.category,
  slug: t.slug,
  related: t.relatedCalcs || [],
}));

// Merge: JSON terms + legacy terms not covered by JSON
const jsonTermNames = new Set(jsonTerms.map(t => t.term.toLowerCase()));
const filteredLegacy: DisplayTerm[] = legacyOnlyTerms.filter(t => !jsonTermNames.has(t.term.toLowerCase()));
const terms: DisplayTerm[] = [...jsonTerms, ...filteredLegacy];

// Sort alphabetically
terms.sort((a, b) => a.term.localeCompare(b.term, 'es'));

// ─── Calcs lookup ───────────────────────────────────────────────────────────
const calcModules = import.meta.glob<any>('../../content/calcs/*.json', { eager: true });
const allCalcs = Object.values(calcModules).map((m: any) => m.default || m);
function findCalc(slug: string) {
  return allCalcs.find((c: any) => c.slug === slug);
}

const today = new Date().toLocaleDateString('es-AR', { day: '2-digit', month: 'long', year: 'numeric' });

// Schema.org DefinedTermSet
const schema = {
  '@context': 'https://schema.org',
  '@type': 'DefinedTermSet',
  name: 'Glosario financiero, de salud y negocios',
  description: 'Definiciones de términos clave usados en las calculadoras de Hacé Cuentas.',
  inLanguage: 'es-AR',
  hasDefinedTerm: terms.map((t) => ({
    '@type': 'DefinedTerm',
    name: t.term,
    description: t.short,
    ...(t.slug ? { url: `https://hacecuentas.com/glosario/${t.slug}` } : {}),
    inDefinedTermSet: 'https://hacecuentas.com/glosario',
  })),
};
---

<Layout
  title="Glosario — Términos financieros, de salud y negocios | Hacé Cuentas"
  description="Glosario de términos clave usados en las calculadoras: SAC, IMC, BMR, TNA, CFT, ROAS, LTV y muchos más. Definiciones cortas con fuente y ejemplo."
  schema={schema}
>
  <Header slot="header" />

  <article class="glosario">
    <nav class="breadcrumbs" aria-label="Ruta de navegación">
      <a href="/">Inicio</a>
      <span class="sep" aria-hidden="true">/</span>
      <span class="current">Glosario</span>
    </nav>

    <header class="g-header">
      <span class="eyebrow">Glosario</span>
      <h1>Términos financieros, de salud y negocios</h1>
      <p class="lead">
        Definiciones cortas y verificables de los conceptos que usamos en nuestras calculadoras.
        {terms.length} términos ordenados alfabéticamente.
      </p>
      <p class="date">Actualizado al {today}</p>
    </header>

    <div class="g-toolbar">
      <label class="search-wrap" for="g-filter">
        <svg class="s-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
        </svg>
        <input type="search" id="g-filter" placeholder={`Filtrar entre ${terms.length} términos…`} autocomplete="off" />
      </label>
    </div>

    <dl class="g-list" id="g-list">
      {terms.map((t) => (
        <div class="g-item" data-name={(t.term + ' ' + t.short).toLowerCase()}>
          <dt>
            {t.slug ? (
              <a href={`/glosario/${t.slug}`} class="g-term g-term-link">{t.term}</a>
            ) : (
              <span class="g-term">{t.term}</span>
            )}
            <span class="g-cat">{t.category}</span>
          </dt>
          <dd>
            <p class="g-short">{t.short}</p>
            {t.related && t.related.length > 0 && (
              <p class="g-related">
                <span class="g-related-label">Calculadoras:</span>
                {t.related.map((slug) => {
                  const c = findCalc(slug);
                  return c ? <a href={`/${slug}`}>{c.h1}</a> : null;
                })}
              </p>
            )}
            {t.slug && (
              <a href={`/glosario/${t.slug}`} class="g-readmore">Ver definición completa &rarr;</a>
            )}
          </dd>
        </div>
      ))}
    </dl>

    <p class="g-empty" id="g-empty" hidden>No encontramos términos que coincidan.</p>

    <script is:inline>
      (function () {
        var input = document.getElementById('g-filter');
        var list = document.getElementById('g-list');
        var empty = document.getElementById('g-empty');
        if (!input || !list) return;
        var items = Array.from(list.querySelectorAll('.g-item'));
        function norm(s) { return s.toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g, ''); }
        input.addEventListener('input', function () {
          var q = norm(input.value.trim());
          var visible = 0;
          items.forEach(function (el) {
            var hay = norm(el.dataset.name || '');
            var match = !q || hay.indexOf(q) !== -1;
            el.hidden = !match;
            if (match) visible++;
          });
          if (empty) empty.hidden = visible > 0;
        });
      })();
    </script>
  </article>

  <Footer slot="footer" />
</Layout>

<style>
  .glosario { max-width: 920px; margin: 0 auto; padding: 0 1rem; }
  .breadcrumbs {
    display: flex;
    gap: 0.5rem;
    font-size: 0.8125rem;
    color: var(--text-subtle);
    margin-bottom: 1.5rem;
  }
  .breadcrumbs a { color: var(--text-muted); text-decoration: none; }
  .breadcrumbs .sep { color: var(--border-strong); }
  .breadcrumbs .current { color: var(--text); font-weight: 500; }

  .g-header { margin-bottom: 1.5rem; }
  .eyebrow {
    display: inline-block;
    font-size: 0.6875rem;
    font-weight: 700;
    color: var(--accent);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 0.5rem;
  }
  .g-header h1 {
    margin: 0 0 0.5rem;
    font-size: clamp(1.625rem, 3.5vw, 2.125rem);
  }
  .lead {
    color: var(--text-muted);
    font-size: 1rem;
    line-height: 1.55;
    margin: 0 0 0.25rem;
  }
  .date {
    color: var(--text-subtle);
    font-size: 0.8125rem;
    margin: 0;
  }

  .g-toolbar { margin: 1.25rem 0; }
  .search-wrap {
    position: relative;
    display: flex;
    align-items: center;
    max-width: 480px;
  }
  .search-wrap .s-icon {
    position: absolute;
    left: 0.875rem;
    color: var(--text-subtle);
    pointer-events: none;
  }
  .search-wrap input {
    width: 100%;
    padding: 0.625rem 0.875rem 0.625rem 2.375rem;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    font-size: 0.9375rem;
    color: var(--text);
    font-family: inherit;
  }
  .search-wrap input:focus {
    outline: none;
    border-color: var(--accent);
    box-shadow: 0 0 0 3px var(--accent-soft);
  }

  .g-list {
    display: grid;
    gap: 1rem;
    margin: 0;
    padding: 0;
  }
  .g-item {
    padding: 1.125rem 1.25rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
  }
  .g-item dt {
    display: flex;
    align-items: baseline;
    gap: 0.625rem;
    margin-bottom: 0.375rem;
  }
  .g-term { font-weight: 700; color: var(--text); font-size: 1.0625rem; }
  .g-term-link {
    text-decoration: none;
    color: var(--text);
    transition: color 0.15s;
  }
  .g-term-link:hover { color: var(--accent); }
  .g-cat {
    display: inline-block;
    padding: 0.0625rem 0.5rem;
    background: var(--accent-soft);
    color: var(--accent-strong);
    border-radius: 999px;
    font-size: 0.6875rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    font-weight: 600;
  }
  .g-item dd { margin: 0; }
  .g-short {
    color: var(--text);
    font-size: 0.9375rem;
    margin: 0 0 0.5rem;
    line-height: 1.5;
    font-weight: 500;
  }
  .g-related {
    margin: 0 0 0.5rem;
    font-size: 0.8125rem;
    color: var(--text-subtle);
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    align-items: center;
  }
  .g-related-label { font-weight: 600; }
  .g-related a {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .g-readmore {
    display: inline-block;
    font-size: 0.8125rem;
    color: var(--accent);
    text-decoration: none;
    font-weight: 500;
  }
  .g-readmore:hover { text-decoration: underline; }
  .g-empty {
    margin: 1.5rem 0;
    padding: 1.25rem;
    background: var(--bg-soft);
    border: 1px dashed var(--border);
    border-radius: var(--radius);
    color: var(--text-muted);
    text-align: center;
  }
</style>
