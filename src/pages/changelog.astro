---
export const prerender = true;

import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface ChangelogEntry {
  slug: string;
  date: string;
  title: string;
  summary: string;
  tags: string[];
  body: string;
  related?: string[];
}

const entryModules = import.meta.glob<ChangelogEntry>('../content/changelog/*.json', { eager: true });
const allEntries: ChangelogEntry[] = Object.values(entryModules).map((m: any) => (m.default ? m.default : m));

// Sort desc by date (then by slug to keep stable order within same day)
allEntries.sort((a, b) => {
  const cmp = b.date.localeCompare(a.date);
  return cmp !== 0 ? cmp : b.slug.localeCompare(a.slug);
});

const MAX_ON_PAGE = 50;
const entries = allEntries.slice(0, MAX_ON_PAGE);
const hasArchive = allEntries.length > MAX_ON_PAGE;

// Group by YYYY-MM
const monthLabels = [
  'enero', 'febrero', 'marzo', 'abril', 'mayo', 'junio',
  'julio', 'agosto', 'septiembre', 'octubre', 'noviembre', 'diciembre',
];

interface Group { key: string; label: string; items: ChangelogEntry[] }
const groupsMap = new Map<string, Group>();
for (const e of entries) {
  const [y, m] = e.date.split('-');
  const key = `${y}-${m}`;
  if (!groupsMap.has(key)) {
    groupsMap.set(key, {
      key,
      label: `${monthLabels[parseInt(m, 10) - 1]} ${y}`,
      items: [],
    });
  }
  groupsMap.get(key)!.items.push(e);
}
const groups: Group[] = Array.from(groupsMap.values());

// Tag-friendly labels
const tagLabels: Record<string, string> = {
  'calcs-nuevas': 'Calculadoras nuevas',
  'fixes-formula': 'Fórmulas',
  'datos-actualizados': 'Datos actualizados',
  'mejoras-seo': 'SEO',
  'mejoras-contenido': 'Contenido',
  'performance': 'Performance',
  'ux': 'UX',
};

function tagLabel(t: string): string {
  return tagLabels[t] || t;
}

function formatDate(d: string): string {
  const [y, m, day] = d.split('-');
  return `${parseInt(day, 10)} de ${monthLabels[parseInt(m, 10) - 1]} ${y}`;
}

const lastUpdated = entries[0]?.date || null;
const siteUrl = 'https://hacecuentas.com';

// Schema.org: list of BlogPosting items
const itemListSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'Changelog de Hacé Cuentas',
  itemListElement: entries.map((e, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    item: {
      '@type': 'BlogPosting',
      headline: e.title,
      description: e.summary,
      datePublished: e.date,
      url: `${siteUrl}/changelog#${e.slug}`,
      author: { '@type': 'Organization', name: 'Hacé Cuentas' },
      publisher: { '@id': `${siteUrl}/#organization` },
    },
  })),
};
---

<Layout
  title="Changelog — Cambios recientes en Hacé Cuentas"
  description="Historial público de cambios de Hacé Cuentas: calculadoras nuevas, fórmulas actualizadas, fixes y mejoras del sitio."
  schema={itemListSchema}
>
  <Header slot="header" />

  <article class="changelog">
    <header class="changelog-head">
      <h1>Changelog</h1>
      <p class="lede">
        Acá publicamos los cambios significativos de Hacé Cuentas: calculadoras nuevas,
        actualizaciones de fórmulas y datos oficiales, mejoras y arreglos. Si querés
        seguirlo, podés suscribirte al <a href="/changelog.xml">feed RSS</a>.
      </p>
      {lastUpdated && (
        <p class="meta">Última actualización: <time datetime={lastUpdated}>{formatDate(lastUpdated)}</time></p>
      )}
    </header>

    {groups.map((group) => (
      <section class="month-group" aria-labelledby={`m-${group.key}`}>
        <h2 id={`m-${group.key}`} class="month-heading">{group.label}</h2>
        <ol class="entries">
          {group.items.map((e) => (
            <li id={e.slug} class="entry">
              <div class="entry-meta">
                <time datetime={e.date}>{formatDate(e.date)}</time>
                <ul class="tags" aria-label="Categorías">
                  {e.tags.map((t) => (
                    <li class={`tag tag-${t}`}>{tagLabel(t)}</li>
                  ))}
                </ul>
              </div>
              <h3 class="entry-title">{e.title}</h3>
              <p class="entry-summary">{e.summary}</p>
              {e.body && <div class="entry-body" set:html={e.body} />}
              {e.related && e.related.length > 0 && (
                <p class="entry-related">
                  <span class="related-label">Calculadoras relacionadas:</span>
                  {e.related.map((slug, i) => (
                    <>
                      <a href={`/${slug}`}>{slug.replace(/-/g, ' ')}</a>
                      {i < e.related!.length - 1 && <span aria-hidden="true">, </span>}
                    </>
                  ))}
                </p>
              )}
            </li>
          ))}
        </ol>
      </section>
    ))}

    {hasArchive && (
      <p class="archive-note">
        Mostramos las {MAX_ON_PAGE} entradas más recientes. Para ver todo el historial,
        suscribite al <a href="/changelog.xml">feed RSS</a>.
      </p>
    )}
  </article>

  <Footer slot="footer" />
</Layout>

<style>
  .changelog {
    max-width: 760px;
    margin: 2rem auto 4rem;
    padding: 0 1rem;
  }
  .changelog-head {
    margin-bottom: 2.5rem;
  }
  .changelog-head h1 {
    margin: 0 0 0.75rem;
  }
  .lede {
    color: var(--text-muted);
    line-height: 1.7;
    margin: 0 0 0.75rem;
  }
  .meta {
    color: var(--text-subtle);
    font-size: 0.875rem;
    margin: 0;
  }

  .month-group {
    margin-bottom: 2.5rem;
  }
  .month-heading {
    font-size: 0.8125rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-subtle);
    margin: 0 0 1.25rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--border);
  }

  .entries {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .entry {
    padding: 1.5rem 0;
    border-bottom: 1px solid var(--border);
  }
  .entry:last-child {
    border-bottom: none;
  }

  .entry-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.625rem 0.875rem;
    align-items: center;
    margin-bottom: 0.5rem;
  }
  .entry-meta time {
    font-size: 0.8125rem;
    color: var(--text-subtle);
  }

  .tags {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
  }
  .tag {
    display: inline-block;
    padding: 0.125rem 0.5rem;
    background: var(--bg-soft);
    border: 1px solid var(--border);
    border-radius: 999px;
    font-size: 0.6875rem;
    font-weight: 500;
    color: var(--text-muted);
    text-transform: lowercase;
    letter-spacing: 0.02em;
  }

  .entry-title {
    font-size: 1.25rem;
    margin: 0 0 0.5rem;
    color: var(--text);
  }
  .entry-summary {
    color: var(--text-muted);
    margin: 0 0 0.75rem;
    line-height: 1.6;
  }
  .entry-body {
    color: var(--text-muted);
    line-height: 1.7;
  }
  .entry-body :global(p) {
    margin: 0 0 0.75rem;
  }
  .entry-body :global(ul),
  .entry-body :global(ol) {
    margin: 0 0 0.75rem 1.25rem;
  }
  .entry-body :global(strong) {
    color: var(--text);
  }
  .entry-body :global(a) {
    color: var(--accent);
  }
  .entry-body :global(code) {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.875em;
    background: var(--bg-soft);
    padding: 0.0625rem 0.25rem;
    border-radius: 4px;
  }

  .entry-related {
    margin-top: 0.75rem;
    font-size: 0.875rem;
    color: var(--text-subtle);
  }
  .related-label {
    font-weight: 500;
    margin-right: 0.25rem;
  }
  .entry-related a {
    color: var(--accent);
  }

  .archive-note {
    margin-top: 2rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border);
    color: var(--text-subtle);
    font-size: 0.875rem;
  }
</style>
