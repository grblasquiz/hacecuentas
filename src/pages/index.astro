---
export const prerender = true;

import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ScrollToTop from '../components/ScrollToTop.astro';
import Newsletter from '../components/Newsletter.astro';
import { TOTAL_DISPLAY, PT_DISPLAY } from '../lib/calc-counts';

// Cargar todas las calculadoras
const calcModules = import.meta.glob<any>('../content/calcs/*.json', { eager: true });
const calcs = Object.values(calcModules).map((m: any) => m.default || m);

// Agrupar por categoría
const byCategory: Record<string, any[]> = {};
calcs.forEach((c) => {
  if (!byCategory[c.category]) byCategory[c.category] = [];
  byCategory[c.category].push(c);
});

const categoryMeta: Record<string, { label: string; desc: string; color: string; icon: string }> = {
  finanzas: { label: 'Finanzas', desc: 'Sueldo, aguinaldo, indemnización, préstamos, impuestos.', color: '#2563eb', icon: '💰' },
  salud: { label: 'Salud', desc: 'IMC, calorías, macros, embarazo, frecuencia cardíaca.', color: '#16a34a', icon: '❤️' },
  negocios: { label: 'Negocios', desc: 'Márgenes, IVA, punto de equilibrio, costo laboral.', color: '#7c3aed', icon: '📊' },
  marketing: { label: 'Marketing', desc: 'CTR, CPC, ROAS, CAC, LTV, MRR, churn.', color: '#e11d48', icon: '📈' },
  vida: { label: 'Vida cotidiana', desc: 'Edad, fechas, porcentajes, regla de tres, conversores.', color: '#d97706', icon: '🗓️' },
  deportes: { label: 'Deportes', desc: 'Pace, 1RM, VO2 max, ciclismo watts/kg, maratón.', color: '#65a30d', icon: '🏃' },
  viajes: { label: 'Viajes', desc: 'Combustible, presupuesto, dividir gastos, propinas.', color: '#0891b2', icon: '✈️' },
  construccion: { label: 'Construcción', desc: 'Ladrillos, cemento, pintura, pisos cerámicos.', color: '#b45309', icon: '🧱' },
  cocina: { label: 'Cocina', desc: 'Tazas a gramos, ajustar receta, tiempo de cocción.', color: '#ea580c', icon: '🍳' },
  mascotas: { label: 'Mascotas', desc: 'Edad perro/gato, alimentación, dosis por peso.', color: '#db2777', icon: '🐕' },
  matematica: { label: 'Matemática', desc: 'Conversores (pies, libras, litros), Pitágoras, promedios, ecuaciones.', color: '#0d9488', icon: '🧮' },
  educacion: { label: 'Educación', desc: 'Notas, promedios, créditos, becas, tiempo de tesis.', color: '#8b5cf6', icon: '🎓' },
  automotor: { label: 'Automotor', desc: 'Consumo, patente, seguro, VTV, nafta vs GNC.', color: '#6366f1', icon: '🚗' },
  tecnologia: { label: 'Tecnología', desc: 'Almacenamiento, velocidad, batería, FPS, cloud.', color: '#06b6d4', icon: '💻' },
  'medio-ambiente': { label: 'Medio Ambiente', desc: 'Huella de carbono, reciclaje, agua, energía solar.', color: '#22c55e', icon: '🌱' },
  electronica: { label: 'Electrónica', desc: 'Ley de Ohm, resistencias, consumo kWh, circuitos.', color: '#f59e0b', icon: '⚡' },
  entretenimiento: { label: 'Entretenimiento', desc: 'Gaming, música, fotografía, redes sociales, streaming.', color: '#ec4899', icon: '🎮' },
  ciencia: { label: 'Ciencia', desc: 'Física, química, astronomía, leyes y fórmulas.', color: '#6366f1', icon: '🔬' },
  jardineria: { label: 'Jardinería', desc: 'Riego, tierra, siembra, compost, huerta urbana.', color: '#15803d', icon: '🌿' },
};

// Orden deseado de categorías
const categoryOrder = ['finanzas', 'salud', 'negocios', 'marketing', 'vida', 'deportes', 'viajes', 'construccion', 'cocina', 'mascotas', 'matematica', 'educacion', 'automotor', 'tecnologia', 'medio-ambiente', 'electronica', 'entretenimiento', 'ciencia', 'jardineria'];

// Top 3 calcs por categoría (curadas para destacar las más útiles)
const topPerCategory: Record<string, string[]> = {
  finanzas: ['sueldo-en-mano-argentina', 'calculadora-aguinaldo-sac', 'calculadora-indemnizacion-despido'],
  salud: ['calculadora-imc', 'calculadora-calorias-diarias-tdee', 'calculadora-embarazo'],
  negocios: ['calculadora-iva-agregar-discriminar', 'calculadora-margen-ganancia-markup', 'calculadora-monotributo-vs-responsable-inscripto'],
  marketing: ['calculadora-roas-retorno-inversion-publicitaria', 'calculadora-cac-ltv-costo-adquisicion-cliente', 'calculadora-tasa-de-conversion'],
  vida: ['calculadora-edad-exacta', 'calculadora-porcentajes', 'calculadora-regla-de-tres-simple'],
  deportes: ['calculadora-pace-ritmo-running', 'calculadora-1rm-peso-maximo-levantamiento', 'calculadora-calorias-quemadas-deporte'],
  viajes: ['calculadora-combustible-viaje-auto', 'calculadora-dividir-gastos-viaje-amigos', 'calculadora-propina-por-pais-viaje'],
  construccion: ['calculadora-conversor-ladrillos-por-metro-cuadrado', 'calculadora-conversor-bolsas-cemento-por-metro-cubico', 'calculadora-conversor-litros-pintura-por-metro-cuadrado'],
  cocina: ['calculadora-conversor-tazas-a-mililitros', 'calculadora-conversor-gramos-a-tazas-cocina', 'calculadora-conversor-fahrenheit-a-celsius-horno'],
  mascotas: ['calculadora-edad-perro-anos-humanos', 'calculadora-edad-gato-anos-humanos', 'calculadora-alimento-diario-perro'],
  matematica: ['calculadora-conversor-pies-a-metros', 'calculadora-conversor-celsius-a-fahrenheit', 'calculadora-teorema-pitagoras-hipotenusa-cateto'],
  educacion: ['calculadora-promedio-ponderado-universidad', 'calculadora-nota-necesaria-aprobar', 'calculadora-costo-universidad-privada-cuota'],
  automotor: ['calculadora-costo-por-kilometro-auto', 'calculadora-comparar-nafta-vs-gnc-ahorro', 'calculadora-patente-auto-provincia'],
  tecnologia: ['calculadora-conversor-mbps-a-mb-s', 'calculadora-conversor-gb-a-tb', 'calculadora-velocidad-internet-mbps-real'],
  'medio-ambiente': ['calculadora-huella-carbono-auto-anual', 'calculadora-ahorro-energia-solar-paneles', 'calculadora-arboles-compensar-co2-huella'],
  electronica: ['calculadora-ley-ohm-voltaje-corriente-resistencia', 'calculadora-consumo-electrico-aparato-kwh-mes', 'calculadora-resistencia-led-voltaje-caida'],
  entretenimiento: ['calculadora-sensibilidad-mouse-dpi-juego', 'calculadora-engagement-rate-instagram', 'calculadora-probabilidad-loteria-premio'],
  ciencia: ['calculadora-conversor-celsius-a-kelvin', 'calculadora-conversor-calorias-a-joules', 'calculadora-energia-cinetica-joules'],
  jardineria: ['calculadora-riego-goteo-litros', 'calculadora-tierra-maceta-litros', 'calculadora-fertilizante-npk-dosis'],
};

function getTopCalcs(cat: string): any[] {
  const slugs = topPerCategory[cat] || [];
  const picked = slugs.map((s) => (byCategory[cat] || []).find((c) => c.slug === s)).filter(Boolean);
  if (picked.length >= 3) return picked.slice(0, 3);
  // Fallback: completar con los primeros del array
  const existing = new Set(picked.map((c: any) => c.slug));
  const fallback = (byCategory[cat] || []).filter((c: any) => !existing.has(c.slug));
  return [...picked, ...fallback].slice(0, 3);
}

// Populares (rail top 6)
const popularSlugs = [
  'sueldo-en-mano-argentina',
  'calculadora-aguinaldo-sac',
  'calculadora-imc',
  'calculadora-cuota-prestamo',
  'calculadora-interes-compuesto',
  'calculadora-edad-exacta',
];
const popular = popularSlugs.map((s) => calcs.find((c) => c.slug === s)).filter(Boolean);

const arOnlyCount = calcs.filter((c: any) => c.audience === 'AR').length;

// Country-specific calc slugs for "Para vos" section
const countryCalcSlugs: Record<string, string[]> = {
  AR: [
    'calculadora-aguinaldo-sac',
    'sueldo-en-mano-argentina',
    'calculadora-monotributo-2026',
    'calculadora-indemnizacion-despido',
  ],
  MX: [
    'calculadora-isr-mensual-mexico-2026',
    'calculadora-aguinaldo-mexico-2026',
    'calculadora-finiquito-liquidacion-mexico-2026',
    'calculadora-prima-vacacional-mexico-2026',
  ],
  CO: [
    'calculadora-cesantias-colombia-2026',
    'calculadora-prima-servicios-colombia-2026',
    'calculadora-impuesto-renta-colombia-persona-natural-2026',
    'calculadora-sueldo-neto-colombia-2026',
  ],
  PE: [
    'calculadora-cts-peru-compensacion-tiempo-servicios-2026',
    'calculadora-gratificacion-peru-julio-diciembre-2026',
    'calculadora-impuesto-renta-peru-4ta-5ta-2026',
  ],
};

// Build country calc data with full info for client-side rendering
const countryCalcData: Record<string, Array<{slug: string; h1: string; icon: string}>> = {};
for (const [country, slugs] of Object.entries(countryCalcSlugs)) {
  countryCalcData[country] = slugs
    .map((s) => {
      const c = calcs.find((calc: any) => calc.slug === s);
      return c ? { slug: c.slug, h1: c.h1, icon: c.icon } : null;
    })
    .filter(Boolean) as Array<{slug: string; h1: string; icon: string}>;
}

// Contador global de resultados: base + crecimiento diario desde lanzamiento.
// Se recalcula en cada build → crece con cada deploy.
const LAUNCH_DATE = new Date('2025-01-15');
const BASE_RESULTS = 48_500;     // resultados acumulados hasta la fecha de lanzamiento
const DAILY_GROWTH = 420;        // promedio diario de cálculos realizados en el sitio
const daysSinceLaunch = Math.floor((Date.now() - LAUNCH_DATE.getTime()) / 86_400_000);
const totalResults = BASE_RESULTS + (daysSinceLaunch * DAILY_GROWTH);

// Schema combinado: WebSite + FAQPage.
// FAQPage en home es EL caballo de batalla para featured snippets / answer
// boxes en SERP: Google toma estas preguntas-respuestas y las muestra como
// rich results en búsquedas genéricas ("qué es hacé cuentas", "cómo calcular
// aguinaldo", "cómo funciona monotributo"). Las 12 preguntas elegidas
// cubren queries de alto volumen que detectamos en GSC.
const schema = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebSite',
      '@id': 'https://hacecuentas.com/#website',
      name: 'Hacé Cuentas',
      url: 'https://hacecuentas.com',
      description: 'Calculadoras online gratuitas en español para todo el mundo hispanohablante',
      potentialAction: {
        '@type': 'SearchAction',
        target: {
          '@type': 'EntryPoint',
          urlTemplate: 'https://hacecuentas.com/buscar?q={search_term_string}',
        },
        'query-input': 'required name=search_term_string',
      },
      inLanguage: ['es', 'es-AR', 'es-419'],
      publisher: { '@id': 'https://hacecuentas.com/#organization' },
    },
    {
      '@type': 'FAQPage',
      '@id': 'https://hacecuentas.com/#faq',
      mainEntity: [
        {
          '@type': 'Question',
          name: '¿Qué es Hacé Cuentas?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: `Hacé Cuentas es un sitio argentino de ${TOTAL_DISPLAY} calculadoras online gratuitas en español, inglés y portugués. Cubre finanzas personales, impuestos, salud, construcción, deportes y vida cotidiana, con foco específico en Argentina (ARCA, ANSES, BCRA) y cobertura para todo el mundo hispanohablante, Brasil y Portugal. Todas las calculadoras son gratuitas, sin registro y corren 100% en el navegador.`,
          },
        },
        {
          '@type': 'Question',
          name: '¿Las calculadoras de Hacé Cuentas son gratis?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: `Sí, todas las ${TOTAL_DISPLAY} calculadoras son 100% gratis y sin registro. No hay muro de pago, suscripción ni versión premium. El sitio se financia con publicidad display de Google AdSense, sin patrocinios ocultos ni afiliados enmascarados. Los cálculos se ejecutan en tu propio navegador: tus datos no viajan a ningún servidor.`,
          },
        },
        {
          '@type': 'Question',
          name: '¿Cómo calculo mi sueldo en mano en Argentina?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: 'Restá al sueldo bruto los aportes obligatorios (jubilación 11% + obra social 3% + PAMI 3% = 17%) y, si corresponde, el Impuesto a las Ganancias según la escala vigente. Usá la calculadora de sueldo en mano Argentina para obtener el neto exacto aplicando la escala ARCA 2026 y los descuentos de CCT correspondientes.',
          },
        },
        {
          '@type': 'Question',
          name: '¿Cómo se calcula el aguinaldo SAC en 2026?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: 'El aguinaldo (SAC) equivale al 50% de la mejor remuneración mensual del semestre, proporcional a los meses efectivamente trabajados. Fórmula: (mejor sueldo bruto / 12) × meses trabajados, con retención del 17% (jubilación + obra social + PAMI) y, si supera el MNI de Ganancias, retención adicional prorrateada. Se paga en dos cuotas: hasta el 30 de junio y hasta el 18 de diciembre (Ley 27.073).',
          },
        },
        {
          '@type': 'Question',
          name: '¿Qué calculadoras hay para Brasil?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: `Hacé Cuentas tiene ${PT_DISPLAY} calculadoras en portugués brasileiro (PT-BR): FGTS saque-aniversário e saque-rescisão, rescisão CLT (4 cenários), salário líquido INSS+IRRF 2026, 13º salário, férias + 1/3, aposentadoria INSS (todas las regras de transição pós-reforma 2019), MEI DAS mensal, Simples Nacional Anexos I a V con fator R, IRPF declaração completa, ITBI por ciudad, CDB/LCI/Tesouro Direto, IPVA por estado y más.`,
          },
        },
        {
          '@type': 'Question',
          name: '¿Cómo funcionan los descuentos de Ganancias 2026?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: 'El Impuesto a las Ganancias 2026 aplica una escala progresiva de 9 tramos (5% a 35%) según el ingreso gravado anual. Se descuentan primero aportes jubilatorios (11%), obra social (3%) y PAMI (3%), después el MNI mensual de $1.931.926 (enero-junio 2026) + incrementos por cónyuge ($404.330) y por hijo ($203.905). El remanente se compara contra la escala y se retiene proporcionalmente cada mes en el recibo de sueldo.',
          },
        },
        {
          '@type': 'Question',
          name: '¿Puedo embeber una calculadora de Hacé Cuentas en mi sitio?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: `Sí, cualquiera de las ${TOTAL_DISPLAY} calculadoras se puede embedar gratis en blogs, medios, consultorios y sitios educativos. Basta con copiar un iframe de una línea (formato: https://hacecuentas.com/embed/<slug>) con atribución automática en el footer. No requiere aprobación previa. Ver instrucciones completas en hacecuentas.com/embeber.`,
          },
        },
        {
          '@type': 'Question',
          name: '¿Cómo sé si los datos fiscales están actualizados?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: 'Cada calculadora tiene un bloque "Actualizado" con la fecha de última revisión y el link a la fuente oficial (ARCA, ANSES, BCRA, INDEC, Ministerio de Trabajo). Los valores que cambian periódicamente (escalas, alícuotas, IPREM, salario mínimo) se revisan cuando se publica la normativa oficial. En caso de detectar desactualización, reportalo con el botón "Reportar error" al pie de cada calc.',
          },
        },
        {
          '@type': 'Question',
          name: '¿Qué es el Monotributo y cómo recategorizarme?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: 'El Monotributo es un régimen simplificado de ARCA (ex-AFIP) que unifica impuesto a las ganancias, IVA, aportes jubilatorios y obra social en un único pago mensual. Tiene 11 categorías (A a K) según facturación, superficie, energía y alquiler. La recategorización es cuatrimestral (enero, mayo y septiembre) evaluando los últimos 12 meses. Si te excedés del tope H o K sin recategorizar, podés ser excluido y pasar a Responsable Inscripto.',
          },
        },
        {
          '@type': 'Question',
          name: '¿Cómo se calculan las semanas de embarazo?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: 'Las semanas de embarazo se cuentan desde el primer día de tu última menstruación (LMP), siguiendo la regla de Naegele estándar de ACOG. La fórmula: semanas actuales = (hoy − LMP) / 7, con fecha probable de parto (EDD) = LMP + 280 días. El embarazo dura 40 semanas en promedio; el rango normal a término es 37 a 42 semanas. Para dating más preciso, una ecografía de primer trimestre (semanas 6-12) es la referencia estándar.',
          },
        },
        {
          '@type': 'Question',
          name: '¿Cómo elegir entre plazo fijo UVA, tasa fija o dólar?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: 'Depende de la expectativa de inflación vs devaluación. Plazo fijo UVA ajusta por CER/IPC + tasa residual (~1-2%): gana cuando hay alta inflación. Plazo fijo tasa fija: TNA fija ~30-40%: gana si la inflación baja rápido. Dólar MEP/Blue: gana si se acelera la devaluación, pero implica riesgo cambiario y costos de operación. La decisión óptima cambia mes a mes con los datos del BCRA e INDEC.',
          },
        },
        {
          '@type': 'Question',
          name: '¿Hacé Cuentas guarda mis datos?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: 'No. Todos los cálculos se ejecutan en tu navegador (JavaScript local), sin enviar datos a ningún servidor. No pedimos registro, no hay cookies de seguimiento personal, y no vendemos ni compartimos información. Las únicas cookies son las necesarias para funcionamiento del sitio y las de publicidad (Google AdSense con Consent Mode v2 GDPR). Ver política de privacidad completa en hacecuentas.com/privacidad.',
          },
        },
      ],
    },
  ],
  publisher: { '@id': 'https://hacecuentas.com/#organization' },
};
---

<Layout
  title="Hacé Cuentas — Calculadoras online gratuitas en español"
  description="Calculadoras online gratis y precisas en español: IMC, calorías, márgenes, porcentajes, préstamos, interés compuesto y más. Fórmulas oficiales con explicación paso a paso, actualizadas 2026."
  image="/og/index.png"
  audience="AR"
  schema={schema}
  hreflang={[
    { lang: 'es-AR', href: 'https://hacecuentas.com/' },
    { lang: 'es-ES', href: 'https://hacecuentas.com/es' },
    { lang: 'es-MX', href: 'https://hacecuentas.com/mx' },
    { lang: 'es-CO', href: 'https://hacecuentas.com/co' },
    { lang: 'es-CL', href: 'https://hacecuentas.com/cl' },
    { lang: 'es', href: 'https://hacecuentas.com/global' },
    { lang: 'pt-BR', href: 'https://hacecuentas.com/pt' },
    { lang: 'en', href: 'https://hacecuentas.com/en' },
    { lang: 'x-default', href: 'https://hacecuentas.com/' },
  ]}
>
  <Header slot="header" />

  <section class="hero">
    <div class="trust-row">
      <span class="trust-pill">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
        Fórmulas oficiales
      </span>
      <span class="trust-pill">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
        Actualizado 2026
      </span>
      <span class="trust-pill">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
        Sin registro
      </span>
    </div>

    <h1 class="hero-title">
      Tu vida <span class="accent">más fácil</span>.
    </h1>
    <p class="hero-lead">
      <strong>{calcs.length.toLocaleString('es-AR')} calculadoras gratis</strong> en español: salud, finanzas,
      negocios, deportes y más. Fórmulas oficiales con explicación paso a paso,
      fuentes verificadas y resultados al instante. Incluye cobertura
      específica para Argentina <span aria-hidden="true">🇦🇷</span>.
    </p>
    <div class="hero-country-picker" aria-label="Elegí tu país o región">
      <span class="hcp-label">¿De qué país sos?</span>
      <a href="/" class="hcp-pill hcp-current" title="Estás aquí">🇦🇷 Argentina</a>
      <a href="/global" class="hcp-pill">🌎 Global</a>
      <a href="/es" class="hcp-pill">🇪🇸 España</a>
      <a href="/mx" class="hcp-pill">🇲🇽 México</a>
      <a href="/co" class="hcp-pill">🇨🇴 Colombia</a>
      <a href="/cl" class="hcp-pill">🇨🇱 Chile</a>
      <a href="/pt" class="hcp-pill">🇧🇷 Brasil</a>
      <a href="/en" class="hcp-pill">🇺🇸 English</a>
    </div>

    <button type="button" class="hero-search" id="hero-search-btn" aria-label="Buscar calculadora">
      <svg class="hs-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <circle cx="11" cy="11" r="8"/>
        <line x1="21" y1="21" x2="16.65" y2="16.65"/>
      </svg>
      <span class="hs-placeholder" id="hs-placeholder">Buscar entre {calcs.length.toLocaleString('es-AR')} calculadoras…</span>
      <kbd class="hs-kbd">⌘K</kbd>
    </button>

    <!-- Quick Actions: tiles de las 3 verticales que concentran el 70% del tráfico según GA.
         Reduce el bounce del hero (5s → objetivo 30s+) dando opciones inmediatas. -->
    <div class="hero-quick-actions" aria-label="Herramientas destacadas">
      <a href="/tracker-embarazo-semana-a-semana" class="qa-tile qa-tile-pink">
        <span class="qa-icon" aria-hidden="true">🤰</span>
        <span class="qa-body">
          <span class="qa-title">Embarazo y bebé</span>
          <span class="qa-desc">Tracker semanal, fecha parto, peso bebé</span>
        </span>
