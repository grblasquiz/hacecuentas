      var langs = [];
      try {
        if (navigator.languages && navigator.languages.length) {
          langs = [].slice.call(navigator.languages);
        } else if (navigator.language) {
          langs = [navigator.language];
        }
      } catch (e) {}

      for (var i = 0; i < langs.length; i++) {
        var code = LANG_MAP[langs[i]];
        if (code) return code;
      }

      return null;
    }

    function renderSection(country) {
      var section = document.getElementById('para-vos-section');
      var grid = document.getElementById('pv-grid');
      var flag = document.getElementById('pv-flag');
      var name = document.getElementById('pv-country-name');
      if (!section || !grid || !country) return;

      var calcsData = countryCalcData[country];
      if (!calcsData || !calcsData.length) return;

      // Set heading
      if (flag) flag.textContent = COUNTRY_FLAGS[country] || '';
      if (name) name.textContent = COUNTRY_NAMES[country] || 'tu país';

      // Render cards
      grid.innerHTML = calcsData.map(function (c) {
        return '<a href="/' + c.slug + '" class="pv-card">' +
          '<span class="pv-icon" aria-hidden="true">' + c.icon + '</span>' +
          '<span class="pv-title">' + c.h1 + '</span>' +
          '</a>';
      }).join('');

      section.style.display = '';

      // Save to localStorage
      try { localStorage.setItem('hc_country', country); } catch (e) {}
    }

    var detected = detectCountry();
    if (detected) {
      renderSection(detected);
    }
  });
</script>

