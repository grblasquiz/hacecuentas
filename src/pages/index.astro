---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

// Cargar todas las calculadoras desde /content/calcs
const calcModules = import.meta.glob<any>('../content/calcs/*.json', { eager: true });
const calcs = Object.values(calcModules).map((m: any) => m.default || m);

// Agrupar por categoría
const byCategory: Record<string, any[]> = {};
calcs.forEach((c) => {
  if (!byCategory[c.category]) byCategory[c.category] = [];
  byCategory[c.category].push(c);
});

const categoryLabels: Record<string, string> = {
  finanzas: '💰 Finanzas',
  salud: '❤️ Salud',
  vida: '📅 Vida cotidiana',
  negocio: '📊 Negocios',
};

const schema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'Hacé Cuentas',
  url: 'https://hacecuentas.com',
  description: 'Calculadoras online gratuitas para Argentina y Latinoamérica',
  potentialAction: {
    '@type': 'SearchAction',
    target: 'https://hacecuentas.com/buscar?q={search_term_string}',
    'query-input': 'required name=search_term_string',
  },
  inLanguage: 'es-AR',
};
---

<Layout
  title="Hacé Cuentas — Calculadoras online gratuitas para Argentina"
  description="Decenas de calculadoras online gratuitas: sueldo, embarazo, IMC, dólar, días entre fechas y más. Precisas, rápidas y pensadas para Argentina."
  schema={schema}
>
  <Header slot="header" />

  <section class="hero">
    <h1>Calculadoras online para todo 🧮</h1>
    <p class="lead">
      Sueldo, embarazo, dólar, IMC, préstamos, alquileres y mucho más.
      Gratis, sin registro y pensadas para Argentina.
    </p>
  </section>

  {Object.entries(byCategory).map(([cat, items]) => (
    <section class="category">
      <h2>{categoryLabels[cat] || cat}</h2>
      <div class="grid">
        {items.map((c) => (
          <a href={`/${c.slug}`} class="card">
            <div class="card-icon">{c.icon}</div>
            <div class="card-title">{c.h1}</div>
            <div class="card-desc">{c.description}</div>
          </a>
        ))}
      </div>
    </section>
  ))}

  <section class="why">
    <h2>¿Por qué Hacé Cuentas?</h2>
    <div class="why-grid">
      <div class="why-item">
        <div class="why-icon">⚡</div>
        <h3>Rápido</h3>
        <p>Resultados instantáneos, sin esperas ni registros.</p>
      </div>
      <div class="why-item">
        <div class="why-icon">🇦🇷</div>
        <h3>Pensado para Argentina</h3>
        <p>Fórmulas adaptadas a leyes, impuestos y realidad local.</p>
      </div>
      <div class="why-item">
        <div class="why-icon">🔒</div>
        <h3>Privado</h3>
        <p>Todo se calcula en tu navegador. Nunca guardamos tus datos.</p>
      </div>
      <div class="why-item">
        <div class="why-icon">📱</div>
        <h3>Compartible</h3>
        <p>Mandás resultados por WhatsApp con un click.</p>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</Layout>

<style>
  .hero {
    text-align: center;
    padding: 3rem 1rem 2rem;
  }

  .hero h1 {
    font-size: clamp(2rem, 5vw, 3rem);
    margin-bottom: 1rem;
    background: linear-gradient(135deg, var(--accent), var(--success));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .lead {
    font-size: 1.125rem;
    max-width: 600px;
    margin: 0 auto;
    color: var(--text-muted);
  }

  .category {
    margin: 3rem 0;
  }

  .category h2 {
    margin-bottom: 1rem;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 1rem;
  }

  .card {
    display: flex;
    flex-direction: column;
    padding: 1.25rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 12px;
    text-decoration: none;
    color: var(--text);
    transition: all 0.2s;
  }

  .card:hover {
    border-color: var(--accent);
    transform: translateY(-2px);
    text-decoration: none;
  }

  .card-icon {
    font-size: 2rem;
    margin-bottom: 0.5rem;
  }

  .card-title {
    font-weight: 600;
    margin-bottom: 0.25rem;
    color: var(--text);
  }

  .card-desc {
    font-size: 0.875rem;
    color: var(--text-muted);
    line-height: 1.5;
  }

  .why {
    margin-top: 4rem;
    padding: 2rem 0;
  }

  .why-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 1.5rem;
    margin-top: 1.5rem;
  }

  .why-item {
    text-align: center;
  }

  .why-icon {
    font-size: 2.5rem;
    margin-bottom: 0.75rem;
  }

  .why-item h3 {
    margin-bottom: 0.5rem;
  }

  .why-item p {
    font-size: 0.9375rem;
    color: var(--text-muted);
  }
</style>
