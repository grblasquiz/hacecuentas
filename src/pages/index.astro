  <!-- Prefetch inteligente: en requestIdleCallback (no interfiere con render crítico)
       precargamos el HTML de las 6 calcs más visitadas. Si el user clickea una,
       carga instantánea desde cache. No usamos prefetchAll de Astro porque eso
       dispararía cientos de requests inútiles. -->
  <!-- Próximo feriado 2026 — texto en el tile de feriados. Lo calculamos
       client-side porque la fecha "hoy" es dinámica (cambia cada día).
       Lista hardcoded sincronizada con la fórmula de feriados. -->
  <script is:inline>
    (function () {
      var FERIADOS = [
        ['2026-01-01','Año Nuevo'],['2026-02-16','Carnaval'],['2026-02-17','Carnaval'],
        ['2026-03-24','Día de la Memoria'],['2026-04-02','Malvinas'],['2026-04-03','Viernes Santo'],
        ['2026-05-01','Día del Trabajador'],['2026-05-25','Revolución de Mayo'],
        ['2026-06-15','Güemes'],['2026-06-20','Belgrano'],['2026-07-09','Independencia'],
        ['2026-08-17','San Martín'],['2026-10-12','Diversidad Cultural'],
        ['2026-11-20','Soberanía'],['2026-12-08','Inmaculada'],['2026-12-25','Navidad'],
      ];
      var el = document.getElementById('proxi-feriado');
      if (!el) return;
      var hoy = new Date(); hoy.setHours(0,0,0,0);
      var prox = FERIADOS.map(function(f){
        var d = new Date(f[0]+'T00:00:00');
        return { d: d, n: f[1], diff: Math.ceil((d-hoy)/86400000) };
      }).filter(function(x){ return x.diff >= 0; });
      if (prox.length === 0) { el.textContent = 'Último feriado del año ya pasó'; return; }
      var p = prox[0];
      var dow = ['dom','lun','mar','mié','jue','vie','sáb'][p.d.getDay()];
      var dia = p.d.getDate();
      var mes = ['ene','feb','mar','abr','may','jun','jul','ago','sep','oct','nov','dic'][p.d.getMonth()];
      var txt = 'Próximo: ' + p.n + ' (' + dow + ' ' + dia + ' ' + mes;
      if (p.diff === 0) txt += ' — HOY)';
      else if (p.diff === 1) txt += ' — mañana)';
      else txt += ' — en ' + p.diff + ' días)';
      el.textContent = txt;
    })();
  </script>

  <script is:inline>
    (function () {
      var topUrls = [
        '/sueldo-en-mano-argentina',
        '/calculadora-aguinaldo-sac',
        '/calculadora-imc',
        '/calculadora-interes-compuesto',
        '/calculadora-porcentajes',
        '/calculadora-plazo-fijo',
      ];
      function schedule(cb) {
        if ('requestIdleCallback' in window) window.requestIdleCallback(cb, { timeout: 3000 });
        else setTimeout(cb, 2000);
      }
      function prefetch(url) {
        try {
          var l = document.createElement('link');
          l.rel = 'prefetch'; l.href = url; l.as = 'document';
          document.head.appendChild(l);
        } catch (e) {}
      }
      schedule(function () {
        // Save-Data o slow-2g: no prefetch
        var conn = navigator.connection || navigator.mozConnection || navigator.webkitConnection;
        if (conn && (conn.saveData || /2g/.test(conn.effectiveType))) return;
        topUrls.forEach(prefetch);
      });
    })();
  </script>
</Layout>

<script is:inline>
  // Wrapper: defer non-critical scripts a idle callback para reducir TBT
  (window.requestIdleCallback || function (fn) { return setTimeout(fn, 1); })(function () {

  // Hero search button → abre el modal de search del header
  document.getElementById('hero-search-btn')?.addEventListener('click', function () {
    var openBtn = document.getElementById('open-search');
    if (openBtn) openBtn.click();
  });

  // [2] Live counter — incrementa +1 cada 2-8s para dar feel de actividad real.
  // Los valores base vienen renderizados en el HTML (SSR) así no hay flash 0→target.
  // Antes había animación 0→target que causaba ver "0 categorías / 27 calculadoras"
  // mid-animation en conexiones lentas — se removió.
  (function () {
    var fmt = typeof Intl !== 'undefined'
      ? new Intl.NumberFormat('es-AR').format
      : function (n) { return String(n); };
    var liveEls = document.querySelectorAll('[data-live-counter]');
    if (!liveEls.length) return;
    liveEls.forEach(function (el) {
      var current = parseInt(el.getAttribute('data-initial'), 10) || 0;
      function bump() {
        current += 1;
        el.textContent = fmt(current);
        var next = 2000 + Math.random() * 6000; // 2-8s
        setTimeout(bump, next);
      }
      setTimeout(bump, 2000 + Math.random() * 6000);
    });
  })();

  // [3] Rotating placeholder in search bar
  (function () {
    var phrases = [
      'Calcular sueldo en mano...',
      '¿Cuántas calorías quemo?...',
      'Cuota de préstamo...',
      'Calcular aguinaldo...',
      'Convertir tazas a gramos...',
      'Calcular IMC...',
      'Margen de ganancia...',
    ];
    var el = document.getElementById('hs-placeholder');
    if (!el) return;
    var idx = 0;
    var interval = setInterval(function () {
      idx = (idx + 1) % phrases.length;
      el.style.opacity = '0';
      setTimeout(function () {
        el.textContent = phrases[idx];
        el.style.opacity = '1';
      }, 200);
    }, 3000);
    // Cleanup if navigated away (SPA)
    document.addEventListener('astro:before-swap', function () { clearInterval(interval); });
  })();

  }); // end requestIdleCallback
</script>

<script define:vars={{ countryCalcData }}>
