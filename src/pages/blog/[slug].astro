---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Newsletter from '../../components/Newsletter.astro';

export async function getStaticPaths() {
  const posts = import.meta.glob<any>('../../content/blog/*.json', { eager: true });
  return Object.values(posts).map((mod: any) => {
    const p = mod.default || mod;
    return {
      params: { slug: p.slug },
      props: { post: p },
    };
  });
}

const { post } = Astro.props;

const siteUrl = 'https://hacecuentas.com';

// ─── Related calcs ──────────────────────────────────────────────────────────
const calcModules = import.meta.glob<any>('../../content/calcs/*.json', { eager: true });
const allCalcs = Object.values(calcModules).map((m: any) => m.default || m);
const calcBySlug = new Map(allCalcs.map((c: any) => [c.slug, c]));

const relatedCalcs = (post.relatedCalcs || [])
  .map((s: string) => calcBySlug.get(s))
  .filter(Boolean);

// ─── Category labels ─────────────────────────────────────────────────────────
const categoryLabels: Record<string, string> = {
  finanzas: 'Finanzas',
  negocios: 'Negocios',
  negocio: 'Negocios',
  salud: 'Salud',
  marketing: 'Marketing',
  deportes: 'Deportes',
  viajes: 'Viajes',
  vida: 'Vida cotidiana',
  mascotas: 'Mascotas',
  matematica: 'Matemática',
  construccion: 'Construcción',
  cocina: 'Cocina',
  educacion: 'Educación',
  automotor: 'Automotor',
  tecnologia: 'Tecnología',
  'medio-ambiente': 'Medio Ambiente',
  electronica: 'Electrónica',
};

const categoryLabel = categoryLabels[post.category] || post.category;

// ─── Category badge colors ────────────────────────────────────────────────────
const categoryColors: Record<string, { bg: string; text: string }> = {
  finanzas:       { bg: '#eff6ff', text: '#1d4ed8' },
  negocios:       { bg: '#f0fdf4', text: '#15803d' },
  negocio:        { bg: '#f0fdf4', text: '#15803d' },
  salud:          { bg: '#fdf4ff', text: '#9333ea' },
  marketing:      { bg: '#fff7ed', text: '#c2410c' },
  deportes:       { bg: '#ecfdf5', text: '#059669' },
  viajes:         { bg: '#fff1f2', text: '#be123c' },
  vida:           { bg: '#f0f9ff', text: '#0369a1' },
  mascotas:       { bg: '#fefce8', text: '#854d0e' },
  matematica:     { bg: '#f5f3ff', text: '#6d28d9' },
  construccion:   { bg: '#fafaf9', text: '#78716c' },
  cocina:         { bg: '#fff7ed', text: '#c2410c' },
  educacion:      { bg: '#eff6ff', text: '#1d4ed8' },
  automotor:      { bg: '#f8fafc', text: '#475569' },
  tecnologia:     { bg: '#f0fdf4', text: '#15803d' },
  'medio-ambiente': { bg: '#f0fdf4', text: '#166534' },
  electronica:    { bg: '#eff6ff', text: '#1e40af' },
};
const catColor = categoryColors[post.category] || { bg: 'var(--accent-soft)', text: 'var(--accent)' };

// ─── Date formatting ──────────────────────────────────────────────────────────
function formatDate(iso: string): string {
  const d = new Date(iso + 'T00:00:00Z');
  return d.toLocaleDateString('es-AR', { day: 'numeric', month: 'long', year: 'numeric', timeZone: 'UTC' });
}
const dateFormatted = formatDate(post.date);
const dateISO = new Date(post.date + 'T00:00:00Z').toISOString();

// ─── TOC: parse h2 headings from HTML content ─────────────────────────────────
interface TocItem { id: string; text: string }
function buildToc(html: string): TocItem[] {
  const toc: TocItem[] = [];
  const re = /<h2[^>]*>(.*?)<\/h2>/gi;
  let match: RegExpExecArray | null;
  while ((match = re.exec(html)) !== null) {
    const rawText = match[1].replace(/<[^>]+>/g, '').trim();
    const id = rawText
      .toLowerCase()
      .normalize('NFD').replace(/[\u0300-\u036f]/g, '')
      .replace(/[^a-z0-9\s-]/g, '')
      .replace(/\s+/g, '-')
      .slice(0, 80);
    toc.push({ id, text: rawText });
  }
  return toc;
}

// Inject IDs into h2 tags in content so anchor links work
function injectH2Ids(html: string, toc: TocItem[]): string {
  let idx = 0;
  return html.replace(/<h2([^>]*)>/gi, (_match: string, attrs: string) => {
    const item = toc[idx++];
    if (!item) return `<h2${attrs}>`;
    // Avoid double-injecting if id already present
    if (/\bid=/.test(attrs)) return `<h2${attrs}>`;
    return `<h2${attrs} id="${item.id}">`;
  });
}

const toc = buildToc(post.content || '');
const contentWithIds = injectH2Ids(post.content || '', toc);

// ─── Schema.org ──────────────────────────────────────────────────────────────
const articleSchema: any = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: post.title,
  description: post.description,
  datePublished: dateISO,
  dateModified: dateISO,
  author: {
    '@type': 'Organization',
    name: post.author || 'Hacé Cuentas',
    url: siteUrl,
  },
  publisher: {
    '@type': 'Organization',
    name: 'Hacé Cuentas',
    url: siteUrl,
    logo: {
      '@type': 'ImageObject',
      url: `${siteUrl}/favicon.svg`,
    },
  },
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': `${siteUrl}/blog/${post.slug}`,
  },
  image: `${siteUrl}/og-default.png`,
  inLanguage: 'es-AR',
  keywords: (post.seoKeywords || []).join(', '),
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: 'Inicio',
      item: siteUrl,
    },
    {
      '@type': 'ListItem',
      position: 2,
      name: 'Blog',
      item: `${siteUrl}/blog`,
    },
    {
      '@type': 'ListItem',
      position: 3,
      name: post.title,
      item: `${siteUrl}/blog/${post.slug}`,
    },
  ],
};

const faqSchema = post.faq && post.faq.length > 0
  ? {
      '@context': 'https://schema.org',
      '@type': 'FAQPage',
      mainEntity: post.faq.map((item: { q: string; a: string }) => ({
        '@type': 'Question',
        name: item.q,
        acceptedAnswer: {
          '@type': 'Answer',
          text: item.a,
        },
      })),
    }
  : null;

// Combine all schemas into a @graph
const pageSchema = {
  '@context': 'https://schema.org',
  '@graph': [
    articleSchema,
    breadcrumbSchema,
    ...(faqSchema ? [faqSchema] : []),
  ],
};
---

<Layout
  title={post.title}
  description={post.description}
  canonical={`/blog/${post.slug}`}
  schema={pageSchema}
  noindex={false}
  audience="AR"
>
  <Header slot="header" />

  <div class="blog-wrap">

    <!-- Breadcrumbs -->
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <ol>
        <li><a href="/">Inicio</a></li>
        <li aria-hidden="true" class="sep">›</li>
        <li><a href="/blog">Blog</a></li>
        <li aria-hidden="true" class="sep">›</li>
        <li aria-current="page">{post.title}</li>
      </ol>
    </nav>

    <div class="blog-layout">

      <!-- Main column -->
      <article class="article">

        <!-- Article header -->
        <header class="article-header">
          <div class="hero-emoji" aria-hidden="true">{post.heroEmoji || '📝'}</div>
          <span
            class="cat-badge"
            style={`background:${catColor.bg};color:${catColor.text}`}
          >{categoryLabel}</span>
          <h1>{post.title}</h1>
          <p class="article-description">{post.description}</p>
          <div class="meta-line">
            <span class="meta-item">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/></svg>
              <time datetime={dateISO}>{dateFormatted}</time>
            </span>
            <span class="meta-sep" aria-hidden="true">·</span>
            <span class="meta-item">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
              {post.readingTime} min de lectura
            </span>
            {post.author && (
              <>
                <span class="meta-sep" aria-hidden="true">·</span>
                <span class="meta-item">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                  {post.author}
                </span>
              </>
            )}
          </div>
        </header>

        <!-- TOC mobile (inline box, shown above content on small screens) -->
        {toc.length >= 3 && (
          <nav class="toc-mobile" aria-label="Tabla de contenidos">
            <details open>
              <summary>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M8 6h13M8 12h13M8 18h13M3 6h.01M3 12h.01M3 18h.01"/></svg>
                Contenidos
              </summary>
              <ol class="toc-list">
                {toc.map((item) => (
                  <li><a href={`#${item.id}`}>{item.text}</a></li>
                ))}
              </ol>
            </details>
          </nav>
        )}

        <!-- Disclaimer pre-content para posts YMYL (finanzas, salud, etc.) -->
        {['finanzas', 'negocios', 'salud', 'familia'].includes(post.category) && (
          <aside class="post-disclaimer" role="note">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <circle cx="12" cy="12" r="10"/>
              <line x1="12" y1="16" x2="12" y2="12"/>
              <line x1="12" y1="8" x2="12.01" y2="8"/>
            </svg>
            <p>
              <strong>Información educativa, no asesoramiento profesional.</strong> Este artículo es contenido periodístico basado en fuentes públicas. No constituye asesoramiento {post.category === 'salud' ? 'médico' : 'financiero en inversión (Ley 26.831, RG CNV 840/2020) ni contable'}. Para decisiones importantes consultá con un/a {post.category === 'salud' ? 'profesional de la salud matriculado/a' : 'contador/a o asesor/a financiero/a matriculado/a'}. <a href="/aviso-legal">Leer aviso legal</a>.
            </p>
          </aside>
        )}

        <!-- Article body -->
        <div class="article-body prose" set:html={contentWithIds} />

        <!-- Disclaimer post-content en YMYL -->
        {['finanzas', 'negocios'].includes(post.category) && (
          <aside class="post-disclaimer-bottom" role="note">
            <p>
              <strong>📌 Recordá:</strong> Hacé Cuentas no es un asesor financiero registrado ante la CNV. Este contenido es educativo y no sustituye el consejo profesional. Las decisiones de inversión implican riesgo de pérdida de capital y deben tomarse consultando con un profesional matriculado.
            </p>
          </aside>
        )}

        <!-- Related calcs section -->
        {relatedCalcs.length > 0 && (
          <section class="related-calcs-section">
            <h2>Calculadoras relacionadas</h2>
            <div class="related-calcs-grid">
              {relatedCalcs.map((calc: any) => (
                <a href={`/${calc.slug}`} class="calc-card">
                  <div class="calc-card-icon">{calc.icon}</div>
                  <div class="calc-card-body">
                    <div class="calc-card-cat">
                      {categoryLabels[calc.category] || calc.category}
                    </div>
                    <div class="calc-card-title">{calc.h1}</div>
                    {calc.description && (
                      <div class="calc-card-desc">{calc.description.slice(0, 90)}{calc.description.length > 90 ? '…' : ''}</div>
                    )}
                  </div>
                  <svg class="calc-card-arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M9 18l6-6-6-6"/></svg>
                </a>
              ))}
            </div>
          </section>
        )}

        <!-- FAQ section -->
        {post.faq && post.faq.length > 0 && (
          <section class="faq-section">
            <h2>Preguntas frecuentes</h2>
            <div class="faq-list">
              {post.faq.map((item: { q: string; a: string }, i: number) => (
                <details class="faq-item" open={i === 0}>
                  <summary class="faq-q">
                    <span>{item.q}</span>
                    <svg class="faq-chevron" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M6 9l6 6 6-6"/></svg>
                  </summary>
                  <div class="faq-a">{item.a}</div>
                </details>
              ))}
            </div>
          </section>
        )}

        <!-- Newsletter -->
        <div class="newsletter-wrap">
          <Newsletter />
        </div>

      </article>

      <!-- Sidebar TOC (desktop sticky) -->
      {toc.length >= 3 && (
        <aside class="toc-sidebar" aria-label="Tabla de contenidos">
          <div class="toc-sticky">
            <div class="toc-title">En este artículo</div>
            <nav>
              <ol class="toc-list">
                {toc.map((item) => (
                  <li><a href={`#${item.id}`}>{item.text}</a></li>
                ))}
              </ol>
            </nav>
          </div>
        </aside>
      )}

    </div><!-- /blog-layout -->
  </div><!-- /blog-wrap -->

  <Footer slot="footer" />
</Layout>

<script>
  // TOC active heading highlight via IntersectionObserver
  (function () {
    const tocLinks = document.querySelectorAll<HTMLAnchorElement>('.toc-sidebar a, .toc-mobile a');
    if (!tocLinks.length) return;

    const headings = Array.from(
      document.querySelectorAll<HTMLElement>('.article-body h2[id]')
    );
    if (!headings.length) return;

    const observer = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            const id = entry.target.getAttribute('id');
            tocLinks.forEach((a) => {
              const active = a.getAttribute('href') === `#${id}`;
              a.classList.toggle('active', active);
            });
            break;
          }
        }
      },
      { rootMargin: '0px 0px -70% 0px', threshold: 0 }
    );

    headings.forEach((h) => observer.observe(h));
  })();
</script>

<style>
  /* ── Layout wrapper ─────────────────────────────────────────────────────── */
  .blog-wrap {
    max-width: 1100px;
    margin: 0 auto;
    padding: 1.5rem 1rem 4rem;
  }

  .blog-layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    margin-top: 1.5rem;
  }

  @media (min-width: 1024px) {
    .blog-layout {
      grid-template-columns: 1fr 220px;
      align-items: start;
    }
    /* Put sidebar in column 2 via order, article stays col 1 */
    .toc-sidebar { order: 2; }
    .article     { order: 1; }
  }

  /* ── Breadcrumb ─────────────────────────────────────────────────────────── */
  .breadcrumb ol {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.25rem 0.375rem;
    list-style: none;
    margin: 0;
    padding: 0;
    font-size: 0.8125rem;
    color: var(--text-muted);
  }
  .breadcrumb a {
    color: var(--text-muted);
    text-decoration: none;
  }
  .breadcrumb a:hover { color: var(--accent); text-decoration: underline; }
  .breadcrumb .sep { color: var(--border-strong); }
  .breadcrumb [aria-current="page"] {
    color: var(--text-subtle);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    max-width: 260px;
  }

  /* ── Article container ──────────────────────────────────────────────────── */
  .article {
    min-width: 0;
    max-width: 720px;
  }

  /* ── Article header ─────────────────────────────────────────────────────── */
  .article-header {
    margin-bottom: 2rem;
  }

  .hero-emoji {
    font-size: 3rem;
    line-height: 1;
    margin-bottom: 1rem;
    display: block;
  }

  .cat-badge {
    display: inline-block;
    font-size: 0.6875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    padding: 0.25rem 0.625rem;
    border-radius: 99px;
    margin-bottom: 0.875rem;
  }

  .article-header h1 {
    font-size: clamp(1.5rem, 4vw, 2.125rem);
    font-weight: 800;
    line-height: 1.2;
    color: var(--text);
    margin: 0 0 0.75rem;
    letter-spacing: -0.02em;
  }

  .article-description {
    font-size: 1.0625rem;
    color: var(--text-muted);
    line-height: 1.6;
    margin: 0 0 1.25rem;
  }

  .meta-line {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.25rem 0.5rem;
    font-size: 0.8125rem;
    color: var(--text-subtle);
  }

  .meta-item {
    display: flex;
    align-items: center;
    gap: 0.3rem;
  }

  .meta-item svg { flex-shrink: 0; }

  .meta-sep { color: var(--border-strong); }

  /* ── TOC mobile ─────────────────────────────────────────────────────────── */
  .toc-mobile {
    background: var(--bg-soft);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 0.75rem 1rem;
    margin-bottom: 2rem;
  }

  .toc-mobile details[open] summary svg { transform: rotate(180deg); }

  .toc-mobile summary {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-weight: 600;
    font-size: 0.9375rem;
    cursor: pointer;
    list-style: none;
    color: var(--text);
  }
  .toc-mobile summary::-webkit-details-marker { display: none; }
  .toc-mobile summary svg { transition: transform 0.2s; }

  @media (min-width: 1024px) {
    .toc-mobile { display: none; }
  }

  /* ── TOC shared list styles ─────────────────────────────────────────────── */
  .toc-list {
    list-style: none;
    margin: 0.75rem 0 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
    counter-reset: toc-counter;
  }

  .toc-list li {
    counter-increment: toc-counter;
  }

  .toc-list a {
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
    font-size: 0.875rem;
    color: var(--text-muted);
    text-decoration: none;
    padding: 0.3rem 0.5rem;
    border-radius: var(--radius-sm);
    line-height: 1.4;
    transition: background 0.12s, color 0.12s;
  }

  .toc-list a::before {
    content: counter(toc-counter) ".";
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--border-strong);
    flex-shrink: 0;
  }

  .toc-list a:hover,
  .toc-list a.active {
    color: var(--accent);
    background: var(--accent-soft);
  }

  /* ── Sidebar TOC ────────────────────────────────────────────────────────── */
  .toc-sidebar {
    display: none;
  }

  @media (min-width: 1024px) {
    .toc-sidebar {
      display: block;
    }

    .toc-sticky {
      position: sticky;
      top: 5rem;
      background: var(--bg-soft);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 1rem 1.25rem;
    }

    .toc-title {
      font-size: 0.75rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: var(--text-subtle);
      margin-bottom: 0.5rem;
    }
  }

  /* ── YMYL Disclaimer ─────────────────────────────────────────────────────── */
  .post-disclaimer {
    display: flex;
    gap: 0.875rem;
    align-items: flex-start;
    margin: 0 0 2rem;
    padding: 1rem 1.25rem;
    background: #fffbeb;
    border: 1px solid #fde68a;
    border-left: 4px solid #f59e0b;
    border-radius: var(--radius-sm);
    color: #78350f;
    font-size: 0.9375rem;
    line-height: 1.6;
  }
  .post-disclaimer svg { flex-shrink: 0; color: #d97706; margin-top: 3px; }
  .post-disclaimer p { margin: 0; }
  .post-disclaimer a { color: #92400e; font-weight: 600; }
  :root[data-theme="dark"] .post-disclaimer {
    background: rgba(180, 83, 9, 0.15);
    border-color: rgba(245, 158, 11, 0.4);
    color: #fde68a;
  }
  :root[data-theme="dark"] .post-disclaimer a { color: #fbbf24; }

  .post-disclaimer-bottom {
    margin: 2.5rem 0 1.5rem;
    padding: 1rem 1.25rem;
    background: var(--bg-soft);
    border: 1px solid var(--border);
    border-left: 3px solid var(--accent);
    border-radius: var(--radius-sm);
    color: var(--text-muted);
    font-size: 0.9375rem;
    line-height: 1.6;
  }
  .post-disclaimer-bottom p { margin: 0; }

  /* ── Prose / Article body ───────────────────────────────────────────────── */
  .prose {
    font-size: 1.0625rem;
    line-height: 1.75;
    color: var(--text);
  }

  .prose :global(h2) {
    font-size: 1.5rem;
    font-weight: 700;
    line-height: 1.25;
    color: var(--text);
    margin: 2.5rem 0 1rem;
    letter-spacing: -0.015em;
    padding-bottom: 0.5rem;
    border-bottom: 2px solid var(--border);
    scroll-margin-top: 4.5rem;
  }

  .prose :global(h3) {
    font-size: 1.1875rem;
    font-weight: 700;
    line-height: 1.3;
    color: var(--text);
    margin: 2rem 0 0.75rem;
    scroll-margin-top: 4.5rem;
  }

  .prose :global(h4) {
    font-size: 1rem;
    font-weight: 700;
    color: var(--text);
    margin: 1.5rem 0 0.5rem;
  }

  .prose :global(p) {
    margin: 0 0 1.25rem;
  }

  .prose :global(a) {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-thickness: 1px;
  }
  .prose :global(a:hover) {
    color: var(--accent-hover);
  }

  .prose :global(ul),
  .prose :global(ol) {
    margin: 0 0 1.25rem 1.5rem;
    padding: 0;
  }

  .prose :global(li) {
    margin-bottom: 0.4rem;
