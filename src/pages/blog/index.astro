---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Newsletter from '../../components/Newsletter.astro';

// Load all published blog posts from content/blog/*.json
const postModules = import.meta.glob('../../content/blog/*.json', { eager: true });

interface BlogPost {
  slug: string;
  title: string;
  description: string;
  category: string;
  date: string;
  readingTime: number;
  heroEmoji: string;
  seoKeywords?: string[];
}

const allPosts: BlogPost[] = Object.values(postModules) as BlogPost[];

// Sort by date descending
const posts = allPosts.sort(
  (a, b) => new Date(b.date).getTime() - new Date(a.date).getTime()
);

// Which "planned" topics have NOT yet been published as posts
const publishedSlugs = new Set(posts.map((p) => p.slug));

const plannedArticulos = [
  {
    cat: 'finanzas',
    titulo: 'Cómo se calcula el sueldo en mano en Argentina paso a paso',
    bajada: 'Aportes, descuentos, ganancias: la fórmula completa con un ejemplo real.',
    slug: 'como-calcular-sueldo-en-mano-argentina',
  },
  {
    cat: 'finanzas',
    titulo: 'Plazo fijo vs UVA vs dólar: cuál te conviene este mes',
    bajada: 'Comparativa con TNA actualizada y simulación a 30, 60 y 90 días.',
    slug: 'plazo-fijo-vs-uva-vs-dolar',
  },
  {
    cat: 'finanzas',
    titulo: 'Monotributo 2026: nuevas escalas y cuándo recategorizar',
    bajada: 'Tabla actualizada de cuotas, topes y obra social por categoría.',
    slug: 'monotributo-2026-escalas-recategorizar',
  },
  {
    cat: 'finanzas',
    titulo: 'Indemnización por despido: cómo calcular el mejor remunerativo',
    bajada: 'Errores comunes que te pueden costar varios sueldos.',
    slug: 'indemnizacion-despido-mejor-remunerativo',
  },
  {
    cat: 'salud',
    titulo: 'IMC, grasa corporal y TDEE: qué mide cada cosa y cuál te sirve',
    bajada: 'Las 3 calculadoras de salud más buscadas, explicadas sin tecnicismos.',
    slug: 'imc-grasa-corporal-tdee-diferencias',
  },
  {
    cat: 'salud',
    titulo: 'Calorías para bajar de peso: el método Mifflin-St Jeor',
    bajada: 'Por qué las "calculadoras de calorías" online suelen darte mal.',
    slug: 'calorias-bajar-peso-mifflin-st-jeor',
  },
  {
    cat: 'negocios',
    titulo: 'Markup vs margen: el error que arruina los precios de tu negocio',
    bajada: 'Diferencias prácticas y cómo subir precios sin perder clientes.',
    slug: 'markup-vs-margen-precios-negocio',
  },
  {
    cat: 'marketing',
    titulo: 'CAC, LTV y payback: las tres métricas que definen si tu negocio escala',
    bajada: 'Fórmulas, benchmarks por industria y cómo mejorarlas.',
    slug: 'cac-ltv-payback-metricas-negocio',
  },
  {
    cat: 'vida',
    titulo: 'Calcular gastos compartidos: la mejor forma de no pelearte con tus amigos',
    bajada: 'Tres métodos para dividir cuentas (proporcional, igualitario, ponderado).',
    slug: 'calcular-gastos-compartidos-metodos',
  },
].filter((a) => !publishedSlugs.has(a.slug));

// Format date: "15 abril 2026"
function formatDate(dateStr: string): string {
  const d = new Date(dateStr + 'T12:00:00');
  return d.toLocaleDateString('es-AR', { day: 'numeric', month: 'long', year: 'numeric' });
}

const hasPosts = posts.length > 0;
const featuredPost = hasPosts ? posts[0] : null;
const restPosts = hasPosts ? posts.slice(1) : [];

const description = hasPosts
  ? 'Artículos prácticos sobre finanzas personales, salud, negocios y matemática aplicada. ' +
    'Con cobertura específica para Argentina en sueldos, impuestos y monotributo. Sin tecnicismos, con ejemplos reales.'
  : 'Próximamente: artículos sobre finanzas personales, salud, negocios y matemática práctica ' +
    'para todo el mundo hispanohablante, con cobertura específica para Argentina (sueldos, impuestos, monotributo). ' +
    'Suscribite al newsletter para enterarte cuando publiquemos.';

const blogPostingEntries = posts.map((p) => ({
  '@type': 'BlogPosting',
  headline: p.title,
  description: p.description,
  datePublished: p.date,
  url: `https://hacecuentas.com/blog/${p.slug}`,
  author: {
    '@type': 'Organization',
    name: 'Hacé Cuentas',
    url: 'https://hacecuentas.com',
  },
  publisher: {
    '@type': 'Organization',
    name: 'Hacé Cuentas',
    url: 'https://hacecuentas.com',
    logo: 'https://hacecuentas.com/favicon.svg',
  },
  inLanguage: 'es',
}));

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Blog',
  '@id': 'https://hacecuentas.com/blog#blog',
  name: 'Blog de Hacé Cuentas',
  description,
  url: 'https://hacecuentas.com/blog',
  inLanguage: ['es', 'es-AR', 'es-419'],
  publisher: {
    '@type': 'Organization',
    name: 'Hacé Cuentas',
    url: 'https://hacecuentas.com',
    logo: 'https://hacecuentas.com/favicon.svg',
  },
  ...(blogPostingEntries.length > 0 && { blogPost: blogPostingEntries }),
};
---

<Layout
  title="Blog | Hacé Cuentas"
  description={description}
  schema={schema}
>
  <Header slot="header" />

  <article class="blog-index">
    <nav class="breadcrumbs" aria-label="Migas de pan">
      <a href="/">Inicio</a>
      <span aria-hidden="true">›</span>
      <span aria-current="page">Blog</span>
    </nav>

    <header class="hero">
      <h1>Blog</h1>
      <p class="lead">
        Artículos prácticos sobre finanzas personales, salud, negocios y todo
        lo que quieras calcular bien. Universales para hispanohablantes, con
        cobertura específica para Argentina <span aria-hidden="true">🇦🇷</span> en
        sueldos, impuestos y monotributo. Sin tecnicismos, con ejemplos reales y fuentes oficiales.
      </p>
    </header>

    {hasPosts ? (
      <section class="posts-section">
        {/* Featured post — full width */}
        {featuredPost && (
          <a href={`/blog/${featuredPost.slug}`} class="post-card post-card--featured">
            <div class="post-card__emoji" aria-hidden="true">{featuredPost.heroEmoji}</div>
            <div class="post-card__body">
              <span class={`cat-tag cat-${featuredPost.category}`}>{featuredPost.category}</span>
              <h2 class="post-card__title">{featuredPost.title}</h2>
              <p class="post-card__desc">{featuredPost.description}</p>
              <div class="post-card__meta">
                <time datetime={featuredPost.date}>{formatDate(featuredPost.date)}</time>
                <span class="meta-dot" aria-hidden="true">·</span>
                <span>{featuredPost.readingTime} min de lectura</span>
              </div>
            </div>
          </a>
        )}

        {/* Rest of posts — 2-column grid */}
        {restPosts.length > 0 && (
          <ul class="posts-grid">
            {restPosts.map((post) => (
              <li>
                <a href={`/blog/${post.slug}`} class="post-card">
                  <div class="post-card__emoji" aria-hidden="true">{post.heroEmoji}</div>
                  <div class="post-card__body">
                    <span class={`cat-tag cat-${post.category}`}>{post.category}</span>
                    <h3 class="post-card__title">{post.title}</h3>
                    <p class="post-card__desc">{post.description}</p>
                    <div class="post-card__meta">
                      <time datetime={post.date}>{formatDate(post.date)}</time>
                      <span class="meta-dot" aria-hidden="true">·</span>
                      <span>{post.readingTime} min de lectura</span>
                    </div>
                  </div>
                </a>
              </li>
            ))}
          </ul>
        )}
      </section>
    ) : null}

    {/* Planned articles (only if there are unpublished ones left) */}
    {plannedArticulos.length > 0 && (
      <section class="upcoming">
        <h2>{hasPosts ? 'Próximamente' : 'Lo que estamos preparando'}</h2>
        <p class="upcoming-intro">
          {hasPosts
            ? 'Artículos que estamos terminando de preparar.'
            : 'Estos son algunos de los artículos que publicaremos primero. ¿Te falta alguno?'}{' '}
          <a href="/contacto">Sugerinos un tema.</a>
        </p>
        <ul class="article-list">
          {plannedArticulos.map((a) => (
            <li class="article-item">
              <span class={`cat-tag cat-${a.cat}`}>{a.cat}</span>
              <h3>{a.titulo}</h3>
              <p>{a.bajada}</p>
            </li>
          ))}
        </ul>
      </section>
    )}

    <section class="meanwhile">
      <h2>Mientras tanto</h2>
      <p>
        Tenemos más de <strong>100 calculadoras gratis</strong> con explicaciones
        paso a paso, fórmulas y fuentes. Cada una incluye un glosario corto y
        ejemplos para que entiendas qué estás calculando, no solo el resultado.
      </p>
      <div class="quick-links">
        <a href="/categoria/finanzas" class="ql-card">
          <span class="ql-icon">💰</span>
          <span class="ql-title">Calculadoras de finanzas</span>
          <span class="ql-arrow">→</span>
        </a>
        <a href="/categoria/salud" class="ql-card">
          <span class="ql-icon">❤️</span>
          <span class="ql-title">Calculadoras de salud</span>
          <span class="ql-arrow">→</span>
        </a>
        <a href="/glosario" class="ql-card">
          <span class="ql-icon">📚</span>
          <span class="ql-title">Glosario de términos</span>
          <span class="ql-arrow">→</span>
        </a>
        <a href="/buscar" class="ql-card">
          <span class="ql-icon">🔎</span>
          <span class="ql-title">Buscar una calculadora</span>
          <span class="ql-arrow">→</span>
        </a>
      </div>
    </section>

    <Newsletter />
  </article>

  <Footer slot="footer" />
</Layout>

<style>
  .blog-index {
    max-width: 880px;
    margin: 1rem auto 2rem;
    padding: 0 1rem;
  }

  /* ── Breadcrumbs ── */
  .breadcrumbs {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.875rem;
    color: var(--text-subtle);
    margin-bottom: 1.5rem;
  }
  .breadcrumbs a { color: var(--text-muted); text-decoration: none; }
  .breadcrumbs a:hover { color: var(--accent); }

  /* ── Hero ── */
  .hero {
    text-align: center;
    padding: 2rem 0 2.5rem;
    border-bottom: 1px solid var(--border);
    margin-bottom: 2.5rem;
  }
  .hero h1 {
    font-size: clamp(2rem, 4.5vw, 2.75rem);
    margin-bottom: 1rem;
  }
  .hero .lead {
    font-size: 1.0625rem;
    color: var(--text-muted);
    max-width: 640px;
    margin: 0 auto;
    line-height: 1.6;
  }

  /* ── Category badges ── */
  .cat-tag {
    display: inline-block;
    font-size: 0.6875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    padding: 0.1875rem 0.5rem;
    border-radius: 4px;
    margin-bottom: 0.5rem;
  }
  .cat-finanzas  { background: #fef3c7; color: #92400e; }
  .cat-salud     { background: #fce7f3; color: #9d174d; }
  .cat-marketing { background: #ddd6fe; color: #5b21b6; }
  .cat-negocios  { background: #d1fae5; color: #065f46; }
  .cat-vida      { background: #dbeafe; color: #1e40af; }
  .cat-matematica { background: #fef9c3; color: #713f12; }
  .cat-educacion { background: #e0f2fe; color: #0369a1; }

  :global([data-theme="dark"]) .cat-finanzas   { background: #78350f33; color: #fcd34d; }
  :global([data-theme="dark"]) .cat-salud      { background: #831843aa; color: #f9a8d4; }
  :global([data-theme="dark"]) .cat-marketing  { background: #4c1d9544; color: #c4b5fd; }
  :global([data-theme="dark"]) .cat-negocios   { background: #064e3b44; color: #6ee7b7; }
  :global([data-theme="dark"]) .cat-vida       { background: #1e3a8a44; color: #93c5fd; }
  :global([data-theme="dark"]) .cat-matematica { background: #78350f22; color: #fde68a; }
  :global([data-theme="dark"]) .cat-educacion  { background: #0c4a6e44; color: #7dd3fc; }

  /* ── Posts section ── */
  .posts-section {
    margin-bottom: 3rem;
  }

  /* Featured card */
  .post-card--featured {
    display: flex;
    gap: 1.5rem;
    align-items: flex-start;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.75rem;
    text-decoration: none;
    color: inherit;
    transition: border-color 0.15s, transform 0.15s, box-shadow 0.15s;
    margin-bottom: 1.5rem;
    width: 100%;
  }
  .post-card--featured:hover {
    border-color: var(--accent);
    transform: translateY(-2px);
    box-shadow: 0 4px 16px rgba(0,0,0,0.07);
    text-decoration: none;
    color: inherit;
  }
  .post-card--featured .post-card__emoji {
    font-size: 3rem;
    line-height: 1;
    flex-shrink: 0;
    margin-top: 0.125rem;
  }
  .post-card--featured .post-card__title {
    font-size: 1.375rem;
    line-height: 1.3;
    margin-bottom: 0.625rem;
    color: var(--text);
  }
  .post-card--featured .post-card__desc {
    font-size: 0.9375rem;
    color: var(--text-muted);
    line-height: 1.55;
    margin-bottom: 0.875rem;
  }

  /* Grid of remaining posts */
  .posts-grid {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
  }

  /* Regular post card (in grid) */
  .post-card {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.25rem;
    text-decoration: none;
    color: inherit;
    height: 100%;
    transition: border-color 0.15s, transform 0.15s, box-shadow 0.15s;
  }
  .post-card:hover {
    border-color: var(--accent);
    transform: translateY(-2px);
    box-shadow: 0 4px 16px rgba(0,0,0,0.07);
    text-decoration: none;
    color: inherit;
  }
  .post-card .post-card__emoji {
    font-size: 2rem;
    line-height: 1;
  }
  .post-card .post-card__title {
    font-size: 1rem;
    line-height: 1.35;
    margin-bottom: 0.375rem;
    color: var(--text);
  }
  .post-card .post-card__desc {
    font-size: 0.875rem;
    color: var(--text-muted);
    line-height: 1.5;
    flex: 1;
    margin-bottom: 0.5rem;
  }

  /* Shared card body */
  .post-card__body {
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  .post-card__meta {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.8125rem;
    color: var(--text-subtle);
  }
  .meta-dot { opacity: 0.5; }

  /* ── Upcoming (planned) ── */
  section { margin-bottom: 3rem; }

  .upcoming h2,
  .meanwhile h2 {
    font-size: 1.375rem;
    margin-bottom: 0.5rem;
  }
  .upcoming-intro {
    color: var(--text-muted);
    margin-bottom: 1.5rem;
    font-size: 0.9375rem;
  }
  .upcoming-intro a { color: var(--accent); font-weight: 500; }

  .article-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1rem;
  }
  .article-item {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.25rem;
    transition: border-color 0.15s, transform 0.15s;
  }
  .article-item:hover {
    border-color: var(--border-strong);
    transform: translateY(-2px);
  }
  .article-item h3 {
    font-size: 1rem;
    line-height: 1.35;
    margin-bottom: 0.5rem;
    color: var(--text);
  }
  .article-item p {
    font-size: 0.875rem;
    color: var(--text-muted);
    line-height: 1.5;
    margin: 0;
  }

  /* ── Meanwhile quick links ── */
  .meanwhile p {
    color: var(--text-muted);
    line-height: 1.65;
    margin-bottom: 1.5rem;
  }
  .meanwhile strong { color: var(--text); }

  .quick-links {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 0.75rem;
  }
  .ql-card {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    padding: 0.875rem 1rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    text-decoration: none;
    color: var(--text);
    transition: all 0.15s;
  }
  .ql-card:hover {
    border-color: var(--accent);
    color: var(--accent);
    transform: translateY(-1px);
    text-decoration: none;
  }
  .ql-icon { font-size: 1.25rem; }
  .ql-title { flex: 1; font-weight: 500; font-size: 0.9375rem; }
  .ql-arrow { color: var(--text-subtle); transition: transform 0.15s; }
  .ql-card:hover .ql-arrow { transform: translateX(2px); color: var(--accent); }

  /* ── Responsive ── */
  @media (max-width: 640px) {
    .post-card--featured {
      flex-direction: column;
      gap: 0.75rem;
    }
    .post-card--featured .post-card__emoji {
      font-size: 2.25rem;
    }
    .posts-grid {
      grid-template-columns: 1fr;
    }
    .article-list {
      grid-template-columns: 1fr;
    }
  }
</style>
