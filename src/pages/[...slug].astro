        {sources.length > 0 && (
          <section id="fuentes" class="sources-box" aria-labelledby="sources-heading">
            <h2 id="sources-heading">Fuentes y referencias</h2>
            <ul>
              {sources.map((s: any) => (
                <li>
                  {s.url
                    ? <a href={s.url} target="_blank" rel="noopener nofollow">{s.name}</a>
                    : <span>{s.name}</span>
                  }
                </li>
              ))}
            </ul>
          </section>
        )}

        <section class="trust-block" id="metodologia" aria-labelledby="trust-heading">
          <h2 id="trust-heading">Metodología y confianza</h2>
          <div class="trust-grid">
            <div class="trust-item">
              <span class="trust-label">Editorial</span>
              <p>Contenido revisado por el <a href="/sobre-nosotros">equipo editorial de Hacé Cuentas</a>, con apego a nuestra <a href="/politica-editorial">política editorial</a> y <a href="/metodologia">metodología de cálculo</a>.</p>
            </div>
            <div class="trust-item">
              <span class="trust-label">Actualización</span>
              <p>Última revisión: <strong>{updated}</strong>. Los parámetros fiscales, legales y datos se verifican periódicamente con las fuentes citadas.</p>
            </div>
            <div class="trust-item">
              <span class="trust-label">Privacidad</span>
              <p>Los cálculos corren 100% en tu navegador. No guardamos ni transmitimos tus datos. Leé nuestra <a href="/privacidad">política de privacidad</a>.</p>
            </div>
            <div class="trust-item">
              <span class="trust-label">Limitaciones</span>
              <p>Resultados orientativos. Para decisiones financieras, médicas o legales críticas, consultá con un profesional.</p>
            </div>
          </div>
        </section>

        {relatedContextual.length > 0 && (
          <section class="also-see" aria-labelledby="also-heading">
            <h2 id="also-heading">También te puede interesar</h2>
            <div class="also-grid">
              {relatedContextual.map((c: any) => (
                <a href={`/${c.slug}`} class="also-card">
                  <span class="also-icon" aria-hidden="true">{c.icon}</span>
                  <span class="also-body">
                    <span class="also-title">{c.h1}</span>
                    <span class="also-desc">{c.description}</span>
                  </span>
                </a>
              ))}
            </div>
          </section>
        )}

        <RelatedCalcs currentSlug={calc.slug} category={calc.category} limit={4} manualSlugs={relatedSlugs} />

        {pillarGuideSlug && pillarGuideTitle && (
          <aside class="guide-link-cta">
            <span class="guide-link-icon" aria-hidden="true">📘</span>
            <div class="guide-link-body">
              <span class="guide-link-eyebrow">¿Querés entender más a fondo?</span>
              <strong>Leé la guía: {pillarGuideTitle}</strong>
              <span class="guide-link-desc">Contexto, conceptos y cómo combinar calculadoras del tema.</span>
            </div>
            <a href={`/guia/${pillarGuideSlug}`} class="guide-link-btn">Abrir guía →</a>
          </aside>
        )}

        <aside class="cta-back">
          <p>¿Buscabas otra calculadora?</p>
          <a href="/" class="btn-ghost">Ver todas las calculadoras →</a>
          <p class="cta-suggest">¿No encontrás lo que buscás? <a href="mailto:ideas@hacecuentas.com?subject=Idea de calculadora&body=Me gustaría que Hacé Cuentas tenga una calculadora de...">Pedí una calculadora nueva →</a></p>
        </aside>
      </div>
    </div>
  </article>

  {hasMath && (
    <Fragment>
      <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.11/dist/katex.min.css" integrity="sha384-nB0miv6/jRmo5UMMR1wu3Gz6NLsoTkbqJghGIsx//Rlm+ZU03BU6SQNC66uf4l5+" crossorigin="anonymous" />
      <script defer src="https://cdn.jsdelivr.net/npm/katex@0.16.11/dist/katex.min.js" integrity="sha384-7zkQWkzuo3B5mTepMUcHkMB5jZaolc2xDwL6VFqjFALcbeS9Ggm/Yr2r3Dy4lfFg" crossorigin="anonymous"></script>
      <script defer src="https://cdn.jsdelivr.net/npm/katex@0.16.11/dist/contrib/auto-render.min.js" integrity="sha384-43gviWU0YVjaDtb/GhzOouOXtZMP/7XUzwPTstBeZFe/+rCMvRwr4yROQP43s0Xk" crossorigin="anonymous" onload="renderMathInElement(document.querySelector('#como-funciona'), {delimiters:[{left:'$$',right:'$$',display:true},{left:'$',right:'$',display:false},{left:'\\\\(',right:'\\\\)',display:false},{left:'\\\\[',right:'\\\\]',display:true}], throwOnError:false});"></script>
    </Fragment>
  )}

  <script is:inline>
    (function () {
      // Thumbs feedback — guarda en D1 vía /api/vote + GA4.
      var feedback = document.querySelector('.ca-feedback');
      if (feedback) {
        var slug = window.location.pathname;
        var key = 'hc-vote-' + slug;
        var prev = null;
        try { prev = localStorage.getItem(key); } catch (e) {}
        if (prev === 'up' || prev === 'down') {
          renderThanks(prev);
        }
        feedback.querySelectorAll('.ca-vote').forEach(function (btn) {
          btn.addEventListener('click', function () {
            var v = btn.getAttribute('data-vote');
            try { localStorage.setItem(key, v); } catch (e) {}
            renderThanks(v);
            // GA4
            if (typeof window.gtag === 'function') {
              window.gtag('event', 'calc_feedback', { value: v, slug: slug });
            }
            // D1 vía API (fire-and-forget, no bloqueamos UX si falla)
            try {
              fetch('/api/vote', {
                method: 'POST',
                headers: { 'content-type': 'application/json' },
                body: JSON.stringify({ slug: slug, vote: v }),
                keepalive: true,
              }).catch(function () {});
            } catch (e) {}
          });
        });
        function renderThanks(v) {
          if (v === 'up') {
            feedback.setAttribute('data-state', 'thanks');
            feedback.innerHTML = '<span class="ca-msg">¡Gracias por tu voto! 🙌</span>';
          } else {
            // Para 👎 mostramos un form inline en vez de mailto (que no llegaba a nadie).
            feedback.setAttribute('data-state', 'sorry');
            feedback.innerHTML =
              '<span class="ca-msg">Gracias. ¿Qué falta o está mal? Contanos:</span>' +
              '<form class="ca-err-form" id="ca-err-form">' +
              '  <textarea name="message" required placeholder="Ej: la fórmula devuelve X pero debería ser Y" rows="3" maxlength="2000"></textarea>' +
              '  <input type="email" name="email" placeholder="Tu email (opcional, para responderte)" />' +
              '  <button type="submit">Enviar</button>' +
              '  <p class="ca-err-msg" hidden></p>' +
              '</form>';
            var form = document.getElementById('ca-err-form');
            var emsg = form.querySelector('.ca-err-msg');
            form.addEventListener('submit', async function (e) {
              e.preventDefault();
              var fd = new FormData(form);
              var btn2 = form.querySelector('button');
              btn2.disabled = true;
              emsg.hidden = false;
              emsg.textContent = 'Enviando…';
              try {
                var res = await fetch('/api/error-report', {
                  method: 'POST',
                  headers: { 'content-type': 'application/json' },
                  body: JSON.stringify({
                    slug: slug,
                    message: String(fd.get('message') || ''),
                    email: String(fd.get('email') || ''),
                  }),
                });
                if (res.ok) {
                  feedback.innerHTML = '<span class="ca-msg">¡Gracias! Ya recibimos tu reporte y lo revisamos.</span>';
                } else {
                  var j = await res.json().catch(function () { return {}; });
                  emsg.textContent = j.error || 'No se pudo enviar. Probá más tarde.';
                  btn2.disabled = false;
                }
              } catch (err) {
                emsg.textContent = 'Error de red.';
                btn2.disabled = false;
              }
            });
          }
        }
      }

      // Compartir
      var shareBtn = document.getElementById('ca-share');
      if (shareBtn) {
        shareBtn.addEventListener('click', async function () {
          var url = shareBtn.getAttribute('data-url');
          var title = shareBtn.getAttribute('data-title');
          if (navigator.share) {
            try { await navigator.share({ title: title, url: url }); } catch (e) {}
          } else if (navigator.clipboard) {
            try {
              await navigator.clipboard.writeText(url);
              var orig = shareBtn.innerHTML;
              shareBtn.innerHTML = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg> ¡Copiado!';
              setTimeout(function () { shareBtn.innerHTML = orig; }, 2000);
            } catch (e) {}
          }
        });
      }

      // TOC scrollspy
      var tocLinks = document.querySelectorAll('[data-toc-link]');
      if (tocLinks.length > 0 && 'IntersectionObserver' in window) {
        var sections = Array.from(tocLinks).map(function (l) {
          return document.getElementById(l.getAttribute('data-toc-link'));
        }).filter(Boolean);
        var observer = new IntersectionObserver(function (entries) {
          entries.forEach(function (entry) {
            if (entry.isIntersecting) {
              tocLinks.forEach(function (l) { l.classList.remove('active'); });
              var match = document.querySelector('[data-toc-link="' + entry.target.id + '"]');
              if (match) match.classList.add('active');
            }
          });
        }, { rootMargin: '-80px 0px -60% 0px' });
        sections.forEach(function (s) { observer.observe(s); });
      }

      // Floating recalculate FAB (mobile only)
      var fab = document.getElementById('fab-recalc');
      if (fab && window.innerWidth < 1100) {
        var calcSection = document.getElementById('calculadora');
        if (calcSection) {
          var resultsEl = calcSection.querySelector('.calc-results');
          var calcObs = new IntersectionObserver(function (entries) {
            entries.forEach(function (entry) {
              if (resultsEl && !resultsEl.hidden && !entry.isIntersecting) {
                fab.hidden = false;
              } else {
                fab.hidden = true;
              }
            });
          }, { threshold: 0 });
          calcObs.observe(calcSection);
          fab.addEventListener('click', function () {
            calcSection.scrollIntoView({ behavior: 'smooth', block: 'start' });
          });
        }
      }
    })();
  </script>

  <!-- Floating recalculate (mobile only, post-result) -->
  <div class="fab-recalc" id="fab-recalc" hidden aria-label="Volver a calcular">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 1 0 2.13-9.36L1 10"/></svg>
    Recalcular
  </div>

  <ScrollToTop />

  <Footer slot="footer" />
</Layout>

<style>
  .calc-page {
