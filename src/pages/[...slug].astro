---
export const prerender = true;

import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Calculator from '../components/Calculator.astro';
import RelatedCalcs from '../components/RelatedCalcs.astro';
import ogManifest from '../lib/og-manifest.json';
import ClusterHub from '../components/ClusterHub.astro';
import CalendarioFeriados from '../components/CalendarioFeriados.astro';
import GaugeImcPediatrico from '../components/GaugeImcPediatrico.astro';
import GaugeEmbarazo from '../components/GaugeEmbarazo.astro';
import ScrollToTop from '../components/ScrollToTop.astro';
import { findClusterForSlug } from '../lib/clusters';
import { md, mdInline } from '../lib/markdown';
import { CATEGORY_TO_GUIDE, GUIDE_TITLES } from '../lib/category-guide-map';

export async function getStaticPaths() {
  const calcs = import.meta.glob<any>('../content/calcs/*.json', { eager: true });
  return Object.values(calcs).map((mod: any) => {
    const c = mod.default || mod;
    return {
      params: { slug: c.slug },
      props: { calc: c },
    };
  });
}

const { calc } = Astro.props;

// Cargar calcs de otros locales para hreflang bidireccional
const enCalcModules = import.meta.glob<any>('../content/calcs-en/*.json', { eager: true });
const enCalcs = Object.values(enCalcModules).map((m: any) => m.default || m);
const ptCalcModules = import.meta.glob<any>('../content/calcs-pt/*.json', { eager: true });
const ptCalcs = Object.values(ptCalcModules).map((m: any) => m.default || m);
const mxCalcModules = import.meta.glob<any>('../content/calcs-mx/*.json', { eager: true });
const mxCalcs = Object.values(mxCalcModules).map((m: any) => m.default || m);
const esCalcModules = import.meta.glob<any>('../content/calcs-es/*.json', { eager: true });
const esCalcs = Object.values(esCalcModules).map((m: any) => m.default || m);

// Markdown simple → HTML
// Escape HTML antes de inyectar en templates. Defense-in-depth por si un JSON
// contribuido externamente contiene <script> o eventos inline.
function escHtml(s: string): string {
  return s.replace(/[&<>"']/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c]!));
}
// Escape para atributos href — solo permite protocolos seguros
function safeUrl(u: string): string {
  const trimmed = u.trim();
  // Permitir solo http(s), mailto, tel, anchors y relative paths
  if (/^(https?:|mailto:|tel:|#|\/)/i.test(trimmed)) {
    return escHtml(trimmed);
  }
  return '#'; // bloquear javascript:, data:, etc.
}

const categoryLabels: Record<string, string> = {
  finanzas: 'Finanzas',
  negocios: 'Negocios',
  negocio: 'Negocios',
  salud: 'Salud',
  marketing: 'Marketing',
  deportes: 'Deportes',
  viajes: 'Viajes',
  vida: 'Vida cotidiana',
  mascotas: 'Mascotas',
  matematica: 'Matemática',
  construccion: 'Construcción',
  cocina: 'Cocina',
  educacion: 'Educación',
  automotor: 'Automotor',
  tecnologia: 'Tecnología',
  'medio-ambiente': 'Medio Ambiente',
  electronica: 'Electrónica',
};

// dateModified = lastReviewed del JSON > mtime del archivo > build date
let dateModified: string;
let lastReviewedLabel: string;
// OG image: se usa /og/{slug}.png si la slug figura en el manifest generado
// en pre-build (scripts/generate-og-manifest.ts). Fallback al default.
// No podemos usar fs directo acá porque con output:'server' el frontmatter
// corre en el runtime Cloudflare Workers (que no tiene node:fs).
let ogImage = '/og-default.png';
if ((ogManifest as Record<string, boolean>)[calc.slug]) {
  ogImage = `/og/${calc.slug}.png`;
}

// dateModified: de calc.lastReviewed si declarado, sino build date
if (calc.lastReviewed && /^\d{4}-\d{2}-\d{2}$/.test(calc.lastReviewed)) {
  dateModified = new Date(calc.lastReviewed + 'T00:00:00Z').toISOString();
} else {
  dateModified = new Date().toISOString();
}
lastReviewedLabel = new Date(dateModified).toLocaleDateString('es-AR', {
  day: '2-digit',
  month: 'long',
  year: 'numeric',
});
const datePublished = '2025-09-01T00:00:00Z';

// audience: 'AR' = específica para Argentina; 'global' (default) = aplica en todo el mundo hispanohablante
const audience: 'AR' | 'global' = calc.audience === 'AR' ? 'AR' : 'global';
const schemaLang = audience === 'AR' ? 'es-AR' : 'es';

/**
 * Description "safe" para schemas structured data. Google Rich Results exige
 * longitud mínima (~50 chars) en varios tipos (Dataset, SoftwareApplication,
 * Article); descriptions cortas caen como "La longitud de cadena del campo
 * description no es válida" en Search Console.
 *
 * Estrategia: partir de calc.description, y si es corta completar con h1,
 * keyTakeaway y category label — contenido real, no padding artificial.
 * Cap a 500 chars para no inflar el HTML innecesariamente.
 */
function buildSchemaDescription(c: any): string {
  const base = (c.description || '').trim();
  if (base.length >= 50) return base.slice(0, 500);
  const parts = [base];
  if (c.h1) parts.push(c.h1);
  if (c.keyTakeaway) parts.push(String(c.keyTakeaway).replace(/\*\*/g, ''));
  const catLabel = categoryLabels[c.category] || c.category;
  if (catLabel) parts.push(`Categoría: ${catLabel}.`);
  const merged = parts.filter(Boolean).join(' — ').trim();
  return (merged.length >= 50 ? merged : `${merged} Calculadora gratis, sin registro, resultado inmediato.`).slice(0, 500);
}
const schemaDescription = buildSchemaDescription(calc);

const howToSteps = calc.howToSteps && calc.howToSteps.length > 0
  ? calc.howToSteps
  : calc.fields.map((f: any) => ({
      name: f.label,
      text: f.help || `Ingresá ${f.label.toLowerCase()}`,
    }));

const schemaHowTo = {
  '@context': 'https://schema.org',
  '@type': 'HowTo',
  name: `Cómo usar la ${calc.h1}`,
  description: schemaDescription,
  totalTime: 'PT1M',
  inLanguage: schemaLang,
  step: howToSteps.map((s: any, i: number) => ({
    '@type': 'HowToStep',
    position: i + 1,
    name: s.name,
    text: s.text,
    url: `https://hacecuentas.com/${calc.slug}#paso-${i + 1}`,
  })),
};

const schemaFAQ = calc.faq && calc.faq.length > 0 ? {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: calc.faq.map((f: any) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: {
      '@type': 'Answer',
      text: f.a,
    },
  })),
} : null;

const schemaBreadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Inicio', item: 'https://hacecuentas.com/' },
    { '@type': 'ListItem', position: 2, name: categoryLabels[calc.category] || calc.category, item: `https://hacecuentas.com/categoria/${calc.category}` },
    { '@type': 'ListItem', position: 3, name: calc.h1 },
  ],
};

// SoftwareApplication + WebApplication — Google las usa para web apps / calculadoras
const schemaApp = {
  '@context': 'https://schema.org',
  '@type': ['SoftwareApplication', 'WebApplication'],
  name: calc.h1,
  description: schemaDescription,
  url: `https://hacecuentas.com/${calc.slug}`,
  mainEntityOfPage: `https://hacecuentas.com/${calc.slug}`,
  applicationCategory: 'UtilitiesApplication',
  applicationSubCategory: 'Calculator',
  operatingSystem: 'Any (Web)',
  browserRequirements: 'Requires JavaScript. Requires HTML5.',
  inLanguage: schemaLang,
  isAccessibleForFree: true,
  datePublished,
  dateModified,
  offers: { '@type': 'Offer', price: '0', priceCurrency: audience === 'AR' ? 'ARS' : 'USD' },
  publisher: {
    '@type': 'Organization',
    name: 'Hacé Cuentas',
    url: 'https://hacecuentas.com',
  },
  // Speakable: permite a voice assistants (Alexa, Google Assistant) leer las
  // partes clave de la calc en respuesta a queries de voz.
  speakable: {
    '@type': 'SpeakableSpecification',
    cssSelector: ['h1', '.lead', '.key-takeaway'],
  },
};

// Article schema para categorías YMYL (Finanzas, Salud) y cualquier calc con explanation extensa
const isYMYL = ['finanzas', 'salud', 'negocios', 'mascotas'].includes(calc.category);
const schemaArticle = (isYMYL || (calc.explanation && calc.explanation.length > 1500)) ? {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: calc.h1,
  description: schemaDescription,
  url: `https://hacecuentas.com/${calc.slug}`,
  mainEntityOfPage: `https://hacecuentas.com/${calc.slug}`,
  inLanguage: schemaLang,
  datePublished,
  dateModified,
  author: {
    '@type': 'Organization',
    name: 'Equipo Hacé Cuentas',
    url: 'https://hacecuentas.com/politica-editorial',
  },
  publisher: {
    '@type': 'Organization',
    name: 'Hacé Cuentas',
    url: 'https://hacecuentas.com',
    logo: {
      '@type': 'ImageObject',
      url: 'https://hacecuentas.com/og-default.png',
    },
  },
  about: categoryLabels[calc.category] || calc.category,
  isAccessibleForFree: true,
  citation: calc.sources?.map((s: any) => s.url || s.name).filter(Boolean) || [],
} : null;

const schemaGraph: any[] = [schemaHowTo, schemaBreadcrumb, schemaApp];
if (schemaFAQ) schemaGraph.push(schemaFAQ);
if (schemaArticle) schemaGraph.push(schemaArticle);

// Dataset schema for calcs whose explanation contains markdown tables
const hasTable = calc.explanation && /\|.*\|.*\n\|[-:\s|]+\|/.test(calc.explanation);
if (hasTable) {
  schemaGraph.push({
    '@type': 'Dataset',
    name: `${calc.h1} — Datos y tablas de referencia`,
    description: schemaDescription,
    url: `https://hacecuentas.com/${calc.slug}`,
    inLanguage: schemaLang,
    creator: {
      '@type': 'Organization',
      name: 'Hacé Cuentas',
      url: 'https://hacecuentas.com',
    },
    dateModified,
    license: 'https://creativecommons.org/licenses/by/4.0/',
  });
}

const schema = { '@context': 'https://schema.org', '@graph': schemaGraph };

const updated = lastReviewedLabel;

// Reading time: ~200 palabras/minuto en español
const wordCount = calc.explanation ? calc.explanation.split(/\s+/).length : 0;
const readingMin = Math.max(1, Math.round(wordCount / 200));

// Nuevos campos SEO (todos opcionales)
const sources: Array<{ name: string; url?: string }> = calc.sources || [];
const useCases: string[] = calc.useCases || [];
const example: { title?: string; steps?: string[]; result?: string } | null = calc.example || null;
const keyTakeaway: string = calc.keyTakeaway || '';
const relatedSlugs: string[] = calc.relatedSlugs || [];
const downloads: Array<{ label: string; href: string; description?: string }> = calc.downloads || [];

// Guía pilar del tema (para link contextual de SEO)
// Se puede override con `calc.guideSlug`, si no, se deduce por categoría.
const pillarGuideSlug: string | null = calc.guideSlug || CATEGORY_TO_GUIDE[calc.category] || null;
const pillarGuideTitle: string | null = pillarGuideSlug ? GUIDE_TITLES[pillarGuideSlug] : null;

// Cluster al que pertenece esta calc (embarazo, dólar, etc.)
const cluster = findClusterForSlug(calc.slug);

// Lookup para related links dentro del contenido
const allCalcsModules = import.meta.glob<any>('../content/calcs/*.json', { eager: true });
const allCalcs = Object.values(allCalcsModules).map((m: any) => m.default || m);
const relatedContextual = relatedSlugs
  .map((s) => allCalcs.find((c) => c.slug === s))
  .filter(Boolean);

// TOC: secciones top-level renderizadas (en orden de aparición)
const tocSections: Array<{ id: string; label: string }> = [
  { id: 'calculadora', label: 'Calculadora' },
];
if (keyTakeaway) tocSections.push({ id: 'resumen', label: 'En pocas palabras' });
if (useCases.length > 0) tocSections.push({ id: 'cuando-usar', label: 'Cuándo usar' });
if (example && example.steps) tocSections.push({ id: 'ejemplo', label: 'Ejemplo paso a paso' });
if (calc.explanation) tocSections.push({ id: 'como-funciona', label: 'Cómo funciona' });
if (calc.faq && calc.faq.length > 0) tocSections.push({ id: 'faq', label: 'Preguntas frecuentes' });
if (sources.length > 0) tocSections.push({ id: 'fuentes', label: 'Fuentes y referencias' });

// Detección heurística de fórmulas LaTeX en el explanation (para cargar KaTeX condicional)
const hasMath = calc.explanation && /(\$[^$\n]+\$|\\frac|\\sqrt|\\sum|\\times|\\cdot)/.test(calc.explanation);

// Asunto pre-llenado para "Reportar error"
const reportSubject = encodeURIComponent(`Error en /${calc.slug}`);
const reportBody = encodeURIComponent(
  `Hola Equipo Hacé Cuentas,\n\nEncontré un error en la calculadora "${calc.h1}":\n\nURL: https://hacecuentas.com/${calc.slug}\nDatos que ingresé: \nResultado esperado: \nResultado obtenido: \nFuente / referencia: \n\nGracias.`
);

// hreflang bidireccional: detectar versiones en otros locales por slug similar o matching explícito
const enVersion = enCalcs.find((c: any) => c.esSlug === calc.slug);
const ptVersion = ptCalcs.find((c: any) => c.esSlug === calc.slug);
const mxVersion = mxCalcs.find((c: any) => c.esSlug === calc.slug || (c.slug && c.slug.replace('calculadora-','') === calc.slug.replace('calculadora-','')));
const esVersion = esCalcs.find((c: any) => c.esSlug === calc.slug || (c.slug && c.slug.replace('calculadora-','') === calc.slug.replace('calculadora-','')));

const alternates: Array<{ lang: string; href: string }> = [
  { lang: 'es-AR', href: `https://hacecuentas.com/${calc.slug}` },
];
if (enVersion) alternates.push({ lang: 'en', href: `https://hacecuentas.com/en/${enVersion.slug}` });
if (ptVersion) alternates.push({ lang: 'pt', href: `https://hacecuentas.com/pt/${ptVersion.slug}` });
if (mxVersion) alternates.push({ lang: 'es-MX', href: `https://hacecuentas.com/mx/${mxVersion.slug}` });
if (esVersion) alternates.push({ lang: 'es-ES', href: `https://hacecuentas.com/es/${esVersion.slug}` });
alternates.push({ lang: 'x-default', href: `https://hacecuentas.com/${calc.slug}` });

const hreflangTags = alternates.length > 2 ? alternates : undefined;
---

<Layout
  title={calc.title}
  description={calc.description}
  schema={schema}
  audience={audience}
  image={ogImage}
  hreflang={hreflangTags}
  canonical={calc.canonicalSlug ? `/${calc.canonicalSlug}` : undefined}
>
  <Header slot="header" />

  <article class="calc-page">
    <nav class="breadcrumbs" aria-label="Ruta de navegación">
      <a href="/">Inicio</a>
      <span class="sep" aria-hidden="true">/</span>
      <a href={`/categoria/${calc.category}`}>{categoryLabels[calc.category] || calc.category}</a>
      <span class="sep" aria-hidden="true">/</span>
      <span class="current">{calc.h1}</span>
    </nav>

    <header class="calc-header">
      <div class="header-left">
        <span class="icon-wrap" aria-hidden="true">{calc.icon}</span>
        <div>
          <div class="eyebrow">{categoryLabels[calc.category] || calc.category}</div>
          <h1>{calc.h1}{audience === 'AR' && <span class="ar-badge-h1" title="Específica para Argentina" aria-label="Específica para Argentina">🇦🇷</span>}</h1>
        </div>
      </div>
    </header>

    {(enVersion || ptVersion || mxVersion || esVersion) && (
      <nav class="lang-switch" aria-label="Versiones en otros idiomas">
        <span class="lang-label">También disponible en:</span>
        {ptVersion && <a class="lang-pill" href={`/pt/${ptVersion.slug}`} hreflang="pt" lang="pt"><span aria-hidden="true">🇧🇷</span> Português</a>}
        {enVersion && <a class="lang-pill" href={`/en/${enVersion.slug}`} hreflang="en" lang="en"><span aria-hidden="true">🇺🇸</span> English</a>}
        {mxVersion && <a class="lang-pill" href={`/mx/${mxVersion.slug}`} hreflang="es-MX" lang="es-MX"><span aria-hidden="true">🇲🇽</span> México</a>}
        {esVersion && <a class="lang-pill" href={`/es/${esVersion.slug}`} hreflang="es-ES" lang="es-ES"><span aria-hidden="true">🇪🇸</span> España</a>}
      </nav>
    )}

    <div class="calc-layout">
      {tocSections.length > 2 && (
        <aside class="toc" aria-label="Índice del artículo">
          <div class="toc-title">En esta página</div>
          <ol class="toc-list">
            {tocSections.map((s) => (
              <li><a href={`#${s.id}`} data-toc-link={s.id}>{s.label}</a></li>
            ))}
          </ol>
        </aside>
      )}

      <div class="calc-main">
        {cluster && <ClusterHub cluster={cluster} currentSlug={calc.slug} />}

        <section id="calculadora">
          <Calculator config={calc} />
        </section>

        {calc.slug === 'calculadora-feriados-argentina-2026-calendario' && (
          <CalendarioFeriados />
        )}

        {calc.slug === 'calculadora-indice-masa-corporal-pediatrico' && (
          <GaugeImcPediatrico />
        )}

        {calc.slug === 'calculadora-embarazo' && (
          <GaugeEmbarazo />
        )}

        {downloads.length > 0 && (
          <aside class="calc-downloads" aria-label="Descargas">
            <div class="calc-downloads-head">
              <span class="calc-downloads-icon" aria-hidden="true">⬇️</span>
              <strong>Llevate esto contigo</strong>
            </div>
            <div class="calc-downloads-list">
              {downloads.map((d) => (
                <a href={d.href} download class="calc-download-item">
                  <span class="calc-download-label">{d.label}</span>
                  {d.description && <span class="calc-download-desc">{d.description}</span>}
                </a>
              ))}
            </div>
          </aside>
        )}

        <div class="calc-actions" id="calc-actions">
          <div class="ca-feedback" data-state="ask">
            <span class="ca-q">¿Te resultó útil esta calculadora?</span>
            <div class="ca-buttons">
              <button type="button" class="ca-vote" data-vote="up" aria-label="Sí, me sirvió">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 10v12"/><path d="M15 5.88 14 10h5.83a2 2 0 0 1 1.92 2.56l-2.33 8A2 2 0 0 1 17.5 22H7"/></svg>
                Sí
              </button>
              <button type="button" class="ca-vote" data-vote="down" aria-label="No me sirvió">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 14V2"/><path d="M9 18.12 10 14H4.17a2 2 0 0 1-1.92-2.56l2.33-8A2 2 0 0 1 6.5 2H17"/></svg>
                No
              </button>
            </div>
          </div>
          <div class="ca-tools">
            <button type="button" class="ca-tool" id="ca-share" data-url={`https://hacecuentas.com/${calc.slug}`} data-title={calc.h1}>
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/></svg>
              Compartir
            </button>
            <a class="ca-tool" href={`mailto:errores@hacecuentas.com?subject=${reportSubject}&body=${reportBody}`}>
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 15s1-1 4-1 5 2 8 2 4-1 4-1V3s-1 1-4 1-5-2-8-2-4 1-4 1z"/><line x1="4" y1="22" x2="4" y2="15"/></svg>
              Reportar error
            </a>
          </div>
        </div>

        <p class="intro" set:html={mdInline(calc.intro)}></p>

        {audience === 'AR' && (
          <aside class="audience-notice" role="note" aria-label="Aviso sobre la audiencia de esta calculadora">
            <span class="an-flag" aria-hidden="true">🇦🇷</span>
            <div class="an-body">
              <strong>Calculadora específica para Argentina.</strong>
              Las leyes, escalas y valores usados son los vigentes en Argentina (AFIP/ARCA, BCRA, ANSES). Para otros países los importes no aplican.
            </div>
          </aside>
        )}

        <div class="meta">
          <span class="meta-item" title={`Última revisión: ${updated} · Equipo Hacé Cuentas`}>
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            Última revisión: <strong>{updated}</strong>
          </span>
          <span class="meta-item meta-reviewer">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
            Verificado por <a href="/politica-editorial">Equipo Hacé Cuentas</a>
          </span>
          {sources.length > 0 && (
            <span class="meta-item">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>
              Fuente: {sources.map((s) => s.name).join(', ')}
            </span>
          )}
          {sources.length === 0 && (
            <span class="meta-item">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
              Fórmula explicada
            </span>
          )}
          <span class="meta-item">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            100% privado
          </span>
        </div>

        {keyTakeaway && (
          <aside id="resumen" class="key-takeaway" aria-label="Resumen rápido">
            <div class="kt-icon" aria-hidden="true">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>
