---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Calculator from '../components/Calculator.astro';
import RelatedCalcs from '../components/RelatedCalcs.astro';
import ScrollToTop from '../components/ScrollToTop.astro';

export async function getStaticPaths() {
  const calcs = import.meta.glob<any>('../content/calcs/*.json', { eager: true });
  return Object.values(calcs).map((mod: any) => {
    const c = mod.default || mod;
    return {
      params: { slug: c.slug },
      props: { calc: c },
    };
  });
}

const { calc } = Astro.props;

// Markdown simple → HTML
function md(text: string): string {
  return text
    .replace(/^### (.+)$/gm, '<h3>$1</h3>')
    .replace(/^## (.+)$/gm, '<h2>$1</h2>')
    .replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>')
    .replace(/\*(.+?)\*/g, '<em>$1</em>')
    .replace(/`([^`]+)`/g, '<code>$1</code>')
    .replace(/\[(.+?)\]\((.+?)\)/g, '<a href="$2" rel="noopener">$1</a>')
    .replace(/^\- (.+)$/gm, '<li>$1</li>')
    .replace(/^\| (.+) \|$/gm, (match) => {
      const cells = match.slice(2, -2).split(' | ');
      return '<tr>' + cells.map((c) => `<td>${c}</td>`).join('') + '</tr>';
    })
    .replace(/\n\n/g, '</p><p>')
    .replace(/\n/g, '<br>');
}

const categoryLabels: Record<string, string> = {
  finanzas: 'Finanzas',
  negocios: 'Negocios',
  negocio: 'Negocios',
  salud: 'Salud',
  marketing: 'Marketing',
  deportes: 'Deportes',
  viajes: 'Viajes',
  vida: 'Vida cotidiana',
  mascotas: 'Mascotas',
  matematica: 'Matemática',
  construccion: 'Construcción',
  cocina: 'Cocina',
};

// dateModified = lastReviewed del JSON > mtime del archivo > build date
let dateModified: string;
let lastReviewedLabel: string;
try {
  const { statSync } = await import('node:fs');
  const { fileURLToPath } = await import('node:url');
  const { dirname, join } = await import('node:path');
  const __dir = dirname(fileURLToPath(import.meta.url));
  const filePath = join(__dir, '..', 'content', 'calcs', `${calc.formulaId || calc.slug}.json`);
  // Si el JSON declara lastReviewed (YYYY-MM-DD), tiene precedencia
  if (calc.lastReviewed && /^\d{4}-\d{2}-\d{2}$/.test(calc.lastReviewed)) {
    dateModified = new Date(calc.lastReviewed + 'T00:00:00Z').toISOString();
  } else {
    dateModified = statSync(filePath).mtime.toISOString();
  }
} catch {
  dateModified = new Date().toISOString();
}
lastReviewedLabel = new Date(dateModified).toLocaleDateString('es-AR', {
  day: '2-digit',
  month: 'long',
  year: 'numeric',
});
const datePublished = '2025-09-01T00:00:00Z';

const schemaHowTo = {
  '@context': 'https://schema.org',
  '@type': 'HowTo',
  name: calc.h1,
  description: calc.description,
  totalTime: 'PT1M',
  inLanguage: 'es-AR',
  step: calc.fields.map((f: any, i: number) => ({
    '@type': 'HowToStep',
    position: i + 1,
    name: f.label,
    text: f.help || `Ingresá ${f.label.toLowerCase()}`,
  })),
};

const schemaFAQ = calc.faq && calc.faq.length > 0 ? {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: calc.faq.map((f: any) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: {
      '@type': 'Answer',
      text: f.a,
    },
  })),
} : null;

const schemaBreadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Inicio', item: 'https://hacecuentas.com/' },
    { '@type': 'ListItem', position: 2, name: categoryLabels[calc.category] || calc.category, item: `https://hacecuentas.com/categoria/${calc.category}` },
    { '@type': 'ListItem', position: 3, name: calc.h1 },
  ],
};

// SoftwareApplication + WebApplication — Google las usa para web apps / calculadoras
const schemaApp = {
  '@context': 'https://schema.org',
  '@type': ['SoftwareApplication', 'WebApplication'],
  name: calc.h1,
  description: calc.description,
  url: `https://hacecuentas.com/${calc.slug}`,
  mainEntityOfPage: `https://hacecuentas.com/${calc.slug}`,
  applicationCategory: 'UtilitiesApplication',
  applicationSubCategory: 'Calculator',
  operatingSystem: 'Any (Web)',
  browserRequirements: 'Requires JavaScript. Requires HTML5.',
  inLanguage: 'es-AR',
  isAccessibleForFree: true,
  datePublished,
  dateModified,
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'ARS' },
  publisher: {
    '@type': 'Organization',
    name: 'Hacé Cuentas',
    url: 'https://hacecuentas.com',
  },
};

const schemaGraph: any[] = [schemaHowTo, schemaBreadcrumb, schemaApp];
if (schemaFAQ) schemaGraph.push(schemaFAQ);
const schema = { '@context': 'https://schema.org', '@graph': schemaGraph };

const updated = lastReviewedLabel;

// Reading time: ~200 palabras/minuto en español
const wordCount = calc.explanation ? calc.explanation.split(/\s+/).length : 0;
const readingMin = Math.max(1, Math.round(wordCount / 200));

// Nuevos campos SEO (todos opcionales)
const sources: Array<{ name: string; url?: string }> = calc.sources || [];
const useCases: string[] = calc.useCases || [];
const example: { title?: string; steps?: string[]; result?: string } | null = calc.example || null;
const keyTakeaway: string = calc.keyTakeaway || '';
const relatedSlugs: string[] = calc.relatedSlugs || [];

// Lookup para related links dentro del contenido
const allCalcsModules = import.meta.glob<any>('../content/calcs/*.json', { eager: true });
const allCalcs = Object.values(allCalcsModules).map((m: any) => m.default || m);
const relatedContextual = relatedSlugs
  .map((s) => allCalcs.find((c) => c.slug === s))
  .filter(Boolean);
---

<Layout
  title={calc.title}
  description={calc.description}
  schema={schema}
>
  <Header slot="header" />

  <article class="calc-page">
    <nav class="breadcrumbs" aria-label="Ruta de navegación">
      <a href="/">Inicio</a>
      <span class="sep" aria-hidden="true">/</span>
      <a href={`/categoria/${calc.category}`}>{categoryLabels[calc.category] || calc.category}</a>
      <span class="sep" aria-hidden="true">/</span>
      <span class="current">{calc.h1}</span>
    </nav>

    <header class="calc-header">
      <div class="header-left">
        <span class="icon-wrap" aria-hidden="true">{calc.icon}</span>
        <div>
          <div class="eyebrow">{categoryLabels[calc.category] || calc.category}</div>
          <h1>{calc.h1}</h1>
        </div>
      </div>
      <p class="intro">{calc.intro}</p>
      <div class="meta">
        <span class="meta-item" title={`Última revisión: ${updated} · Equipo Hacé Cuentas`}>
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          Última revisión: <strong>{updated}</strong>
        </span>
        <span class="meta-item meta-reviewer">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
          Verificado por <a href="/politica-editorial">Equipo Hacé Cuentas</a>
        </span>
        {sources.length > 0 && (
          <span class="meta-item">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>
            Fuente: {sources.map((s) => s.name).join(', ')}
          </span>
        )}
        {sources.length === 0 && (
          <span class="meta-item">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            Fórmula explicada
          </span>
        )}
        <span class="meta-item">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          100% privado
        </span>
      </div>
    </header>

    <Calculator config={calc} />

    {keyTakeaway && (
      <aside class="key-takeaway" aria-label="Resumen rápido">
        <div class="kt-icon" aria-hidden="true">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>
        </div>
        <div><strong>En pocas palabras:</strong> <span set:html={md(keyTakeaway)} /></div>
      </aside>
    )}

    {useCases.length > 0 && (
      <section class="use-cases" aria-labelledby="use-cases-heading">
        <h2 id="use-cases-heading">Cuándo usar esta calculadora</h2>
        <ul>
          {useCases.map((u: string) => (
            <li set:html={md(u)} />
          ))}
        </ul>
      </section>
    )}

    {example && example.steps && (
      <section class="example" aria-labelledby="example-heading">
        <h2 id="example-heading">{example.title || 'Ejemplo paso a paso'}</h2>
        <ol class="example-steps">
          {example.steps.map((s: string) => <li set:html={md(s)} />)}
        </ol>
        {example.result && (
          <div class="example-result"><strong>Resultado:</strong> <span set:html={md(example.result)} /></div>
        )}
      </section>
    )}

    {calc.explanation && (
      <section class="explanation">
        <div class="explanation-header">
          <h2 class="explanation-title">Cómo funciona</h2>
          <span class="reading-time">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>
            {readingMin} min de lectura
          </span>
        </div>
        <Fragment set:html={`<p>${md(calc.explanation)}</p>`} />
      </section>
    )}

    {calc.faq && calc.faq.length > 0 && (
      <section class="faq">
        <h2>Preguntas frecuentes</h2>
        <div class="faq-list">
          {calc.faq.map((f: any) => (
            <details>
              <summary>
                <span>{f.q}</span>
                <svg class="chev" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
              </summary>
              <div set:html={`<p>${md(f.a)}</p>`} />
            </details>
          ))}
        </div>
      </section>
    )}

    {sources.length > 0 && (
      <section class="sources-box" aria-labelledby="sources-heading">
        <h2 id="sources-heading">Fuentes y referencias</h2>
        <ul>
          {sources.map((s: any) => (
            <li>
              {s.url
                ? <a href={s.url} target="_blank" rel="noopener nofollow">{s.name}</a>
                : <span>{s.name}</span>
              }
            </li>
          ))}
        </ul>
      </section>
    )}

    {relatedContextual.length > 0 && (
      <section class="also-see" aria-labelledby="also-heading">
        <h2 id="also-heading">También te puede interesar</h2>
        <div class="also-grid">
          {relatedContextual.map((c: any) => (
            <a href={`/${c.slug}`} class="also-card">
              <span class="also-icon" aria-hidden="true">{c.icon}</span>
              <span class="also-body">
                <span class="also-title">{c.h1}</span>
                <span class="also-desc">{c.description}</span>
              </span>
            </a>
          ))}
        </div>
      </section>
    )}

    <RelatedCalcs currentSlug={calc.slug} category={calc.category} limit={4} />

    <aside class="cta-back">
      <p>¿Buscabas otra calculadora?</p>
      <a href="/" class="btn-ghost">Ver todas las calculadoras →</a>
    </aside>
  </article>

  <ScrollToTop />

  <Footer slot="footer" />
</Layout>

<style>
  .calc-page {
    max-width: 780px;
    margin: 0 auto;
  }

  /* Breadcrumbs */
  .breadcrumbs {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.8125rem;
    color: var(--text-subtle);
    margin-bottom: 1.75rem;
  }

  .breadcrumbs a {
    color: var(--text-muted);
    text-decoration: none;
  }

  .breadcrumbs a:hover {
    color: var(--accent);
  }

  .breadcrumbs .sep {
    color: var(--border-strong);
  }

  .breadcrumbs .current {
    color: var(--text);
    font-weight: 500;
  }

  /* Header */
  .calc-header {
    margin-bottom: 2rem;
  }

  .header-left {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1rem;
  }

  .icon-wrap {
    flex-shrink: 0;
    width: 56px;
    height: 56px;
    background: var(--accent-soft);
    border-radius: var(--radius);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.75rem;
  }

  .eyebrow {
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--accent);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 0.25rem;
  }

  .calc-header h1 {
    margin: 0;
    font-size: clamp(1.625rem, 3.5vw, 2.25rem);
    line-height: 1.15;
  }

  .intro {
    font-size: 1rem;
    color: var(--text-muted);
    margin-bottom: 1rem;
    line-height: 1.6;
  }

  .meta-reviewer a {
    color: var(--accent);
    text-decoration: none;
    font-weight: 500;
  }
  .meta-reviewer a:hover { text-decoration: underline; }

  .meta {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    padding-top: 1rem;
    border-top: 1px solid var(--border);
  }

  .meta-item {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.8125rem;
    color: var(--text-subtle);
    font-weight: 500;
  }

  /* Explanation */
  .explanation {
    margin-top: 3rem;
    padding: 2rem 2.25rem;
    background: var(--bg-soft);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
  }

  .explanation-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1.25rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--border);
  }

  .explanation-title {
    margin: 0;
    font-size: 1.375rem;
    font-weight: 700;
  }

  .reading-time {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.8125rem;
    color: var(--text-subtle);
    font-weight: 500;
    white-space: nowrap;
  }

  .explanation :global(h2) {
    margin-top: 0;
    font-size: 1.375rem;
  }

  .explanation :global(h3) {
    margin: 1.75rem 0 0.5rem;
    font-size: 1.0625rem;
  }

  .explanation :global(p) {
    color: var(--text-muted);
    margin-bottom: 0.75rem;
    line-height: 1.7;
  }

  .explanation :global(strong) {
    color: var(--text);
    font-weight: 600;
  }

  .explanation :global(code) {
    background: var(--bg);
    border: 1px solid var(--border);
    padding: 0.125rem 0.375rem;
    border-radius: var(--radius-sm);
    font-family: var(--font-mono);
    font-size: 0.8125em;
    color: var(--accent-strong);
  }

  .explanation :global(ul),
  .explanation :global(ol) {
    margin-left: 1.25rem;
    margin-bottom: 1rem;
  }

  .explanation :global(li) {
    margin-bottom: 0.375rem;
    color: var(--text-muted);
    line-height: 1.65;
  }

  .explanation :global(table) {
    border-collapse: collapse;
    margin: 1rem 0;
    width: 100%;
    background: var(--bg);
    border-radius: var(--radius-sm);
    overflow: hidden;
    border: 1px solid var(--border);
  }

  .explanation :global(td) {
    padding: 0.625rem 0.875rem;
    border-bottom: 1px solid var(--border);
    color: var(--text-muted);
    font-size: 0.9375rem;
  }

  .explanation :global(tr:last-child td) {
    border-bottom: none;
  }

  .explanation :global(a) {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  /* FAQ */
  .faq {
    margin-top: 3rem;
  }

  .faq h2 {
    margin-bottom: 1.25rem;
    font-size: 1.5rem;
  }

  .faq-list {
    display: grid;
    gap: 0.625rem;
  }

  .faq details {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    transition: border-color 0.15s;
  }

  .faq details:hover {
    border-color: var(--border-strong);
  }

  .faq details[open] {
    border-color: var(--accent);
    background: var(--bg);
    box-shadow: var(--shadow-sm);
  }

  .faq summary {
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 1rem 1.25rem;
    font-weight: 600;
    font-size: 0.9375rem;
    color: var(--text);
    list-style: none;
  }

  .faq summary::-webkit-details-marker { display: none; }

  .faq .chev {
    color: var(--text-subtle);
    transition: transform 0.2s;
    flex-shrink: 0;
  }

  .faq details[open] .chev {
    transform: rotate(180deg);
    color: var(--accent);
  }

  .faq details p {
    color: var(--text-muted);
    padding: 0 1.25rem 1.125rem;
    margin: 0;
    line-height: 1.65;
    font-size: 0.9375rem;
  }

  /* Key takeaway (resumen rápido) */
  .key-takeaway {
    display: flex;
    gap: 0.75rem;
    align-items: flex-start;
    margin-top: 2rem;
    padding: 1rem 1.25rem;
    background: var(--accent-soft);
    border-left: 3px solid var(--accent);
    border-radius: var(--radius-sm);
    color: var(--text);
    font-size: 0.9375rem;
    line-height: 1.55;
  }
  .key-takeaway .kt-icon { color: var(--accent); flex-shrink: 0; margin-top: 2px; }
  .key-takeaway strong { color: var(--accent-strong); }

  /* Use cases */
  .use-cases {
    margin-top: 2.5rem;
    padding: 1.75rem 2rem;
    background: var(--bg-soft);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
  }
  .use-cases h2 {
    margin: 0 0 0.875rem;
    font-size: 1.25rem;
  }
  .use-cases ul {
    margin: 0;
    padding-left: 1.25rem;
  }
  .use-cases li {
    color: var(--text-muted);
    line-height: 1.65;
    margin-bottom: 0.375rem;
  }

  /* Example paso a paso */
  .example {
    margin-top: 2.5rem;
    padding: 1.75rem 2rem;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
  }
  .example h2 { margin: 0 0 1rem; font-size: 1.25rem; }
  .example-steps {
    margin: 0 0 1rem;
    padding-left: 1.25rem;
    counter-reset: step;
  }
  .example-steps li {
    color: var(--text-muted);
    line-height: 1.65;
    margin-bottom: 0.5rem;
  }
  .example-steps li :global(code), .example-steps :global(code) {
    background: var(--bg-muted);
    padding: 0.0625rem 0.375rem;
    border-radius: 4px;
    font-family: var(--font-mono);
    font-size: 0.875em;
    color: var(--accent-strong);
  }
  .example-result {
    padding: 0.75rem 1rem;
    background: var(--accent-soft);
    border-radius: var(--radius-sm);
    color: var(--text);
    font-size: 0.9375rem;
  }
  .example-result strong { color: var(--accent-strong); }

  /* Fuentes */
  .sources-box {
    margin-top: 2.5rem;
    padding: 1.25rem 1.5rem;
    background: var(--bg-soft);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
  }
  .sources-box h2 {
    margin: 0 0 0.625rem;
    font-size: 1rem;
    font-weight: 600;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .sources-box ul {
    margin: 0;
    padding-left: 1.25rem;
  }
  .sources-box li {
    color: var(--text-muted);
    margin-bottom: 0.25rem;
    font-size: 0.9375rem;
  }
  .sources-box a {
    color: var(--accent);
    text-decoration: none;
  }
  .sources-box a:hover { text-decoration: underline; }

  /* Related contextual */
  .also-see {
    margin-top: 3rem;
  }
  .also-see h2 {
    font-size: 1.25rem;
    margin: 0 0 1rem;
  }
  .also-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 0.75rem;
  }
  .also-card {
    display: flex;
    gap: 0.75rem;
    padding: 0.875rem 1rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    text-decoration: none;
    color: var(--text);
