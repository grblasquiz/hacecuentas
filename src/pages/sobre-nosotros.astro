---
export const prerender = true;

import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { TOTAL_DISPLAY } from '../lib/calc-counts';

// Schema.org Person + Organization + AboutPage para señales E-E-A-T fuertes
// y para que AI bots (ChatGPT, Claude, Perplexity) identifiquen al autor
// como entidad verificable cuando citen contenido del sitio.
const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  '@id': 'https://hacecuentas.com/sobre-nosotros#martin-rodriguez',
  name: 'Martín Rodríguez',
  givenName: 'Martín',
  familyName: 'Rodríguez',
  alternateName: ['Martín Rodríguez Baranek'],
  jobTitle: 'Editor general y fundador',
  description: 'Fundador de Hacé Cuentas. CMO en Argenprop con +10 años en producto digital y análisis de audiencia. Especializado en cálculos fiscales y financieros argentinos.',
  worksFor: {
    '@type': 'Organization',
    name: 'Hacé Cuentas',
    url: 'https://hacecuentas.com',
  },
  url: 'https://hacecuentas.com/sobre-nosotros',
  sameAs: [
    'https://www.linkedin.com/in/martinrodriguezbaranek/',
    'https://github.com/grblasquiz',
  ],
  knowsAbout: [
    'Cálculos fiscales argentinos',
    'Impuesto a las Ganancias',
    'Monotributo',
    'Aguinaldo SAC',
    'Jubilación ANSES',
    'Inflación y poder de compra',
    'Mercado inmobiliario argentino',
    'Análisis financiero',
    'SEO y producto digital',
  ],
  nationality: { '@type': 'Country', name: 'Argentina' },
};

const organizationSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  '@id': 'https://hacecuentas.com#organization',
  name: 'Hacé Cuentas',
  alternateName: 'hacecuentas.com',
  url: 'https://hacecuentas.com',
  logo: {
    '@type': 'ImageObject',
    url: 'https://hacecuentas.com/og-default.png',
    width: 1200,
    height: 630,
  },
  description: 'Plataforma argentina de calculadoras online gratuitas para cálculos fiscales, laborales, financieros, de salud y matemática. +2.500 calculadoras con datos oficiales de AFIP, BCRA, ANSES, INDEC.',
  founder: { '@id': 'https://hacecuentas.com/sobre-nosotros#martin-rodriguez' },
  foundingDate: '2026-04-14',
  foundingLocation: {
    '@type': 'Place',
    address: { '@type': 'PostalAddress', addressCountry: 'AR' },
  },
  knowsLanguage: ['es-AR', 'es', 'en', 'pt-BR'],
  sameAs: [
    'https://github.com/grblasquiz/hacecuentas',
  ],
  contactPoint: {
    '@type': 'ContactPoint',
    email: 'rodriguezb.martin@gmail.com',
    contactType: 'customer support',
  },
};

const aboutPageSchema = {
  '@context': 'https://schema.org',
  '@type': 'AboutPage',
  url: 'https://hacecuentas.com/sobre-nosotros',
  name: 'Sobre Hacé Cuentas',
  inLanguage: 'es-AR',
  mainEntity: { '@id': 'https://hacecuentas.com#organization' },
  about: { '@id': 'https://hacecuentas.com/sobre-nosotros#martin-rodriguez' },
  publisher: { '@id': 'https://hacecuentas.com#organization' },
};
---

<Layout
  title="Sobre nosotros — Hacé Cuentas"
  description="Hacé Cuentas es un proyecto argentino de calculadoras online gratuitas para todo el mundo hispanohablante, pensadas para ayudar a resolver cálculos cotidianos de forma rápida y precisa."
>
  <Header slot="header" />

  <script type="application/ld+json" is:inline set:html={JSON.stringify(personSchema)}></script>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(organizationSchema)}></script>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(aboutPageSchema)}></script>

  <article class="legal">
    <h1>Sobre Hacé Cuentas</h1>

    <h2>Qué somos</h2>
    <p>
      Hacé Cuentas es un proyecto independiente argentino que desarrolla
      <strong>{TOTAL_DISPLAY} calculadoras online gratuitas</strong> para todo el mundo hispanohablante,
      Brasil y Portugal: salud, matemática, finanzas, negocios, deportes, viajes, mascotas,
      cocina y más. Sumamos también una cobertura profunda y específica para Argentina
      <span aria-hidden="true">🇦🇷</span> en sueldo, impuestos, monotributo, jubilaciones e
      inflación; y una vertical fiscal/trabalhista completa para Brasil 🇧🇷 (FGTS, INSS,
      IRPF, MEI, Simples Nacional, rescisão CLT) y España 🇪🇸 (IRPF por CCAA, SEPE,
      indemnización despido).
    </p>

    <h2>Equipo</h2>
    <ul>
      <li><strong>Editor general:</strong> Martín Rodríguez. Fundador del proyecto con una
        década de experiencia en producto digital y análisis de audiencia.</li>
      <li><strong>Equipo editorial:</strong> revisores en contabilidad, economía, salud y
        derecho que auditan las calculadoras de sus áreas antes de publicar.</li>
      <li><strong>Código abierto:</strong> todo el código (fórmulas, tests, infraestructura)
        está público en <a href="https://github.com/grblasquiz/hacecuentas" rel="nofollow">GitHub</a>
        para que cualquiera pueda auditar cómo calculamos cada resultado.</li>
    </ul>

    <h2>Nuestra misión</h2>
    <p>
      Darle a cualquier persona acceso gratuito e inmediato a cálculos precisos que
      antes requerían consultar a contadores, médicos o profesionales financieros.
      Todo con fórmulas validadas, explicadas en lenguaje claro, en español, y con
      el contexto que cada país necesita.
    </p>

    <h2>Por qué lo hacemos</h2>
    <p>
      Porque en internet hay miles de calculadoras, pero pocas están bien explicadas
      en español, y aún menos están pensadas para realidades específicas como la
      argentina (impuestos locales, leyes actuales, inflación). Queremos cerrar esa
      brecha: lo universal, bien hecho; y lo local, cuando hace falta, también.
    </p>

    <h2>Para quién es Hacé Cuentas</h2>
    <p>
      Si hablás español, Hacé Cuentas es para vos. Las calculadoras universales —IMC,
      embarazo, calorías, porcentajes, regla de tres, ROAS, CAC, márgenes, conversiones
      de cocina, etc.— funcionan igual en Argentina, México, España, Colombia, Chile o
      donde sea. Las calculadoras específicas para Argentina están claramente
      identificadas con la bandera <span aria-hidden="true">🇦🇷</span>: si estás en otro
      país, los importes no aplican, pero la fórmula y la explicación te pueden servir
      como referencia.
    </p>

    <h2>Principios</h2>
    <ul>
      <li><strong>Gratuito para siempre:</strong> todas nuestras calculadoras son gratis. Sin registro, sin muros de pago.</li>
      <li><strong>Privacidad primero:</strong> tus datos se procesan en tu navegador. No los guardamos ni los compartimos.</li>
      <li><strong>Transparencia:</strong> cada cálculo explica cómo se hace y qué fuentes usa.</li>
      <li><strong>Actualización:</strong> las fórmulas con datos que cambian (impuestos, cotizaciones, leyes) se revisan periódicamente.</li>
    </ul>

    <h2>Cómo construimos las calculadoras</h2>
    <ol>
      <li><strong>Investigación:</strong> revisamos normativa oficial (AFIP/ARCA, BCRA, ANSES, ministerios) y estándares internacionales (OMS, ISSN, ACOG, Mifflin-St Jeor, Cockcroft-Gault).</li>
      <li><strong>Implementación:</strong> programamos la fórmula en TypeScript con casos de prueba contra resultados conocidos.</li>
      <li><strong>Validación:</strong> contrastamos contra calculadoras oficiales, publicaciones científicas o cálculos manuales.</li>
      <li><strong>Explicación:</strong> cada calculadora incluye contexto educativo, FAQ y cuándo <em>no</em> usar el resultado.</li>
      <li><strong>Revisión continua:</strong> si alguien reporta un error, lo corregimos. Si cambia una ley o parámetro, actualizamos.</li>
    </ol>
    <p>
      Detalle completo en <a href="/metodologia">/metodologia</a> y
      <a href="/politica-editorial">/politica-editorial</a>.
    </p>

    <h2>Transparencia financiera</h2>
    <p>
      Nos financiamos con <strong>Google AdSense</strong>, el programa de publicidad de
      Google. No cobramos por listar calculadoras, no tenemos afiliación con bancos ni
      aseguradoras, no recomendamos productos financieros específicos y no vendemos tus
      datos. Si alguna vez cambiamos el modelo (donaciones, API paga, etc.) lo
      avisaremos acá y en el footer.
    </p>

    <h2>Limitaciones</h2>
    <p>
      Nuestras calculadoras son herramientas orientativas. No reemplazan el consejo
      profesional de contadores, abogados, médicos o asesores financieros. Si una
      decisión importante depende de un cálculo, consultá con un/a profesional.
    </p>

    <h2>Contacto</h2>
    <ul>
      <li>Consultas generales: <a href="mailto:contacto@hacecuentas.com">contacto@hacecuentas.com</a></li>
      <li>Sugerencias de calculadoras: <a href="mailto:sugerencias@hacecuentas.com">sugerencias@hacecuentas.com</a></li>
      <li>Privacidad y datos: <a href="mailto:privacidad@hacecuentas.com">privacidad@hacecuentas.com</a></li>
      <li>Errores en fórmulas: <a href="mailto:contacto@hacecuentas.com">contacto@hacecuentas.com</a> (respondemos en ≤48h)</li>
    </ul>
  </article>

  <Footer slot="footer" />
</Layout>

<style>
  .legal {
    max-width: 720px;
    margin: 2rem auto;
    padding: 0 1rem;
  }
  .legal h1 {
    margin-bottom: 2rem;
  }
  .legal h2 {
    margin-top: 2rem;
    color: var(--text);
  }
  .legal p, .legal li {
    color: var(--text-muted);
    line-height: 1.7;
  }
  .legal ul {
    margin-left: 1.5rem;
    margin-bottom: 1rem;
  }
  .legal li {
    margin-bottom: 0.5rem;
  }
  .legal strong {
    color: var(--text);
  }
</style>
