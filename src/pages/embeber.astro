---
export const prerender = true;

import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Newsletter from '../components/Newsletter.astro';

const title = "Embeber Calculadoras Gratis en tu Web — Widget Hacé Cuentas | Hacé Cuentas";
const description =
  "Más de 535 calculadoras listas para embeber en tu sitio web. Widget gratis, sin registro, sin límites. Copiá el iframe y pegalo en WordPress, Blogger, Wix, Squarespace o cualquier HTML.";

const schema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "@id": "https://hacecuentas.com/embeber#webpage",
  name: title,
  description,
  url: "https://hacecuentas.com/embeber",
  inLanguage: ["es", "es-AR", "es-419"],
  isPartOf: {
    "@type": "WebSite",
    name: "Hacé Cuentas",
    url: "https://hacecuentas.com",
  },
  publisher: {
    "@type": "Organization",
    name: "Hacé Cuentas",
    url: "https://hacecuentas.com",
    logo: "https://hacecuentas.com/favicon.svg",
  },
};

const schemaBreadcrumb = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Inicio", item: "https://hacecuentas.com/" },
    { "@type": "ListItem", position: 2, name: "Embeber calculadoras", item: "https://hacecuentas.com/embeber" },
  ],
};

const popularCalcs = [
  {
    slug: "calculadora-porcentajes",
    name: "Calculadora de porcentajes",
    category: "matematica",
    emoji: "📊",
  },
  {
    slug: "calculadora-imc",
    name: "Calculadora de IMC",
    category: "salud",
    emoji: "⚖️",
  },
  {
    slug: "calculadora-calorias-tdee",
    name: "Calculadora de calorías TDEE",
    category: "salud",
    emoji: "🔥",
  },
  {
    slug: "calculadora-interes-compuesto",
    name: "Calculadora de interés compuesto",
    category: "finanzas",
    emoji: "📈",
  },
  {
    slug: "calculadora-iva",
    name: "Calculadora de IVA",
    category: "finanzas",
    emoji: "🧾",
  },
  {
    slug: "calculadora-plazo-fijo",
    name: "Calculadora de plazo fijo",
    category: "finanzas",
    emoji: "🏦",
  },
  {
    slug: "calculadora-cuota-prestamo",
    name: "Calculadora de cuota de préstamo",
    category: "finanzas",
    emoji: "💳",
  },
  {
    slug: "calculadora-aguinaldo",
    name: "Calculadora de aguinaldo",
    category: "finanzas",
    emoji: "💰",
  },
  {
    slug: "calculadora-dias-entre-fechas",
    name: "Calculadora de días entre fechas",
    category: "matematica",
    emoji: "📅",
  },
  {
    slug: "calculadora-regla-de-tres",
    name: "Calculadora de regla de tres",
    category: "matematica",
    emoji: "🔢",
  },
];

const faqs = [
  {
    q: "¿Es realmente gratis embeber las calculadoras?",
    a: "Sí, 100% gratis. No hay plan pago, no hay límite de uso, no hay fecha de vencimiento. Solo pedimos que mantengas visible el enlace \"Powered by Hacé Cuentas\" debajo del widget.",
  },
  {
    q: "¿Puedo personalizar el ancho del widget?",
    a: "Sí. El widget es completamente responsive. Podés cambiar el atributo width del iframe (ej. width=\"600\" o width=\"100%\") y se adaptará automáticamente. El alto recomendado es entre 450 y 600px según la calculadora.",
  },
  {
    q: "¿Funciona en WordPress?",
    a: "Sí. En el editor de bloques (Gutenberg), agregá un bloque de HTML personalizado y pegá el código del iframe. En el editor clásico, cambiá a modo \"Texto\" (no Visual) antes de pegar el código.",
  },
  {
    q: "¿Funciona en Blogger, Wix o Squarespace?",
    a: "Sí, en todos. En Blogger usá el widget de HTML/JavaScript. En Wix, insertá un elemento HTML personalizado. En Squarespace, usá un bloque de código. El iframe es HTML estándar y funciona en cualquier plataforma que acepte código personalizado.",
  },
  {
    q: "¿Los datos del usuario son privados?",
    a: "Totalmente. Todas las calculadoras de Hacé Cuentas procesan los cálculos en el navegador del usuario — no se envía ningún dato a nuestros servidores. No hay tracking de las entradas del formulario.",
  },
  {
    q: "¿Puedo embeber más de una calculadora en la misma página?",
    a: "Sí, podés embeber tantas como necesites en la misma página o en páginas distintas de tu sitio. No hay límite.",
  },
  {
    q: "¿Cómo elijo qué calculadora embeber?",
    a: "Entrá a hacecuentas.com/buscar, encontrá la calculadora que necesitás, y hacé clic en el botón \"Embeber\" en la página de esa calculadora. Vas a ver el código del iframe listo para copiar.",
  },
  {
    q: "¿El widget se adapta al modo oscuro?",
    a: "Sí. Las calculadoras detectan automáticamente la preferencia de color del sistema del usuario (prefers-color-scheme) y se muestran en light o dark mode según corresponda.",
  },
];
---

<Layout
  title={title}
  description={description}
  schema={schema}
>
  <Header slot="header" />

  <article class="embeber-page">

    <!-- Breadcrumbs -->
    <nav class="breadcrumbs" aria-label="Migas de pan">
      <a href="/">Inicio</a>
      <span aria-hidden="true">›</span>
      <span aria-current="page">Embeber calculadoras</span>
    </nav>

    <!-- ══════════════════════════════════════
         1. HERO
    ══════════════════════════════════════ -->
    <header class="hero">
      <div class="hero__badge">Widget gratis</div>
      <h1>Embebé calculadoras gratis<br />en tu sitio web</h1>
      <p class="hero__sub">
        Más de 535 calculadoras listas para copiar y pegar.
        Sin costo, sin registro, sin límites.
      </p>
      <a href="/buscar" class="btn-primary">
        Ver calculadoras disponibles <span aria-hidden="true">→</span>
      </a>
    </header>

    <!-- ══════════════════════════════════════
         2. HOW IT WORKS — 3 steps
    ══════════════════════════════════════ -->
    <section class="steps-section" aria-labelledby="steps-heading">
      <h2 id="steps-heading">Cómo embeber en 3 pasos</h2>
      <div class="steps">
        <div class="step">
          <div class="step__num" aria-hidden="true">1</div>
          <div class="step__body">
            <h3>Elegí una calculadora</h3>
            <p>Navegá las 535+ calculadoras y encontrá la que necesitás para tu contenido.</p>
            <a href="/buscar" class="step__link">Explorar calculadoras →</a>
          </div>
        </div>
        <div class="step__connector" aria-hidden="true"></div>
        <div class="step">
          <div class="step__num" aria-hidden="true">2</div>
          <div class="step__body">
            <h3>Copiá el código</h3>
            <p>Hacé clic en "Embeber" en cualquier calculadora y copiá el código iframe con un clic.</p>
          </div>
        </div>
        <div class="step__connector" aria-hidden="true"></div>
        <div class="step">
          <div class="step__num" aria-hidden="true">3</div>
          <div class="step__body">
            <h3>Pegalo en tu web</h3>
            <p>Pegá el HTML en WordPress, Blogger, Wix, Squarespace o cualquier editor de código. Listo.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ══════════════════════════════════════
         3. LIVE DEMO
    ══════════════════════════════════════ -->
    <section class="demo-section" aria-labelledby="demo-heading">
      <h2 id="demo-heading">Demo en vivo</h2>
      <p class="demo-intro">
        Así se ve una calculadora embedida. Este widget está corriendo directamente en esta página:
      </p>

      <div class="demo-widget">
        <iframe
          src="https://hacecuentas.com/embed/calculadora-porcentajes"
          width="100%"
          height="500"
          frameborder="0"
          loading="lazy"
          title="Calculadora de porcentajes"
        ></iframe>
        <p class="embed-credit">
          Powered by <a href="https://hacecuentas.com" target="_blank" rel="noopener">Hacé Cuentas</a>
        </p>
      </div>

      <div class="code-block-wrapper">
        <div class="code-block-header">
          <span class="code-block-label">Código para copiar</span>
          <button
            class="btn-copy"
            data-code={`<iframe src="https://hacecuentas.com/embed/calculadora-porcentajes" width="100%" height="500" frameborder="0" loading="lazy" title="Calculadora de porcentajes"></iframe>\n<p style="font-size:12px;text-align:center">Powered by <a href="https://hacecuentas.com" target="_blank" rel="noopener">Hacé Cuentas</a></p>`}
            aria-label="Copiar código"
          >
            Copiar código
          </button>
        </div>
        <pre class="code-block"><code>&lt;iframe
  src="https://hacecuentas.com/embed/calculadora-porcentajes"
  width="100%"
  height="500"
  frameborder="0"
  loading="lazy"
  title="Calculadora de porcentajes"
&gt;&lt;/iframe&gt;
&lt;p style="font-size:12px;text-align:center"&gt;
  Powered by &lt;a href="https://hacecuentas.com" target="_blank" rel="noopener"&gt;Hacé Cuentas&lt;/a&gt;
&lt;/p&gt;</code></pre>
      </div>
    </section>

    <!-- ══════════════════════════════════════
         4. BENEFITS — 4 cards
    ══════════════════════════════════════ -->
    <section class="benefits-section" aria-labelledby="benefits-heading">
      <h2 id="benefits-heading">¿Por qué usar los widgets de Hacé Cuentas?</h2>
      <div class="benefits-grid">
        <div class="benefit-card">
          <div class="benefit-icon" aria-hidden="true">🎁</div>
          <h3>Gratis para siempre</h3>
          <p>Sin costo, sin plan premium, sin límites de uso. No hay letra chica.</p>
        </div>
        <div class="benefit-card">
          <div class="benefit-icon" aria-hidden="true">📱</div>
          <h3>Se adapta a tu diseño</h3>
          <p>Responsive, funciona en cualquier ancho. Light/dark mode automático según el sistema del usuario.</p>
        </div>
        <div class="benefit-card">
          <div class="benefit-icon" aria-hidden="true">🚫</div>
          <h3>Sin registro</h3>
          <p>No necesitás cuenta ni API key. Copiá el iframe y pegalo donde quieras.</p>
        </div>
        <div class="benefit-card">
          <div class="benefit-icon" aria-hidden="true">🔒</div>
          <h3>Procesamiento local</h3>
          <p>Los datos del usuario nunca salen de su navegador. Cálculos 100% del lado del cliente. Privacidad total.</p>
        </div>
      </div>
    </section>

    <!-- ══════════════════════════════════════
         5. POPULAR EMBEDS
    ══════════════════════════════════════ -->
    <section class="popular-section" aria-labelledby="popular-heading">
      <h2 id="popular-heading">Calculadoras más embedidas</h2>
      <p class="popular-intro">
        Hacé clic en "Copiar código" para obtener el iframe listo para usar.
        O visitá la página de cada calculadora para verla completa.
      </p>
      <div class="popular-grid">
        {popularCalcs.map((calc) => {
          const iframeCode = `<iframe src="https://hacecuentas.com/embed/${calc.slug}" width="100%" height="500" frameborder="0" loading="lazy" title="${calc.name}"></iframe>\n<p style="font-size:12px;text-align:center">Powered by <a href="https://hacecuentas.com" target="_blank" rel="noopener">Hacé Cuentas</a></p>`;
          return (
            <div class="popular-card">
              <div class="popular-card__top">
                <span class="popular-card__emoji" aria-hidden="true">{calc.emoji}</span>
                <div>
                  <h3 class="popular-card__name">{calc.name}</h3>
                  <span class={`cat-tag cat-${calc.category}`}>{calc.category}</span>
                </div>
              </div>
              <div class="popular-card__actions">
                <button
                  class="btn-copy btn-copy--small"
                  data-code={iframeCode}
                  aria-label={`Copiar código de ${calc.name}`}
                >
                  Copiar código
                </button>
                <a href={`/${calc.slug}`} class="btn-ghost btn-ghost--small" aria-label={`Ver ${calc.name}`}>
                  Ver →
                </a>
              </div>
            </div>
          );
        })}
      </div>
    </section>

    <!-- ══════════════════════════════════════
         6. USE CASES
    ══════════════════════════════════════ -->
    <section class="usecases-section" aria-labelledby="usecases-heading">
      <h2 id="usecases-heading">¿Quién usa los widgets?</h2>
      <div class="usecases-grid">
        <div class="usecase-card">
          <div class="usecase-icon" aria-hidden="true">💰</div>
          <h3>Blogs de finanzas personales</h3>
          <p>Embebé calculadoras de plazo fijo, sueldo neto, monotributo o inversiones para darle valor real a tus artículos.</p>
        </div>
        <div class="usecase-card">
          <div class="usecase-icon" aria-hidden="true">🏃</div>
          <h3>Sitios de salud y fitness</h3>
          <p>IMC, calorías TDEE, grasa corporal, peso ideal — herramientas interactivas que mantienen a tus lectores más tiempo en la página.</p>
        </div>
        <div class="usecase-card">
          <div class="usecase-icon" aria-hidden="true">🏪</div>
          <h3>E-commerce y negocios</h3>
          <p>Calculadoras de margen, markup, ROI e IVA directamente en tus páginas de producto o recursos para vendedores.</p>
        </div>
        <div class="usecase-card">
          <div class="usecase-icon" aria-hidden="true">📰</div>
          <h3>Medios y periodismo</h3>
          <p>Embed interactivo para notas de actualidad — inflación, tipo de cambio, aumentos de tarifas. Más engagement, más tiempo en página.</p>
        </div>
        <div class="usecase-card">
          <div class="usecase-icon" aria-hidden="true">🎓</div>
          <h3>Educación</h3>
          <p>Matemática, física, química, conversores de unidades. Herramientas de práctica para alumnos directamente en tu plataforma o blog educativo.</p>
        </div>
      </div>
    </section>

    <!-- ══════════════════════════════════════
         7. ATTRIBUTION
    ══════════════════════════════════════ -->
    <section class="attribution-section" aria-labelledby="attribution-heading">
      <div class="attribution-inner">
        <div class="attribution-icon" aria-hidden="true">🤝</div>
        <h2 id="attribution-heading">Solo pedimos una cosa</h2>
        <p>
          Mantené el enlace <strong>"Powered by Hacé Cuentas"</strong> visible debajo del widget.
          Ese link ya viene incluido en el código que copiás — no necesitás hacer nada extra.
        </p>
        <p class="attribution-reason">
          Es gratis porque los backlinks nos ayudan a seguir creciendo y a crear más calculadoras
          para todos. Una relación justa: vos obtenés herramientas útiles para tus visitantes,
          nosotros obtenemos visibilidad. Sin secretos.
        </p>
      </div>
    </section>

    <!-- ══════════════════════════════════════
         8. FAQ
    ══════════════════════════════════════ -->
    <section class="faq-section" aria-labelledby="faq-heading">
      <h2 id="faq-heading">Preguntas frecuentes</h2>
      <dl class="faq-list">
        {faqs.map((item) => (
          <details class="faq-item">
            <summary class="faq-q">
              <span>{item.q}</span>
              <span class="faq-chevron" aria-hidden="true">›</span>
            </summary>
            <dd class="faq-a"><p>{item.a}</p></dd>
          </details>
        ))}
      </dl>
    </section>

    <!-- ══════════════════════════════════════
         9. FINAL CTA
    ══════════════════════════════════════ -->
    <section class="cta-final" aria-labelledby="cta-heading">
      <h2 id="cta-heading">Listo para empezar</h2>
      <p>Explorá las 535+ calculadoras y elegí la que mejor se adapta a tu contenido.</p>
      <a href="/buscar" class="btn-primary btn-primary--large">
        Explorá las 535+ calculadoras <span aria-hidden="true">→</span>
      </a>
    </section>

    <Newsletter />

  </article>

  <script is:inline type="application/ld+json" set:html={JSON.stringify(schemaBreadcrumb)}></script>

  <Footer slot="footer" />
</Layout>

<script>
  // Copy-to-clipboard for all .btn-copy buttons
  document.querySelectorAll<HTMLButtonElement>('.btn-copy').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const code = btn.dataset.code ?? '';
      try {
        await navigator.clipboard.writeText(code);
      } catch {
        // Fallback for older browsers
        const ta = document.createElement('textarea');
        ta.value = code;
        ta.style.position = 'fixed';
        ta.style.opacity = '0';
        document.body.appendChild(ta);
        ta.select();
        document.execCommand('copy');
        document.body.removeChild(ta);
      }
      const original = btn.textContent ?? '';
      btn.textContent = '¡Copiado!';
      btn.classList.add('btn-copy--success');
      setTimeout(() => {
        btn.textContent = original;
        btn.classList.remove('btn-copy--success');
      }, 2000);
    });
  });
</script>

<style>
  /* ── Page wrapper ── */
  .embeber-page {
    max-width: 880px;
    margin: 1rem auto 2rem;
    padding: 0 1rem;
  }

  /* ── Breadcrumbs ── */
  .breadcrumbs {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.875rem;
    color: var(--text-subtle);
    margin-bottom: 1.5rem;
  }
  .breadcrumbs a { color: var(--text-muted); text-decoration: none; }
  .breadcrumbs a:hover { color: var(--accent); }

  /* ── Shared section spacing ── */
  section { margin-bottom: 4rem; }
  section h2 {
    font-size: clamp(1.375rem, 3vw, 1.75rem);
    margin-bottom: 1.25rem;
    color: var(--text);
  }

  /* ══════════════════════════════
     1. HERO
  ══════════════════════════════ */
  .hero {
    text-align: center;
    padding: 3rem 1rem 3.5rem;
    border-bottom: 1px solid var(--border);
    margin-bottom: 3.5rem;
  }
  .hero__badge {
    display: inline-block;
    background: var(--accent-subtle, #ecfdf5);
    color: var(--accent);
    border: 1px solid var(--accent);
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding: 0.25rem 0.75rem;
    border-radius: 999px;
    margin-bottom: 1.25rem;
  }
  :global([data-theme="dark"]) .hero__badge {
    background: rgba(52,211,153,0.1);
  }
  .hero h1 {
    font-size: clamp(2rem, 5vw, 3rem);
    line-height: 1.15;
    margin-bottom: 1rem;
  }
  .hero__sub {
    font-size: 1.0625rem;
    color: var(--text-muted);
    max-width: 520px;
    margin: 0 auto 2rem;
    line-height: 1.6;
  }

  /* ── Buttons ── */
  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 0.4em;
    background: var(--accent);
    color: #fff;
    font-size: 1rem;
    font-weight: 600;
    padding: 0.75rem 1.75rem;
    border-radius: var(--radius);
    text-decoration: none;
    transition: filter 0.15s, transform 0.15s;
    border: none;
    cursor: pointer;
  }
  .btn-primary:hover {
    filter: brightness(1.08);
    transform: translateY(-1px);
    text-decoration: none;
    color: #fff;
  }
  .btn-primary--large {
    font-size: 1.0625rem;
    padding: 0.875rem 2rem;
  }
  .btn-copy {
    display: inline-flex;
    align-items: center;
    gap: 0.4em;
    background: var(--bg-card);
    color: var(--text);
    border: 1px solid var(--border);
    font-size: 0.875rem;
    font-weight: 500;
    padding: 0.5rem 1rem;
    border-radius: var(--radius);
    cursor: pointer;
    transition: all 0.15s;
  }
  .btn-copy:hover {
    border-color: var(--accent);
    color: var(--accent);
  }
  .btn-copy--success {
    border-color: var(--accent) !important;
    color: var(--accent) !important;
    background: var(--accent-subtle, #ecfdf5) !important;
  }
  :global([data-theme="dark"]) .btn-copy--success {
    background: rgba(52,211,153,0.1) !important;
  }
  .btn-copy--small {
    font-size: 0.8125rem;
    padding: 0.375rem 0.75rem;
  }
  .btn-ghost {
    display: inline-flex;
    align-items: center;
    gap: 0.3em;
    color: var(--text-muted);
    font-size: 0.8125rem;
    font-weight: 500;
    text-decoration: none;
    padding: 0.375rem 0.75rem;
    border-radius: var(--radius);
    border: 1px solid transparent;
    transition: all 0.15s;
  }
  .btn-ghost:hover {
    color: var(--accent);
    border-color: var(--border);
    text-decoration: none;
  }
  .btn-ghost--small { font-size: 0.8125rem; }

  /* ══════════════════════════════
     2. HOW IT WORKS — Steps
  ══════════════════════════════ */
  .steps-section h2 { text-align: center; }

  .steps {
    display: flex;
    align-items: flex-start;
    gap: 0;
    margin-top: 2rem;
  }
  .step {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 1rem;
    padding: 0 1rem;
  }
  .step__num {
    width: 3rem;
    height: 3rem;
    border-radius: 50%;
    background: var(--accent);
    color: #fff;
    font-size: 1.25rem;
    font-weight: 800;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .step__body h3 {
    font-size: 1.0625rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
    color: var(--text);
  }
  .step__body p {
    font-size: 0.9375rem;
    color: var(--text-muted);
    line-height: 1.55;
    margin: 0 0 0.75rem;
  }
  .step__link {
    color: var(--accent);
    font-size: 0.875rem;
    font-weight: 500;
    text-decoration: none;
  }
  .step__link:hover { text-decoration: underline; }

