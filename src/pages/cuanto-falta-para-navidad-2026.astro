---
export const prerender = true;

import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const title = 'Cuánto falta para Navidad 2026 — Contador en vivo 🎄 | Hacé Cuentas';
const description = 'Contador en tiempo real para Navidad 2026: días, semanas, domingos, horas, minutos y segundos. ¿Cuánto falta para el 25 de diciembre? Cálculo automático, gratis.';

const schema = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebApplication',
      name: 'Cuánto falta para Navidad 2026',
      applicationCategory: 'UtilitiesApplication',
      operatingSystem: 'Web',
      url: 'https://hacecuentas.com/cuanto-falta-para-Navidad-2026',
      description,
      offers: { '@type': 'Offer', price: '0', priceCurrency: 'ARS' },
      speakable: { '@type': 'SpeakableSpecification', cssSelector: ['h1', '[data-countdown-big]'] },
    },
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Inicio', item: 'https://hacecuentas.com/' },
        { '@type': 'ListItem', position: 2, name: 'Fechas', item: 'https://hacecuentas.com/categoria/vida' },
        { '@type': 'ListItem', position: 3, name: 'Navidad 2026' },
      ],
    },
    {
      '@type': 'FAQPage',
      mainEntity: [
        {
          '@type': 'Question',
          name: '¿Cuántos días faltan para Navidad 2026?',
          acceptedAnswer: { '@type': 'Answer', text: 'El contador en vivo de esta página te muestra exactamente cuántos días, horas, minutos y segundos faltan para el 25 de diciembre de 2026. Se actualiza cada segundo.' },
        },
        {
          '@type': 'Question',
          name: '¿Cuántas semanas faltan para Navidad?',
          acceptedAnswer: { '@type': 'Answer', text: 'Navidad 2026 cae en viernes. Desde hoy hasta el 25 de diciembre de 2026 podés ver el conteo exacto de semanas completas + días extra en la tabla de esta página.' },
        },
        {
          '@type': 'Question',
          name: '¿Qué día de la semana cae Navidad 2026?',
          acceptedAnswer: { '@type': 'Answer', text: 'Navidad 2026 (25 de diciembre) cae viernes. El 24 (Nochebuena) es jueves y el 31 (Año Nuevo) miércoles.' },
        },
        {
          '@type': 'Question',
          name: '¿Cuándo empieza a descontar el contador?',
          acceptedAnswer: { '@type': 'Answer', text: 'El contador usa la hora actual de tu dispositivo. Se calcula en zona horaria de Argentina (UTC-3) por default, pero vos lo ves en tu hora local porque corre en tu browser.' },
        },
      ],
    },
  ],
};
---

<Layout title={title} description={description} image="/og/cuanto-falta-para-Navidad-2026.png" schema={schema}>
  <Header slot="header" />

  <article class="navidad-page">
    <nav class="breadcrumbs" aria-label="Ruta">
      <a href="/">Inicio</a>
      <span class="sep" aria-hidden="true">/</span>
      <a href="/categoria/vida">Fechas</a>
      <span class="sep" aria-hidden="true">/</span>
      <span class="current">Navidad 2026</span>
    </nav>

    <header class="navidad-header">
      <div class="snow-bg" aria-hidden="true"></div>
      <span class="big-emoji">🎄</span>
      <h1>Cuánto falta para Navidad 2026</h1>

      <div class="countdown-big" data-countdown-big aria-live="polite">
        <div class="cd-unit"><span class="cd-num" data-days>—</span><span class="cd-label">días</span></div>
        <div class="cd-unit"><span class="cd-num" data-hours>—</span><span class="cd-label">horas</span></div>
        <div class="cd-unit"><span class="cd-num" data-minutes>—</span><span class="cd-label">min</span></div>
        <div class="cd-unit"><span class="cd-num" data-seconds>—</span><span class="cd-label">seg</span></div>
      </div>

      <p class="cd-target">hasta el <strong>viernes 25 de diciembre de 2026</strong></p>
    </header>

    <section class="cd-stats">
      <div class="stat-card">
        <span class="stat-label">Semanas completas</span>
        <span class="stat-value" data-weeks>—</span>
      </div>
      <div class="stat-card">
        <span class="stat-label">Días hábiles (lun-vie)</span>
        <span class="stat-value" data-business>—</span>
      </div>
      <div class="stat-card">
        <span class="stat-label">Sábados que faltan</span>
        <span class="stat-value" data-saturdays>—</span>
      </div>
      <div class="stat-card">
        <span class="stat-label">Domingos que faltan</span>
        <span class="stat-value" data-sundays>—</span>
      </div>
      <div class="stat-card">
        <span class="stat-label">Total de horas</span>
        <span class="stat-value" data-total-hours>—</span>
      </div>
      <div class="stat-card">
        <span class="stat-label">Total de segundos</span>
        <span class="stat-value" data-total-seconds>—</span>
      </div>
    </section>

    <section class="cd-extras">
      <h2>Fechas clave de fin de año 2026</h2>
      <div class="dates-grid">
        <div class="date-card">
          <span class="date-emoji">🦃</span>
          <div><strong>Thanksgiving (USA)</strong><span data-thanksgiving>—</span></div>
        </div>
        <div class="date-card">
          <span class="date-emoji">🌟</span>
          <div><strong>Nochebuena (24 dic)</strong><span data-nochebuena>—</span></div>
        </div>
        <div class="date-card">
          <span class="date-emoji">🎅</span>
          <div><strong>Navidad (25 dic)</strong><span data-navidad>—</span></div>
        </div>
        <div class="date-card">
          <span class="date-emoji">🎆</span>
          <div><strong>Año Nuevo 2027 (1 ene)</strong><span data-yearnew>—</span></div>
        </div>
        <div class="date-card">
          <span class="date-emoji">👑</span>
          <div><strong>Reyes (6 ene 2027)</strong><span data-reyes>—</span></div>
        </div>
      </div>
    </section>

    <section class="cd-share">
      <p>💬 Compartí el contador:</p>
      <div class="share-buttons">
        <a id="share-wa" class="share-btn" target="_blank" rel="noopener" href="#">📱 WhatsApp</a>
        <a id="share-tw" class="share-btn" target="_blank" rel="noopener" href="#">🐦 Twitter</a>
        <button type="button" id="share-copy" class="share-btn">🔗 Copiar link</button>
      </div>
    </section>

    <section class="cd-faqs">
      <h2>Preguntas frecuentes</h2>
      <details>
        <summary>¿Cuántos días faltan para Navidad 2026?</summary>
        <p>El contador de arriba se actualiza cada segundo con el dato exacto. También tenés la tabla con semanas, días hábiles, sábados y domingos restantes.</p>
      </details>
      <details>
        <summary>¿Cuántas semanas faltan para Navidad?</summary>
        <p>Depende de cuándo consultes. El cálculo es: días restantes dividido 7. Arriba ves el valor exacto actualizado.</p>
      </details>
      <details>
        <summary>¿Qué día de la semana cae Navidad 2026?</summary>
        <p><strong>Viernes</strong>. El 24 de diciembre (Nochebuena) es jueves, y el 26 de diciembre es sábado, por lo que queda un fin de semana largo.</p>
      </details>
      <details>
        <summary>¿Cuándo es el Aguinaldo de diciembre 2026?</summary>
        <p>El segundo SAC (Aguinaldo de diciembre) se paga hasta el 18 de diciembre de 2026 (15 + 4 días hábiles de tolerancia). Calculalo exacto en <a href="/calculadora-aguinaldo-sac">nuestra calculadora de aguinaldo</a>.</p>
      </details>
      <details>
        <summary>¿Cuándo es Thanksgiving (USA) 2026?</summary>
        <p>El 4to jueves de noviembre de 2026 cae el <strong>26 de noviembre</strong>. Black Friday es el 27 de noviembre.</p>
      </details>
      <details>
        <summary>¿Cómo lo uso para el trabajo/colegio?</summary>
        <p>Mirá los "días hábiles" — te dice cuántos lunes a viernes faltan hasta Navidad. Útil para planear licencias, proyectos o vacaciones de fin de año.</p>
      </details>
    </section>

    <section class="cd-related">
      <h2>Otras calculadoras de fechas</h2>
      <div class="related-grid">
        <a href="/calculadora-feriados-argentina-2026-calendario" class="rel-card"><span>📅</span><span>Feriados Argentina 2026</span></a>
        <a href="/calculadora-aguinaldo-sac" class="rel-card"><span>💰</span><span>Aguinaldo SAC 2026</span></a>
        <a href="/calculadora-edad-exacta" class="rel-card"><span>🎂</span><span>Edad exacta en años/meses/días</span></a>
        <a href="/calculadora-dias-entre-dos-fechas" class="rel-card"><span>📆</span><span>Días entre dos fechas</span></a>
        <a href="/calculadora-fecha-probable-parto-ultima-menstruacion" class="rel-card"><span>🤰</span><span>Fecha probable parto</span></a>
        <a href="/tracker-embarazo-semana-a-semana" class="rel-card"><span>👶</span><span>Tracker embarazo semanal</span></a>
      </div>
    </section>
  </article>

  <Footer slot="footer" />
</Layout>

<script is:inline>
  (function () {
    const TARGET = new Date('2026-12-25T00:00:00-03:00').getTime();
    const DAYS_ES = ['domingo', 'lunes', 'martes', 'miércoles', 'jueves', 'viernes', 'sábado'];
    const MESES_ES = ['enero', 'febrero', 'marzo', 'abril', 'mayo', 'junio', 'julio', 'agosto', 'septiembre', 'octubre', 'noviembre', 'diciembre'];

    function fmtFullDate(d) {
      return `${DAYS_ES[d.getDay()]} ${d.getDate()} de ${MESES_ES[d.getMonth()]} de ${d.getFullYear()}`;
    }

    function countWeekdays(from, to, targetDays) {
      let n = 0;
      const d = new Date(from);
      d.setHours(0, 0, 0, 0);
      const end = new Date(to);
      end.setHours(0, 0, 0, 0);
      while (d <= end) {
        if (targetDays.indexOf(d.getDay()) !== -1) n++;
        d.setDate(d.getDate() + 1);
      }
      return n;
    }

    function diffDays(from, to) {
      const a = new Date(from); a.setHours(0,0,0,0);
      const b = new Date(to); b.setHours(0,0,0,0);
      return Math.max(0, Math.round((b - a) / 86400000));
    }

    function tick() {
      const now = new Date();
      const nowT = now.getTime();
      const diff = Math.max(0, TARGET - nowT);

      const days = Math.floor(diff / 86400000);
      const hours = Math.floor((diff % 86400000) / 3600000);
      const minutes = Math.floor((diff % 3600000) / 60000);
      const seconds = Math.floor((diff % 60000) / 1000);

      document.querySelector('[data-days]').textContent = String(days).padStart(2, '0');
      document.querySelector('[data-hours]').textContent = String(hours).padStart(2, '0');
      document.querySelector('[data-minutes]').textContent = String(minutes).padStart(2, '0');
      document.querySelector('[data-seconds]').textContent = String(seconds).padStart(2, '0');

      // Stats (update less often — cada 30s)
      if (seconds % 30 === 0) {
        const navidad = new Date('2026-12-25T00:00:00-03:00');
        const weeksComplete = Math.floor(days / 7);
        const extraDays = days % 7;
        const businessDays = countWeekdays(now, navidad, [1, 2, 3, 4, 5]);
        const saturdays = countWeekdays(now, navidad, [6]);
        const sundays = countWeekdays(now, navidad, [0]);
        const totalHours = Math.floor(diff / 3600000);
        const totalSeconds = Math.floor(diff / 1000);

        document.querySelector('[data-weeks]').textContent = `${weeksComplete} sem · ${extraDays}d`;
        document.querySelector('[data-business]').textContent = `${businessDays}`;
        document.querySelector('[data-saturdays]').textContent = `${saturdays}`;
        document.querySelector('[data-sundays]').textContent = `${sundays}`;
        document.querySelector('[data-total-hours]').textContent = totalHours.toLocaleString('es-AR');
        document.querySelector('[data-total-seconds]').textContent = totalSeconds.toLocaleString('es-AR');

        // Fechas clave
        const thanksgiving = new Date('2026-11-26T00:00:00-03:00');
        const nochebuena = new Date('2026-12-24T00:00:00-03:00');
        const navidadD = navidad;
        const yearnew = new Date('2027-01-01T00:00:00-03:00');
        const reyes = new Date('2027-01-06T00:00:00-03:00');

        function labelDaysFrom(d) {
          const n = diffDays(now, d);
          if (n === 0) return '¡Es HOY!';
          if (n === 1) return 'Mañana';
          return `En ${n} días · ${fmtFullDate(d)}`;
        }
        document.querySelector('[data-thanksgiving]').textContent = labelDaysFrom(thanksgiving);
        document.querySelector('[data-nochebuena]').textContent = labelDaysFrom(nochebuena);
        document.querySelector('[data-navidad]').textContent = labelDaysFrom(navidadD);
        document.querySelector('[data-yearnew]').textContent = labelDaysFrom(yearnew);
        document.querySelector('[data-reyes]').textContent = labelDaysFrom(reyes);
      }
    }

    tick();
    setInterval(tick, 1000);

    // Share buttons
    const url = 'https://hacecuentas.com/cuanto-falta-para-Navidad-2026';
    const waBtn = document.getElementById('share-wa');
    const twBtn = document.getElementById('share-tw');
    waBtn.href = `https://wa.me/?text=${encodeURIComponent('🎄 Cuánto falta para Navidad 2026: ' + url)}`;
    twBtn.href = `https://twitter.com/intent/tweet?url=${encodeURIComponent(url)}&text=${encodeURIComponent('🎄 Cuánto falta para Navidad 2026 ⏳')}`;
    document.getElementById('share-copy').addEventListener('click', async function () {
      try { await navigator.clipboard.writeText(url); this.textContent = '✓ Link copiado'; setTimeout(() => { this.textContent = '🔗 Copiar link'; }, 2000); } catch (e) {}
    });
  })();
</script>

<style>
  .navidad-page { max-width: 960px; margin: 0 auto; padding: 1rem 1.25rem 5rem; color: var(--text); }
  .breadcrumbs { font-size: .875rem; color: var(--text-muted); margin-bottom: 1.5rem; }
  .breadcrumbs a { color: var(--accent); text-decoration: none; }
  .breadcrumbs .sep { margin: 0 .5rem; color: var(--text-subtle); }

  .navidad-header {
    position: relative;
    text-align: center;
    padding: 2.5rem 1.5rem 3rem;
    background: linear-gradient(135deg, #7c2d2d 0%, #dc2626 50%, #059669 100%);
    border-radius: var(--radius-lg);
    color: #fff;
    overflow: hidden;
    margin-bottom: 2rem;
  }
  .snow-bg {
    position: absolute; inset: 0;
    background-image: radial-gradient(circle at 10% 20%, rgba(255,255,255,0.15) 0%, transparent 1%),
                      radial-gradient(circle at 80% 50%, rgba(255,255,255,0.12) 0%, transparent 1%),
                      radial-gradient(circle at 30% 80%, rgba(255,255,255,0.1) 0%, transparent 1%),
                      radial-gradient(circle at 60% 30%, rgba(255,255,255,0.1) 0%, transparent 1%);
    background-size: 150px 150px, 200px 200px, 120px 120px, 180px 180px;
    pointer-events: none;
  }
  .big-emoji { font-size: 4rem; display: block; position: relative; }
  .navidad-header h1 {
    position: relative;
    font-size: clamp(1.6rem, 4vw, 2.5rem);
    margin: .5rem 0 1.5rem;
    color: #fff;
    text-shadow: 0 2px 20px rgba(0,0,0,.3);
  }

  .countdown-big {
    position: relative;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: .75rem;
    max-width: 640px;
    margin: 0 auto;
  }
  .cd-unit {
    padding: 1rem .5rem;
    background: rgba(255,255,255,0.15);
    backdrop-filter: blur(10px);
    border: 1px solid rgba(255,255,255,0.2);
    border-radius: var(--radius);
  }
  .cd-num {
    display: block;
    font-size: clamp(2rem, 8vw, 3.5rem);
    font-weight: 800;
    color: #fff;
    font-variant-numeric: tabular-nums;
    line-height: 1;
    text-shadow: 0 2px 10px rgba(0,0,0,.3);
  }
  .cd-label { font-size: .75rem; text-transform: uppercase; letter-spacing: .1em; opacity: .85; }

  .cd-target { position: relative; margin: 1.5rem 0 0; font-size: 1.0625rem; color: #fef3c7; }
  .cd-target strong { color: #fff; }

  .cd-stats {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
    gap: .625rem;
    margin-bottom: 2.5rem;
  }
  .stat-card {
    padding: 1rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    text-align: center;
  }
  .stat-label { display: block; font-size: .75rem; color: var(--text-muted); text-transform: uppercase; letter-spacing: .05em; margin-bottom: .35rem; }
  .stat-value { display: block; font-size: 1.5rem; font-weight: 800; color: var(--text); font-variant-numeric: tabular-nums; }

  .cd-extras { margin-bottom: 2rem; }
  .cd-extras h2, .cd-faqs h2, .cd-related h2 { font-size: 1.25rem; margin: 0 0 1rem; }
  .dates-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: .625rem; }
  .date-card { display: flex; align-items: center; gap: .75rem; padding: .875rem 1rem; background: var(--bg-card); border: 1px solid var(--border); border-radius: var(--radius-sm); }
  .date-emoji { font-size: 1.5rem; }
  .date-card strong { display: block; font-size: .875rem; color: var(--text); }
  .date-card span { font-size: .8125rem; color: var(--text-muted); }

  .cd-share { padding: 1.25rem; background: var(--bg-soft); border-radius: var(--radius); margin-bottom: 2rem; }
  .cd-share p { margin: 0 0 .75rem; font-weight: 600; }
  .share-buttons { display: flex; flex-wrap: wrap; gap: .5rem; }
  .share-btn {
    padding: .5rem .875rem; background: var(--bg-card); border: 1px solid var(--border);
    border-radius: var(--radius-sm); color: var(--text); text-decoration: none; cursor: pointer;
    font-size: .875rem; font-weight: 600;
  }
  .share-btn:hover { border-color: var(--accent); color: var(--accent); text-decoration: none; }

  .cd-faqs { margin-bottom: 2rem; }
  .cd-faqs details {
    border: 1px solid var(--border); border-radius: var(--radius-sm);
    margin-bottom: .5rem; background: var(--bg-card); overflow: hidden;
  }
  .cd-faqs summary { padding: 1rem 1.25rem; cursor: pointer; font-weight: 600; list-style: none; }
  .cd-faqs summary::-webkit-details-marker { display: none; }
  .cd-faqs details p { padding: 0 1.25rem 1rem; margin: 0; color: var(--text-muted); line-height: 1.6; }
  .cd-faqs a { color: var(--accent); }

  .related-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: .5rem; }
  .rel-card {
    display: flex; align-items: center; gap: .625rem;
    padding: .75rem 1rem; background: var(--bg-card); border: 1px solid var(--border);
    border-radius: var(--radius-sm); color: var(--text); text-decoration: none; font-size: .875rem; font-weight: 600;
    transition: all .15s;
  }
  .rel-card:hover { border-color: var(--accent); color: var(--accent); text-decoration: none; }
</style>
