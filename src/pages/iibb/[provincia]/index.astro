---
export const prerender = true;

import Layout from '../../../layouts/Layout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';

export async function getStaticPaths() {
  const provinciasMod = await import('../../../content/argentina/provincias.json');
  const provincias: any[] = provinciasMod.default || provinciasMod;
  return provincias.map((p) => ({ params: { provincia: p.slug }, props: { provincia: p } }));
}

const { provincia } = Astro.props;
const actividadesMod = await import('../../../content/iibb/actividades.json');
const actividades: any[] = actividadesMod.default || actividadesMod;
const ibMod = await import('../../../content/argentina/ingresos-brutos.json');
const iibb: any = ibMod.default || ibMod;
const provData = iibb.provinceData?.[provincia.slug] || {};

const title = `Ingresos Brutos en ${provincia.name} 2026 — Alícuotas por actividad | Hacé Cuentas`;
const description = `IIBB en ${provincia.name}: alícuotas 2026 por actividad económica, retenciones bancarias, régimen simplificado y Convenio Multilateral. Datos oficiales.`;

const schema = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: title,
  description,
  url: `https://hacecuentas.com/iibb/${provincia.slug}`,
  inLanguage: 'es-AR',
  about: { '@type': 'Place', name: provincia.name, addressCountry: 'AR' },
};
---

<Layout title={title} description={description} canonical={`/iibb/${provincia.slug}`} schema={schema} audience="AR">
  <Header slot="header" />

  <article class="iibb-prov">
    <nav class="breadcrumb">
      <a href="/">Inicio</a> › <a href="/iibb">IIBB</a> › <span>{provincia.name}</span>
    </nav>
    <h1>Ingresos Brutos en {provincia.name} — Alícuotas por actividad 2026</h1>
    <p class="lead">
      Elegí tu actividad económica para ver la alícuota de IIBB aplicable en
      <strong>{provincia.name}</strong> en 2026, junto con retenciones, régimen
      simplificado y Convenio Multilateral.
    </p>

    {provData.details && (
      <section class="prov-details">
        <h2>Cómo funciona IIBB en {provincia.name}</h2>
        <p>{provData.details}</p>
      </section>
    )}

    {provData.metrics && (
      <section>
        <h2>Alícuotas oficiales {provincia.name} 2026</h2>
        <table class="metrics-table">
          <tbody>
            {Object.entries(provData.metrics).map(([k, v]) => (
              <tr>
                <th>{k}</th>
                <td>{v}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </section>
    )}

    {provData.localNotes && (
      <aside class="local-notes">
        <h2>Particularidades de {provincia.name}</h2>
        <p>{provData.localNotes}</p>
      </aside>
    )}

    <section>
      <h2>Buscar IIBB en {provincia.name} por actividad</h2>
      <p>Elegí tu rubro para ver la alícuota exacta aplicable en {provincia.name},
        cómo se calcula el impuesto sobre tu facturación, retenciones bancarias
        habituales y régimen simplificado disponible para monotributistas.</p>
      <ul class="act-grid">
        {actividades.map((a) => (
          <li>
            <a href={`/iibb/${provincia.slug}/${a.slug}`}>
              <span class="act-icon">{a.icon}</span>
              <div>
                <strong>{a.label} en {provincia.name}</strong>
                <small>Alícuota base: {a.rateRange}</small>
              </div>
            </a>
          </li>
        ))}
      </ul>
    </section>

    <section>
      <h2>Convenio Multilateral en {provincia.name}</h2>
      <p>
        Si tu actividad genera ingresos o gastos en {provincia.name} <em>y</em>
        en otra jurisdicción argentina, debés inscribirte en
        <strong> Convenio Multilateral (CM)</strong> y distribuir tu base imponible
        entre las provincias mediante coeficientes calculados sobre ingresos y
        gastos del año anterior.
      </p>
      <ul>
        <li><strong>Régimen general (Art. 2):</strong> aplica para la mayoría de las actividades. Coeficiente unificado.</li>
        <li><strong>Régimen especial:</strong> para construcción (Art. 6), entidades financieras (Art. 7), seguros (Art. 8), transporte (Art. 9), profesionales (Art. 10), comisionistas (Art. 11), prestamistas (Art. 12).</li>
      </ul>
      <p>
        El Convenio Multilateral se administra a través de <strong>SIFERE</strong>
        (Sistema Federal de Recaudación) y la Comisión Arbitral. La presentación
        es mensual y la liquidación se distribuye automáticamente a {provincia.name}
        y al resto de las jurisdicciones donde operás.
      </p>
    </section>

    <section>
      <h2>Régimen simplificado de IIBB en {provincia.name}</h2>
      <p>
        Para monotributistas y pequeños contribuyentes que operan exclusivamente
        en {provincia.name} y no superan ciertos topes de ingresos anuales, suele
        existir un <strong>régimen simplificado</strong> con cuota fija mensual
        en lugar del porcentaje sobre facturación. Esto simplifica la operatoria
        (no requiere DDJJ mensual) y unifica el pago.
      </p>
      <p>
        Verificá los topes y requisitos exactos en el portal oficial de la
        dirección de rentas de {provincia.name}. El régimen suele estar atado
        al monotributo nacional (categoría máxima permitida) y a la actividad
        ejercida.
      </p>
    </section>

    <section>
      <h2>Vencimientos y presentación</h2>
      <p>
        Las declaraciones juradas de IIBB en {provincia.name} se presentan
        <strong>mensualmente</strong> mediante el sistema digital del organismo
        recaudador. Los vencimientos dependen de la terminación del CUIT y se
        publican en el calendario fiscal anual.
      </p>
      <p>
        El pago se realiza por <strong>VEP, transferencia bancaria o débito
        automático</strong>. Las retenciones bancarias y percepciones se
        acreditan como pago a cuenta. Si tenés saldos a favor recurrentes,
        es común tramitar exención o reducción de retenciones.
      </p>
    </section>
  </article>

  <Footer slot="footer" />
</Layout>

<style>
  .iibb-prov { max-width: 920px; margin: 0 auto; padding: 24px 16px 64px; line-height: 1.6; }
  .breadcrumb { color: #64748b; font-size: 14px; margin-bottom: 16px; }
  .breadcrumb a { color: inherit; text-decoration: none; }
  h1 { font-size: 30px; line-height: 1.25; margin: 8px 0 12px; }
  .lead { color: #475569; font-size: 17px; }
  .local-notes { background: #fef3c7; border-radius: 10px; padding: 16px 22px; margin: 18px 0; }
  .local-notes h2 { font-size: 18px; margin: 0 0 6px; color: #92400e; }
  .prov-details { margin: 24px 0; }
  .prov-details p { color: #475569; font-size: 16px; }
  .metrics-table {
    width: 100%; border-collapse: collapse; margin: 12px 0;
    background: #f8fafc; border-radius: 10px; overflow: hidden;
  }
  .metrics-table th, .metrics-table td {
    padding: 10px 14px; text-align: left; border-bottom: 1px solid #e2e8f0;
    font-size: 14px;
  }
  .metrics-table th { color: #64748b; font-weight: 500; width: 40%; }
  .metrics-table td { color: #1e293b; font-weight: 500; }
  .metrics-table tr:last-child th, .metrics-table tr:last-child td { border-bottom: none; }
  section { margin: 28px 0; }
  section ul { padding-left: 22px; }
  section ul li { margin-bottom: 6px; color: #475569; }
  .act-grid {
    list-style: none; padding: 0;
    display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 10px;
  }
  .act-grid a {
    display: flex; gap: 12px; padding: 14px 16px;
    background: #f8fafc; border-radius: 10px; border: 1px solid #e2e8f0;
    text-decoration: none; color: #1e293b; align-items: center;
  }
  .act-grid a:hover { background: #f1f5f9; border-color: #cbd5e1; }
  .act-icon { font-size: 26px; }
  .act-grid strong { display: block; font-size: 15px; }
  .act-grid small { color: #64748b; font-size: 13px; }
</style>
