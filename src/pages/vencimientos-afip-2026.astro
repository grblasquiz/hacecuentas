---
<Layout title={title} description={description} schema={schema} audience="AR">
  <Header slot="header" />

  <article class="landing">
    <nav class="breadcrumbs" aria-label="Ruta de navegación">
      <a href="/">Inicio</a>
      <span class="sep" aria-hidden="true">/</span>
      <a href="/categoria/finanzas">Finanzas</a>
      <span class="sep" aria-hidden="true">/</span>
      <span class="current">Vencimientos AFIP 2026</span>
    </nav>

    <!-- HERO -->
    <header class="hero">
      <h1>Vencimientos AFIP 2026: calendario fiscal completo</h1>
      <p class="lead">
        Todas las fechas de vencimiento de AFIP para 2026: monotributo mensual, IVA, Ganancias, Bienes Personales, anticipos y recategorizaciones. Filtrá por mes y tipo de obligación para encontrar tus fechas rápido.
      </p>
      <div class="hero-meta">
        <span>Actualizado: abril 2026</span>
        <span>Fuente: AFIP / RG vigentes</span>
      </div>
    </header>

    <!-- FILTROS -->
    <section class="section">
      <div class="filters" id="filters">
        <button class="filter-btn active" data-filter="all">Todos</button>
        <button class="filter-btn" data-filter="monotributo">Monotributo</button>
        <button class="filter-btn" data-filter="iva">IVA</button>
        <button class="filter-btn" data-filter="ganancias">Ganancias</button>
        <button class="filter-btn" data-filter="bienes">Bienes Personales</button>
      </div>
    </section>

    <!-- RESUMEN RÁPIDO MONOTRIBUTO -->
    <section class="section">
      <h2>Vencimientos monotributo 2026 (resumen)</h2>
      <div class="mono-grid">
        {monotributoVto.map((v) => (
          <div class="mono-card">
            <div class="mono-mes">{v.mes}</div>
            <div class="mono-fecha">{v.fecha}</div>
          </div>
        ))}
      </div>
      <p class="section-note">
        La cuota del monotributo vence el día 20 de cada mes. Cuando el 20 cae en feriado o fin de semana, se corre al siguiente día hábil. Podés pagar con VEP, débito automático o en red de pagos.
      </p>
    </section>

    <!-- CALENDARIO MES A MES -->
    <section class="section" id="calendario">
      <h2>Calendario completo mes a mes</h2>
      <p>Hacé clic en cada mes para ver el detalle de vencimientos. Usá los filtros de arriba para mostrar solo un tipo de obligación.</p>

      <div class="calendar-accordion">
        {calendario.map((m, idx) => (
          <details class="month-block" open={idx === 3}>
            <summary class="month-header">
              <span class="month-name">{m.mes}</span>
              <span class="month-count">{m.items.length} vencimientos</span>
            </summary>
            <div class="month-body">
              {m.items.map((item) => (
                <div class={`vto-row ${item.tipo}`} data-tipo={item.tipo}>
                  <span class="vto-fecha">{item.fecha}</span>
                  <span class={`vto-badge ${item.tipo}`}>{tipoLabel[item.tipo]}</span>
                  <span class="vto-concepto">{item.concepto}</span>
                </div>
              ))}
            </div>
          </details>
        ))}
      </div>
    </section>

    <!-- FECHAS DESTACADAS -->
    <section class="section">
      <h2>Fechas clave 2026</h2>
      <div class="key-dates">
        <div class="kd-card">
          <div class="kd-date">20 de enero</div>
          <div class="kd-title">Recategorización monotributo</div>
          <div class="kd-desc">Primera recategorización semestral. Evaluación julio-diciembre 2025.</div>
        </div>
        <div class="kd-card accent">
          <div class="kd-date">11-13 de junio</div>
          <div class="kd-title">DDJJ Ganancias + Bienes Personales</div>
          <div class="kd-desc">Declaraciones juradas anuales del ejercicio 2025. Fecha según terminación de CUIT.</div>
        </div>
        <div class="kd-card">
          <div class="kd-date">20 de julio</div>
          <div class="kd-title">Recategorización monotributo</div>
          <div class="kd-desc">Segunda recategorización semestral. Evaluación julio 2025 - junio 2026.</div>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <div class="cta-box">
      <h3>Calculadoras para monotributistas y autónomos</h3>
      <p>Calculá tu cuota, comparate con Responsable Inscripto o estimá Ganancias.</p>
      <div class="cta-links">
        <a href="/calculadora-monotributo-2026" class="cta-btn">Monotributo 2026</a>
        <a href="/calculadora-impuesto-ganancias-sueldo" class="cta-btn secondary">Imp. Ganancias</a>
      </div>
    </div>

    <!-- LINKS RELACIONADOS -->
    <section class="section">
      <h2>Calculadoras y guías relacionadas</h2>
      <div class="link-grid">
        <a href="/calculadora-monotributo-2026" class="link-card">
          <span class="link-title">Calculadora Monotributo</span>
          <span class="link-desc">Cuota mensual según tu categoría</span>
        </a>
        <a href="/calculadora-monotributo-categoria-ingresos-tope" class="link-card">
          <span class="link-title">Categoría por Ingresos</span>
          <span class="link-desc">En qué categoría te corresponde estar</span>
        </a>
        <a href="/calculadora-impuesto-ganancias-sueldo" class="link-card">
          <span class="link-title">Impuesto a las Ganancias</span>
          <span class="link-desc">Estimá la retención de 4ta categoría</span>
        </a>
        <a href="/calculadora-monotributo-vs-responsable-inscripto" class="link-card">
          <span class="link-title">Monotributo vs. Resp. Inscripto</span>
          <span class="link-desc">Compará regímenes antes de la recategorización</span>
        </a>
        <a href="/recategorizacion-monotributo-julio-2026" class="link-card">
          <span class="link-title">Recategorización Julio 2026</span>
          <span class="link-desc">Guía paso a paso para recategorizarte</span>
        </a>
        <a href="/aguinaldo-junio-2026" class="link-card">
          <span class="link-title">Aguinaldo Junio 2026</span>
          <span class="link-desc">Fechas, cálculo y montos del SAC</span>
        </a>
      </div>
    </section>

    <!-- FAQ -->
    <section class="section faq-section">
      <h2>Preguntas frecuentes sobre vencimientos AFIP 2026</h2>
      <div class="faq-list">
        {faqItems.map((item) => (
          <details class="faq-item">
            <summary>{item.q}</summary>
            <p>{item.a}</p>
          </details>
        ))}
      </div>
    </section>

    <Newsletter />
  </article>

  <Footer slot="footer" />
</Layout>

<script>
  // Filtro interactivo por tipo de obligación
  const filters = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
  const rows = document.querySelectorAll<HTMLElement>('.vto-row');

  filters.forEach((btn) => {
    btn.addEventListener('click', () => {
      const filter = btn.dataset.filter;
      filters.forEach((b) => b.classList.remove('active'));
      btn.classList.add('active');

      rows.forEach((row) => {
        if (filter === 'all' || row.dataset.tipo === filter) {
          row.style.display = '';
        } else {
          row.style.display = 'none';
        }
      });

      // Update month counts
      document.querySelectorAll<HTMLElement>('.month-block').forEach((block) => {
        const visibleRows = block.querySelectorAll<HTMLElement>('.vto-row:not([style*="display: none"])');
        const countEl = block.querySelector('.month-count');
        if (countEl) {
          countEl.textContent = `${visibleRows.length} vencimiento${visibleRows.length !== 1 ? 's' : ''}`;
        }
      });
    });
  });
</script>

<style>
  .landing { max-width: 920px; margin: 0 auto; padding: 0 0 3rem; }
  .breadcrumbs { font-size: 0.875rem; color: var(--text-subtle); margin-bottom: 1rem; display: flex; gap: 0.5rem; flex-wrap: wrap; }
  .breadcrumbs a { color: var(--text-muted); }
  .breadcrumbs .current { color: var(--text); font-weight: 500; }
  .breadcrumbs .sep { color: var(--border-strong); }

  .hero { margin-bottom: 2.5rem; }
  .hero h1 { margin-bottom: 1rem; }
  .lead { font-size: 1.0625rem; color: var(--text-muted); margin-bottom: 1rem; max-width: 760px; line-height: 1.65; }
  .hero-meta { display: flex; gap: 1.5rem; flex-wrap: wrap; font-size: 0.8125rem; color: var(--text-subtle); }

  .section { margin-bottom: 2.5rem; }
  .section h2 { margin-bottom: 0.75rem; }
  .section p { margin-bottom: 0.75rem; color: var(--text-muted); line-height: 1.65; }
  .section-note { font-size: 0.8125rem; color: var(--text-subtle); margin-top: 0.75rem; }

  /* Filters */
  .filters { display: flex; gap: 0.5rem; flex-wrap: wrap; margin-bottom: 0.5rem; }
  .filter-btn {
    padding: 0.5rem 1rem; border: 1px solid var(--border); border-radius: 999px;
    background: var(--bg-card); color: var(--text-muted); font-size: 0.8125rem;
    font-weight: 500; cursor: pointer; transition: all 0.15s;
  }
  .filter-btn:hover { border-color: var(--accent); color: var(--accent); }
  .filter-btn.active { background: var(--accent); color: #fff; border-color: var(--accent); }

  /* Monotributo grid */
