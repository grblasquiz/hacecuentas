// Schemas combinados: CollectionPage + BreadcrumbList + FAQPage
// ItemList top-level (standalone) — Google lo prefiere así para rich results
// en lugar de embebido en CollectionPage. Incluye imagen + descripción por item.
const schemaItemList = {
  '@type': 'ItemList',
  '@id': `https://hacecuentas.com/categoria/${cat}#itemlist`,
  name: `Calculadoras de ${m.label}`,
  description: m.desc,
  numberOfItems: calcs.length,
  itemListOrder: 'https://schema.org/ItemListOrderAscending',
  itemListElement: calcs.map((c: any, i: number) => ({
    '@type': 'ListItem',
    position: i + 1,
    url: `https://hacecuentas.com/${c.slug}`,
    name: c.h1,
    description: c.description,
    image: 'https://hacecuentas.com/og-default.png',
  })),
};

const schemaCollection = {
  '@type': 'CollectionPage',
  '@id': `https://hacecuentas.com/categoria/${cat}`,
  name: m.label,
  description: m.desc,
  url: `https://hacecuentas.com/categoria/${cat}`,
  inLanguage: 'es-AR',
  mainEntity: { '@id': `https://hacecuentas.com/categoria/${cat}#itemlist` },
};

const schemaBreadcrumb = {
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Inicio', item: 'https://hacecuentas.com/' },
    { '@type': 'ListItem', position: 2, name: m.label, item: `https://hacecuentas.com/categoria/${cat}` },
  ],
};

const schemaFAQ = m.faq.length > 0 ? {
  '@type': 'FAQPage',
  mainEntity: m.faq.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: {
      '@type': 'Answer',
      text: f.a,
    },
  })),
} : null;

const graph: any[] = [schemaCollection, schemaItemList, schemaBreadcrumb];
if (schemaFAQ) graph.push(schemaFAQ);
const schema = { '@context': 'https://schema.org', '@graph': graph };

// Markdown → HTML (simple, igual que [...slug].astro)
function md(text: string): string {
  return text
    .replace(/^### (.+)$/gm, '<h3>$1</h3>')
    .replace(/^## (.+)$/gm, '<h2>$1</h2>')
    .replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>')
    .replace(/\*(.+?)\*/g, '<em>$1</em>')
    .replace(/`([^`]+)`/g, '<code>$1</code>')
    .replace(/\[(.+?)\]\((.+?)\)/g, '<a href="$2" rel="noopener">$1</a>')
    .replace(/^\- (.+)$/gm, '<li>$1</li>')
    .replace(/^\| (.+) \|$/gm, (match) => {
      const cells = match.slice(2, -2).split(' | ');
      return '<tr>' + cells.map((c) => `<td>${c}</td>`).join('') + '</tr>';
    })
    .replace(/\n\n/g, '</p><p>')
    .replace(/\n/g, '<br>');
}
