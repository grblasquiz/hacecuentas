const m = meta[cat] || meta.finanzas;

// Schemas combinados: CollectionPage + BreadcrumbList + FAQPage
const schemaCollection = {
  '@type': 'CollectionPage',
  '@id': `https://hacecuentas.com/categoria/${cat}`,
  name: m.label,
  description: m.desc,
  url: `https://hacecuentas.com/categoria/${cat}`,
  inLanguage: 'es-AR',
  mainEntity: {
    '@type': 'ItemList',
    itemListElement: calcs.map((c, i) => ({
      '@type': 'ListItem',
      position: i + 1,
      name: c.h1,
      url: `https://hacecuentas.com/${c.slug}`,
    })),
  },
};

const schemaBreadcrumb = {
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Inicio', item: 'https://hacecuentas.com/' },
    { '@type': 'ListItem', position: 2, name: m.label, item: `https://hacecuentas.com/categoria/${cat}` },
  ],
};

const schemaFAQ = m.faq.length > 0 ? {
  '@type': 'FAQPage',
  mainEntity: m.faq.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: {
      '@type': 'Answer',
      text: f.a,
    },
  })),
} : null;

const graph: any[] = [schemaCollection, schemaBreadcrumb];
if (schemaFAQ) graph.push(schemaFAQ);
const schema = { '@context': 'https://schema.org', '@graph': graph };

// Markdown → HTML (simple, igual que [...slug].astro)
function md(text: string): string {
  return text
    .replace(/^### (.+)$/gm, '<h3>$1</h3>')
    .replace(/^## (.+)$/gm, '<h2>$1</h2>')
    .replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>')
    .replace(/\*(.+?)\*/g, '<em>$1</em>')
    .replace(/`([^`]+)`/g, '<code>$1</code>')
    .replace(/\[(.+?)\]\((.+?)\)/g, '<a href="$2" rel="noopener">$1</a>')
    .replace(/^\- (.+)$/gm, '<li>$1</li>')
    .replace(/^\| (.+) \|$/gm, (match) => {
      const cells = match.slice(2, -2).split(' | ');
      return '<tr>' + cells.map((c) => `<td>${c}</td>`).join('') + '</tr>';
    })
    .replace(/\n\n/g, '</p><p>')
    .replace(/\n/g, '<br>');
}
---

<Layout title={m.title} description={m.desc} schema={schema}>
  <Header slot="header" />

  <nav class="breadcrumbs" aria-label="Ruta de navegación">
    <a href="/">Inicio</a>
    <span class="sep" aria-hidden="true">/</span>
    <span class="current">{m.label}</span>
  </nav>

  <header class="cat-header" style={`--cat-color: ${m.color}`}>
    <div class="icon-wrap" aria-hidden="true">{m.icon}</div>
    <div>
      <div class="eyebrow">Categoría</div>
      <h1>{m.label}</h1>
      <p class="intro">{m.intro}</p>
      <div class="quick-stats">
        <span class="qs-item"><strong>{calcs.length}</strong> calculadoras</span>
        <span class="qs-dot" aria-hidden="true">·</span>
        <span class="qs-item">Actualizadas a <strong>2026</strong></span>
        <span class="qs-dot" aria-hidden="true">·</span>
        <span class="qs-item"><strong>100%</strong> gratis</span>
        <span class="qs-dot" aria-hidden="true">·</span>
        <span class="qs-item">Sin registro</span>
      </div>
    </div>
  </header>

  <div class="cat-toolbar">
    <label class="search-wrap" for={`cat-filter-${cat}`}>
      <svg class="s-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
      </svg>
      <input
        type="search"
        id={`cat-filter-${cat}`}
        class="cat-filter"
        placeholder={`Filtrar entre ${calcs.length} calculadoras de ${m.label.toLowerCase()}…`}
        autocomplete="off"
      />
    </label>
    <span class="cat-filter-count" data-total={calcs.length}>{calcs.length} resultados</span>
  </div>

  <div class="grid" id="cat-grid">
    {calcs.map((c: any) => (
      <a
        href={`/${c.slug}`}
        class="card"
        data-name={(c.h1 + ' ' + (c.description || '')).toLowerCase()}
        data-audience={c.audience || 'global'}
      >
        <div class="card-icon">{c.icon}</div>
        <div class="card-body">
          <div class="card-title">
            {c.h1}
            {c.audience === 'AR' && (
              <span class="ar-badge" title="Específica para Argentina" aria-label="Específica para Argentina">🇦🇷</span>
            )}
          </div>
          <div class="card-desc">{c.description}</div>
        </div>
        <div class="card-arrow" aria-hidden="true">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="5" y1="12" x2="19" y2="12"/>
            <polyline points="12 5 19 12 12 19"/>
          </svg>
        </div>
      </a>
    ))}
  </div>

  <p class="cat-empty" id="cat-empty" hidden>
    No encontramos calculadoras que coincidan. Probá otro término o
    <a href="/buscar">buscá en todo el sitio</a>.
  </p>

  <script is:inline define:vars={{ catSlug: cat }}>
    (function () {
      var input = document.getElementById('cat-filter-' + catSlug);
      var grid = document.getElementById('cat-grid');
      var counter = document.querySelector('.cat-filter-count');
      var empty = document.getElementById('cat-empty');
      if (!input || !grid || !counter) return;
      var cards = Array.from(grid.querySelectorAll('.card'));
      var total = cards.length;

      function norm(s) { return s.toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g, ''); }

      function filter() {
        var q = norm(input.value.trim());
        if (!q) {
          cards.forEach(function (c) { c.hidden = false; });
          counter.textContent = total + ' resultados';
          if (empty) empty.hidden = true;
          return;
        }
        var visible = 0;
        cards.forEach(function (c) {
          var hay = norm(c.dataset.name || '');
          var match = hay.indexOf(q) !== -1;
          c.hidden = !match;
          if (match) visible++;
        });
        counter.textContent = visible + ' / ' + total + ' resultados';
        if (empty) empty.hidden = visible > 0;
      }

      input.addEventListener('input', filter);
      input.addEventListener('keydown', function (e) {
        if (e.key === 'Escape') { input.value = ''; filter(); input.blur(); }
      });
    })();
  </script>

  {m.seoContent && (
    <section class="seo-content">
      <Fragment set:html={`<p>${md(m.seoContent)}</p>`} />
    </section>
  )}

  {m.faq.length > 0 && (
    <section class="faq">
      <h2>Preguntas frecuentes sobre {m.label}</h2>
      <div class="faq-list">
        {m.faq.map((f) => (
          <details>
            <summary>
              <span>{f.q}</span>
              <svg class="chev" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
            </summary>
            <div set:html={`<p>${md(f.a)}</p>`} />
          </details>
        ))}
      </div>
    </section>
  )}

  <aside class="cta-back">
    <p>¿Buscás otra categoría?</p>
    <a href="/" class="btn-ghost">Ver todas las calculadoras →</a>
  </aside>

  <Footer slot="footer" />
</Layout>

