const m = meta[cat] || meta.finanzas;

// Interlinking: guía pilar del tema + categorías hermanas
const pillarSlug = CATEGORY_TO_GUIDE[cat];
const pillarTitle = pillarSlug ? GUIDE_TITLES[pillarSlug] : null;
