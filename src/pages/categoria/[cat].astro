            <polyline points="12 5 19 12 12 19"/>
          </svg>
        </div>
      </a>
    ))}
  </div>

  <p class="cat-empty" id="cat-empty" hidden>
    No encontramos calculadoras que coincidan. Probá otro término o
    <a href="/buscar">buscá en todo el sitio</a>.
  </p>

  <script is:inline define:vars={{ catSlug: cat }}>
    (function () {
      var input = document.getElementById('cat-filter-' + catSlug);
      var grid = document.getElementById('cat-grid');
      var counter = document.querySelector('.cat-filter-count');
      var empty = document.getElementById('cat-empty');
      if (!input || !grid || !counter) return;
      function norm(s) { return s.toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g, ''); }

      // Pre-computamos el texto buscable leyendo del DOM existente (title + desc)
      // \u2014 antes esto viv\u00eda duplicado en data-name lowercased, que sumaba ~80-150
      // bytes por card al HTML servido. La normalizaci\u00f3n se hace una sola vez al
      // cargar; el filtro per-keystroke solo hace string.includes() contra el cache.
      var cards = Array.from(grid.querySelectorAll('.card')).map(function (el) {
        var t = el.querySelector('.card-title');
        var d = el.querySelector('.card-desc');
        return {
          el: el,
          text: norm(((t && t.textContent) || '') + ' ' + ((d && d.textContent) || '')),
        };
      });
      var total = cards.length;

      function filter() {
        var q = norm(input.value.trim());
        if (!q) {
          cards.forEach(function (c) { c.el.hidden = false; });
          counter.textContent = total + ' resultados';
          if (empty) empty.hidden = true;
          return;
        }
        var visible = 0;
        cards.forEach(function (c) {
          var match = c.text.indexOf(q) !== -1;
          c.el.hidden = !match;
          if (match) visible++;
        });
        counter.textContent = visible + ' / ' + total + ' resultados';
        if (empty) empty.hidden = visible > 0;
      }

      input.addEventListener('input', filter);
      input.addEventListener('keydown', function (e) {
        if (e.key === 'Escape') { input.value = ''; filter(); input.blur(); }
      });
    })();
  </script>

  {m.seoContent && (
    <section class="seo-content">
      <Fragment set:html={`<p>${md(m.seoContent)}</p>`} />
    </section>
  )}

  {m.faq.length > 0 && (
