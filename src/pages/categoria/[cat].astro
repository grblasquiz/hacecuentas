            </summary>
            <div set:html={`<p>${md(f.a)}</p>`} />
          </details>
        ))}
      </div>
    </section>
  )}

  {siblings.length > 0 && (
    <section class="cat-siblings">
      <h2>Categorías relacionadas</h2>
      <div class="sib-grid">
        {siblings.map((sc: string) => (
          <a href={`/categoria/${sc}`} class="sib-card">
            <span class="sib-icon">{CATEGORY_ICONS[sc] || '🧮'}</span>
            <span class="sib-name">{CATEGORY_TITLES[sc] || sc}</span>
            <span class="sib-arrow" aria-hidden="true">→</span>
          </a>
        ))}
      </div>
    </section>
  )}

  <aside class="cta-back">
    <p>¿Buscás otra categoría?</p>
    <a href="/" class="btn-ghost">Ver todas las calculadoras →</a>
    <a href="/guias" class="btn-ghost-alt">📘 Ver todas las guías</a>
  </aside>

  <Footer slot="footer" />
</Layout>

