---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

export async function getStaticPaths() {
  const calcs = import.meta.glob<any>('../../content/calcs/*.json', { eager: true });
  const all = Object.values(calcs).map((m: any) => m.default || m);
  const cats = [...new Set(all.map((c) => c.category))];
  return cats.map((cat) => ({
    params: { cat },
    props: { cat, calcs: all.filter((c) => c.category === cat) },
  }));
}

const { cat, calcs } = Astro.props;

const meta: Record<string, { label: string; title: string; desc: string; intro: string; color: string; icon: string }> = {
  finanzas: {
    label: 'Finanzas',
    title: 'Calculadoras de Finanzas — Sueldo, Préstamos, Impuestos | Hacé Cuentas',
    desc: 'Calculadoras financieras para Argentina: sueldo en mano, aguinaldo, indemnización, préstamos, monotributo, plazo fijo y más. Fórmulas oficiales actualizadas.',
    intro: 'Todo lo que necesitás calcular para manejar tu plata y tu trabajo: sueldos, aguinaldo, indemnización, préstamos, impuestos e inversiones. Fórmulas adaptadas a la legislación argentina y actualizadas a 2026.',
    color: '#2563eb',
    icon: '💰',
  },
  salud: {
    label: 'Salud',
    title: 'Calculadoras de Salud — IMC, Calorías, Embarazo | Hacé Cuentas',
    desc: 'Calculadoras de salud: IMC, calorías diarias (TDEE), semanas de embarazo, ovulación. Basadas en fórmulas de la OMS y ACOG.',
    intro: 'Herramientas para monitorear tu salud: IMC, necesidades calóricas, embarazo y ciclo menstrual. Basadas en fórmulas validadas por OMS y ACOG.',
    color: '#16a34a',
    icon: '❤️',
  },
  vida: {
    label: 'Vida cotidiana',
    title: 'Calculadoras de Vida Cotidiana — Edad, Fechas, Porcentajes | Hacé Cuentas',
    desc: 'Calculadoras para el día a día: edad exacta, días entre fechas, porcentajes, propinas y más.',
    intro: 'Las cuentas chicas que hacés todos los días: tu edad, cuántos días faltan, calcular porcentajes, dividir una cuenta con amigos.',
    color: '#d97706',
    icon: '📅',
  },
  marketing: {
    label: 'Marketing',
    title: 'Calculadoras de Marketing — CTR, CPC, CPM, ROAS, CAC | Hacé Cuentas',
    desc: 'Calculadoras para marketing digital: CTR, CPC, CPM, ROAS, tasa de conversión, CAC y LTV. Benchmarks por canal e industria.',
    intro: 'Las métricas clave del marketing digital: CTR, CPC, CPM, ROAS, tasa de conversión y CAC/LTV. Para decidir si tus campañas de Google Ads, Meta o TikTok están rindiendo.',
    color: '#e11d48',
    icon: '📈',
  },
  viajes: {
    label: 'Viajes',
    title: 'Calculadoras de Viajes — Combustible, Presupuesto, Dividir Gastos | Hacé Cuentas',
    desc: 'Calculadoras para planificar tus viajes: combustible, presupuesto total, división de gastos entre amigos.',
    intro: 'Calculadoras para antes, durante y después del viaje: combustible, presupuesto completo, división de gastos con amigos. Pensadas para viajes en Argentina y al exterior.',
    color: '#0891b2',
    icon: '✈️',
  },
  deportes: {
    label: 'Deportes',
    title: 'Calculadoras de Deportes — Descenso del Fútbol Argentino | Hacé Cuentas',
    desc: 'Calculadoras deportivas: descenso del fútbol argentino por promedios, proyecciones de temporada y más.',
    intro: 'Calculadoras para los fanáticos del deporte: descenso del fútbol argentino, proyección de promedios y más.',
    color: '#65a30d',
    icon: '⚽',
  },
  negocios: {
    label: 'Negocios',
    title: 'Calculadoras para Negocios — Margen, Precio, Break-even | Hacé Cuentas',
    desc: 'Calculadoras para pymes y emprendedores: margen de ganancia, precio con IVA, punto de equilibrio, facturación mínima monotributo, rotación de inventario, DSO, comisiones.',
    intro: 'Herramientas para tomar decisiones comerciales con números: márgenes, precios de venta con IVA, punto de equilibrio (break-even), costo laboral, comisiones y gestión de cobros. Para pymes, autónomos y emprendedores en Argentina.',
    color: '#7c3aed',
    icon: '📊',
  },
  negocio: {
    label: 'Negocios',
    title: 'Calculadoras para Negocios — Margen, Precio, Break-even | Hacé Cuentas',
    desc: 'Calculadoras para pymes y emprendedores: margen de ganancia, precio con IVA, punto de equilibrio, facturación mínima monotributo, rotación de inventario.',
    intro: 'Herramientas para decisiones comerciales: márgenes, precios, facturación, break-even y gestión de cobros.',
    color: '#7c3aed',
    icon: '📊',
  },
  mascotas: {
    label: 'Mascotas',
    title: 'Calculadoras para Mascotas — Edad Perro/Gato, Alimento, Dosis | Hacé Cuentas',
    desc: 'Calculadoras para el cuidado de tu mascota: edad en años humanos, alimento diario, peso ideal y dosis de medicamentos según peso.',
    intro: 'Herramientas para cuidar mejor a tu perro o gato: edad en años humanos (escala UCSD 2019 y Cornell), cuánto alimento necesita por día (NRC 2006), peso ideal por raza y dosis de medicamentos.',
    color: '#db2777',
    icon: '🐶',
  },
  matematica: {
    label: 'Matemática',
    title: 'Calculadoras de Matemática — Pitágoras, Factorial, MCD/MCM | Hacé Cuentas',
    desc: 'Calculadoras de matemática: teorema de Pitágoras, ecuación cuadrática, factorial, combinatoria, MCD, MCM, promedio, mediana, moda, interés simple.',
    intro: 'Cálculos matemáticos del cole y la facultad: Pitágoras, fórmula resolvente, factorial y combinatoria, MCD/MCM, estadística básica e interés simple. Con fórmulas y pasos explicados.',
    color: '#0d9488',
    icon: '🧮',
  },
  construccion: {
    label: 'Construcción',
    title: 'Calculadoras de Construcción — Ladrillos, Cemento, Pintura, Cerámicos | Hacé Cuentas',
    desc: 'Calculadoras para construcción y refacción: ladrillos por m², cemento/arena/piedra por m³ (CIRSOC 201), pintura por m², pisos cerámicos y costo por m² de obra.',
    intro: 'Cuántos ladrillos, bolsas de cemento, litros de pintura y cajas de cerámicos necesitás. Dosificaciones según CIRSOC 201 y costos actualizados por zona. Para obras, refacciones y albañilería en Argentina.',
    color: '#b45309',
    icon: '🏗️',
  },
  cocina: {
    label: 'Cocina',
    title: 'Calculadoras de Cocina — Tazas a Gramos, Escalar Receta, Cocción | Hacé Cuentas',
    desc: 'Calculadoras para la cocina: convertir tazas a gramos, escalar recetas a más o menos porciones, tiempo y temperatura de cocción por carne y peso.',
    intro: 'Todo lo que necesitás en la cocina: convertir tazas y cucharadas a gramos, multiplicar o dividir recetas, y tiempos de cocción por carne y peso. Con densidades por ingrediente y temperaturas internas seguras.',
    color: '#ea580c',
    icon: '🍳',
  },
};

const m = meta[cat] || meta.finanzas;

const schema = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: m.label,
  description: m.desc,
  url: `https://hacecuentas.com/categoria/${cat}`,
  inLanguage: 'es-AR',
  mainEntity: {
    '@type': 'ItemList',
    itemListElement: calcs.map((c, i) => ({
      '@type': 'ListItem',
      position: i + 1,
      name: c.h1,
      url: `https://hacecuentas.com/${c.slug}`,
    })),
  },
};
---

<Layout title={m.title} description={m.desc} schema={schema}>
  <Header slot="header" />

  <nav class="breadcrumbs" aria-label="Ruta de navegación">
    <a href="/">Inicio</a>
    <span class="sep" aria-hidden="true">/</span>
    <span class="current">{m.label}</span>
  </nav>

  <header class="cat-header" style={`--cat-color: ${m.color}`}>
    <div class="icon-wrap" aria-hidden="true">{m.icon}</div>
    <div>
      <div class="eyebrow">Categoría</div>
      <h1>{m.label}</h1>
      <p class="intro">{m.intro}</p>
      <div class="count">{calcs.length} calculadoras disponibles</div>
    </div>
  </header>

  <div class="grid">
    {calcs.map((c: any) => (
      <a href={`/${c.slug}`} class="card">
        <div class="card-icon">{c.icon}</div>
        <div class="card-body">
          <div class="card-title">{c.h1}</div>
          <div class="card-desc">{c.description}</div>
        </div>
        <div class="card-arrow" aria-hidden="true">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="5" y1="12" x2="19" y2="12"/>
            <polyline points="12 5 19 12 12 19"/>
          </svg>
        </div>
      </a>
    ))}
  </div>

  <aside class="cta-back">
    <p>¿Buscás otra categoría?</p>
    <a href="/" class="btn-ghost">Ver todas las calculadoras →</a>
  </aside>

  <Footer slot="footer" />
</Layout>

<style>
  .breadcrumbs {
    display: flex;
    gap: 0.5rem;
    font-size: 0.8125rem;
    color: var(--text-subtle);
    margin-bottom: 1.75rem;
  }
  .breadcrumbs a { color: var(--text-muted); text-decoration: none; }
  .breadcrumbs a:hover { color: var(--accent); }
  .breadcrumbs .sep { color: var(--border-strong); }
  .breadcrumbs .current { color: var(--text); font-weight: 500; }

  .cat-header {
    display: flex;
    gap: 1.25rem;
    align-items: flex-start;
    padding: 2rem;
    background: linear-gradient(135deg, var(--bg-soft) 0%, var(--bg) 100%);
    border: 1px solid var(--border);
    border-left: 4px solid var(--cat-color);
    border-radius: var(--radius-lg);
    margin-bottom: 2rem;
  }

  .icon-wrap {
    flex-shrink: 0;
    width: 60px;
    height: 60px;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.875rem;
  }

  .eyebrow {
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--cat-color);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 0.25rem;
  }

  .cat-header h1 { margin: 0 0 0.5rem; font-size: clamp(1.5rem, 3vw, 2rem); }
  .intro { margin: 0 0 0.75rem; color: var(--text-muted); font-size: 0.9375rem; }
  .count { font-size: 0.8125rem; color: var(--text-subtle); font-weight: 500; }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(290px, 1fr));
    gap: 0.875rem;
  }

  .card {
    display: flex;
    align-items: flex-start;
    gap: 0.875rem;
    padding: 1.125rem 1.25rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    text-decoration: none;
    color: var(--text);
    transition: all 0.15s;
  }
  .card:hover {
    border-color: var(--accent);
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
  }
  .card:hover .card-arrow { color: var(--accent); transform: translateX(2px); }

  .card-icon {
    flex-shrink: 0;
    width: 40px;
    height: 40px;
    background: var(--accent-soft);
    border-radius: var(--radius-sm);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.25rem;
  }
  .card-body { flex: 1; min-width: 0; }
  .card-title { font-weight: 600; font-size: 0.9375rem; margin-bottom: 0.25rem; line-height: 1.35; }
  .card-desc {
    font-size: 0.8125rem;
    color: var(--text-muted);
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .card-arrow { flex-shrink: 0; color: var(--text-subtle); transition: all 0.15s; margin-top: 0.5rem; }

  .cta-back {
    margin-top: 3rem;
    padding: 1.5rem;
    background: var(--accent-soft);
    border: 1px solid #dbeafe;
    border-radius: var(--radius-lg);
    text-align: center;
  }
  .cta-back p { margin: 0 0 0.75rem; color: var(--accent-strong); font-weight: 500; }
  .btn-ghost {
    display: inline-flex;
    padding: 0.625rem 1.125rem;
    background: var(--bg);
    color: var(--accent);
    border: 1px solid var(--accent);
    border-radius: var(--radius-sm);
    font-weight: 600;
    font-size: 0.9375rem;
    text-decoration: none;
    transition: all 0.15s;
  }
  .btn-ghost:hover { background: var(--accent); color: var(--bg); }
</style>
