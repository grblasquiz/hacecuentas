---
export const prerender = true;

import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { CATEGORY_TO_GUIDE, GUIDE_TITLES, SIBLING_CATEGORIES, CATEGORY_TITLES, CATEGORY_ICONS } from '../../lib/category-guide-map';

export async function getStaticPaths() {
  const calcs = import.meta.glob<any>('../../content/calcs/*.json', { eager: true });
  const all = Object.values(calcs).map((m: any) => m.default || m);
  const cats = [...new Set(all.map((c) => c.category))];
  return cats.map((cat) => ({
    params: { cat },
    props: { cat, calcs: all.filter((c) => c.category === cat) },
  }));
}

const { cat, calcs } = Astro.props;

interface CatMeta {
  label: string;
  title: string;
  desc: string;
  intro: string;
  color: string;
  icon: string;
  seoContent: string; // markdown con H2/H3
  faq: Array<{ q: string; a: string }>;
}

